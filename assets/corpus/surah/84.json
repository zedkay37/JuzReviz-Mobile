te","en":"Then as for he who is given his record in his right hand,","words":[{"position":1,"ar":"فَأَمَّا","fr":"Quant à","en":"Then as for","tr":"fa-ammā","isWaqf":false},{"position":2,"ar":"مَنْ","fr":"(celui) qui","en":"(him) who","tr":"man","isWaqf":false},{"position":3,"ar":"أُوتِىَ","fr":"est donné","en":"is given","tr":"ūtiya","isWaqf":false},{"position":4,"ar":"كِتَـٰبَهُۥ","fr":"son registre","en":"his record","tr":"kitābahu","isWaqf":false},{"position":5,"ar":"بِيَمِينِهِۦ","fr":"dans son droit (main)","en":"in his right (hand)","tr":"biyamīnihi","isWaqf":false}]},{"ayah":8,"verseKey":"84:8","juz":30,"arabic":"فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا","fr":"sera jugé d’un jugement clément,","en":"He will be judged with an easy account","words":[{"position":1,"ar":"فَسَوْفَ","fr":"Puis bientôt","en":"Then soon","tr":"fasawfa","isWaqf":false},{"position":2,"ar":"يُحَاسَبُ","fr":"son compte va être pris","en":"his account will be taken","tr":"yuḥāsabu","isWaqf":false},{"position":3,"ar":"حِسَابًۭا","fr":"un compte","en":"an account","tr":"ḥisāban","isWaqf":false},{"position":4,"ar":"يَسِيرًۭا","fr":"facile","en":"easy","tr":"yasīran","isWaqf":false}]},{"ayah":9,"verseKey":"84:9","juz":30,"arabic":"وَيَنقَلِبُ إِلَىٰٓ أَهْلِهِۦ مَسْرُورًا","fr":"et s’en reviendra heureux auprès de sa famille.","en":"And return to his people in happiness.","words":[{"position":1,"ar":"وَيَنقَلِبُ","fr":"Et il va retourner","en":"And he will return","tr":"wayanqalibu","isWaqf":false},{"position":2,"ar":"إِلَىٰٓ","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":3,"ar":"أَهْلِهِۦ","fr":"son peuple","en":"his people","tr":"ahlihi","isWaqf":false},{"position":4,"ar":"مَسْرُورًۭا","fr":"joyeusement","en":"happily","tr":"masrūran","isWaqf":false}]},{"ayah":10,"verseKey":"84:10","juz":30,"arabic":"وَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ وَرَآءَ ظَهْرِهِۦ","fr":"Quant à celui qui recevra son Livre derrière son dos,","en":"But as for he who is given his record behind his back,","words":