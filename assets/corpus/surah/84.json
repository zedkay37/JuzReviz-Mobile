"position":4,"ar":"يُؤْمِنُونَ","fr":"ils croient","en":"they believe","tr":"yu'minūna","isWaqf":false}]},{"ayah":21,"verseKey":"84:21","juz":30,"arabic":"وَإِذَا قُرِئَ عَلَيْهِمُ ٱلْقُرْءَانُ لَا يَسْجُدُونَ ۩","fr":"Et quand le Coran leur est lu ne se prosternent-ils pas ?","en":"And when the Qur’ān is recited to them, they do not prostrate [to Allāh]?","words":[{"position":1,"ar":"وَإِذَا","fr":"Et quand","en":"And when","tr":"wa-idhā","isWaqf":false},{"position":2,"ar":"قُرِئَ","fr":"est récité","en":"is recited","tr":"quri-a","isWaqf":false},{"position":3,"ar":"عَلَيْهِمُ","fr":"à eux","en":"to them","tr":"ʿalayhimu","isWaqf":false},{"position":4,"ar":"ٱلْقُرْءَانُ","fr":"le Coran","en":"the Quran","tr":"l-qur'ānu","isWaqf":false},{"position":5,"ar":"لَا","fr":"non","en":"not","tr":"lā","isWaqf":false},{"position":6,"ar":"يَسْجُدُونَ ۩","fr":"ils se prosterner","en":"they prostrate","tr":"yasjudūna","isWaqf":false}]},{"ayah":22,"verseKey":"84:22","juz":30,"arabic":"بَلِ ٱلَّذِينَ كَفَرُوا۟ يُكَذِّبُونَ","fr":"C’est que les mécréants le tiennent pour mensonge.","en":"But those who have disbelieved deny,","words":[{"position":1,"ar":"بَلِ","fr":"Non","en":"Nay","tr":"bali","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"Ceux qui","en":"Those who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"كَفَرُوا۟","fr":"a mécru","en":"disbelieved","tr":"kafarū","isWaqf":false},{"position":4,"ar":"يُكَذِّبُونَ","fr":"nier","en":"deny","tr":"yukadhibūna","isWaqf":false}]},{"ayah":23,"verseKey":"84:23","juz":30,"arabic":"وَٱللَّهُ أَعْلَمُ بِمَا يُوعُونَ","fr":"Mais Allah Sait le mieux (les sentiments secrets) qu’ils nourrissent.","en":"And Allāh is most knowing of what they keep within themselves.","words":[{"position":1,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":2,"ar":"أَعْلَمُ","fr":"(est) le mieux informeré","en":"(is) most knowing","tr":"aʿlamu","isWaqf":false},{"position":3,"ar":"بِمَا","fr":"de ce que","en":"of what","tr":"bimā","isWaqf":false},{"position":4,"ar":"يُوعُونَ","fr":"ils gardent en eux-mêmes","en":"they keep within themselves","tr":"yūʿūna","isWaqf":false}]},{"ayah":24,"verseKey":"84:24","juz":30,"arabic":"فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ","fr":"Annonce-leur donc un supplice très douloureux.","en":"So give them tidings of a painful punishment,","words":[{"position":1,"ar":"فَبَشِّرْهُم","fr":"donc donner eux nouvelle","en":"so give them tidings","tr":"fabashir'hum","isWaqf":false},{"position":2,"ar":"بِعَذَابٍ","fr":"de un châtiment","en":"of a punishment","tr":"biʿadhābin","isWaqf":false},{"position":3,"ar":"أَلِيمٍ","fr":"douloureux","en":"painful","tr":"alīmin","isWaqf":false}]},{"ayah":25,"verseKey":"84:25","juz":30,"arabic":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍۭ","fr":"À l’exception de ceux qui ont cru et ont accompli les bonnes œuvres, et qui auront alors une récompense illimitée.","en":"Except for those who believe and do righteous deeds. For them is a reward uninterrupted.","words":[{"position":1,"ar":"إِلَّا","fr":"Sauf","en":"Except","tr":"illā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"croire","en":"believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"وَعَمِلُوا۟","fr":"et faire","en":"and do","tr":"waʿamilū","isWaqf":false},{"position":5,"ar":"ٱلصَّـٰلِحَـٰتِ","fr":"bonnes œuvres","en":"righteous deeds","tr":"l-ṣāliḥāti","isWaqf":false},{"position":6,"ar":"لَهُمْ","fr":"Pour eux","en":"For them","tr":"lahum","isWaqf":false},{"position":7,"ar":"أَجْرٌ","fr":"(est) une récompense","en":"(is) a reward","tr":"ajrun","isWaqf":false},{"position":8,"ar":"غَيْرُ","fr":"jamais","en":"never","tr":"ghayru","isWaqf":false},{"position":9,"ar":"مَمْنُونٍۭ","fr":"finissant","en":"ending","tr":"mamnūnin","isWaqf":false}]}]