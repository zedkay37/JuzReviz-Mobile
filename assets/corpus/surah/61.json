,"fr":"et lutter","en":"and strive","tr":"watujāhidūna","isWaqf":false},{"position":5,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":6,"ar":"سَبِيلِ","fr":"(le) voie","en":"(the) way","tr":"sabīli","isWaqf":false},{"position":7,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":8,"ar":"بِأَمْوَٰلِكُمْ","fr":"avec votre richesse","en":"with your wealth","tr":"bi-amwālikum","isWaqf":false},{"position":9,"ar":"وَأَنفُسِكُمْ ۚ","fr":"et votre vies","en":"and your lives","tr":"wa-anfusikum","isWaqf":false},{"position":10,"ar":"ذَٰلِكُمْ","fr":"Cela","en":"That","tr":"dhālikum","isWaqf":false},{"position":11,"ar":"خَيْرٌۭ","fr":"(est) meilleur","en":"(is) better","tr":"khayrun","isWaqf":false},{"position":12,"ar":"لَّكُمْ","fr":"pour vous","en":"for you","tr":"lakum","isWaqf":false},{"position":13,"ar":"إِن","fr":"si","en":"if","tr":"in","isWaqf":false},{"position":14,"ar":"كُنتُمْ","fr":"vous","en":"you","tr":"kuntum","isWaqf":false},{"position":15,"ar":"تَعْلَمُونَ","fr":"savoir","en":"know","tr":"taʿlamūna","isWaqf":false}]},{"ayah":12,"verseKey":"61:12","juz":28,"arabic":"يَغْفِرْ لَكُمْ ذُنُوبَكُمْ وَيُدْخِلْكُمْ جَنَّـٰتٍ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَـٰرُ وَمَسَـٰكِنَ طَيِّبَةً فِى جَنَّـٰتِ عَدْنٍ ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْعَظِيمُ","fr":"Il vous pardonnera vos péchés et vous fera entrer dans des jardins sous lesquels coulent les rivières, et dans de belles habitations dans les Jardins d’Éden. Voilà le suprême succès !","en":"He will forgive for you your sins and admit you to gardens beneath which rivers flow and pleasant dwellings in gardens of perpetual residence. That is the great attainment.","words":[{"position":1,"ar":"يَغْفِرْ","fr":"Il va pardonner","en":"He will forgive","tr":"yaghfir","isWaqf":false},{"position":2,"ar":"لَكُمْ","fr":"pour vous","en":"for you","tr":"lakum","isWaqf":false},{"position":3,"ar":"ذُنُوبَكُمْ","fr":"vos péchés","en":"your sins","tr":"dhunūbakum","isWaqf":false},{"posi