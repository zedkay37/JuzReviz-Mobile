[{"ayah":1,"verseKey":"61:1","juz":28,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ سَبَّحَ لِلَّهِ مَا فِى ٱلسَّمَـٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۖ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","fr":"Tout ce qui est dans les cieux et tout ce qui est sur terre rend gloire à Allah, Lui le Tout-Puissant, le Sage.","en":"Whatever is in the heavens and whatever is on the earth exalts Allāh, and He is the Exalted in Might, the Wise.","words":[{"position":1,"ar":"سَبَّحَ","fr":"Glorifie","en":"Glorifies","tr":"sabbaḥa","isWaqf":false},{"position":2,"ar":"لِلَّهِ","fr":"Allah","en":"Allah","tr":"lillahi","isWaqf":false},{"position":3,"ar":"مَا","fr":"quoi que","en":"whatever","tr":"mā","isWaqf":false},{"position":4,"ar":"فِى","fr":"(est) en","en":"(is) in","tr":"fī","isWaqf":false},{"position":5,"ar":"ٱلسَّمَـٰوَٰتِ","fr":"les cieux","en":"the heavens","tr":"l-samāwāti","isWaqf":false},{"position":6,"ar":"وَمَا","fr":"et quoi que","en":"and whatever","tr":"wamā","isWaqf":false},{"position":7,"ar":"فِى","fr":"(est) en","en":"(is) in","tr":"fī","isWaqf":false},{"position":8,"ar":"ٱلْأَرْضِ ۖ","fr":"la terre","en":"the earth","tr":"l-arḍi","isWaqf":false},{"position":9,"ar":"وَهُوَ","fr":"Et Il","en":"And He","tr":"wahuwa","isWaqf":false},{"position":10,"ar":"ٱلْعَزِيزُ","fr":"(est) le Tout-Puissant","en":"(is) the All-Mighty","tr":"l-ʿazīzu","isWaqf":false},{"position":11,"ar":"ٱلْحَكِيمُ","fr":"le Très-Sage","en":"the All-Wise","tr":"l-ḥakīmu","isWaqf":false}]},{"ayah":2,"verseKey":"61:2","juz":28,"arabic":"يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لِمَ تَقُولُونَ مَا لَا تَفْعَلُونَ","fr":"Ô vous qui avez cru ! Pourquoi dites-vous ce que vous ne faites pas ?","en":"O you who have believed, why do you say what you do not do?","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô","en":"O","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"(vous) qui","en":"(you) who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"croire","en":"believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"لِمَ","fr":"Pourquoi","en":"Why","tr":"lima","isWaqf":false},{"position":5,"ar":"تَقُولُونَ","fr":"(fais) vous dites","en":"(do) you say","tr":"taqūlūna","isWaqf":false},{"position":6,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":7,"ar":"لَا","fr":"non","en":"not","tr":"lā","isWaqf":false},{"position":8,"ar":"تَفْعَلُونَ","fr":"vous faire","en":"you do","tr":"tafʿalūna","isWaqf":false}]},{"ayah":3,"verseKey":"61:3","juz":28,"arabic":"كَبُرَ مَقْتًا عِندَ ٱللَّهِ أَن تَقُولُوا۟ مَا لَا تَفْعَلُونَ","fr":"C’est une chose exécrable pour Allah que vous disiez ce que vous ne faites pas.","en":"Greatly hateful in the sight of Allāh is that you say what you do not do.","words":[{"position":1,"ar":"كَبُرَ","fr":"Grand est","en":"Great is","tr":"kabura","isWaqf":false},{"position":2,"ar":"مَقْتًا","fr":"haine","en":"hatred","tr":"maqtan","isWaqf":false},{"position":3,"ar":"عِندَ","fr":"avec","en":"with","tr":"ʿinda","isWaqf":false},{"position":4,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":5,"ar":"أَن","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":6,"ar":"تَقُولُوا۟","fr":"vous dites","en":"you say","tr":"taqūlū","isWaqf":false},{"position":7,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":8,"ar":"لَا","fr":"non","en":"not","tr":"lā","isWaqf":false},{"position":9,"ar":"تَفْعَلُونَ","fr":"vous faire","en":"you do","tr":"tafʿalūna","isWaqf":false}]},{"ayah":4,"verseKey":"61:4","juz":28,"arabic":"إِنَّ ٱللَّهَ يُحِبُّ ٱلَّذِينَ يُقَـٰتِلُونَ فِى سَبِيلِهِۦ صَفًّا كَأَنَّهُم بُنْيَـٰنٌ مَّرْصُوصٌ","fr":"Allah aime ceux qui combattent pour Sa cause en rang, semblables à un édifice solidement bâti.","en":"Indeed, Allāh loves those who fight in His cause in a row as though they are a [single] structure joined firmly.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":3,"ar":"يُحِبُّ","fr":"aime","en":"loves","tr":"yuḥibbu","isWaqf":false},{"position":4,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":5,"ar":"يُقَـٰتِلُونَ","fr":"combattre","en":"fight","tr":"yuqātilūna","isWaqf":false},{"position":6,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":7,"ar":"سَبِيلِهِۦ","fr":"Son Voie","en":"His Way","tr":"sabīlihi","isWaqf":false},{"position":8,"ar":"صَفًّۭا","fr":"(dans) un row","en":"(in) a row","tr":"ṣaffan","isWaqf":false},{"position":9,"ar":"كَأَنَّهُم","fr":"comme si ils","en":"as if they","tr":"ka-annahum","isWaqf":false},{"position":10,"ar":"بُنْيَـٰنٌۭ","fr":"(étaient) un édifice","en":"(were) a structure","tr":"bun'yānun","isWaqf":false},{"position":11,"ar":"مَّرْصُوصٌۭ","fr":"joint fermement","en":"joined firmly","tr":"marṣūṣun","isWaqf":false}]},{"ayah":5,"verseKey":"61:5","juz":28,"arabic":"وَإِذْ قَالَ مُوسَىٰ لِقَوْمِهِۦ يَـٰقَوْمِ لِمَ تُؤْذُونَنِى وَقَد تَّعْلَمُونَ أَنِّى رَسُولُ ٱللَّهِ إِلَيْكُمْ ۖ فَلَمَّا زَاغُوٓا۟ أَزَاغَ ٱللَّهُ قُلُوبَهُمْ ۚ وَٱللَّهُ لَا يَهْدِى ٱلْقَوْمَ ٱلْفَـٰسِقِينَ","fr":"(Souviens-toi) lorsque Moïse dit à son peuple : « Ô peuple mien, pourquoi cherchez-vous à me faire du mal alors que vous savez que je suis le Messager d’Allah (envoyé) vers vous ? » Lorsqu’ils dévièrent (du droit chemin), Allah fit dévier leurs cœurs. Allah ne guide pas la gent corrompue.","en":"And [mention, O Muḥammad], when Moses said to his people, \"O my people, why do you harm me while you certainly know that I am the messenger of Allāh to you?\" And when they deviated, Allāh caused their hearts to deviate. And Allāh does not guide the defiantly disobedient people.","words":[{"position":1,"ar":"وَإِذْ","fr":"Et quand","en":"And when","tr":"wa-idh","isWaqf":false},{"position":2,"ar":"قَالَ","fr":"dit","en":"said","tr":"qāla","isWaqf":false},{"position":3,"ar":"مُوسَىٰ","fr":"Musa","en":"Musa","tr":"mūsā","isWaqf":false},{"position":4,"ar":"لِقَوْمِهِۦ","fr":"à son peuple","en":"to his people","tr":"liqawmihi","isWaqf":false},{"position":5,"ar":"يَـٰقَوْمِ","fr":"Ô mon peuple","en":"O my people","tr":"yāqawmi","isWaqf":false},{"position":6,"ar":"لِمَ","fr":"Pourquoi","en":"Why","tr":"lima","isWaqf":false},{"position":7,"ar":"تُؤْذُونَنِى","fr":"fais vous blessez moi","en":"do you hurt me","tr":"tu'dhūnanī","isWaqf":false},{"position":8,"ar":"وَقَد","fr":"tandis que certainement","en":"while certainly","tr":"waqad","isWaqf":false},{"position":9,"ar":"تَّعْلَمُونَ","fr":"vous savez","en":"you know","tr":"taʿlamūna","isWaqf":false},{"position":10,"ar":"أَنِّى","fr":"que je suis","en":"that I am","tr":"annī","isWaqf":false},{"position":11,"ar":"رَسُولُ","fr":"(le) Messager","en":"(the) Messenger","tr":"rasūlu","isWaqf":false},{"position":12,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":13,"ar":"إِلَيْكُمْ ۖ","fr":"à vous","en":"to you","tr":"ilaykum","isWaqf":false},{"position":14,"ar":"فَلَمَّا","fr":"Puis quand","en":"Then when","tr":"falammā","isWaqf":false},{"position":15,"ar":"زَاغُوٓا۟","fr":"ils dévié","en":"they deviated","tr":"zāghū","isWaqf":false},{"position":16,"ar":"أَزَاغَ","fr":"(était fit à) dévier","en":"(was caused to) deviate","tr":"azāgha","isWaqf":false},{"position":17,"ar":"ٱللَّهُ","fr":"(par) Allah","en":"(by) Allah","tr":"l-lahu","isWaqf":false},{"position":18,"ar":"قُلُوبَهُمْ ۚ","fr":"leurs cœurs","en":"their hearts","tr":"qulūbahum","isWaqf":false},{"position":19,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":20,"ar":"لَا","fr":"(ne) fait pas","en":"(does) not","tr":"lā","isWaqf":false},{"position":21,"ar":"يَهْدِى","fr":"guide","en":"guide","tr":"yahdī","isWaqf":false},{"position":22,"ar":"ٱلْقَوْمَ","fr":"les gens","en":"the people","tr":"l-qawma","isWaqf":false},{"position":23,"ar":"ٱلْفَـٰسِقِينَ","fr":"les rebelles","en":"the defiantly disobedient","tr":"l-fāsiqīna","isWaqf":false}]},{"ayah":6,"verseKey":"61:6","juz":28,"arabic":"وَإِذْ قَالَ عِيسَى ٱبْنُ مَرْيَمَ يَـٰبَنِىٓ إِسْرَٰٓءِيلَ إِنِّى رَسُولُ ٱللَّهِ إِلَيْكُم مُّصَدِّقًا لِّمَا بَيْنَ يَدَىَّ مِنَ ٱلتَّوْرَىٰةِ وَمُبَشِّرًۢا بِرَسُولٍ يَأْتِى مِنۢ بَعْدِى ٱسْمُهُۥٓ أَحْمَدُ ۖ فَلَمَّا جَآءَهُم بِٱلْبَيِّنَـٰتِ قَالُوا۟ هَـٰذَا سِحْرٌ مُّبِينٌ","fr":"Et lorsque Jésus, fils de Marie, dit : « Ô Enfants d’Israël ! Je suis le Messager d’Allah (envoyé) vers vous, je suis venu confirmer ce qui m’a déjà précédé dans la Torah, et annoncer la venue d’un Messager qui me succèdera, du nom d’Ahmad. » Or, lorsqu’il leur eut apporté les preuves évidentes, ils dirent : « C’est manifestement de la magie ! »","en":"And [mention] when Jesus, the son of Mary, said, \"O Children of Israel, indeed I am the messenger of Allāh to you confirming what came before me of the Torah and bringing good tidings of a messenger to come after me, whose name is Aḥmad.\" But when he came to them with clear evidences, they said, \"This is obvious magic.\"","words":[{"position":1,"ar":"وَإِذْ","fr":"Et quand","en":"And when","tr":"wa-idh","isWaqf":false},{"position":2,"ar":"قَالَ","fr":"dit","en":"said","tr":"qāla","isWaqf":false},{"position":3,"ar":"عِيسَى","fr":"Isa","en":"Isa","tr":"ʿīsā","isWaqf":false},{"position":4,"ar":"ٱبْنُ","fr":"fils","en":"son","tr":"ub'nu","isWaqf":false},{"position":5,"ar":"مَرْيَمَ","fr":"(de) Maryam","en":"(of) Maryam","tr":"maryama","isWaqf":false},{"position":6,"ar":"يَـٰبَنِىٓ","fr":"Ô Enfants","en":"O Children","tr":"yābanī","isWaqf":false},{"position":7,"ar":"إِسْرَٰٓءِيلَ","fr":"(d') Israël","en":"(of) Israel","tr":"is'rāīla","isWaqf":false},{"position":8,"ar":"إِنِّى","fr":"Certes, je suis","en":"Indeed, I am","tr":"innī","isWaqf":false},{"position":9,"ar":"رَسُولُ","fr":"(le) Messager","en":"(the) Messenger","tr":"rasūlu","isWaqf":false},{"position":10,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":11,"ar":"إِلَيْكُم","fr":"à vous","en":"to you","tr":"ilaykum","isWaqf":false},{"position":12,"ar":"مُّصَدِّقًۭا","fr":"confirmant","en":"confirming","tr":"muṣaddiqan","isWaqf":false},{"position":13,"ar":"لِّمَا","fr":"ce qui","en":"that which","tr":"limā","isWaqf":false},{"position":14,"ar":"بَيْنَ","fr":"(était) entre","en":"(was) between","tr":"bayna","isWaqf":false},{"position":15,"ar":"يَدَىَّ","fr":"mon mains","en":"my hands","tr":"yadayya","isWaqf":false},{"position":16,"ar":"مِنَ","fr":"de","en":"of","tr":"mina","isWaqf":false},{"position":17,"ar":"ٱلتَّوْرَىٰةِ","fr":"la Torah","en":"the Taurat","tr":"l-tawrāti","isWaqf":false},{"position":18,"ar":"وَمُبَشِّرًۢا","fr":"et apportant heureux nouvelle","en":"and bringing glad tidings","tr":"wamubashiran","isWaqf":false},{"position":19,"ar":"بِرَسُولٍۢ","fr":"(de) un Messager","en":"(of) a Messenger","tr":"birasūlin","isWaqf":false},{"position":20,"ar":"يَأْتِى","fr":"à venir","en":"to come","tr":"yatī","isWaqf":false},{"position":21,"ar":"مِنۢ","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":22,"ar":"بَعْدِى","fr":"après moi","en":"after me","tr":"baʿdī","isWaqf":false},{"position":23,"ar":"ٱسْمُهُۥٓ","fr":"dont nom (va être)","en":"whose name (will be)","tr":"us'muhu","isWaqf":false},{"position":24,"ar":"أَحْمَدُ ۖ","fr":"Ahmad","en":"Ahmad","tr":"aḥmadu","isWaqf":false},{"position":25,"ar":"فَلَمَّا","fr":"Mais quand","en":"But when","tr":"falammā","isWaqf":false},{"position":26,"ar":"جَآءَهُم","fr":"il leur vint","en":"he came to them","tr":"jāahum","isWaqf":false},{"position":27,"ar":"بِٱلْبَيِّنَـٰتِ","fr":"avec des preuves évidentes","en":"with clear proofs","tr":"bil-bayināti","isWaqf":false},{"position":28,"ar":"قَالُوا۟","fr":"ils dirent","en":"they said","tr":"qālū","isWaqf":false},{"position":29,"ar":"هَـٰذَا","fr":"Ceci","en":"This","tr":"hādhā","isWaqf":false},{"position":30,"ar":"سِحْرٌۭ","fr":"(est) un magie","en":"(is) a magic","tr":"siḥ'run","isWaqf":false},{"position":31,"ar":"مُّبِينٌۭ","fr":"clair","en":"clear","tr":"mubīnun","isWaqf":false}]},{"ayah":7,"verseKey":"61:7","juz":28,"arabic":"وَمَنْ أَظْلَمُ مِمَّنِ ٱفْتَرَىٰ عَلَى ٱللَّهِ ٱلْكَذِبَ وَهُوَ يُدْعَىٰٓ إِلَى ٱلْإِسْلَـٰمِ ۚ وَٱللَّهُ لَا يَهْدِى ٱلْقَوْمَ ٱلظَّـٰلِمِينَ","fr":"Est-il plus injuste que celui qui élabore des mensonges sur le compte d’Allah alors qu’il est invité à (embrasser) l’Islam ? Allah ne guide certes pas les gens injustes.","en":"And who is more unjust than one who invents about Allāh untruth while he is being invited to Islām. And Allāh does not guide the wrongdoing people.","words":[{"position":1,"ar":"وَمَنْ","fr":"Et qui","en":"And who","tr":"waman","isWaqf":false},{"position":2,"ar":"أَظْلَمُ","fr":"(est) plus tort","en":"(is) more wrong","tr":"aẓlamu","isWaqf":false},{"position":3,"ar":"مِمَّنِ","fr":"que celui qui","en":"than (one) who","tr":"mimmani","isWaqf":false},{"position":4,"ar":"ٱفْتَرَىٰ","fr":"invente","en":"invents","tr":"if'tarā","isWaqf":false},{"position":5,"ar":"عَلَى","fr":"sur","en":"upon","tr":"ʿalā","isWaqf":false},{"position":6,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":7,"ar":"ٱلْكَذِبَ","fr":"le mensonge","en":"the lie","tr":"l-kadhiba","isWaqf":false},{"position":8,"ar":"وَهُوَ","fr":"tandis qu'il","en":"while he","tr":"wahuwa","isWaqf":false},{"position":9,"ar":"يُدْعَىٰٓ","fr":"est invité","en":"is invited","tr":"yud'ʿā","isWaqf":false},{"position":10,"ar":"إِلَى","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":11,"ar":"ٱلْإِسْلَـٰمِ ۚ","fr":"Islam","en":"Islam","tr":"l-is'lāmi","isWaqf":false},{"position":12,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":13,"ar":"لَا","fr":"(ne) fait pas","en":"(does) not","tr":"lā","isWaqf":false},{"position":14,"ar":"يَهْدِى","fr":"guide","en":"guide","tr":"yahdī","isWaqf":false},{"position":15,"ar":"ٱلْقَوْمَ","fr":"les gens","en":"the people","tr":"l-qawma","isWaqf":false},{"position":16,"ar":"ٱلظَّـٰلِمِينَ","fr":"[le] injustes","en":"[the] wrongdoers","tr":"l-ẓālimīna","isWaqf":false}]},{"ayah":8,"verseKey":"61:8","juz":28,"arabic":"يُرِيدُونَ لِيُطْفِـُٔوا۟ نُورَ ٱللَّهِ بِأَفْوَٰهِهِمْ وَٱللَّهُ مُتِمُّ نُورِهِۦ وَلَوْ كَرِهَ ٱلْكَـٰفِرُونَ","fr":"Ils veulent, de leurs seules bouches, éteindre la lumière d’Allah ; or Allah accomplira (la manifestation) de Sa lumière, quelque dépit qu’en aient les mécréants.","en":"They want to extinguish the light of Allāh with their mouths, but Allāh will perfect His light, although the disbelievers dislike it.","words":[{"position":1,"ar":"يُرِيدُونَ","fr":"Ils Vouloent","en":"They intend","tr":"yurīdūna","isWaqf":false},{"position":2,"ar":"لِيُطْفِـُٔوا۟","fr":"à mettre hors","en":"to put out","tr":"liyuṭ'fiū","isWaqf":false},{"position":3,"ar":"نُورَ","fr":"(le) lumière","en":"(the) light","tr":"nūra","isWaqf":false},{"position":4,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":5,"ar":"بِأَفْوَٰهِهِمْ","fr":"avec leur bouches","en":"with their mouths","tr":"bi-afwāhihim","isWaqf":false},{"position":6,"ar":"وَٱللَّهُ","fr":"mais Allah","en":"but Allah","tr":"wal-lahu","isWaqf":false},{"position":7,"ar":"مُتِمُّ","fr":"va parfait","en":"will perfect","tr":"mutimmu","isWaqf":false},{"position":8,"ar":"نُورِهِۦ","fr":"Son Lumière","en":"His Light","tr":"nūrihi","isWaqf":false},{"position":9,"ar":"وَلَوْ","fr":"bien que","en":"although","tr":"walaw","isWaqf":false},{"position":10,"ar":"كَرِهَ","fr":"détester","en":"dislike","tr":"kariha","isWaqf":false},{"position":11,"ar":"ٱلْكَـٰفِرُونَ","fr":"les mécréants","en":"the disbelievers","tr":"l-kāfirūna","isWaqf":false}]},{"ayah":9,"verseKey":"61:9","juz":28,"arabic":"هُوَ ٱلَّذِىٓ أَرْسَلَ رَسُولَهُۥ بِٱلْهُدَىٰ وَدِينِ ٱلْحَقِّ لِيُظْهِرَهُۥ عَلَى ٱلدِّينِ كُلِّهِۦ وَلَوْ كَرِهَ ٱلْمُشْرِكُونَ","fr":"C’est Lui Qui envoya Son Messager avec la juste direction (hudâ) et la religion de la vérité, afin qu’il la fasse triompher de toute autre religion, quelque dépit qu’en aient les associâtres.","en":"It is He who sent His Messenger with guidance and the religion of truth to manifest it over all religion, although those who associate others with Allāh dislike it.","words":[{"position":1,"ar":"هُوَ","fr":"Il","en":"He","tr":"huwa","isWaqf":false},{"position":2,"ar":"ٱلَّذِىٓ","fr":"(est) Celui qui","en":"(is) the One Who","tr":"alladhī","isWaqf":false},{"position":3,"ar":"أَرْسَلَ","fr":"envoyé","en":"sent","tr":"arsala","isWaqf":false},{"position":4,"ar":"رَسُولَهُۥ","fr":"Son Messager","en":"His Messenger","tr":"rasūlahu","isWaqf":false},{"position":5,"ar":"بِٱلْهُدَىٰ","fr":"avec bonne direction","en":"with guidance","tr":"bil-hudā","isWaqf":false},{"position":6,"ar":"وَدِينِ","fr":"et (la) religion","en":"and (the) religion","tr":"wadīni","isWaqf":false},{"position":7,"ar":"ٱلْحَقِّ","fr":"(de) la vérité","en":"(of) the truth","tr":"l-ḥaqi","isWaqf":false},{"position":8,"ar":"لِيُظْهِرَهُۥ","fr":"à faire cela prévaloir","en":"to make it prevail","tr":"liyuẓ'hirahu","isWaqf":false},{"position":9,"ar":"عَلَى","fr":"sur","en":"over","tr":"ʿalā","isWaqf":false},{"position":10,"ar":"ٱلدِّينِ","fr":"la religion","en":"the religion","tr":"l-dīni","isWaqf":false},{"position":11,"ar":"كُلِّهِۦ","fr":"tous d'entre eux","en":"all of them","tr":"kullihi","isWaqf":false},{"position":12,"ar":"وَلَوْ","fr":"bien que","en":"although","tr":"walaw","isWaqf":false},{"position":13,"ar":"كَرِهَ","fr":"détester (cela)","en":"dislike (it)","tr":"kariha","isWaqf":false},{"position":14,"ar":"ٱلْمُشْرِكُونَ","fr":"les polythéistes","en":"the polytheists","tr":"l-mush'rikūna","isWaqf":false}]},{"ayah":10,"verseKey":"61:10","juz":28,"arabic":"يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ هَلْ أَدُلُّكُمْ عَلَىٰ تِجَـٰرَةٍ تُنجِيكُم مِّنْ عَذَابٍ أَلِيمٍ","fr":"Ô vous qui avez cru ! Vous montrerai-je un commerce qui puisse vous épargner un supplice très douloureux ?","en":"O you who have believed, shall I gui