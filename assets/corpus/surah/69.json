rseKey":"69:32","juz":29,"arabic":"ثُمَّ فِى سِلْسِلَةٍ ذَرْعُهَا سَبْعُونَ ذِرَاعًا فَٱسْلُكُوهُ","fr":"Ensuite, avec une chaîne (longue) de soixante-dix coudées, attachez-le !","en":"Then into a chain whose length is seventy cubits insert him.\"","words":[{"position":1,"ar":"ثُمَّ","fr":"Puis","en":"Then","tr":"thumma","isWaqf":false},{"position":2,"ar":"فِى","fr":"dans","en":"into","tr":"fī","isWaqf":false},{"position":3,"ar":"سِلْسِلَةٍۢ","fr":"un chain","en":"a chain","tr":"sil'silatin","isWaqf":false},{"position":4,"ar":"ذَرْعُهَا","fr":"son length","en":"its length","tr":"dharʿuhā","isWaqf":false},{"position":5,"ar":"سَبْعُونَ","fr":"(est) soixante-dix","en":"(is) seventy","tr":"sabʿūna","isWaqf":false},{"position":6,"ar":"ذِرَاعًۭا","fr":"coudées","en":"cubits","tr":"dhirāʿan","isWaqf":false},{"position":7,"ar":"فَٱسْلُكُوهُ","fr":"insert lui","en":"insert him","tr":"fa-us'lukūhu","isWaqf":false}]},{"ayah":33,"verseKey":"69:33","juz":29,"arabic":"إِنَّهُۥ كَانَ لَا يُؤْمِنُ بِٱللَّهِ ٱلْعَظِيمِ","fr":"Car il ne croyait pas en Allah le Très Grand,","en":"Indeed, he did not used to believe in Allāh, the Most Great,","words":[{"position":1,"ar":"إِنَّهُۥ","fr":"Certes, il","en":"Indeed, he","tr":"innahu","isWaqf":false},{"position":2,"ar":"كَانَ","fr":"était","en":"was","tr":"kāna","isWaqf":false},{"position":3,"ar":"لَا","fr":"non","en":"not","tr":"lā","isWaqf":false},{"position":4,"ar":"يُؤْمِنُ","fr":"croyant","en":"believing","tr":"yu'minu","isWaqf":false},{"position":5,"ar":"بِٱللَّهِ","fr":"dans Allah","en":"in Allah","tr":"bil-lahi","isWaqf":false},{"position":6,"ar":"ٱلْعَظِيمِ","fr":"le Très-Grand","en":"the Most Great","tr":"l-ʿaẓīmi","isWaqf":false}]},{"ayah":34,"verseKey":"69:34","juz":29,"arabic":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ","fr":"pas plus qu’il n’incitait à donner à manger au pauvre.","en":"Nor did he encourage the feeding of the poor.","words":[{"position":1,"ar":"وَلَا","fr":"Et (fit) non","en":"And (did) not","tr":"walā","isWaqf":false},{"position":2,"ar":"يَحُضُّ","fr":"sentir l’urge","en":"feel the urge","tr":"yaḥuḍḍu","isWaqf":false},{"position":3,"ar":"عَلَىٰ","fr":"sur","en":"on","tr":"ʿalā","isWaqf":false},{"position":4,"ar":"طَعَامِ","fr":"(le) nourrissant","en":"(the) feeding","tr":"ṭaʿāmi","isWaqf":false},{"position":5,"ar":"ٱلْمِسْكِينِ","fr":"(de) le pauvre","en":"(of) the poor","tr":"l-mis'kīni","isWaqf":false}]},{"ayah":35,"verseKey":"69:35","juz":29,"arabic":"فَلَيْسَ لَهُ ٱلْيَوْمَ هَـٰهُنَا حَمِيمٌ","fr":"Aujourd’hui, ici, il n’a aucun ami chaleureux,","en":"So there is not for him here this Day any devoted friend","words":[{"position":1,"ar":"فَلَيْسَ","fr":"Donc non","en":"So not","tr":"falaysa","isWaqf":false},{"position":2,"ar":"لَهُ","fr":"pour lui","en":"for him","tr":"lahu","isWaqf":false},{"position":3,"ar":"ٱلْيَوْمَ","fr":"aujourd'hui","en":"today","tr":"l-yawma","isWaqf":false},{"position":4,"ar":"هَـٰهُنَا","fr":"ici","en":"here","tr":"hāhunā","isWaqf":false},{"position":5,"ar":"حَمِيمٌۭ","fr":"tout dévoué ami","en":"any devoted friend","tr":"ḥamīmun","isWaqf":false}]},{"ayah":36,"verseKey":"69:36","juz":29,"arabic":"وَلَا طَعَامٌ إِلَّا مِنْ غِسْلِينٍ","fr":"ni nourriture autre que le pus","en":"Nor any food except from the discharge of wounds;","words":[{"position":1,"ar":"وَلَا","fr":"Et non","en":"And not","tr":"walā","isWaqf":false},{"position":2,"ar":"طَعَامٌ","fr":"tout nourriture","en":"any food","tr":"ṭaʿāmun","isWaqf":false},{"position":3,"ar":"إِلَّا","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":4,"ar":"مِنْ","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":5,"ar":"غِسْلِينٍۢ","fr":"(le) acquitter de blessures","en":"(the) discharge of wounds","tr":"ghis'līnin","isWaqf":false}]},{"ayah":37,"verseKey":"69:37","juz":29,"arabic":"لَّا يَأْكُلُهُۥٓ إِلَّا ٱلْخَـٰطِـُٔونَ","fr":"dont seuls se nourriront les coupables. »","en":"None will eat it except the sinners.","words":[{"position":1,"ar":"لَّا","fr":"Non","en":"Not","tr":"lā","isWaqf":false},{"position":2,"ar":"يَأْكُلُهُۥٓ","fr":"va manger cela","en":"will eat it","tr":"yakuluhu","isWaqf":false},{"position":3,"ar":"إِلَّا","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":4,"ar":"ٱلْخَـٰطِـُٔونَ","fr":"le pécheurs","en":"the sinners","tr":"l-khāṭiūna","isWaqf":false}]},{"ayah":38,"verseKey":"69:38","juz":29,"arabic":"فَلَآ أُقْسِمُ بِمَا تُبْصِرُونَ","fr":"Non, J’en jure par ce que vous voyez,","en":"So I swear by what you see","words":[{"position":1,"ar":"فَلَآ","fr":"Mais non","en":"But nay","tr":"falā","isWaqf":false},{"position":2,"ar":"أُقْسِمُ","fr":"Je Jure","en":"I swear","tr":"uq'simu","isWaqf":false},{"position":3,"ar":"بِمَا","fr":"par ce que","en":"by what","tr":"bimā","isWaqf":false},{"position":4,"ar":"تُبْصِرُونَ","fr":"vous voyez","en":"you see","tr":"tub'ṣirūna","isWaqf":false}]},{"ayah":39,"verseKey":"69:39","juz":29,"arabic":"وَمَا لَا تُبْصِرُونَ","fr":"et par ce que vous ne voyez pas,","en":"And what you do not see","words":[{"position":1,"ar":"وَمَا","fr":"Et quoi","en":"And what","tr":"wamā","isWaqf":false},{"position":2,"ar":"لَا","fr":"non","en":"not","tr":"lā","isWaqf":false},{"position":3,"ar":"تُبْصِرُونَ","fr":"vous voyez","en":"you see","tr":"tub'ṣirūna","isWaqf":false}]},{"ayah":40,"verseKey":"69:40","juz":29,"arabic":"إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ","fr":"ceci est le propos (transmis) par un Noble Messager,","en":"[That] indeed, it [i.e., the Qur’ān] is the word of a noble Messenger.","words":[{"position":1,"ar":"إِنَّهُۥ","fr":"Certes, c'(est)","en":"Indeed, it (is)","tr":"innahu","isWaqf":false},{"position":2,"ar":"لَقَوْلُ","fr":"assurément (le) Parole","en":"surely (the) Word","tr":"laqawlu","isWaqf":false},{"position":3,"ar":"رَسُولٍۢ","fr":"(de) un Messager","en":"(of) a Messenger","tr":"rasūlin","isWaqf":false},{"position":4,"ar":"كَرِيمٍۢ","fr":"noble","en":"noble","tr":"karīmin","isWaqf":false}]},{"ayah":41,"verseKey":"69:41","juz":29,"arabic":"وَمَا هُوَ بِقَوْلِ شَاعِرٍ ۚ قَلِيلًا مَّا تُؤْمِنُونَ","fr":"et non le propos d’un poète. Comme vous êtes peu nombreux à y croire !","en":"And it is not the word of a poet; little do you believe.","words":[{"position":1,"ar":"وَمَا","fr":"Et non","en":"And not","tr":"wamā","isWaqf":false},{"position":2,"ar":"هُوَ","fr":"cela","en":"it","tr":"huwa","isWaqf":false},{"position":3,"ar":"بِقَوْلِ","fr":"(est le) parole","en":"(is the) word","tr":"biqawli","isWaqf":false},{"position":4,"ar":"شَاعِرٍۢ ۚ","fr":"(de) un poète","en":"(of) a poet","tr":"shāʿirin","isWaqf":false},{"position":5,"ar":"قَلِيلًۭا","fr":"peu","en":"little","tr":"qalīlan","isWaqf":false},{"position":6,"ar":"مَّا","fr":"(est) ce que","en":"(is) what","tr":"mā","isWaqf":false},{"position":7,"ar":"تُؤْمِنُونَ","fr":"vous croire","en":"you believe","tr":"tu'minūna","isWaqf":false}]},{"ayah":42,"verseKey":"69:42","juz":29,"arabic":"وَلَا بِقَوْلِ كَاهِنٍ ۚ قَلِيلًا مَّا تَذَكَّرُونَ","fr":"Et ce n’est pas, non plus, le propos d’un devin. Comme vous êtes peu nombreux à y réfléchir !","en":"Nor the word of a soothsayer; little do you remember.","words":[{"position":1,"ar":"وَلَا","fr":"Et non","en":"And not","tr":"walā","isWaqf":false},{"position":2,"ar":"بِقَوْلِ","fr":"(cela est le) parole","en":"(it is the) word","tr":"biqawli","isWaqf":false},{"position":3,"ar":"كَاهِنٍۢ ۚ","fr":"(de) un devin","en":"(of) a soothsayer","tr":"kāhinin","isWaqf":false},{"position":4,"ar":"قَلِيلًۭا","fr":"peu","en":"little","tr":"qalīlan","isWaqf":false},{"position":5,"ar":"مَّا","fr":"(est) ce que","en":"(is) what","tr":"mā","isWaqf":false},{"position":6,"ar":"تَذَكَّرُونَ","fr":"vous prendre prêter attention","en":"you take heed","tr":"tadhakkarūna","isWaqf":false}]},{"ayah":43,"verseKey":"69:43","juz":29,"arabic":"تَنزِيلٌ مِّن رَّبِّ ٱلْعَـٰلَمِينَ","fr":"C’est bien une révélation du Seigneur de l’Univers.","en":"[It is] a revelation from the Lord of the worlds.","words":[{"position":1,"ar":"تَنزِيلٌۭ","fr":"(Cela est) un revelation","en":"(It is) a revelation","tr":"tanzīlun","isWaqf":false},{"position":2,"ar":"مِّن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":3,"ar":"رَّبِّ","fr":"(le) Seigneur","en":"(the) Lord","tr":"rabbi","isWaqf":false},{"position":4,"ar":"ٱلْعَـٰلَمِينَ","fr":"(des) mondes","en":"(of) the worlds","tr":"l-ʿālamīna","isWaqf":false}]},{"ayah":44,"verseKey":"69:44","juz":29,"arabic":"وَلَوْ تَقَوَّلَ عَلَيْنَا بَعْضَ ٱلْأَقَاوِيلِ","fr":"Si (Muhammad) Nous avait attribué certaines paroles (qui n’étaient pas les Nôtres),","en":"And if he [i.e., Muḥammad] had made up about Us some [false] sayings,","words":[{"position":1,"ar":"وَلَوْ","fr":"Et si","en":"And if","tr":"walaw","isWaqf":false},{"position":2,"ar":"تَقَوَّلَ","fr":"il (avait) fabriqué","en":"he (had) fabricated","tr":"taqawwala","isWaqf":false},{"position":3,"ar":"عَلَيْنَا","fr":"contre Nous","en":"against Us","tr":"ʿalaynā","isWaqf":false},{"position":4,"ar":"بَعْضَ","fr":"certains","en":"some","tr":"baʿḍa","isWaqf":false},{"position":5,"ar":"ٱلْأَقَاوِيلِ","fr":"paroles","en":"sayings","tr":"l-aqāwīli","isWaqf":false}]},{"ayah":45,"verseKey":"69:45","juz":29,"arabic":"لَأَخَذْنَا مِنْهُ بِٱلْيَمِينِ","fr":"Nous l’aurions saisi en Notre Main Droite,","en":"We would have seized him by the right hand;","words":[{"position":1,"ar":"لَأَخَذْنَا","fr":"Assurément Nous (irait) ont saisit","en":"Certainly We (would) have seized","tr":"la-akhadhnā","isWaqf":false},{"position":2,"ar":"مِنْهُ","fr":"lui","en":"him","tr":"min'hu","isWaqf":false},{"position":3,"ar":"بِٱلْيَمِينِ","fr":"par le droit main","en":"by the right hand","tr":"bil-yamīni","isWaqf":false}]},{"ayah":46,"verseKey":"69:46","juz":29,"arabic":"ثُمَّ لَقَطَعْنَا مِنْهُ ٱلْوَتِينَ","fr":"puis lui aurions tranché l’aorte.","en":"Then We would have cut from him the aorta.","words":[{"position":1,"ar":"ثُمَّ","fr":"Puis","en":"Then","tr":"thumma","isWaqf":false},{"position":2,"ar":"لَقَطَعْنَا","fr":"certainement Nous (irait) ont couper loin","en":"certainly We (would) have cut off","tr":"laqaṭaʿnā","isWaqf":false},{"position":3,"ar":"مِنْهُ","fr":"de lui","en":"from him","tr":"min'hu","isWaqf":false},{"position":4,"ar":"ٱلْوَتِينَ","fr":"l’aorta","en":"the aorta","tr":"l-watīna","isWaqf":false}]},{"ayah":47,"verseKey":"69:47","juz":29,"arabic":"فَمَا مِنكُم مِّنْ أَحَدٍ عَنْهُ حَـٰجِزِينَ","fr":"Nul d’entre vous alors n’aurait pu le protéger.","en":"And there is no one of you who could prevent [Us] from him.","words":[{"position":1,"ar":"فَمَا","fr":"Et non","en":"And not","tr":"famā","isWaqf":false},{"position":2,"ar":"مِنكُم","fr":"de vous","en":"from you","tr":"minkum","isWaqf":false},{"position":3,"ar":"مِّنْ","fr":"tout","en":"any","tr":"min","isWaqf":false},{"position":4,"ar":"أَحَدٍ","fr":"un","en":"one","tr":"aḥadin","isWaqf":false},{"position":5,"ar":"عَنْهُ","fr":"[de lui]","en":"[from him]","tr":"ʿanhu","isWaqf":false},{"position":6,"ar":"حَـٰجِزِينَ","fr":"(qui pourrait) empêcher (cela)","en":"(who could) prevent (it)","tr":"ḥājizīna","isWaqf":false}]},{"ayah":48,"verseKey":"69:48","juz":29,"arabic":"وَإِنَّهُۥ لَتَذْكِرَةٌ لِّلْمُتَّقِينَ","fr":"Ce (Coran) est, en vérité, un Rappel à l’adresse de ceux qui sont pieux.","en":"And indeed, it [i.e., the Qur’ān] is a reminder for the righteous.","words":[{"position":1,"ar":"وَإِنَّهُۥ","fr":"Et certes,","en":"And indeed, it","tr":"wa-innahu","isWaqf":false},{"position":2,"ar":"لَتَذْكِرَةٌۭ","fr":"(est) assurément un rappel","en":"(is) surely a reminder","tr":"latadhkiratun","isWaqf":false},{"position":3,"ar":"لِّلْمُتَّقِينَ","fr":"pour l’Allah-fearing","en":"for the Allah-fearing","tr":"lil'muttaqīna","isWaqf":false}]},{"ayah":49,"verseKey":"69:49","juz":29,"arabic":"وَإِنَّا لَنَعْلَمُ أَنَّ مِنكُم مُّكَذِّبِينَ","fr":"Nous savons (pourtant) que, parmi vous, certains crient (encore) au mensonge.","en":"And indeed, We know that among you are deniers.","words":[{"position":1,"ar":"وَإِنَّا","fr":"Et certes, Nous","en":"And indeed, We","tr":"wa-innā","isWaqf":false},{"position":2,"ar":"لَنَعْلَمُ","fr":"assurément savoir","en":"surely know","tr":"lanaʿlamu","isWaqf":false},{"position":3,"ar":"أَنَّ","fr":"que","en":"that","tr":"anna","isWaqf":false},{"position":4,"ar":"مِنكُم","fr":"parmi vous","en":"among you","tr":"minkum","isWaqf":false},{"position":5,"ar":"مُّكَذِّبِينَ","fr":"(sont) négateurs","en":"(are) deniers","tr":"mukadhibīna","isWaqf":false}]},{"ayah":50,"verseKey":"69:50","juz":29,"arabic":"وَإِنَّهُۥ لَحَسْرَةٌ عَلَى ٱلْكَـٰفِرِينَ","fr":"Ce sera plutôt un sujet d’amers regrets pour les mécréants.","en":"And indeed, it will be [a cause of] regret upon the disbelievers.","words":[{"position":1,"ar":"وَإِنَّهُۥ","fr":"Et certes,","en":"And indeed, it","tr":"wa-innahu","isWaqf":false},{"position":2,"ar":"لَحَسْرَةٌ","fr":"(est) assurément un regret","en":"(is) surely a regret","tr":"laḥasratun","isWaqf":false},{"position":3,"ar":"عَلَى","fr":"sur","en":"upon","tr":"ʿalā","isWaqf":false},{"position":4,"ar":"ٱلْكَـٰفِرِينَ","fr":"les mécréants","en":"the disbelievers","tr":"l-kāfirīna","isWaqf":false}]},{"ayah":51,"verseKey":"69:51","juz":29,"arabic":"وَإِنَّهُۥ لَحَقُّ ٱلْيَقِينِ","fr":"C’est là, assurément, la vraie certitude.","en":"And indeed, it is the truth of certainty.","words":[{"position":1,"ar":"وَإِنَّهُۥ","fr":"Et certes, c'(est)","en":"And indeed, it (is)","tr":"wa-innahu","isWaqf":false},{"position":2,"ar":"لَحَقُّ","fr":"assurément (le) vérité","en":"surely (the) truth","tr":"laḥaqqu","isWaqf":false},{"position":3,"ar":"ٱلْيَقِينِ","fr":"(de) certitude","en":"(of) certainty","tr":"l-yaqīni","isWaqf":false}]},{"ayah":52,"verseKey":"69:52","juz":29,"arabic":"فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ","fr":"Rends donc gloire au Nom de ton Seigneur, le Très Grand !","en":"So exalt the name of your Lord, the Most Great.","words":[{"position":1,"ar":"فَسَبِّحْ","fr":"Donc glorifier","en":"So glorify","tr":"fasabbiḥ","isWaqf":false},{"position":2,"ar":"بِٱسْمِ","fr":"(le) nom","en":"(the) name","tr":"bi-is'mi","isWaqf":false},{"position":3,"ar":"رَبِّكَ","fr":"(de) votre Seigneur","en":"(of) your Lord","tr":"rabbika","isWaqf":false},{"position":4,"ar":"ٱلْعَظِيمِ","fr":"le Très-Grand","en":"the Most Great","tr":"l-ʿaẓīmi","isWaqf":false}]}]