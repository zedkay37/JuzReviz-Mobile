understanding","tr":"l-albābi","isWaqf":false},{"position":10,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":11,"ar":"ءَامَنُوا۟ ۚ","fr":"ont cru","en":"have believed","tr":"āmanū","isWaqf":false},{"position":12,"ar":"قَدْ","fr":"Certes","en":"Indeed","tr":"qad","isWaqf":false},{"position":13,"ar":"أَنزَلَ","fr":"A envoyé bas","en":"Has sent down","tr":"anzala","isWaqf":false},{"position":14,"ar":"ٱللَّهُ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":15,"ar":"إِلَيْكُمْ","fr":"à vous","en":"to you","tr":"ilaykum","isWaqf":false},{"position":16,"ar":"ذِكْرًۭا","fr":"un Message","en":"a Message","tr":"dhik'ran","isWaqf":false}]},{"ayah":11,"verseKey":"65:11","juz":28,"arabic":"رَّسُولًا يَتْلُوا۟ عَلَيْكُمْ ءَايَـٰتِ ٱللَّهِ مُبَيِّنَـٰتٍ لِّيُخْرِجَ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ مِنَ ٱلظُّلُمَـٰتِ إِلَى ٱلنُّورِ ۚ وَمَن يُؤْمِنۢ بِٱللَّهِ وَيَعْمَلْ صَـٰلِحًا يُدْخِلْهُ جَنَّـٰتٍ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَـٰرُ خَـٰلِدِينَ فِيهَآ أَبَدًا ۖ قَدْ أَحْسَنَ ٱللَّهُ لَهُۥ رِزْقًا","fr":"(et envoyé) un Messager qui vous récite les versets explicites d’Allah, pour faire sortir ceux qui ont cru et ont accompli les bonnes œuvres des ténèbres vers la lumière. (Car) ceux qui croient en Allah et font le bien, (Allah) les fera entrer dans des jardins sous lesquels coulent les rivières, où ils séjourneront à tout jamais. Allah leur dispensera ce qu’il y a de meilleur !","en":"[He sent] a Messenger [i.e., Muḥammad (ﷺ)] reciting to you the distinct verses of Allāh that He may bring out those who believe and do righteous deeds from darknesses into the light. And whoever believes in Allāh and does righteousness - He will admit him into gardens beneath which rivers flow to abide therein forever. Allāh will have perfected for him a provision.","words":[{"position":1,"ar":"رَّسُولًۭا","fr":"Un Messager","en":"A Messenger","tr":"rasūlan","isWaqf":false},{"position":2,"ar":"يَتْلُوا۟","fr":"récitant","en":"reciting","tr":"yatlū","isWaqf":false},{"position":3,"ar":"عَلَيْكُمْ","fr":"à vous","en":"to you","tr":"ʿalaykum","isWaqf":false},{"position":4,"ar":"ءَايَـٰتِ","fr":"(les) Versets","en":"(the) Verses","tr":"āyāti","isWaqf":false},{"position":5,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":6,"ar":"مُبَيِّنَـٰتٍۢ","fr":"clair","en":"clear","tr":"mubayyinātin","isWaqf":false},{"position":7,"ar":"لِّيُخْرِجَ","fr":"que il peut apporter hors","en":"that he may bring out","tr":"liyukh'rija","isWaqf":false},{"position":8,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":9,"ar":"ءَامَنُوا۟","fr":"croire","en":"believe","tr":"āmanū","isWaqf":false},{"position":10,"ar":"وَعَمِلُوا۟","fr":"et faire","en":"and do","tr":"waʿamilū","isWaqf":false},{"position":11,"ar":"ٱلصَّـٰلِحَـٰتِ","fr":"bonnes œuvres","en":"righteous deeds","tr":"l-ṣāliḥāti","isWaqf":false},{"position":12,"ar":"مِنَ","fr":"de","en":"from","tr":"mina","isWaqf":false},{"position":13,"ar":"ٱلظُّلُمَـٰتِ","fr":"les ténèbres","en":"the darkness[es]","tr":"l-ẓulumāti","isWaqf":false},{"position":14,"ar":"إِلَى","fr":"vers","en":"towards","tr":"ilā","isWaqf":false},{"position":15,"ar":"ٱلنُّورِ ۚ","fr":"la lumière","en":"the light","tr":"l-nūri","isWaqf":false},{"position":16,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":17,"ar":"يُؤْمِنۢ","fr":"croit","en":"believes","tr":"yu'min","isWaqf":false},{"position":18,"ar":"بِٱللَّهِ","fr":"dans Allah","en":"in Allah","tr":"bil-lahi","isWaqf":false},{"position":19,"ar":"وَيَعْمَلْ","fr":"et fait","en":"and does","tr":"wayaʿmal","isWaqf":false},{"position":20,"ar":"صَـٰلِحًۭا","fr":"bonnes œuvres","en":"righteous deeds","tr":"ṣāliḥan","isWaqf":false},{"position":21,"ar":"يُدْخِلْهُ","fr":"Il va admettre lui","en":"He will admit him","tr":"yud'khil'hu","isWaqf":false},{"position":22,"ar":"جَنَّـٰتٍۢ","fr":"(dans) Jardins","e