[{"ayah":1,"verseKey":"65:1","juz":28,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ يَـٰٓأَيُّهَا ٱلنَّبِىُّ إِذَا طَلَّقْتُمُ ٱلنِّسَآءَ فَطَلِّقُوهُنَّ لِعِدَّتِهِنَّ وَأَحْصُوا۟ ٱلْعِدَّةَ ۖ وَٱتَّقُوا۟ ٱللَّهَ رَبَّكُمْ ۖ لَا تُخْرِجُوهُنَّ مِنۢ بُيُوتِهِنَّ وَلَا يَخْرُجْنَ إِلَّآ أَن يَأْتِينَ بِفَـٰحِشَةٍ مُّبَيِّنَةٍ ۚ وَتِلْكَ حُدُودُ ٱللَّهِ ۚ وَمَن يَتَعَدَّ حُدُودَ ٱللَّهِ فَقَدْ ظَلَمَ نَفْسَهُۥ ۚ لَا تَدْرِى لَعَلَّ ٱللَّهَ يُحْدِثُ بَعْدَ ذَٰلِكَ أَمْرًا","fr":"Ô Prophète ! Si vous divorcez d’avec les femmes, faites-le (en respectant) leur délai de viduité (‘iddah) dont vous compterez (les jours). Craignez Allah, votre Seigneur, ne les faites pas sortir de leurs maisons ! Qu’elles n’en sortent que si elles ont commis un acte immoral évident. Telles sont les limites d’Allah (hudûd). Celui qui outrepasse les limites d’Allah est injuste envers lui-même. Tu ne peux savoir si, entre-temps, Allah ne fera pas advenir une situation nouvelle.","en":"O Prophet, when you [Muslims] divorce women, divorce them for [the commencement of] their waiting period and keep count of the waiting period, and fear Allāh, your Lord. Do not turn them out of their [husbands'] houses, nor should they [themselves] leave [during that period] unless they are committing a clear immorality. And those are the limits [set by] Allāh. And whoever transgresses the limits of Allāh has certainly wronged himself. You know not; perhaps Allāh will bring about after that a [different] matter.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô","en":"O","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلنَّبِىُّ","fr":"Prophète","en":"Prophet","tr":"l-nabiyu","isWaqf":false},{"position":3,"ar":"إِذَا","fr":"Quand","en":"When","tr":"idhā","isWaqf":false},{"position":4,"ar":"طَلَّقْتُمُ","fr":"vous divorce","en":"you divorce","tr":"ṭallaqtumu","isWaqf":false},{"position":5,"ar":"ٱلنِّسَآءَ","fr":"[le] femmes","en":"[the] women","tr":"l-nisāa","isWaqf":false},{"position":6,"ar":"فَطَلِّقُوهُنَّ","fr":"puis divorce eux","en":"then divorce them","tr":"faṭalliqūhunna","isWaqf":false},{"position":7,"ar":"لِعِدَّتِهِنَّ","fr":"pour leur attendant délai","en":"for their waiting period","tr":"liʿiddatihinna","isWaqf":false},{"position":8,"ar":"وَأَحْصُوا۟","fr":"et garder compter","en":"and keep count","tr":"wa-aḥṣū","isWaqf":false},{"position":9,"ar":"ٱلْعِدَّةَ ۖ","fr":"(de) le attendant délai","en":"(of) the waiting period","tr":"l-ʿidata","isWaqf":false},{"position":10,"ar":"وَٱتَّقُوا۟","fr":"et craindre","en":"and fear","tr":"wa-ittaqū","isWaqf":false},{"position":11,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":12,"ar":"رَبَّكُمْ ۖ","fr":"votre Seigneur","en":"your Lord","tr":"rabbakum","isWaqf":false},{"position":13,"ar":"لَا","fr":"(Ne) fais pas","en":"(Do) not","tr":"lā","isWaqf":false},{"position":14,"ar":"تُخْرِجُوهُنَّ","fr":"expulser eux","en":"expel them","tr":"tukh'rijūhunna","isWaqf":false},{"position":15,"ar":"مِنۢ","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":16,"ar":"بُيُوتِهِنَّ","fr":"leur maisons","en":"their houses","tr":"buyūtihinna","isWaqf":false},{"position":17,"ar":"وَلَا","fr":"et non","en":"and not","tr":"walā","isWaqf":false},{"position":18,"ar":"يَخْرُجْنَ","fr":"ils devrait quitter","en":"they should leave","tr":"yakhruj'na","isWaqf":false},{"position":19,"ar":"إِلَّآ","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":20,"ar":"أَن","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":21,"ar":"يَأْتِينَ","fr":"ils commettre","en":"they commit","tr":"yatīna","isWaqf":false},{"position":22,"ar":"بِفَـٰحِشَةٍۢ","fr":"un turpitude","en":"an immorality","tr":"bifāḥishatin","isWaqf":false},{"position":23,"ar":"مُّبَيِّنَةٍۢ ۚ","fr":"clair","en":"clear","tr":"mubayyinatin","isWaqf":false},{"position":24,"ar":"وَتِلْكَ","fr":"Et ces","en":"And these","tr":"watil'ka","isWaqf":false},{"position":25,"ar":"حُدُودُ","fr":"(sont le) limites","en":"(are the) limits","tr":"ḥudūdu","isWaqf":false},{"position":26,"ar":"ٱللَّهِ ۚ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":27,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":28,"ar":"يَتَعَدَّ","fr":"transgresse","en":"transgresses","tr":"yataʿadda","isWaqf":false},{"position":29,"ar":"حُدُودَ","fr":"(le) limites","en":"(the) limits","tr":"ḥudūda","isWaqf":false},{"position":30,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":31,"ar":"فَقَدْ","fr":"puis certainement","en":"then certainly","tr":"faqad","isWaqf":false},{"position":32,"ar":"ظَلَمَ","fr":"il a lésa","en":"he has wronged","tr":"ẓalama","isWaqf":false},{"position":33,"ar":"نَفْسَهُۥ ۚ","fr":"lui-même","en":"himself","tr":"nafsahu","isWaqf":false},{"position":34,"ar":"لَا","fr":"Non","en":"Not","tr":"lā","isWaqf":false},{"position":35,"ar":"تَدْرِى","fr":"vous savez","en":"you know","tr":"tadrī","isWaqf":false},{"position":36,"ar":"لَعَلَّ","fr":"Peut-être","en":"Perhaps","tr":"laʿalla","isWaqf":false},{"position":37,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":38,"ar":"يُحْدِثُ","fr":"va apporter au sujet de","en":"will bring about","tr":"yuḥ'dithu","isWaqf":false},{"position":39,"ar":"بَعْدَ","fr":"après","en":"after","tr":"baʿda","isWaqf":false},{"position":40,"ar":"ذَٰلِكَ","fr":"que","en":"that","tr":"dhālika","isWaqf":false},{"position":41,"ar":"أَمْرًۭا","fr":"une affaire","en":"a matter","tr":"amran","isWaqf":false}]},{"ayah":2,"verseKey":"65:2","juz":28,"arabic":"فَإِذَا بَلَغْنَ أَجَلَهُنَّ فَأَمْسِكُوهُنَّ بِمَعْرُوفٍ أَوْ فَارِقُوهُنَّ بِمَعْرُوفٍ وَأَشْهِدُوا۟ ذَوَىْ عَدْلٍ مِّنكُمْ وَأَقِيمُوا۟ ٱلشَّهَـٰدَةَ لِلَّهِ ۚ ذَٰلِكُمْ يُوعَظُ بِهِۦ مَن كَانَ يُؤْمِنُ بِٱللَّهِ وَٱلْيَوْمِ ٱلْـَٔاخِرِ ۚ وَمَن يَتَّقِ ٱللَّهَ يَجْعَل لَّهُۥ مَخْرَجًا","fr":"Leur terme ayant été atteint, ou vous les garderez alors d’une manière convenable, ou vous les quitterez d’une manière tout aussi convenable. Faites témoigner de cela deux hommes parmi les plus équitables d’entre vous. Vous devez en témoigner (par obéissance) à Allah. Voilà une exhortation pour qui croit en Allah et au Jour Dernier. À quiconque Le craint, Allah prévoit une (honorable) voie de sortie,","en":"And when they have [nearly] fulfilled their term, either retain them according to acceptable terms or part with them according to acceptable terms. And bring to witness two just men from among you and establish the testimony for [the acceptance of] Allāh. That is instructed to whoever should believe in Allāh and the Last Day. And whoever fears Allāh - He will make for him a way out","words":[{"position":1,"ar":"فَإِذَا","fr":"Puis quand","en":"Then when","tr":"fa-idhā","isWaqf":false},{"position":2,"ar":"بَلَغْنَ","fr":"ils ont atteignit","en":"they have reached","tr":"balaghna","isWaqf":false},{"position":3,"ar":"أَجَلَهُنَّ","fr":"leur terme","en":"their term","tr":"ajalahunna","isWaqf":false},{"position":4,"ar":"فَأَمْسِكُوهُنَّ","fr":"puis retenir eux","en":"then retain them","tr":"fa-amsikūhunna","isWaqf":false},{"position":5,"ar":"بِمَعْرُوفٍ","fr":"avec bonté","en":"with kindness","tr":"bimaʿrūfin","isWaqf":false},{"position":6,"ar":"أَوْ","fr":"ou","en":"or","tr":"aw","isWaqf":false},{"position":7,"ar":"فَارِقُوهُنَّ","fr":"partie avec eux","en":"part with them","tr":"fāriqūhunna","isWaqf":false},{"position":8,"ar":"بِمَعْرُوفٍۢ","fr":"avec bonté","en":"with kindness","tr":"bimaʿrūfin","isWaqf":false},{"position":9,"ar":"وَأَشْهِدُوا۟","fr":"Et prendre témoin","en":"And take witness","tr":"wa-ashhidū","isWaqf":false},{"position":10,"ar":"ذَوَىْ","fr":"deux hommes","en":"two men","tr":"dhaway","isWaqf":false},{"position":11,"ar":"عَدْلٍۢ","fr":"juste","en":"just","tr":"ʿadlin","isWaqf":false},{"position":12,"ar":"مِّنكُمْ","fr":"parmi vous","en":"among you","tr":"minkum","isWaqf":false},{"position":13,"ar":"وَأَقِيمُوا۟","fr":"et établir","en":"and establish","tr":"wa-aqīmū","isWaqf":false},{"position":14,"ar":"ٱلشَّهَـٰدَةَ","fr":"le témoignage","en":"the testimony","tr":"l-shahādata","isWaqf":false},{"position":15,"ar":"لِلَّهِ ۚ","fr":"pour Allah","en":"for Allah","tr":"lillahi","isWaqf":false},{"position":16,"ar":"ذَٰلِكُمْ","fr":"Cela","en":"That","tr":"dhālikum","isWaqf":false},{"position":17,"ar":"يُوعَظُ","fr":"est instruisit","en":"is instructed","tr":"yūʿaẓu","isWaqf":false},{"position":18,"ar":"بِهِۦ","fr":"avec cela","en":"with it","tr":"bihi","isWaqf":false},{"position":19,"ar":"مَن","fr":"quiconque","en":"whoever","tr":"man","isWaqf":false},{"position":20,"ar":"كَانَ","fr":"[est]","en":"[is]","tr":"kāna","isWaqf":false},{"position":21,"ar":"يُؤْمِنُ","fr":"croit","en":"believes","tr":"yu'minu","isWaqf":false},{"position":22,"ar":"بِٱللَّهِ","fr":"dans Allah","en":"in Allah","tr":"bil-lahi","isWaqf":false},{"position":23,"ar":"وَٱلْيَوْمِ","fr":"et le Jour","en":"and the Day","tr":"wal-yawmi","isWaqf":false},{"position":24,"ar":"ٱلْـَٔاخِرِ ۚ","fr":"le Dernier","en":"the Last","tr":"l-ākhiri","isWaqf":false},{"position":25,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":26,"ar":"يَتَّقِ","fr":"craint","en":"fears","tr":"yattaqi","isWaqf":false},{"position":27,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":28,"ar":"يَجْعَل","fr":"Il va faire","en":"He will make","tr":"yajʿal","isWaqf":false},{"position":29,"ar":"لَّهُۥ","fr":"pour lui","en":"for him","tr":"lahu","isWaqf":false},{"position":30,"ar":"مَخْرَجًۭا","fr":"un voie hors","en":"a way out","tr":"makhrajan","isWaqf":false}]},{"ayah":3,"verseKey":"65:3","juz":28,"arabic":"وَيَرْزُقْهُ مِنْ حَيْثُ لَا يَحْتَسِبُ ۚ وَمَن يَتَوَكَّلْ عَلَى ٱللَّهِ فَهُوَ حَسْبُهُۥٓ ۚ إِنَّ ٱللَّهَ بَـٰلِغُ أَمْرِهِۦ ۚ قَدْ جَعَلَ ٱللَّهُ لِكُلِّ شَىْءٍ قَدْرًا","fr":"et lui dispensera (des biens) d’une manière à laquelle il ne s’attendait pas. Quiconque s’en remet à Allah, (Allah) lui suffira. Allah atteint toujours Son objectif et Il a prévu à chaque chose un terme mesuré.","en":"And will provide for him from where he does not expect. And whoever relies upon Allāh - then He is sufficient for him. Indeed, Allāh will accomplish His purpose. Allāh has already set for everything a [decreed] extent.","words":[{"position":1,"ar":"وَيَرْزُقْهُ","fr":"Et Il va pourvoir pour lui","en":"And He will provide for him","tr":"wayarzuq'hu","isWaqf":false},{"position":2,"ar":"مِنْ","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":3,"ar":"حَيْثُ","fr":"où","en":"where","tr":"ḥaythu","isWaqf":false},{"position":4,"ar":"لَا","fr":"non","en":"not","tr":"lā","isWaqf":false},{"position":5,"ar":"يَحْتَسِبُ ۚ","fr":"il pense","en":"he thinks","tr":"yaḥtasibu","isWaqf":false},{"position":6,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":7,"ar":"يَتَوَكَّلْ","fr":"met son dépôt","en":"puts his trust","tr":"yatawakkal","isWaqf":false},{"position":8,"ar":"عَلَى","fr":"sur","en":"upon","tr":"ʿalā","isWaqf":false},{"position":9,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":10,"ar":"فَهُوَ","fr":"puis Il","en":"then He","tr":"fahuwa","isWaqf":false},{"position":11,"ar":"حَسْبُهُۥٓ ۚ","fr":"(est) suffisant pour lui","en":"(is) sufficient for him","tr":"ḥasbuhu","isWaqf":false},{"position":12,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":13,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":14,"ar":"بَـٰلِغُ","fr":"(va) accomplir","en":"(will) accomplish","tr":"bālighu","isWaqf":false},{"position":15,"ar":"أَمْرِهِۦ ۚ","fr":"Son dessein","en":"His purpose","tr":"amrihi","isWaqf":false},{"position":16,"ar":"قَدْ","fr":"Certes","en":"Indeed","tr":"qad","isWaqf":false},{"position":17,"ar":"جَعَلَ","fr":"a placer","en":"has set","tr":"jaʿala","isWaqf":false},{"position":18,"ar":"ٱللَّهُ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":19,"ar":"لِكُلِّ","fr":"pour chaque","en":"for every","tr":"likulli","isWaqf":false},{"position":20,"ar":"شَىْءٍۢ","fr":"chose","en":"thing","tr":"shayin","isWaqf":false},{"position":21,"ar":"قَدْرًۭا","fr":"un mesure","en":"a measure","tr":"qadran","isWaqf":false}]},{"ayah":4,"verseKey":"65:4","juz":28,"arabic":"وَٱلَّـٰٓـِٔى يَئِسْنَ مِنَ ٱلْمَحِيضِ مِن نِّسَآئِكُمْ إِنِ ٱرْتَبْتُمْ فَعِدَّتُهُنَّ ثَلَـٰثَةُ أَشْهُرٍ وَٱلَّـٰٓـِٔى لَمْ يَحِضْنَ ۚ وَأُو۟لَـٰتُ ٱلْأَحْمَالِ أَجَلُهُنَّ أَن يَضَعْنَ حَمْلَهُنَّ ۚ وَمَن يَتَّقِ ٱللَّهَ يَجْعَل لَّهُۥ مِنْ أَمْرِهِۦ يُسْرًا","fr":"Celles qui ont atteint la ménopause, parmi vos femmes, devront observer, si vous avez des doutes (en comptant les jours de la ‘iddah), une (période) d’attente de trois mois. La même (attente est prescrite) à celles qui n’ont pas encore leurs règles. Quant à celles qui sont enceintes, leur terme de viduité est l’accouchement. Quiconque craint Allah, (Allah) lui rendra les choses plus faciles.","en":"And those who no longer expect menstruation among your women - if you doubt, then their period is three months, and [also for] those who have not menstruated. And for those who are pregnant, their term is until they give birth. And whoever fears Allāh - He will make for him of his matter ease.","words":[{"position":1,"ar":"وَٱلَّـٰٓـِٔى","fr":"Et ceux qui","en":"And those who","tr":"wa-allāī","isWaqf":false},{"position":2,"ar":"يَئِسْنَ","fr":"ont désespéra","en":"have despaired","tr":"ya-is'na","isWaqf":false},{"position":3,"ar":"مِنَ","fr":"de","en":"of","tr":"mina","isWaqf":false},{"position":4,"ar":"ٱلْمَحِيضِ","fr":"le menstrues","en":"the menstruation","tr":"l-maḥīḍi","isWaqf":false},{"position":5,"ar":"مِن","fr":"parmi","en":"among","tr":"min","isWaqf":false},{"position":6,"ar":"نِّسَآئِكُمْ","fr":"vos femmes","en":"your women","tr":"nisāikum","isWaqf":false},{"position":7,"ar":"إِنِ","fr":"si","en":"if","tr":"ini","isWaqf":false},{"position":8,"ar":"ٱرْتَبْتُمْ","fr":"vous doute","en":"you doubt","tr":"ir'tabtum","isWaqf":false},{"position":9,"ar":"فَعِدَّتُهُنَّ","fr":"puis leur attendant délai","en":"then their waiting period","tr":"faʿiddatuhunna","isWaqf":false},{"position":10,"ar":"ثَلَـٰثَةُ","fr":"(est) trois","en":"(is) three","tr":"thalāthatu","isWaqf":false},{"position":11,"ar":"أَشْهُرٍۢ","fr":"mois","en":"months","tr":"ashhurin","isWaqf":false},{"position":12,"ar":"وَٱلَّـٰٓـِٔى","fr":"et le ceux qui","en":"and the ones who","tr":"wa-allāī","isWaqf":false},{"position":13,"ar":"لَمْ","fr":"non","en":"not","tr":"lam","isWaqf":false},{"position":14,"ar":"يَحِضْنَ ۚ","fr":"[ils] menstruated","en":"[they] menstruated","tr":"yaḥiḍ'na","isWaqf":false},{"position":15,"ar":"وَأُو۟لَـٰتُ","fr":"Et ceux qui (sont)","en":"And those who (are)","tr":"wa-ulātu","isWaqf":false},{"position":16,"ar":"ٱلْأَحْمَالِ","fr":"enceinte","en":"pregnant","tr":"l-aḥmāli","isWaqf":false},{"position":17,"ar":"أَجَلُهُنَّ","fr":"leur terme","en":"their term","tr":"ajaluhunna","isWaqf":false},{"position":18,"ar":"أَن","fr":"jusqu'à","en":"until","tr":"an","isWaqf":false},{"position":19,"ar":"يَضَعْنَ","fr":"ils délivrent","en":"they deliver","tr":"yaḍaʿna","isWaqf":false},{"position":20,"ar":"حَمْلَهُنَّ ۚ","fr":"leur fardeaux","en":"their burdens","tr":"ḥamlahunna","isWaqf":false},{"position":21,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":22,"ar":"يَتَّقِ","fr":"craint","en":"fears","tr":"yattaqi","isWaqf":false},{"position":23,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":24,"ar":"يَجْعَل","fr":"Il va faire","en":"He will make","tr":"yajʿal","isWaqf":false},{"position":25,"ar":"لَّهُۥ","fr":"pour lui","en":"for him","tr":"lahu","isWaqf":false},{"position":26,"ar":"مِنْ","fr":"de","en":"of","tr":"min","isWaqf":false},{"position":27,"ar":"أَمْرِهِۦ","fr":"son affaire","en":"his affair","tr":"amrihi","isWaqf":false},{"position":28,"ar":"يُسْرًۭا","fr":"aisance","en":"ease","tr":"yus'ran","isWaqf":false}]},{"ayah":5,"verseKey":"65:5","juz":28,"arabic":"ذَٰلِكَ أَمْرُ ٱللَّهِ أَنزَلَهُۥٓ إِلَيْكُمْ ۚ وَمَن يَتَّقِ ٱللَّهَ يُكَفِّرْ عَنْهُ سَيِّـَٔاتِهِۦ وَيُعْظِمْ لَهُۥٓ أَجْرًا","fr":"Tel est l’ordre qu’Allah a fait descendre pour vous. Quiconque craint Allah, (Allah) rachètera ses mauvaises actions et lui accordera une grande récompense.","en":"That is the command of Allāh, which He has sent down to you; and whoever fears Allāh - He will remove for him his misdeeds and make great for him his reward.","words":[{"position":1,"ar":"ذَٰلِكَ","fr":"Cela","en":"That","tr":"dhālika","isWaqf":false},{"position":2,"ar":"أَمْرُ","fr":"(est le) Ordre","en":"(is the) Command","tr":"amru","isWaqf":false},{"position":3,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":4,"ar":"أَنزَلَهُۥٓ","fr":"que Il a envoyé bas","en":"which He has sent down","tr":"anzalahu","isWaqf":false},{"position":5,"ar":"إِلَيْكُمْ ۚ","fr":"à vous","en":"to you","tr":"ilaykum","isWaqf":false},{"position":6,"ar":"وَمَن","fr":"et quiconque","en":"and whoever","tr":"waman","isWaqf":false},{"position":7,"ar":"يَتَّقِ","fr":"craint","en":"fears","tr":"yattaqi","isWaqf":false},{"position":8,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":9,"ar":"يُكَفِّرْ","fr":"Il va ôter","en":"He will remove","tr":"yukaffir","isWaqf":false},{"position":10,"ar":"عَنْهُ","fr":"de lui","en":"from him","tr":"ʿanhu","isWaqf":false},{"position":11,"ar":"سَيِّـَٔاتِهِۦ","fr":"son mal actions","en":"his evil deeds","tr":"sayyiātihi","isWaqf":false},{"position":12,"ar":"وَيُعْظِمْ","fr":"et faire grand","en":"and make great","tr":"wayuʿ'ẓim","isWaqf":false},{"position":13,"ar":"لَهُۥٓ","fr":"pour lui","en":"for him","tr":"lahu","isWaqf":false},{"position":14,"ar":"أَجْرًا","fr":"(son) récompense","en":"(his) reward","tr":"ajran","isWaqf":false}]},{"ayah":6,"verseKey":"65:6","juz":28,"arabic":"أَسْكِنُوهُنَّ مِنْ حَيْثُ سَكَنتُم مِّن وُجْدِكُمْ وَلَا تُضَآرُّوهُنَّ لِتُضَيِّقُوا۟ عَلَيْهِنَّ ۚ وَإِن كُنَّ أُو۟لَـٰتِ حَمْلٍ فَأَنفِقُوا۟ عَلَيْهِنَّ حَتَّىٰ يَضَعْنَ حَمْلَهُنَّ ۚ فَإِنْ أَرْضَعْنَ لَكُمْ فَـَٔاتُوهُنَّ أُجُورَهُنَّ ۖ وَأْتَمِرُوا۟ بَيْنَكُم بِمَعْرُوفٍ ۖ وَإِن تَعَاسَرْتُمْ فَسَتُرْضِعُ لَهُۥٓ أُخْرَىٰ","fr":"Logez (vos femmes répudiées) dans (les habitations) où vous résidez vous-mêmes, selon vos moyens. Ne leur cherchez pas noise en leur rendant la vie insupportable. Et si elles sont enceintes, assurez les dépenses qui leur sont nécessaires jusqu’à ce qu’elles accouchent. Si, (par la suite), elles allaitent (votre enfant), versez-leur une pension. Que vos concertations (à ce sujet) soient sereines et convenables. Mais, si vous ne vous vous êtes pas entendus, que l’allaitement soit confié à une autre (femme).","en":"Lodge them [in a section] of where you dwell out of your means and do not harm them in order to oppress them. And if they should be pregnant, then spend on them until they give birth. And if they breastfeed for you, then give them their payment and confer among yourselves in the acceptable way; but if you are in discord, then there may breastfeed for him [i.e., the father] another woman.","words":[{"position":1,"ar":"أَسْكِنُوهُنَّ","fr":"Lodge eux","en":"Lodge them","tr":"askinūhunna","isWaqf":false},{"position":2,"ar":"مِنْ","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":3,"ar":"حَيْثُ","fr":"où","en":"where","tr":"ḥaythu","isWaqf":false},{"position":4,"ar":"سَكَنتُم","fr":"vous habitez","en":"you dwell","tr":"sakantum","isWaqf":false},{"position":5,"ar":"مِّن","fr":"(hors) de","en":"(out) of","tr":"min","isWaqf":false},{"position":6,"ar":"وُجْدِكُمْ","fr":"votre moyen","en":"your means","tr":"wuj'dikum","isWaqf":false},{"position":7,"ar":"وَلَا","fr":"et (fais) non","en":"and (do) not","tr":"walā","isWaqf":false},{"position":8,"ar":"تُضَآرُّوهُنَّ","fr":"nuire eux","en":"harm them","tr":"tuḍārrūhunna","isWaqf":false},{"position":9,"ar":"لِتُضَيِّقُوا۟","fr":"à détresse","en":"to distress","tr":"lituḍayyiqū","isWaqf":false},{"position":10,"ar":"عَلَيْهِنَّ ۚ","fr":"[sur] eux","en":"[on] them","tr":"ʿalayhinna","isWaqf":false},{"position":11,"ar":"وَإِن","fr":"Et si","en":"And if","tr":"wa-in","isWaqf":false},{"position":12,"ar":"كُنَّ","fr":"ils sont","en":"they are","tr":"kunna","isWaqf":false},{"position":13,"ar":"أُو۟لَـٰتِ","fr":"ceux (qui sont)","en":"those (who are)","tr":"ulāti","isWaqf":false},{"position":14,"ar":"حَمْلٍۢ","fr":"enceinte","en":"pregnant","tr":"ḥamlin","isWaqf":false},{"position":15,"ar":"فَأَنفِقُوا۟","fr":"puis dépenser","en":"then spend","tr":"fa-anfiqū","isWaqf":false},{"position":16,"ar":"عَلَيْهِنَّ","fr":"sur eux","en":"on them","tr":"ʿalayhinna","isWaqf":false},{"position":17,"ar":"حَتَّىٰ","fr":"jusqu'à","en":"until","tr":"ḥattā","isWaqf":false},{"position":18,"ar":"يَضَعْنَ","fr":"ils délivrent","en":"they deliver","tr":"yaḍaʿna","isWaqf":false},{"position":19,"ar":"حَمْلَهُنَّ ۚ","fr":"leur fardeau","en":"their burden","tr":"ḥamlahunna","isWaqf":false},{"position":20,"ar":"فَإِنْ","fr":"Puis si","en":"Then if","tr":"fa-in","isWaqf":false},{"position":21,"ar":"أَرْضَعْنَ","fr":"ils allaitent","en":"they suckle","tr":"arḍaʿna","isWaqf":false},{"position":22,"ar":"لَكُمْ","fr":"pour vous","en":"for you","tr":"lakum","isWaqf":false},{"position":23,"ar":"فَـَٔاتُوهُنَّ","fr":"puis donner eux","en":"then give them","tr":"faātūhunna","isWaqf":false},{"position":24,"ar":"أُجُورَهُنَّ ۖ","fr":"leur paiement","en":"their payment","tr":"ujūrahunna","isWaqf":false},{"position":25,"ar":"وَأْتَمِرُوا۟","fr":"et consulter","en":"and consult","tr":"watamirū","isWaqf":false},{"position":26,"ar":"بَيْنَكُم","fr":"parmi vous-mêmes","en":"among yourselves","tr":"baynakum","isWaqf":false},{"position":27,"ar":"بِمَعْرُوفٍۢ ۖ","fr":"avec bonté","en":"with kindness","tr":"bimaʿrūfin","isWaqf":false},{"position":28,"ar":"وَإِن","fr":"mais si","en":"but if","tr":"wa-in","isWaqf":false},{"position":29,"ar":"تَعَاسَرْتُمْ","fr":"vous divergez","en":"you disagree","tr":"taʿāsartum","isWaqf":false},{"position":30,"ar":"فَسَتُرْضِعُ","fr":"puis peut allaiter","en":"then may suckle","tr":"fasatur'ḍiʿu","isWaqf":false},{"position":31,"ar":"لَهُۥٓ","fr":"pour lui","en":"for him","tr":"lahu","isWaqf":false},{"position":32,"ar":"أُخْرَىٰ","fr":"un autre (femmes)","en":"another (women)","tr":"ukh'rā","isWaqf":false}]},{"ayah":7,"verseKey":"65:7","juz":28,"arabic":"لِيُنفِقْ ذُو سَعَةٍ مِّن سَعَتِهِۦ ۖ وَمَن قُدِرَ عَلَيْهِ رِزْقُهُۥ فَلْيُنفِقْ مِمَّآ ءَاتَىٰهُ ٱللَّهُ ۚ لَا يُكَلِّفُ ٱللَّهُ نَفْسًا إِلَّا مَآ ءَاتَىٰهَا ۚ سَيَجْعَلُ ٱللَّهُ بَعْدَ عُسْرٍ يُسْرًا","fr":"Que le fortuné dépense selon sa fortune ; et que l’homme de condition plus modeste dépense de ce qu’Allah lui a accordé (comme biens). Allah ne charge une personne que selon ce qu’Il lui a donné. Allah fera qu’après la difficulté vienne l’aisance.","en":"Let a man of wealth spend from his wealth, and he whose provision is restricted - let him spend from what Allāh has given him. Allāh does not charge a soul except [according to] what He has given it. Allāh will bring about, after hardship, ease [i.e., relief].","words":[{"position":1,"ar":"لِيُنفِقْ","fr":"Laisser dépenser","en":"Let spend","tr":"liyunfiq","isWaqf":false},{"position":2,"ar":"ذُو","fr":"détenteur","en":"owner","tr":"dhū","isWaqf":false},{"position":3,"ar":"سَعَةٍۢ","fr":"(de) ample moyen","en":"(of) ample means","tr":"saʿatin","isWaqf":false},{"position":4,"ar":"مِّن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":5,"ar":"سَعَتِهِۦ ۖ","fr":"son ample moyen","en":"his ample means","tr":"saʿatihi","isWaqf":false},{"position":6,"ar":"وَمَن","fr":"et (celui) qui","en":"and (he) who","tr":"waman","isWaqf":false},{"position":7,"ar":"قُدِرَ","fr":"est restreint","en":"is restricted","tr":"qudira","isWaqf":false},{"position":8,"ar":"عَلَيْهِ","fr":"sur lui","en":"on him","tr":"ʿalayhi","isWaqf":false},{"posi