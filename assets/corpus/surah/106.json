[{"ayah":1,"verseKey":"106:1","juz":30,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ لِإِيلَـٰفِ قُرَيْشٍ","fr":"Pour les bienfaits reçus par Qoraïch,","en":"For the accustomed security of the Quraysh -","words":[{"position":1,"ar":"لِإِيلَـٰفِ","fr":"Pour (le) familiarité","en":"For (the) familiarity","tr":"liīlāfi","isWaqf":false},{"position":2,"ar":"قُرَيْشٍ","fr":"(du) Quraych","en":"(of the) Quraish","tr":"qurayshin","isWaqf":false}]},{"ayah":2,"verseKey":"106:2","juz":30,"arabic":"إِۦلَـٰفِهِمْ رِحْلَةَ ٱلشِّتَآءِ وَٱلصَّيْفِ","fr":"Pour les bienfaits de leurs voyages d’hiver et d’été,","en":"Their accustomed security [in] the caravan of winter and summer -","words":[{"position":1,"ar":"إِۦلَـٰفِهِمْ","fr":"Leur familiarité","en":"Their familiarity","tr":"īlāfihim","isWaqf":false},{"position":2,"ar":"رِحْلَةَ","fr":"(avec le) voyage","en":"(with the) journey","tr":"riḥ'lata","isWaqf":false},{"position":3,"ar":"ٱلشِّتَآءِ","fr":"(de) winter","en":"(of) winter","tr":"l-shitāi","isWaqf":false},{"position":4,"ar":"وَٱلصَّيْفِ","fr":"et summer","en":"and summer","tr":"wal-ṣayfi","isWaqf":false}]},{"ayah":3,"verseKey":"106:3","juz":30,"arabic":"فَلْيَعْبُدُوا۟ رَبَّ هَـٰذَا ٱلْبَيْتِ","fr":"qu’ils adorent donc le Seigneur de cette Maison,","en":"Let them worship the Lord of this House,","words":[{"position":1,"ar":"فَلْيَعْبُدُوا۟","fr":"Donc laisser eux adorer","en":"So let them worship","tr":"falyaʿbudū","isWaqf":false},{"position":2,"ar":"رَبَّ","fr":"(le) Seigneur","en":"(the) Lord","tr":"rabba","isWaqf":false},{"position":3,"ar":"هَـٰذَا","fr":"(de) ceci","en":"(of) this","tr":"hādhā","isWaqf":false},{"position":4,"ar":"ٱلْبَيْتِ","fr":"Maison","en":"House","tr":"l-bayti","isWaqf":false}]},{"ayah":4,"verseKey":"106:4","juz":30,"arabic":"ٱلَّذِىٓ أَطْعَمَهُم مِّن جُوعٍ وَءَامَنَهُم مِّنْ خَوْفٍۭ","fr":"Qui les a nourris au mépris de la faim, et les a rassurés en dépit de la peur !","en":"Who has fed them, [saving them] from hunger and made them safe, [saving them] from fear.","words":[{"position":1,"ar":"ٱلَّذِىٓ","fr":"Celui qui","en":"The One Who","tr":"alladhī","isWaqf":false},{"position":2,"ar":"أَطْعَمَهُم","fr":"nourrit eux","en":"feeds them","tr":"aṭʿamahum","isWaqf":false},{"position":3,"ar":"مِّن","fr":"[de]","en":"[from]","tr":"min","isWaqf":false},{"position":4,"ar":"جُوعٍۢ","fr":"(contre) faim","en":"(against) hunger","tr":"jūʿin","isWaqf":false},{"position":5,"ar":"وَءَامَنَهُم","fr":"et donne eux sécurité","en":"and gives them security","tr":"waāmanahum","isWaqf":false},{"position":6,"ar":"مِّنْ","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":7,"ar":"خَوْفٍۭ","fr":"craindre","en":"fear","tr":"khawfin","isWaqf":false}]}]