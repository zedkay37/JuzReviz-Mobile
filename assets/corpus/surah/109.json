[{"ayah":1,"verseKey":"109:1","juz":30,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ قُلْ يَـٰٓأَيُّهَا ٱلْكَـٰفِرُونَ","fr":"Dis : « Ô vous les mécréants !","en":"Say, \"O disbelievers,","words":[{"position":1,"ar":"قُلْ","fr":"Dis","en":"Say","tr":"qul","isWaqf":false},{"position":2,"ar":"يَـٰٓأَيُّهَا","fr":"Ô","en":"O","tr":"yāayyuhā","isWaqf":false},{"position":3,"ar":"ٱلْكَـٰفِرُونَ","fr":"mécréants","en":"disbelievers","tr":"l-kāfirūna","isWaqf":false}]},{"ayah":2,"verseKey":"109:2","juz":30,"arabic":"لَآ أَعْبُدُ مَا تَعْبُدُونَ","fr":"Je n’adore point ce que vous adorez.","en":"I do not worship what you worship.","words":[{"position":1,"ar":"لَآ","fr":"Non","en":"Not","tr":"lā","isWaqf":false},{"position":2,"ar":"أَعْبُدُ","fr":"j'adore","en":"I worship","tr":"aʿbudu","isWaqf":false},{"position":3,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":4,"ar":"تَعْبُدُونَ","fr":"vous adorez","en":"you worship","tr":"taʿbudūna","isWaqf":false}]},{"ayah":3,"verseKey":"109:3","juz":30,"arabic":"وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ","fr":"Pas plus que vous n’allez adorer ce que j’adore.","en":"Nor are you worshippers of what I worship.","words":[{"position":1,"ar":"وَلَآ","fr":"Et non","en":"And not","tr":"walā","isWaqf":false},{"position":2,"ar":"أَنتُمْ","fr":"vous","en":"you","tr":"antum","isWaqf":false},{"position":3,"ar":"عَـٰبِدُونَ","fr":"(sont) adorateurs","en":"(are) worshippers","tr":"ʿābidūna","isWaqf":false},{"position":4,"ar":"مَآ","fr":"(de) ce que","en":"(of) what","tr":"mā","isWaqf":false},{"position":5,"ar":"أَعْبُدُ","fr":"j'adore","en":"I worship","tr":"aʿbudu","isWaqf":false}]},{"ayah":4,"verseKey":"109:4","juz":30,"arabic":"وَلَآ أَنَا۠ عَابِدٌ مَّا عَبَدتُّمْ","fr":"Ni moi je ne vais adorer ce que vous avez adoré.","en":"Nor will I be a worshipper of what you worship.","words":[{"position":1,"ar":"وَلَآ","fr":"Et non","en":"And not","tr":"walā","isWaqf":false},{"position":2,"ar":"أَنَا۠","fr":"je suis","en"