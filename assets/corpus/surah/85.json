ابُ","fr":"(est le) châtiment","en":"(is the) punishment","tr":"ʿadhābu","isWaqf":false},{"position":14,"ar":"ٱلْحَرِيقِ","fr":"(de) le Brûlant Feu","en":"(of) the Burning Fire","tr":"l-ḥarīqi","isWaqf":false}]},{"ayah":11,"verseKey":"85:11","juz":30,"arabic":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمْ جَنَّـٰتٌ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَـٰرُ ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْكَبِيرُ","fr":"Ceux qui ont cru et ont accompli les bonnes œuvres auront des jardins sous lesquels coulent les rivières. Tel est le succès suprême !","en":"Indeed, those who have believed and done righteous deeds will have gardens beneath which rivers flow. That is the great attainment.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"croire","en":"believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"وَعَمِلُوا۟","fr":"et faire","en":"and do","tr":"waʿamilū","isWaqf":false},{"position":5,"ar":"ٱلصَّـٰلِحَـٰتِ","fr":"le vertueux actions","en":"the righteous deeds","tr":"l-ṣāliḥāti","isWaqf":false},{"position":6,"ar":"لَهُمْ","fr":"pour eux","en":"for them","tr":"lahum","isWaqf":false},{"position":7,"ar":"جَنَّـٰتٌۭ","fr":"(va être) Jardins","en":"(will be) Gardens","tr":"jannātun","isWaqf":false},{"position":8,"ar":"تَجْرِى","fr":"couler","en":"flow","tr":"tajrī","isWaqf":false},{"position":9,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":10,"ar":"تَحْتِهَا","fr":"en dessous de lui","en":"underneath it","tr":"taḥtihā","isWaqf":false},{"position":11,"ar":"ٱلْأَنْهَـٰرُ ۚ","fr":"les rivières","en":"the rivers","tr":"l-anhāru","isWaqf":false},{"position":12,"ar":"ذَٰلِكَ","fr":"Cela","en":"That","tr":"dhālika","isWaqf":false},{"position":13,"ar":"ٱلْفَوْزُ","fr":"(est) le succès","en":"(is) the success","tr":"l-fawzu","isWaqf":false},{"position":14,"ar":"ٱلْكَبِيرُ","fr":"le grand","en":"the great","tr":"l-kabīru","isWaqf":false}]},{"ayah":12,"verseKey":"85:12","juz":30,"arabic":"إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ","fr":"Les représailles de ton Seigneur seront très dures.","en":"Indeed, the assault [i.e., vengeance] of your Lord is severe.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"بَطْشَ","fr":"(le) Emprise","en":"(the) Grip","tr":"baṭsha","isWaqf":false},{"position":3,"ar":"رَبِّكَ","fr":"(de) votre Seigneur","en":"(of) your Lord","tr":"rabbika","isWaqf":false},{"position":4,"ar":"لَشَدِيدٌ","fr":"(est) assurément fort","en":"(is) surely strong","tr":"lashadīdun","isWaqf":false}]},{"ayah":13,"verseKey":"85:13","juz":30,"arabic":"إِنَّهُۥ هُوَ يُبْدِئُ وَيُعِيدُ","fr":"C’est Lui Qui initie (la création) puis la recommence.","en":"Indeed, it is He who originates [creation] and repeats.","words":[{"position":1,"ar":"إِنَّهُۥ","fr":"Certes Il","en":"Indeed He","tr":"innahu","isWaqf":false},{"position":2,"ar":"هُوَ","fr":"Il","en":"He","tr":"huwa","isWaqf":false},{"position":3,"ar":"يُبْدِئُ","fr":"fait naître","en":"originates","tr":"yub'di-u","isWaqf":false},{"position":4,"ar":"وَيُعِيدُ","fr":"et répète","en":"and repeats","tr":"wayuʿīdu","isWaqf":false}]},{"ayah":14,"verseKey":"85:14","juz":30,"arabic":"وَهُوَ ٱلْغَفُورُ ٱلْوَدُودُ","fr":"C’est Lui l’Absoluteur, plein de Dilection,","en":"And He is the Forgiving, the Affectionate,","words":[{"position":1,"ar":"وَهُوَ","fr":"Et Il","en":"And He","tr":"wahuwa","isWaqf":false},{"position":2,"ar":"ٱلْغَفُورُ","fr":"(est) le Pardonneur","en":"(is) the Oft-Forgiving","tr":"l-ghafūru","isWaqf":false},{"position":3,"ar":"ٱلْوَدُودُ","fr":"le Très Aimant","en":"the Most Loving","tr":"l-wadūdu","isWaqf":false}]},{"ayah":15,"verseKey":"85:15","juz":30,"arabic":"ذُو ٱلْعَرْشِ ٱلْمَجِيدُ","fr":"Le Détenteur du Trône, le Glorieux,","en":"Honorable Owner of the Throne,","words":[{"position":1,"ar":"ذُو","fr":"Détenteur (de)","en":"Owner (of)","tr":"dhū","isWaqf":false},{"position":2,"ar":"ٱلْعَرْشِ","fr":"le Trône","en":"the Throne","tr":"l-ʿarshi","isWaqf":false},{"position":3,"ar":"ٱلْمَجِيدُ","fr":"le Glorieux","en":"the Glorious","tr":"l-majīdu","isWaqf":false}]},{"ayah":16,"verseKey":"85:16","juz":30,"arabic":"فَعَّالٌ لِّمَا يُرِيدُ","fr":"Qui fait toujours ce qu’Il veut !","en":"Effecter of what He intends.","words":[{"position":1,"ar":"فَعَّالٌۭ","fr":"Celui qui fait","en":"Doer","tr":"faʿʿālun","isWaqf":false},{"position":2,"ar":"لِّمَا","fr":"de ce que","en":"of what","tr":"limā","isWaqf":false},{"position":3,"ar":"يُرِيدُ","fr":"Il veut","en":"He intends","tr":"yurīdu","isWaqf":false}]},{"ayah":17,"verseKey":"85:17","juz":30,"arabic":"هَلْ أَتَىٰكَ حَدِيثُ ٱلْجُنُودِ","fr":"T’est-il parvenu le récit des armées ?","en":"Has there reached you the story of the soldiers -","words":[{"position":1,"ar":"هَلْ","fr":"A","en":"Has","tr":"hal","isWaqf":false},{"position":2,"ar":"أَتَىٰكَ","fr":"venir à toi","en":"come to you","tr":"atāka","isWaqf":false},{"position":3,"ar":"حَدِيثُ","fr":"(le) récit","en":"(the) story","tr":"ḥadīthu","isWaqf":false},{"position":4,"ar":"ٱلْجُنُودِ","fr":"(de) le armées","en":"(of) the hosts","tr":"l-junūdi","isWaqf":false}]},{"ayah":18,"verseKey":"85:18","juz":30,"arabic":"فِرْعَوْنَ وَثَمُودَ","fr":"Celles de Pharaon et des Thamûd ?","en":"[Those of] Pharaoh and Thamūd?","words":[{"position":1,"ar":"فِرْعَوْنَ","fr":"Fir'aun","en":"Firaun","tr":"fir'ʿawna","isWaqf":false},{"position":2,"ar":"وَثَمُودَ","fr":"et Thamud","en":"and Thamud","tr":"wathamūda","isWaqf":false}]},{"ayah":19,"verseKey":"85:19","juz":30,"arabic":"بَلِ ٱلَّذِينَ كَفَرُوا۟ فِى تَكْذِيبٍ","fr":"Et pourtant, ceux qui ont mécru crient toujours au mensonge.","en":"But they who disbelieve are in [persistent] denial,","words":[{"position":1,"ar":"بَلِ","fr":"Non","en":"Nay","tr":"bali","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"Ceux qui","en":"Those who","tr":"alladhīna","isWaqf":false},{"pos