":"ٱلنَّارِ","fr":"(de) le feu","en":"(Of) the fire","tr":"al-nāri","isWaqf":false},{"position":2,"ar":"ذَاتِ","fr":"plein","en":"full","tr":"dhāti","isWaqf":false},{"position":3,"ar":"ٱلْوَقُودِ","fr":"(de) le combustible","en":"(of) the fuel","tr":"l-waqūdi","isWaqf":false}]},{"ayah":6,"verseKey":"85:6","juz":30,"arabic":"إِذْ هُمْ عَلَيْهَا قُعُودٌ","fr":"(les mécréants) étaient assis,","en":"When they were sitting near it.","words":[{"position":1,"ar":"إِذْ","fr":"Quand","en":"When","tr":"idh","isWaqf":false},{"position":2,"ar":"هُمْ","fr":"ils","en":"they","tr":"hum","isWaqf":false},{"position":3,"ar":"عَلَيْهَا","fr":"par cela","en":"by it","tr":"ʿalayhā","isWaqf":false},{"position":4,"ar":"قُعُودٌۭ","fr":"(étaient) assis","en":"(were) sitting","tr":"quʿūdun","isWaqf":false}]},{"ayah":7,"verseKey":"85:7","juz":30,"arabic":"وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِٱلْمُؤْمِنِينَ شُهُودٌ","fr":"et regardaient en témoins ce qu’ils faisaient subir aux croyants.","en":"And they, to what they were doing against the believers, were witnesses.","words":[{"position":1,"ar":"وَهُمْ","fr":"Et ils","en":"And they","tr":"wahum","isWaqf":false},{"position":2,"ar":"عَلَىٰ","fr":"sur","en":"over","tr":"ʿalā","isWaqf":false},{"position":3,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":4,"ar":"يَفْعَلُونَ","fr":"ils étaient faisant","en":"they were doing","tr":"yafʿalūna","isWaqf":false},{"position":5,"ar":"بِٱلْمُؤْمِنِينَ","fr":"à les croyants","en":"to the believers","tr":"bil-mu'minīna","isWaqf":false},{"position":6,"ar":"شُهُودٌۭ","fr":"témoins","en":"witnesses","tr":"shuhūdun","isWaqf":false}]},{"ayah":8,"verseKey":"85:8","juz":30,"arabic":"وَمَا نَقَمُوا۟ مِنْهُمْ إِلَّآ أَن يُؤْمِنُوا۟ بِٱللَّهِ ٱلْعَزِيزِ ٱلْحَمِيدِ","fr":"Ils ne leur en voulaient que parce qu’ils croyaient en Allah, le Tout- Puissant, le Digne de Toute Louange,","en":"And they resented them not except because they believed in Allāh, the Exalted in Might, the Praiseworthy,","words":