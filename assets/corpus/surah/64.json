[{"ayah":1,"verseKey":"64:1","juz":28,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ يُسَبِّحُ لِلَّهِ مَا فِى ٱلسَّمَـٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۖ لَهُ ٱلْمُلْكُ وَلَهُ ٱلْحَمْدُ ۖ وَهُوَ عَلَىٰ كُلِّ شَىْءٍ قَدِيرٌ","fr":"Tout ce qui est dans les cieux et sur terre rend gloire à Allah. À Lui la royauté ! À Lui toute louange ! Il est de Toute chose Infiniment Capable.","en":"Whatever is in the heavens and whatever is on the earth is exalting Allāh. To Him belongs dominion, and to Him belongs [all] praise, and He is over all things competent.","words":[{"position":1,"ar":"يُسَبِّحُ","fr":"Glorifie","en":"Glorifies","tr":"yusabbiḥu","isWaqf":false},{"position":2,"ar":"لِلَّهِ","fr":"[à] Allah","en":"[to] Allah","tr":"lillahi","isWaqf":false},{"position":3,"ar":"مَا","fr":"quoi que","en":"whatever","tr":"mā","isWaqf":false},{"position":4,"ar":"فِى","fr":"(est) en","en":"(is) in","tr":"fī","isWaqf":false},{"position":5,"ar":"ٱلسَّمَـٰوَٰتِ","fr":"les cieux","en":"the heavens","tr":"l-samāwāti","isWaqf":false},{"position":6,"ar":"وَمَا","fr":"et quoi que","en":"and whatever","tr":"wamā","isWaqf":false},{"position":7,"ar":"فِى","fr":"(est) en","en":"(is) in","tr":"fī","isWaqf":false},{"position":8,"ar":"ٱلْأَرْضِ ۖ","fr":"la terre","en":"the earth","tr":"l-arḍi","isWaqf":false},{"position":9,"ar":"لَهُ","fr":"Pour Lui","en":"For Him","tr":"lahu","isWaqf":false},{"position":10,"ar":"ٱلْمُلْكُ","fr":"(est le) royaume","en":"(is the) dominion","tr":"l-mul'ku","isWaqf":false},{"position":11,"ar":"وَلَهُ","fr":"et pour Lui","en":"and for Him","tr":"walahu","isWaqf":false},{"position":12,"ar":"ٱلْحَمْدُ ۖ","fr":"(est) le louange","en":"(is) the praise","tr":"l-ḥamdu","isWaqf":false},{"position":13,"ar":"وَهُوَ","fr":"Et Il","en":"And He","tr":"wahuwa","isWaqf":false},{"position":14,"ar":"عَلَىٰ","fr":"(est) sur","en":"(is) on","tr":"ʿalā","isWaqf":false},{"position":15,"ar":"كُلِّ","fr":"chaque","en":"every","tr":"kulli","isWaqf":false},{"position":16,"ar":"شَىْءٍۢ","fr":"chose","en":"thing","tr":"shayin","isWaqf":false},{"position":17,"ar":"قَدِيرٌ","fr":"Tout-Puissant","en":"All-Powerful","tr":"qadīrun","isWaqf":false}]},{"ayah":2,"verseKey":"64:2","juz":28,"arabic":"هُوَ ٱلَّذِى خَلَقَكُمْ فَمِنكُمْ كَافِرٌ وَمِنكُم مُّؤْمِنٌ ۚ وَٱللَّهُ بِمَا تَعْمَلُونَ بَصِيرٌ","fr":"C’est Lui Qui vous a créés. Il y a alors parmi vous le mécréant, et il y a le croyant. Allah est parfaitement Informé de ce que vous faites.","en":"It is He who created you, and among you is the disbeliever, and among you is the believer. And Allāh, of what you do, is Seeing.","words":[{"position":1,"ar":"هُوَ","fr":"Il","en":"He","tr":"huwa","isWaqf":false},{"position":2,"ar":"ٱلَّذِى","fr":"(est) Celui qui","en":"(is) the One Who","tr":"alladhī","isWaqf":false},{"position":3,"ar":"خَلَقَكُمْ","fr":"vous a créés","en":"created you","tr":"khalaqakum","isWaqf":false},{"position":4,"ar":"فَمِنكُمْ","fr":"et parmi vous","en":"and among you","tr":"faminkum","isWaqf":false},{"position":5,"ar":"كَافِرٌۭ","fr":"(est) un mécréant","en":"(is) a disbeliever","tr":"kāfirun","isWaqf":false},{"position":6,"ar":"وَمِنكُم","fr":"et parmi vous","en":"and among you","tr":"waminkum","isWaqf":false},{"position":7,"ar":"مُّؤْمِنٌۭ ۚ","fr":"(est) un croyant","en":"(is) a believer","tr":"mu'minun","isWaqf":false},{"position":8,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":9,"ar":"بِمَا","fr":"de ce que","en":"of what","tr":"bimā","isWaqf":false},{"position":10,"ar":"تَعْمَلُونَ","fr":"vous faire","en":"you do","tr":"taʿmalūna","isWaqf":false},{"position":11,"ar":"بَصِيرٌ","fr":"(est) Clairvoyant","en":"(is) All-Seer","tr":"baṣīrun","isWaqf":false}]},{"ayah":3,"verseKey":"64:3","juz":28,"arabic":"خَلَقَ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضَ بِٱلْحَقِّ وَصَوَّرَكُمْ فَأَحْسَنَ صُوَرَكُمْ ۖ وَإِلَيْهِ ٱلْمَصِيرُ","fr":"Il créa les cieux et la terre pour une juste raison, vous a modelé dans votre forme la plus belle, et c’est vers Lui que sera le devenir.","en":"He created the heavens and earth in truth and formed you and perfected your forms; and to Him is the [final] destination.","words":[{"position":1,"ar":"خَلَقَ","fr":"Il créé","en":"He created","tr":"khalaqa","isWaqf":false},{"position":2,"ar":"ٱلسَّمَـٰوَٰتِ","fr":"les cieux","en":"the heavens","tr":"l-samāwāti","isWaqf":false},{"position":3,"ar":"وَٱلْأَرْضَ","fr":"et la terre","en":"and the earth","tr":"wal-arḍa","isWaqf":false},{"position":4,"ar":"بِٱلْحَقِّ","fr":"avec vérité","en":"with truth","tr":"bil-ḥaqi","isWaqf":false},{"position":5,"ar":"وَصَوَّرَكُمْ","fr":"et Il façonna vous","en":"and He formed you","tr":"waṣawwarakum","isWaqf":false},{"position":6,"ar":"فَأَحْسَنَ","fr":"et fait bon","en":"and made good","tr":"fa-aḥsana","isWaqf":false},{"position":7,"ar":"صُوَرَكُمْ ۖ","fr":"votre formes","en":"your forms","tr":"ṣuwarakum","isWaqf":false},{"position":8,"ar":"وَإِلَيْهِ","fr":"et à Lui","en":"and to Him","tr":"wa-ilayhi","isWaqf":false},{"position":9,"ar":"ٱلْمَصِيرُ","fr":"(est) le final retourner","en":"(is) the final return","tr":"l-maṣīru","isWaqf":false}]},{"ayah":4,"verseKey":"64:4","juz":28,"arabic":"يَعْلَمُ مَا فِى ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ وَيَعْلَمُ مَا تُسِرُّونَ وَمَا تُعْلِنُونَ ۚ وَٱللَّهُ عَلِيمٌۢ بِذَاتِ ٱلصُّدُورِ","fr":"Il Sait ce qui est dans les cieux et sur terre, Il Sait ce que vous tenez secret et ce que vous révélez au grand jour. Allah Sait parfaitement ce qui est au fond des cœurs.","en":"He knows what is within the heavens and earth and knows what you conceal and what you declare. And Allāh is Knowing of that within the breasts.","words":[{"position":1,"ar":"يَعْلَمُ","fr":"Il sait","en":"He knows","tr":"yaʿlamu","isWaqf":false},{"position":2,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":3,"ar":"فِى","fr":"(est) en","en":"(is) in","tr":"fī","isWaqf":false},{"position":4,"ar":"ٱلسَّمَـٰوَٰتِ","fr":"les cieux","en":"the heavens","tr":"l-samāwāti","isWaqf":false},{"position":5,"ar":"وَٱلْأَرْضِ","fr":"et la terre","en":"and the earth","tr":"wal-arḍi","isWaqf":false},{"position":6,"ar":"وَيَعْلَمُ","fr":"et Il sait","en":"and He knows","tr":"wayaʿlamu","isWaqf":false},{"position":7,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":8,"ar":"تُسِرُّونَ","fr":"vous dissimulez","en":"you conceal","tr":"tusirrūna","isWaqf":false},{"position":9,"ar":"وَمَا","fr":"et ce que","en":"and what","tr":"wamā","isWaqf":false},{"position":10,"ar":"تُعْلِنُونَ ۚ","fr":"vous déclarez","en":"you declare","tr":"tuʿ'linūna","isWaqf":false},{"position":11,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":12,"ar":"عَلِيمٌۢ","fr":"(est) Omniscient","en":"(is) All-Knowing","tr":"ʿalīmun","isWaqf":false},{"position":13,"ar":"بِذَاتِ","fr":"de ce que","en":"of what","tr":"bidhāti","isWaqf":false},{"position":14,"ar":"ٱلصُّدُورِ","fr":"(est dans) le poitrines","en":"(is in) the breasts","tr":"l-ṣudūri","isWaqf":false}]},{"ayah":5,"verseKey":"64:5","juz":28,"arabic":"أَلَمْ يَأْتِكُمْ نَبَؤُا۟ ٱلَّذِينَ كَفَرُوا۟ مِن قَبْلُ فَذَاقُوا۟ وَبَالَ أَمْرِهِمْ وَلَهُمْ عَذَابٌ أَلِيمٌ","fr":"Ne vous est-il pas parvenu l’histoire de ceux qui ont mécru autrefois, et qui ont donc goûté le péril dû à leurs actes ? Ils auront aussi (dans l’autre monde) un supplice très douloureux.","en":"Has there not come to you the news of those who disbelieved before? So they tasted the bad consequence of their affair, and they will have a painful punishment.","words":[{"position":1,"ar":"أَلَمْ","fr":"N'a-t-il pas","en":"Has not","tr":"alam","isWaqf":false},{"position":2,"ar":"يَأْتِكُمْ","fr":"venir à toi","en":"come to you","tr":"yatikum","isWaqf":false},{"position":3,"ar":"نَبَؤُا۟","fr":"(les) nouvelles","en":"(the) news","tr":"naba-u","isWaqf":false},{"position":4,"ar":"ٱلَّذِينَ","fr":"(de) ceux qui","en":"(of) those who","tr":"alladhīna","isWaqf":false},{"position":5,"ar":"كَفَرُوا۟","fr":"a mécru","en":"disbelieved","tr":"kafarū","isWaqf":false},{"position":6,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":7,"ar":"قَبْلُ","fr":"avant","en":"before","tr":"qablu","isWaqf":false},{"position":8,"ar":"فَذَاقُوا۟","fr":"Donc ils goûta","en":"So they tasted","tr":"fadhāqū","isWaqf":false},{"position":9,"ar":"وَبَالَ","fr":"(le mauvais) conséquence","en":"(the bad) consequence","tr":"wabāla","isWaqf":false},{"position":10,"ar":"أَمْرِهِمْ","fr":"(de) leur affaire","en":"(of) their affair","tr":"amrihim","isWaqf":false},{"position":11,"ar":"وَلَهُمْ","fr":"et pour eux","en":"and for them","tr":"walahum","isWaqf":false},{"position":12,"ar":"عَذَابٌ","fr":"(est) un châtiment","en":"(is) a punishment","tr":"ʿadhābun","isWaqf":false},{"position":13,"ar":"أَلِيمٌۭ","fr":"douloureux","en":"painful","tr":"alīmun","isWaqf":false}]},{"ayah":6,"verseKey":"64:6","juz":28,"arabic":"ذَٰلِكَ بِأَنَّهُۥ كَانَت تَّأْتِيهِمْ رُسُلُهُم بِٱلْبَيِّنَـٰتِ فَقَالُوٓا۟ أَبَشَرٌ يَهْدُونَنَا فَكَفَرُوا۟ وَتَوَلَّوا۟ ۚ وَّٱسْتَغْنَى ٱللَّهُ ۚ وَٱللَّهُ غَنِىٌّ حَمِيدٌ","fr":"Cela, parce que les Messagers venaient leur apporter les preuves évidentes et eux leur disaient : « Serions-nous donc guidés par des humains comme nous ? » Ils mécroyaient donc et se détournaient. Mais Allah Se passait d’eux. Allah est Celui Qui Se passe de Toute chose et le Digne de Toute Louange.","en":"That is because their messengers used to come to them with clear evidences, but they said, \"Shall human beings guide us?\" and disbelieved and turned away. And Allāh dispensed [with them]; and Allāh is Free of need and Praiseworthy.","words":[{"position":1,"ar":"ذَٰلِكَ","fr":"Cela","en":"That","tr":"dhālika","isWaqf":false},{"position":2,"ar":"بِأَنَّهُۥ","fr":"(est) parce que","en":"(is) because","tr":"bi-annahu","isWaqf":false},{"position":3,"ar":"كَانَت","fr":"avait","en":"had","tr":"kānat","isWaqf":false},{"position":4,"ar":"تَّأْتِيهِمْ","fr":"venir à eux","en":"come to them","tr":"tatīhim","isWaqf":false},{"position":5,"ar":"رُسُلُهُم","fr":"leurs Messagers","en":"their Messengers","tr":"rusuluhum","isWaqf":false},{"position":6,"ar":"بِٱلْبَيِّنَـٰتِ","fr":"avec des preuves évidentes","en":"with clear proofs","tr":"bil-bayināti","isWaqf":false},{"position":7,"ar":"فَقَالُوٓا۟","fr":"mais ils dirent","en":"but they said","tr":"faqālū","isWaqf":false},{"position":8,"ar":"أَبَشَرٌۭ","fr":"Doit humain êtres","en":"Shall human beings","tr":"abasharun","isWaqf":false},{"position":9,"ar":"يَهْدُونَنَا","fr":"guide-nous","en":"guide us","tr":"yahdūnanā","isWaqf":false},{"position":10,"ar":"فَكَفَرُوا۟","fr":"Donc ils a mécru","en":"So they disbelieved","tr":"fakafarū","isWaqf":false},{"position":11,"ar":"وَتَوَلَّوا۟ ۚ","fr":"et se détourna","en":"and turned away","tr":"watawallaw","isWaqf":false},{"position":12,"ar":"وَّٱسْتَغْنَى","fr":"Et peut faire sans eux","en":"And can do without them","tr":"wa-is'taghnā","isWaqf":false},{"position":13,"ar":"ٱللَّهُ ۚ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":14,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":15,"ar":"غَنِىٌّ","fr":"(est) Celui qui se suffit à Lui-même","en":"(is) Self-sufficient","tr":"ghaniyyun","isWaqf":false},{"position":16,"ar":"حَمِيدٌۭ","fr":"Digne de louange","en":"Praiseworthy","tr":"ḥamīdun","isWaqf":false}]},{"ayah":7,"verseKey":"64:7","juz":28,"arabic":"زَعَمَ ٱلَّذِينَ كَفَرُوٓا۟ أَن لَّن يُبْعَثُوا۟ ۚ قُلْ بَلَىٰ وَرَبِّى لَتُبْعَثُنَّ ثُمَّ لَتُنَبَّؤُنَّ بِمَا عَمِلْتُمْ ۚ وَذَٰلِكَ عَلَى ٱللَّهِ يَسِيرٌ","fr":"Ceux qui ont mécru prétendent qu’ils ne seront point ressuscités. Dis : « Que si ! Par mon Seigneur ! Vous serez certainement ressuscités, puis informés des actions que vos aurez faites. Cela est pour Allah chose vraiment aisée. »","en":"Those who disbelieve have claimed that they will never be resurrected. Say, \"Yes, by my Lord, you will surely be resurrected; then you will surely be informed of what you did. And that, for Allāh, is easy.\"","words":[{"position":1,"ar":"زَعَمَ","fr":"Prétendre","en":"Claim","tr":"zaʿama","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"كَفَرُوٓا۟","fr":"mécroire","en":"disbelieve","tr":"kafarū","isWaqf":false},{"position":4,"ar":"أَن","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":5,"ar":"لَّن","fr":"jamais","en":"never","tr":"lan","isWaqf":false},{"position":6,"ar":"يُبْعَثُوا۟ ۚ","fr":"va ils être éleva","en":"will they be raised","tr":"yub'ʿathū","isWaqf":false},{"position":7,"ar":"قُلْ","fr":"Dis","en":"Say","tr":"qul","isWaqf":false},{"position":8,"ar":"بَلَىٰ","fr":"Oui","en":"Yes","tr":"balā","isWaqf":false},{"position":9,"ar":"وَرَبِّى","fr":"par mon Seigneur","en":"by my Lord","tr":"warabbī","isWaqf":false},{"position":10,"ar":"لَتُبْعَثُنَّ","fr":"assurément vous va être éleva","en":"surely you will be raised","tr":"latub'ʿathunna","isWaqf":false},{"position":11,"ar":"ثُمَّ","fr":"puis","en":"then","tr":"thumma","isWaqf":false},{"position":12,"ar":"لَتُنَبَّؤُنَّ","fr":"assurément vous va être informa","en":"surely you will be informed","tr":"latunabba-unna","isWaqf":false},{"position":13,"ar":"بِمَا","fr":"de ce que","en":"of what","tr":"bimā","isWaqf":false},{"position":14,"ar":"عَمِلْتُمْ ۚ","fr":"vous a fait","en":"you did","tr":"ʿamil'tum","isWaqf":false},{"position":15,"ar":"وَذَٰلِكَ","fr":"Et que","en":"And that","tr":"wadhālika","isWaqf":false},{"position":16,"ar":"عَلَى","fr":"pour","en":"for","tr":"ʿalā","isWaqf":false},{"position":17,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":18,"ar":"يَسِيرٌۭ","fr":"(est) facile","en":"(is) easy","tr":"yasīrun","isWaqf":false}]},{"ayah":8,"verseKey":"64:8","juz":28,"arabic":"فَـَٔامِنُوا۟ بِٱللَّهِ وَرَسُولِهِۦ وَٱلنُّورِ ٱلَّذِىٓ أَنزَلْنَا ۚ وَٱللَّهُ بِمَا تَعْمَلُونَ خَبِيرٌ","fr":"Croyez donc en Allah, en Son Messager et en la lumière que Nous avons fait descendre ! Allah est parfaitement Informé de ce que vous faites.","en":"So believe in Allāh and His Messenger and the light [i.e., the Qur’ān] which We have sent down. And Allāh is Aware of what you do.","words":[{"position":1,"ar":"فَـَٔامِنُوا۟","fr":"Donc croire","en":"So believe","tr":"faāminū","isWaqf":false},{"position":2,"ar":"بِٱللَّهِ","fr":"dans Allah","en":"in Allah","tr":"bil-lahi","isWaqf":false},{"position":3,"ar":"وَرَسُولِهِۦ","fr":"et Son Messager","en":"and His Messenger","tr":"warasūlihi","isWaqf":false},{"position":4,"ar":"وَٱلنُّورِ","fr":"et le Lumière","en":"and the Light","tr":"wal-nūri","isWaqf":false},{"position":5,"ar":"ٱلَّذِىٓ","fr":"que","en":"which","tr":"alladhī","isWaqf":false},{"position":6,"ar":"أَنزَلْنَا ۚ","fr":"Nous ont envoyé bas","en":"We have sent down","tr":"anzalnā","isWaqf":false},{"position":7,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":8,"ar":"بِمَا","fr":"de ce que","en":"of what","tr":"bimā","isWaqf":false},{"position":9,"ar":"تَعْمَلُونَ","fr":"vous faire","en":"you do","tr":"taʿmalūna","isWaqf":false},{"position":10,"ar":"خَبِيرٌۭ","fr":"(est) Parfaitement informeré","en":"(is) All-Aware","tr":"khabīrun","isWaqf":false}]},{"ayah":9,"verseKey":"64:9","juz":28,"arabic":"يَوْمَ يَجْمَعُكُمْ لِيَوْمِ ٱلْجَمْعِ ۖ ذَٰلِكَ يَوْمُ ٱلتَّغَابُنِ ۗ وَمَن يُؤْمِنۢ بِٱللَّهِ وَيَعْمَلْ صَـٰلِحًا يُكَفِّرْ عَنْهُ سَيِّـَٔاتِهِۦ وَيُدْخِلْهُ جَنَّـٰتٍ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَـٰرُ خَـٰلِدِينَ فِيهَآ أَبَدًا ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْعَظِيمُ","fr":"Le jour où Il vous réunira, Jour du Rassemblement, ce sera le jour de la Déception. Celui qui croit en Allah et fait le bien verra ses mauvaises actions rachetées. (Allah) le fera entrer dans des jardins sous lesquels coulent les rivières, où ils séjourneront à tout jamais. Voilà le succès suprême !","en":"The Day He will assemble you for the Day of Assembly - that is the Day of Deprivation. And whoever believes in Allāh and does righteousness - He will remove from him his misdeeds and admit him to gardens beneath which rivers flow, wherein they will abide forever. That is the great attainment.","words":[{"position":1,"ar":"يَوْمَ","fr":"(Le) Jour","en":"(The) Day","tr":"yawma","isWaqf":false},{"position":2,"ar":"يَجْمَعُكُمْ","fr":"Il va rassembler vous","en":"He will assemble you","tr":"yajmaʿukum","isWaqf":false},{"position":3,"ar":"لِيَوْمِ","fr":"pour (le) Jour","en":"for (the) Day","tr":"liyawmi","isWaqf":false},{"position":4,"ar":"ٱلْجَمْعِ ۖ","fr":"(de) le Assemblée","en":"(of) the Assembly","tr":"l-jamʿi","isWaqf":false},{"position":5,"ar":"ذَٰلِكَ","fr":"que","en":"that","tr":"dhālika","isWaqf":false},{"position":6,"ar":"يَوْمُ","fr":"(va être le) Jour","en":"(will be the) Day","tr":"yawmu","isWaqf":false},{"position":7,"ar":"ٱلتَّغَابُنِ ۗ","fr":"(de) mutuel perte et gain","en":"(of) mutual loss and gain","tr":"l-taghābuni","isWaqf":false},{"position":8,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":9,"ar":"يُؤْمِنۢ","fr":"croit","en":"believes","tr":"yu'min","isWaqf":false},{"position":10,"ar":"بِٱللَّهِ","fr":"dans Allah","en":"in Allah","tr":"bil-lahi","isWaqf":false},{"position":11,"ar":"وَيَعْمَلْ","fr":"et fait","en":"and does","tr":"wayaʿmal","isWaqf":false},{"position":12,"ar":"صَـٰلِحًۭا","fr":"bonnes œuvres","en":"righteous deeds","tr":"ṣāliḥan","isWaqf":false},{"position":13,"ar":"يُكَفِّرْ","fr":"Il va ôter","en":"He will remove","tr":"yukaffir","isWaqf":false},{"position":14,"ar":"عَنْهُ","fr":"de lui","en":"from him","tr":"ʿanhu","isWaqf":false},{"position":15,"ar":"سَيِّـَٔاتِهِۦ","fr":"son mal actions","en":"his evil deeds","tr":"sayyiātihi","isWaqf":false},{"position":16,"ar":"وَيُدْخِلْهُ","fr":"et Il va admettre lui","en":"and He will admit him","tr":"wayud'khil'hu","isWaqf":false},{"position":17,"ar":"جَنَّـٰتٍۢ","fr":"(vers les) Jardins","en":"(to) Gardens","tr":"jannātin","isWaqf":false},{"position":18,"ar":"تَجْرِى","fr":"couler","en":"flow","tr":"tajrī","isWaqf":false},{"position":19,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":20,"ar":"تَحْتِهَا","fr":"en dessous de lui","en":"underneath it","tr":"taḥtihā","isWaqf":false},{"position":21,"ar":"ٱلْأَنْهَـٰرُ","fr":"les rivières","en":"the rivers","tr":"l-anhāru","isWaqf":false},{"position":22,"ar":"خَـٰلِدِينَ","fr":"demeurant","en":"abiding","tr":"khālidīna","isWaqf":false},{"position":23,"ar":"فِيهَآ","fr":"en cela","en":"therein","tr":"fīhā","isWaqf":false},{"position":24,"ar":"أَبَدًۭا ۚ","fr":"pour toujours","en":"forever","tr":"abadan","isWaqf":false},{"position":25,"ar":"ذَٰلِكَ","fr":"Cela","en":"That","tr":"dhālika","isWaqf":false},{"position":26,"ar":"ٱلْفَوْزُ","fr":"(est) le succès","en":"(is) the success","tr":"l-fawzu","isWaqf":false},{"position":27,"ar":"ٱلْعَظِيمُ","fr":"le grand","en":"the great","tr":"l-ʿaẓīmu","isWaqf":false}]},{"ayah":10,"verseKey":"64:10","juz":28,"arabic":"وَٱلَّذِينَ كَفَرُوا۟ وَكَذَّبُوا۟ بِـَٔايَـٰتِنَآ أُو۟لَـٰٓئِكَ أَصْحَـٰبُ ٱلنَّارِ خَـٰلِدِينَ فِيهَا ۖ وَبِئْسَ ٱلْمَصِيرُ","fr":"Quant à ceux qui ont mécru et ont osé démentir Nos Signes, ceux-là seront les hôtes du Feu, où ils demeureront pour l’éternité. Quel affreux destin que le leur !","en":"But the ones who disbelieved and denied Our verses - those are the companions of the Fire, abiding eternally therein; and wretched is the destination.","words":[{"position":1,"ar":"وَٱلَّذِينَ","fr":"Mais ceux qui","en":"But those who","tr":"wa-alladhīna","isWaqf":false},{"position":2,"ar":"كَفَرُوا۟","fr":"a mécru","en":"disbelieved","tr":"kafarū","isWaqf":false},{"position":3,"ar":"وَكَذَّبُوا۟","fr":"et nia","en":"and denied","tr":"wakadhabū","isWaqf":false},{"position":4,"ar":"بِـَٔايَـٰتِنَآ","fr":"[dans] Nos Versets","en":"[in] Our Verses","tr":"biāyātinā","isWaqf":false},{"position":5,"ar":"أُو۟لَـٰٓئِكَ","fr":"ceux","en":"those","tr":"ulāika","isWaqf":false},{"position":6,"ar":"أَصْحَـٰبُ","fr":"(sont les) gens","en":"(are the) companions","tr":"aṣḥābu","isWaqf":false},{"position":7,"ar":"ٱلنَّارِ","fr":"(du) Feu","en":"(of) the Fire","tr":"l-nāri","isWaqf":false},{"position":8,"ar":"خَـٰلِدِينَ","fr":"demeurant éternellement","en":"abiding forever","tr":"khālidīna","isWaqf":false},{"position":9,"ar":"فِيهَا ۖ","fr":"en cela","en":"therein","tr":"fīhā","isWaqf":false},{"position":10,"ar":"وَبِئْسَ","fr":"Et misérable est","en":"And wretched is","tr":"wabi'sa","isWaqf":false},{"position":11,"ar":"ٱلْمَصِيرُ","fr":"le destination","en":"the destination","tr":"l-maṣīru","isWaqf":false}]},{"ayah":11,"verseKey":"64:11","juz":28,"arabic":"مَآ أَصَابَ مِن مُّصِيبَةٍ إِلَّا بِإِذْنِ ٱللَّهِ ۗ وَمَن يُؤْمِنۢ بِٱللَّهِ يَهْدِ قَلْبَهُۥ ۚ وَٱللَّهُ بِكُلِّ شَىْءٍ عَلِيمٌ","fr":"Il n’est malheur qui puisse vous frapper sans qu’il ne soit par la permission d’Allah. Quiconque croit en Allah, (Allah) guidera son cœur. Allah Sait parfaitement Toute chose.","en":"No disaster strikes except by permission of Allāh. And whoever believes in Allāh - He will guide his heart. And Allāh is Knowing of all things.","words":[{"position":1,"ar":"مَآ","fr":"Non","en":"Not","tr":"mā","isWaqf":false},{"position":2,"ar":"أَصَابَ","fr":"frappe","en":"strikes","tr":"aṣāba","isWaqf":false},{"position":3,"ar":"مِن","fr":"tout","en":"any","tr":"min","isWaqf":false},{"position":4,"ar":"مُّصِيبَةٍ","fr":"calamité","en":"disaster","tr":"muṣībatin","isWaqf":false},{"position":5,"ar":"إِلَّا","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":6,"ar":"بِإِذْنِ","fr":"par (la) permission","en":"by (the) permission","tr":"bi-idh'ni","isWaqf":false},{"position":7,"ar":"ٱللَّهِ ۗ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":8,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":9,"ar":"يُؤْمِنۢ","fr":"croit","en":"believes","tr":"yu'min","isWaqf":false},{"position":10,"ar":"بِٱللَّهِ","fr":"dans Allah","en":"in Allah","tr":"bil-lahi","isWaqf":false},{"position":11,"ar":"يَهْدِ","fr":"Il guide","en":"He guides","tr":"yahdi","isWaqf":false},{"position":12,"ar":"قَلْبَهُۥ ۚ","fr":"son cœur","en":"his heart","tr":"qalbahu","isWaqf":false},{"position":13,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":14,"ar":"بِكُلِّ","fr":"de chaque","en":"of every","tr":"bikulli","isWaqf":false},{"position":15,"ar":"شَىْءٍ","fr":"chose","en":"thing","tr":"shayin","isWaqf":false},{"position":16,"ar":"عَلِيمٌۭ","fr":"(est) Omniscient","en":"(is) All-Knowing","tr":"ʿalīmun","isWaqf":false}]},{"ayah":12,"verseKey":"64:12","juz":28,"arabic":"وَأَطِيعُوا۟ ٱللَّهَ وَأَطِيعُوا۟ ٱلرَّسُولَ ۚ فَإِن تَوَلَّيْتُمْ فَإِنَّمَا عَلَىٰ رَسُولِنَا ٱلْبَلَـٰغُ ٱلْمُبِينُ","fr":"Obéissez à Allah ! Obéissez à Son Messager ! Et si vous vous détournez (de leurs commandements), le Messager n’a pour seul devoir que de transmettre (Notre Message) explicitement.","en":"And obey Allāh and obey the Messenger; but if you turn away - then upon Our Messenger is only [the duty of] clear notification.","words":[{"position":1,"ar":"وَأَطِيعُوا۟","fr":"Donc obéir","en":"So obey","tr":"wa-aṭīʿū","isWaqf":false},{"position":2,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":3,"ar":"وَأَطِيعُوا۟","fr":"et obéis","en":"and obey","tr":"wa-aṭīʿū","isWaqf":false},{"position":4,"ar":"ٱلرَّسُولَ ۚ","fr":"le Messager","en":"the Messenger","tr":"l-rasūla","isWaqf":false},{"position":5,"ar":"فَإِن","fr":"mais si","en":"but if","tr":"fa-in","isWaqf":false},{"position":6,"ar":"تَوَلَّيْتُمْ","fr":"vous vous détournez","en":"you turn away","tr":"tawallaytum","isWaqf":false},{"position":7,"ar":"فَإِنَّمَا","fr":"alors seulement","en":"then only","tr":"fa-innamā","isWaqf":false},{"position":8,"ar":"عَلَىٰ","fr":"sur","en":"upon","tr":"ʿalā","isWaqf":false},{"position":9,"ar":"رَسُولِنَا","fr":"Notre Messager","en":"Our Messenger","tr":"rasūlinā","isWaqf":false},{"position":10,"ar":"ٱلْبَلَـٰغُ","fr":"(est) le monture","en":"(is) the conveyance","tr":"l-balāghu","isWaqf":false},{"position":11,"ar":"ٱلْمُبِينُ","fr":"clair","en":"clear","tr":"l-mubīnu","isWaqf":false}]},{"ayah":13,"verseKey":"64:13","juz":28,"arabic":"ٱللَّهُ لَآ إِلَـٰهَ إِلَّا هُوَ ۚ وَعَلَى ٱللَّهِ فَلْيَتَوَكَّلِ ٱلْمُؤْمِنُونَ","fr":"Allah ! Il n’y a point d’autre divinité que Lui ! Qu’à Lui s’en remettent donc les croyants !","en":"Allāh - there is no deity except Him. And upon Allāh let the believers rely.","words":[{"position":1,"ar":"ٱللَّهُ","fr":"Allah","en":"Allah","tr":"al-lahu","isWaqf":false},{"position":2,"ar":"لَآ","fr":"(il n'y a) pas","en":"(there is) no","tr":"lā","isWaqf":false},{"position":3,"ar":"إِلَـٰهَ","fr":"dieu","en":"god","tr":"ilāha","isWaqf":false},{"position":4,"ar":"إِلَّا","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":5,"ar":"هُوَ ۚ","fr":"Lui","en":"Him","tr":"huwa","isWaqf":false},{"position":6,"ar":"وَعَلَى","fr":"Et sur","en":"And upon","tr":"waʿalā","isWaqf":false},{"position":7,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":8,"ar":"فَلْيَتَوَكَّلِ","fr":"laisser mettre (leur) dépôt","en":"let put (their) trust","tr":"falyatawakkali","isWaqf":false},{"position":9,"ar":"ٱلْمُؤْمِنُونَ","fr":"les croyants","en":"the believers","tr":"l-mu'minūna","isWaqf":false}]},{"ayah":14,"verseKey":"64:14","juz":28,"arabic":"يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّ مِنْ أَزْوَٰجِكُمْ وَأَوْلَـٰدِكُمْ عَدُوًّا لَّكُمْ فَٱحْذَرُوهُمْ ۚ وَإِن تَعْفُوا۟ وَتَصْفَحُوا۟ وَتَغْفِرُوا۟ فَإِنَّ ٱللَّهَ غَفُورٌ رَّحِيمٌ","fr":"Ô vous qui croyez ! Il peut se trouver des ennemis pour vous, (même) parmi vos épouses et en vos enfants. Méfiez-vous en ! Mais si vous passez (les erreurs), excusez et pardonnez, (sachez qu’) Allah est Absoluteur et Tout Miséricordieux.","en":"O you who have believed, indeed, among your spouses and your children are enemies to you, so beware of them. But if you pardon and overlook and forgive - then indeed, Allāh is Forgiving and Merciful.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô","en":"O","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"(vous) qui","en":"(you) who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوٓا۟","fr":"croire","en":"believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":5,"ar":"مِنْ","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":6,"ar":"أَزْوَٰجِكُمْ","fr":"votre époux","en":"your spouses","tr":"azwājikum","isWaqf":false},{"position":7,"ar":"وَأَوْلَـٰدِكُمْ","fr":"et votre enfants","en":"and your children","tr":"wa-awlādikum","isWaqf":false},{"position":8,"ar":"عَدُوًّۭا","fr":"(sont) ennemis","en":"(are) enemies","tr":"ʿaduwwan","isWaqf":false},{"position":9,"ar":"لَّكُمْ","fr":"à vous","en":"to you","tr":"lakum","isWaqf":false},{"position":10,"ar":"فَٱحْذَرُوهُمْ ۚ","fr":"donc prends garde de eux","en":"so beware of them","tr":"fa-iḥ'dharūhum","isWaqf":false},{"position":11,"ar":"وَإِن","fr":"Mais si","en":"But if","tr":"wa-in","isWaqf":false},{"position":12,"ar":"تَعْفُوا۟","fr":"vous pardon","en":"you pardon","tr":"taʿfū","isWaqf":false},{"position":13,"ar":"وَتَصْفَحُوا۟","fr":"et passer outre","en":"and overlook","tr":"wataṣfaḥū","isWaqf":false},{"position":14,"ar":"وَتَغْفِرُوا۟","fr":"et pardonner","en":"and forgive","tr":"wataghfirū","isWaqf":false},{"position":15,"ar":"فَإِنَّ","fr":"puis certes","en":"then indeed","tr":"fa-inna","isWaqf":false},{"position":16,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":17,"ar":"غَفُورٌۭ","fr":"(est) Pardonneur","en":"(is) Oft-Forgiving","tr":"ghafūrun","isWaqf":false},{"position":18,"ar":"رَّحِيمٌ","fr":"Très-Miséricordieux","en":"Most Merciful","tr":"raḥīmun","isWaqf":false}]},{"ayah":15,"verseKey":"64:15","juz":28,"arabic":"إِنَّمَآ أَمْوَٰلُكُمْ وَأَوْلَـٰدُكُمْ فِتْنَةٌ ۚ وَٱللَّهُ عِندَهُۥٓ أَجْرٌ عَظِيمٌ","fr":"Vos biens et vos enfants ne sont que tentation. Mais Allah, détient auprès de Lui une immense récompense.","en":"Your wealth and your children are but a trial, and Allāh has with Him a great reward.","words":[{"position":1,"ar":"إِنَّمَآ","fr":"Seulement","en":"Only","tr":"innamā","isWaqf":false},{"position":2,"ar":"أَمْوَٰلُكُمْ","fr":"votre richesse","en":"your wealth","tr":"amwālukum","isWaqf":false},{"position":3,"ar":"وَأَوْلَـٰدُكُمْ","fr":"et votre enfants","en":"and your children","tr":"wa-awlādukum","isWaqf":false},{"position":4,"ar":"فِتْنَةٌۭ ۚ","fr":"(sont) une épreuve","en":"(are) a trial","tr":"fit'natun","isWaqf":false},{"position":5,"ar":"وَٱللَّهُ","fr":"et Allah","en":"and Allah","tr":"wal-lahu","isWaqf":false},{"position":6,"ar":"عِندَهُۥٓ","fr":"avec Lui","en":"with Him","tr":"ʿindahu","isWaqf":false},{"position":7,"ar":"أَجْرٌ","fr":"(est) une récompense","en":"(is) a reward","tr":"ajrun","isWaqf":false},{"position":8,"ar":"عَظِيمٌۭ","fr":"grand","en":"great","tr":"ʿaẓīmun","isWaqf":false}]},{"ayah":16,"verseKey":"64:16","juz":28,"arabic":"فَٱتَّقُوا۟ ٱللَّهَ مَا ٱسْتَطَعْتُمْ وَٱسْمَعُوا۟ وَأَطِيعُوا۟ وَأَنفِقُوا۟ خَيْرًا لِّأَنفُسِكُمْ ۗ وَمَن يُوقَ شُحَّ نَفْسِهِۦ فَأُو۟لَـٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ","fr":"Craignez donc Allah autant que vous le pourrez. Écoutez, obéissez et dépensez (de vos biens) en charité, cela est meilleur pour vous. Ceux qui sont préservés de leur propre avarice sont ceux qui réussissent.","en":"So fear Allāh as much as you are able and listen and obey and spend [in the way of Allāh]; it is better for your selves. And whoever is protected from the stinginess of his soul - it is those who will be the successful.","words":[{"position":1,"ar":"فَٱتَّقُوا۟","fr":"Donc crains","en":"So fear","tr":"fa-ittaqū","isWaqf":false},{"position":2,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":3,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":4,"ar":"ٱسْتَطَعْتُمْ","fr":"vous sont capable","en":"you are able","tr":"is'taṭaʿtum","isWaqf":false},{"position":5,"ar":"وَٱسْمَعُوا۟","fr":"et écouter","en":"and listen","tr":"wa-is'maʿū","isWaqf":false},{"position":6,"ar":"وَأَطِيعُوا۟","fr":"et obéis","en":"and obey","tr":"wa-aṭīʿū","isWaqf":false},{"position":7,"ar":"وَأَنفِقُوا۟","fr":"et dépenser","en":"and spend","tr":"wa-anfiqū","isWaqf":false},{"position":8,"ar":"خَيْرًۭا","fr":"(cela est) meilleur","en":"(it is) better","tr":"khayran","isWaqf":false},{"position":9,"ar":"لِّأَنفُسِكُمْ ۗ","fr":"pour vous-mêmes","en":"for yourselves","tr":"li-anfusikum","isWaqf":false},{"position":10,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":11,"ar":"يُوقَ","fr":"est sauva","en":"is saved","tr":"yūqa","isWaqf":false},{"position":12,"ar":"شُحَّ","fr":"(de le) greediness","en":"(from the) greediness","tr":"shuḥḥa","isWaqf":false},{"position":13,"ar":"نَفْسِهِۦ","fr":"(de) son âme","en":"(of) his soul","tr":"nafsihi","isWaqf":false},{"position":14,"ar":"فَأُو۟لَـٰٓئِكَ","fr":"puis ceux","en":"then those","tr":"fa-ulāika","isWaqf":false},{"position":15,"ar":"هُمُ","fr":"[ils]","en":"[they]","tr":"humu","isWaqf":false},{"position":16,"ar":"ٱلْمُفْلِحُونَ","fr":"(sont) les bienheureux","en":"(are) the successful ones","tr":"l-muf'liḥūna","isWaqf":false}]},{"ayah":17,"verseKey":"64:17","juz":28,"arabic":"إِن تُقْرِضُوا۟ ٱللَّهَ قَرْضًا حَسَنًا يُضَـٰعِفْهُ لَكُمْ وَيَغْفِرْ لَكُمْ ۚ وَٱللَّهُ شَكُورٌ حَلِيمٌ","fr":"Si, de bonne volonté, vous faites un prêt à Allah, Il vous le remboursera au centuple et vous pardonnera (vos péchés), car Allah est si Reconnaissant, si Magnanime !","en":"If you loan Allāh a goodly loan, He will multiply it for you and forgive you. And Allāh is [most] Appreciative and Forbearing,","words":[{"position":1,"ar":"إِن","fr":"Si","en":"If","tr":"in","isWaqf":false},{"position":2,"ar":"تُقْرِضُوا۟","fr":"vous prêt","en":"you loan","tr":"tuq'riḍū","isWaqf":false},{"position":3,"ar":"ٱللَّهَ","fr":"(à) Allah","en":"(to) Allah","tr":"l-laha","isWaqf":false},{"position":4,"ar":"قَرْضًا","fr":"un prêt","en":"a loan","tr":"qarḍan","isWaqf":false},{"position":5,"ar":"حَسَنًۭا","fr":"beau","en":"goodly","tr":"ḥasanan","isWaqf":false},{"position":6,"ar":"يُضَـٰعِفْهُ","fr":"Il va multiplier cela","en":"He will multiply it","tr":"yuḍāʿif'hu","isWaqf":false},{"position":7,"ar":"لَكُمْ","fr":"pour vous","en":"for you","tr":"lakum","isWaqf":false},{"position":8,"ar":"وَيَغْفِرْ","fr":"et va pardonner","en":"and will forgive","tr":"wayaghfir","isWaqf":false},{"position":9,"ar":"لَكُمْ ۚ","fr":"vous","en":"you","tr":"lakum","isWaqf":false},{"position":10,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":11,"ar":"شَكُورٌ","fr":"(est) Très Reconnaissant","en":"(is) Most Appreciative","tr":"shakūrun","isWaqf":false},{"position":12,"ar":"حَلِيمٌ","fr":"Très Indulgent","en":"Most Forbearing","tr":"ḥalīmun","isWaqf":false}]},{"ayah":18,"verseKey":"64:18","juz":28,"arabic":"عَـٰلِمُ ٱلْغَيْبِ وَٱلشَّهَـٰدَةِ ٱلْعَزِيزُ ٱلْحَكِيمُ","fr":"Il Connaît aussi bien les choses insondables que les choses observables, Lui, le Tout-Puissant, le Sage.","en":"Knower of the unseen and the witnessed, the Exalted in Might, the Wise.","words":[{"position":1,"ar":"عَـٰلِمُ","fr":"(le) Connaisseur","en":"(The) Knower","tr":"ʿālimu","isWaqf":false},{"position":2,"ar":"ٱلْغَيْبِ","fr":"(de) l'Invisible","en":"(of) the unseen","tr":"l-ghaybi","isWaqf":false},{"position":3,"ar":"وَٱلشَّهَـٰدَةِ","fr":"et le témoigna","en":"and the witnessed","tr":"wal-shahādati","isWaqf":false},{"position":4,"ar":"ٱلْعَزِيزُ","fr":"le Tout-Puissant","en":"the All-Mighty","tr":"l-ʿazīzu","isWaqf":false},{"position":5,"ar":"ٱلْحَكِيمُ","fr":"le Très-Sage","en":"the All-Wise","tr":"l-ḥakīmu","isWaqf":false}]}]