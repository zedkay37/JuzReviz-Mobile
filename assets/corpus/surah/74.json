[{"ayah":1,"verseKey":"74:1","juz":29,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ يَـٰٓأَيُّهَا ٱلْمُدَّثِّرُ","fr":"Ô toi qui te couvres (de ton manteau) !","en":"O you who covers himself [with a garment],","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô vous","en":"O you","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلْمُدَّثِّرُ","fr":"qui couvre lui-même","en":"who covers himself","tr":"l-mudathiru","isWaqf":false}]},{"ayah":2,"verseKey":"74:2","juz":29,"arabic":"قُمْ فَأَنذِرْ","fr":"Lève-toi et avertis !","en":"Arise and warn.","words":[{"position":1,"ar":"قُمْ","fr":"Se tenir haut","en":"Stand up","tr":"qum","isWaqf":false},{"position":2,"ar":"فَأَنذِرْ","fr":"et avertir","en":"and warn","tr":"fa-andhir","isWaqf":false}]},{"ayah":3,"verseKey":"74:3","juz":29,"arabic":"وَرَبَّكَ فَكَبِّرْ","fr":"La grandeur de ton Seigneur, exalte-la !","en":"And your Lord glorify.","words":[{"position":1,"ar":"وَرَبَّكَ","fr":"Et votre Seigneur","en":"And your Lord","tr":"warabbaka","isWaqf":false},{"position":2,"ar":"فَكَبِّرْ","fr":"exalter","en":"magnify","tr":"fakabbir","isWaqf":false}]},{"ayah":4,"verseKey":"74:4","juz":29,"arabic":"وَثِيَابَكَ فَطَهِّرْ","fr":"Tes vêtements, purifie-les !","en":"And your clothing purify.","words":[{"position":1,"ar":"وَثِيَابَكَ","fr":"Et votre habit","en":"And your clothing","tr":"wathiyābaka","isWaqf":false},{"position":2,"ar":"فَطَهِّرْ","fr":"purifier","en":"purify","tr":"faṭahhir","isWaqf":false}]},{"ayah":5,"verseKey":"74:5","juz":29,"arabic":"وَٱلرُّجْزَ فَٱهْجُرْ","fr":"L’idolâtrie, éloigne-t-en !","en":"And uncleanliness avoid.","words":[{"position":1,"ar":"وَٱلرُّجْزَ","fr":"Et uncleanliness","en":"And uncleanliness","tr":"wal-ruj'za","isWaqf":false},{"position":2,"ar":"فَٱهْجُرْ","fr":"éviter","en":"avoid","tr":"fa-uh'jur","isWaqf":false}]},{"ayah":6,"verseKey":"74:6","juz":29,"arabic":"وَلَا تَمْنُن تَسْتَكْثِرُ","fr":"Ne te targue pas d’avoir beaucoup donné (en espérant en recevoir davantage en retour)","en