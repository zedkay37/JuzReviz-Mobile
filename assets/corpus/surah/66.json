[{"ayah":1,"verseKey":"66:1","juz":28,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ يَـٰٓأَيُّهَا ٱلنَّبِىُّ لِمَ تُحَرِّمُ مَآ أَحَلَّ ٱللَّهُ لَكَ ۖ تَبْتَغِى مَرْضَاتَ أَزْوَٰجِكَ ۚ وَٱللَّهُ غَفُورٌ رَّحِيمٌ","fr":"Ô Prophète ! Pourquoi, pour faire plaisir à tes épouses, t’interdis-tu ce qu’Allah a rendu pour toi licite ? Allah est Absoluteur et Tout Miséricordieux.","en":"O Prophet, why do you prohibit [yourself from] what Allāh has made lawful for you, seeking the approval of your wives? And Allāh is Forgiving and Merciful.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô","en":"O","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلنَّبِىُّ","fr":"Prophète","en":"Prophet","tr":"l-nabiyu","isWaqf":false},{"position":3,"ar":"لِمَ","fr":"Pourquoi (faire)","en":"Why (do)","tr":"lima","isWaqf":false},{"position":4,"ar":"تُحَرِّمُ","fr":"vous prohibit","en":"you prohibit","tr":"tuḥarrimu","isWaqf":false},{"position":5,"ar":"مَآ","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":6,"ar":"أَحَلَّ","fr":"a fait licite","en":"has made lawful","tr":"aḥalla","isWaqf":false},{"position":7,"ar":"ٱللَّهُ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":8,"ar":"لَكَ ۖ","fr":"pour vous","en":"for you","tr":"laka","isWaqf":false},{"position":9,"ar":"تَبْتَغِى","fr":"cherchant","en":"seeking","tr":"tabtaghī","isWaqf":false},{"position":10,"ar":"مَرْضَاتَ","fr":"(à) plaire","en":"(to) please","tr":"marḍāta","isWaqf":false},{"position":11,"ar":"أَزْوَٰجِكَ ۚ","fr":"votre épouses","en":"your wives","tr":"azwājika","isWaqf":false},{"position":12,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":13,"ar":"غَفُورٌۭ","fr":"(est) Pardonneur","en":"(is) Oft-Forgiving","tr":"ghafūrun","isWaqf":false},{"position":14,"ar":"رَّحِيمٌۭ","fr":"Très-Miséricordieux","en":"Most Merciful","tr":"raḥīmun","isWaqf":false}]},{"ayah":2,"verseKey":"66:2","juz":28,"arabic":"قَدْ فَرَضَ ٱللَّهُ لَكُمْ تَحِلَّةَ أَيْمَـٰنِكُمْ ۚ وَٱللَّهُ مَوْلَىٰكُمْ ۖ وَهُوَ ٱلْعَلِيمُ ٱلْحَكِيمُ","fr":"Allah a prescrit pour vous (le moyen) de vous dégager licitement de vos serments. Allah est votre Protecteur et c’est Lui l’Omniscient, le Sage.","en":"Allāh has already ordained for you [Muslims] the dissolution of your oaths. And Allāh is your protector, and He is the Knowing, the Wise.","words":[{"position":1,"ar":"قَدْ","fr":"Certes","en":"Indeed","tr":"qad","isWaqf":false},{"position":2,"ar":"فَرَضَ","fr":"a prescrivit","en":"has ordained","tr":"faraḍa","isWaqf":false},{"position":3,"ar":"ٱللَّهُ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":4,"ar":"لَكُمْ","fr":"pour vous","en":"for you","tr":"lakum","isWaqf":false},{"position":5,"ar":"تَحِلَّةَ","fr":"(le) dissolution","en":"(the) dissolution","tr":"taḥillata","isWaqf":false},{"position":6,"ar":"أَيْمَـٰنِكُمْ ۚ","fr":"(de) votre serments","en":"(of) your oaths","tr":"aymānikum","isWaqf":false},{"position":7,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":8,"ar":"مَوْلَىٰكُمْ ۖ","fr":"(est) votre Protecteur","en":"(is) your Protector","tr":"mawlākum","isWaqf":false},{"position":9,"ar":"وَهُوَ","fr":"et Il","en":"and He","tr":"wahuwa","isWaqf":false},{"position":10,"ar":"ٱلْعَلِيمُ","fr":"(est) l'Omniscient","en":"(is) the All-Knower","tr":"l-ʿalīmu","isWaqf":false},{"position":11,"ar":"ٱلْحَكِيمُ","fr":"le Très-Sage","en":"the All-Wise","tr":"l-ḥakīmu","isWaqf":false}]},{"ayah":3,"verseKey":"66:3","juz":28,"arabic":"وَإِذْ أَسَرَّ ٱلنَّبِىُّ إِلَىٰ بَعْضِ أَزْوَٰجِهِۦ حَدِيثًا فَلَمَّا نَبَّأَتْ بِهِۦ وَأَظْهَرَهُ ٱللَّهُ عَلَيْهِ عَرَّفَ بَعْضَهُۥ وَأَعْرَضَ عَنۢ بَعْضٍ ۖ فَلَمَّا نَبَّأَهَا بِهِۦ قَالَتْ مَنْ أَنۢبَأَكَ هَـٰذَا ۖ قَالَ نَبَّأَنِىَ ٱلْعَلِيمُ ٱلْخَبِيرُ","fr":"Quand le Prophète fit une confidence à l’une de ses épouses, et que celle-ci s’en fut le divulguer (à une autre épouse), Allah en informa (le Prophète) qui en révéla une partie et ne dit mot de l’autre. Informée, (l’épouse) dit : « Mais qui donc te l’a appris ? » « Celui Qui me l’a appris, répondit (le Messager), est l’Omniscient, le parfaitement Informé. »","en":"And [remember] when the Prophet confided to one of his wives a statement; and when she informed [another] of it and Allāh showed it to him, he made known part of it and ignored a part. And when he informed her about it, she said, \"Who told you this?\" He said, \"I was informed by the Knowing, the Aware.\"","words":[{"position":1,"ar":"وَإِذْ","fr":"Et quand","en":"And when","tr":"wa-idh","isWaqf":false},{"position":2,"ar":"أَسَرَّ","fr":"confia","en":"confided","tr":"asarra","isWaqf":false},{"position":3,"ar":"ٱلنَّبِىُّ","fr":"le Prophète","en":"the Prophet","tr":"l-nabiyu","isWaqf":false},{"position":4,"ar":"إِلَىٰ","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":5,"ar":"بَعْضِ","fr":"un","en":"one","tr":"baʿḍi","isWaqf":false},{"position":6,"ar":"أَزْوَٰجِهِۦ","fr":"(de) son épouses","en":"(of) his wives","tr":"azwājihi","isWaqf":false},{"position":7,"ar":"حَدِيثًۭا","fr":"un parole","en":"a statement","tr":"ḥadīthan","isWaqf":false},{"position":8,"ar":"فَلَمَّا","fr":"et quand","en":"and when","tr":"falammā","isWaqf":false},{"position":9,"ar":"نَبَّأَتْ","fr":"elle informa","en":"she informed","tr":"nabba-at","isWaqf":false},{"position":10,"ar":"بِهِۦ","fr":"à son sujet","en":"about it","tr":"bihi","isWaqf":false},{"position":11,"ar":"وَأَظْهَرَهُ","fr":"et fait cela apparent","en":"and made it apparent","tr":"wa-aẓharahu","isWaqf":false},{"position":12,"ar":"ٱللَّهُ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":13,"ar":"عَلَيْهِ","fr":"à lui","en":"to him","tr":"ʿalayhi","isWaqf":false},{"position":14,"ar":"عَرَّفَ","fr":"il fait connu","en":"he made known","tr":"ʿarrafa","isWaqf":false},{"position":15,"ar":"بَعْضَهُۥ","fr":"un partie de cela","en":"a part of it","tr":"baʿḍahu","isWaqf":false},{"position":16,"ar":"وَأَعْرَضَ","fr":"et avoided","en":"and avoided","tr":"wa-aʿraḍa","isWaqf":false},{"position":17,"ar":"عَنۢ","fr":"[de]","en":"[of]","tr":"ʿan","isWaqf":false},{"position":18,"ar":"بَعْضٍۢ ۖ","fr":"une partie","en":"a part","tr":"baʿḍin","isWaqf":false},{"position":19,"ar":"فَلَمَّا","fr":"Puis quand","en":"Then when","tr":"falammā","isWaqf":false},{"position":20,"ar":"نَبَّأَهَا","fr":"il informa elle","en":"he informed her","tr":"nabba-ahā","isWaqf":false},{"position":21,"ar":"بِهِۦ","fr":"à son sujet","en":"about it","tr":"bihi","isWaqf":false},{"position":22,"ar":"قَالَتْ","fr":"elle dit","en":"she said","tr":"qālat","isWaqf":false},{"position":23,"ar":"مَنْ","fr":"Qui","en":"Who","tr":"man","isWaqf":false},{"position":24,"ar":"أَنۢبَأَكَ","fr":"informa vous","en":"informed you","tr":"anba-aka","isWaqf":false},{"position":25,"ar":"هَـٰذَا ۖ","fr":"ceci","en":"this","tr":"hādhā","isWaqf":false},{"position":26,"ar":"قَالَ","fr":"Il dit","en":"He said","tr":"qāla","isWaqf":false},{"position":27,"ar":"نَبَّأَنِىَ","fr":"A informa moi","en":"Has informed me","tr":"nabba-aniya","isWaqf":false},{"position":28,"ar":"ٱلْعَلِيمُ","fr":"l'Omniscient","en":"the All-Knower","tr":"l-ʿalīmu","isWaqf":false},{"position":29,"ar":"ٱلْخَبِيرُ","fr":"le Parfaitement informeré","en":"the All-Aware","tr":"l-khabīru","isWaqf":false}]},{"ayah":4,"verseKey":"66:4","juz":28,"arabic":"إِن تَتُوبَآ إِلَى ٱللَّهِ فَقَدْ صَغَتْ قُلُوبُكُمَا ۖ وَإِن تَظَـٰهَرَا عَلَيْهِ فَإِنَّ ٱللَّهَ هُوَ مَوْلَىٰهُ وَجِبْرِيلُ وَصَـٰلِحُ ٱلْمُؤْمِنِينَ ۖ وَٱلْمَلَـٰٓئِكَةُ بَعْدَ ذَٰلِكَ ظَهِيرٌ","fr":"Si vous deux vous vous repentez auprès d’Allah, c’est que vos cœurs ont écouté (la voix de la raison) ; et si vous vous liguez contre lui, (alors sachez qu’) Allah sera Son allié, ainsi que (l’Ange) Gabriel et les meilleurs d’entre les croyants, puis les Anges, après cela, sauront le soutenir.","en":"If you two [wives] repent to Allāh, [it is best], for your hearts have deviated. But if you cooperate against him - then indeed Allāh is his protector, and Gabriel and the righteous of the believers and the angels, moreover, are [his] assistants.","words":[{"position":1,"ar":"إِن","fr":"Si","en":"If","tr":"in","isWaqf":false},{"position":2,"ar":"تَتُوبَآ","fr":"vous les deux se détourner","en":"you both turn","tr":"tatūbā","isWaqf":false},{"position":3,"ar":"إِلَى","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":4,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":5,"ar":"فَقَدْ","fr":"donc certes","en":"so indeed","tr":"faqad","isWaqf":false},{"position":6,"ar":"صَغَتْ","fr":"(sont) incliné","en":"(are) inclined","tr":"ṣaghat","isWaqf":false},{"position":7,"ar":"قُلُوبُكُمَا ۖ","fr":"vos cœurs","en":"your hearts","tr":"qulūbukumā","isWaqf":false},{"position":8,"ar":"وَإِن","fr":"mais si","en":"but if","tr":"wa-in","isWaqf":false},{"position":9,"ar":"تَظَـٰهَرَا","fr":"vous backup chacun autre","en":"you backup each other","tr":"taẓāharā","isWaqf":false},{"position":10,"ar":"عَلَيْهِ","fr":"contre lui","en":"against him","tr":"ʿalayhi","isWaqf":false},{"position":11,"ar":"فَإِنَّ","fr":"puis certes","en":"then indeed","tr":"fa-inna","isWaqf":false},{"position":12,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":13,"ar":"هُوَ","fr":"Il","en":"He","tr":"huwa","isWaqf":false},{"position":14,"ar":"مَوْلَىٰهُ","fr":"(est) son Protecteur","en":"(is) his Protector","tr":"mawlāhu","isWaqf":false},{"position":15,"ar":"وَجِبْرِيلُ","fr":"et Jibril","en":"and Jibreel","tr":"wajib'rīlu","isWaqf":false},{"position":16,"ar":"وَصَـٰلِحُ","fr":"et (le) vertueux","en":"and (the) righteous","tr":"waṣāliḥu","isWaqf":false},{"position":17,"ar":"ٱلْمُؤْمِنِينَ ۖ","fr":"croyants","en":"believers","tr":"l-mu'minīna","isWaqf":false},{"position":18,"ar":"وَٱلْمَلَـٰٓئِكَةُ","fr":"et les Anges","en":"and the Angels","tr":"wal-malāikatu","isWaqf":false},{"position":19,"ar":"بَعْدَ","fr":"après","en":"after","tr":"baʿda","isWaqf":false},{"position":20,"ar":"ذَٰلِكَ","fr":"que","en":"that","tr":"dhālika","isWaqf":false},{"position":21,"ar":"ظَهِيرٌ","fr":"(sont son) assistants","en":"(are his) assistants","tr":"ẓahīrun","isWaqf":false}]},{"ayah":5,"verseKey":"66:5","juz":28,"arabic":"عَسَىٰ رَبُّهُۥٓ إِن طَلَّقَكُنَّ أَن يُبْدِلَهُۥٓ أَزْوَٰجًا خَيْرًا مِّنكُنَّ مُسْلِمَـٰتٍ مُّؤْمِنَـٰتٍ قَـٰنِتَـٰتٍ تَـٰٓئِبَـٰتٍ عَـٰبِدَٰتٍ سَـٰٓئِحَـٰتٍ ثَيِّبَـٰتٍ وَأَبْكَارًا","fr":"Il se peut, s’il divorce d’avec vous, qu’Allah lui donne de bien meilleures épouses que vous : des musulmanes, croyantes, obéissantes, repentantes, qui prient et jeûnent assidûment, ayant été déjà mariées ou encore vierges.","en":"Perhaps his Lord, if he divorced you [all], would substitute for him wives better than you - submitting [to Allāh], believing, devoutly obedient, repentant, worshipping, and traveling - [ones] previously married and virgins.","words":[{"position":1,"ar":"عَسَىٰ","fr":"Peut-être","en":"Perhaps","tr":"ʿasā","isWaqf":false},{"position":2,"ar":"رَبُّهُۥٓ","fr":"son Seigneur","en":"his Lord","tr":"rabbuhu","isWaqf":false},{"position":3,"ar":"إِن","fr":"si","en":"if","tr":"in","isWaqf":false},{"position":4,"ar":"طَلَّقَكُنَّ","fr":"il divorça vous","en":"he divorced you","tr":"ṭallaqakunna","isWaqf":false},{"position":5,"ar":"أَن","fr":"[que]","en":"[that]","tr":"an","isWaqf":false},{"position":6,"ar":"يُبْدِلَهُۥٓ","fr":"Il va remplacer pour lui","en":"He will substitute for him","tr":"yub'dilahu","isWaqf":false},{"position":7,"ar":"أَزْوَٰجًا","fr":"épouses","en":"wives","tr":"azwājan","isWaqf":false},{"position":8,"ar":"خَيْرًۭا","fr":"meilleur","en":"better","tr":"khayran","isWaqf":false},{"position":9,"ar":"مِّنكُنَّ","fr":"que vous","en":"than you","tr":"minkunna","isWaqf":false},{"position":10,"ar":"مُسْلِمَـٰتٍۢ","fr":"soumis","en":"submissive","tr":"mus'limātin","isWaqf":false},{"position":11,"ar":"مُّؤْمِنَـٰتٍۢ","fr":"fidèle","en":"faithful","tr":"mu'minātin","isWaqf":false},{"position":12,"ar":"قَـٰنِتَـٰتٍۢ","fr":"obéissant","en":"obedient","tr":"qānitātin","isWaqf":false},{"position":13,"ar":"تَـٰٓئِبَـٰتٍ","fr":"repentant","en":"repentant","tr":"tāibātin","isWaqf":false},{"position":14,"ar":"عَـٰبِدَٰتٍۢ","fr":"qui adorer","en":"who worship","tr":"ʿābidātin","isWaqf":false},{"position":15,"ar":"سَـٰٓئِحَـٰتٍۢ","fr":"qui jeûne","en":"who fast","tr":"sāiḥātin","isWaqf":false},{"position":16,"ar":"ثَيِّبَـٰتٍۢ","fr":"déjà marié","en":"previously married","tr":"thayyibātin","isWaqf":false},{"position":17,"ar":"وَأَبْكَارًۭا","fr":"et vierges","en":"and virgins","tr":"wa-abkāran","isWaqf":false}]},{"ayah":6,"verseKey":"66:6","juz":28,"arabic":"يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ قُوٓا۟ أَنفُسَكُمْ وَأَهْلِيكُمْ نَارًا وَقُودُهَا ٱلنَّاسُ وَٱلْحِجَارَةُ عَلَيْهَا مَلَـٰٓئِكَةٌ غِلَاظٌ شِدَادٌ لَّا يَعْصُونَ ٱللَّهَ مَآ أَمَرَهُمْ وَيَفْعَلُونَ مَا يُؤْمَرُونَ","fr":"Ô vous qui avez cru ! Préservez vos propres personnes ainsi que vos familles d’un Feu qui sera alimenté par les hommes et les pierres, et (qui sera gardé) par des Anges rudes et intraitables, qui ne désobéissent jamais aux ordres d’Allah et exécutent ce qu’Il leur enjoint (de faire).","en":"O you who have believed, protect yourselves and your families from a Fire whose fuel is people and stones, over which are [appointed] angels, harsh and severe; they do not disobey Allāh in what He commands them but do what they are commanded.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô","en":"O","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"(vous) qui","en":"(you) who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"croire","en":"believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"قُوٓا۟","fr":"Protège","en":"Protect","tr":"qū","isWaqf":false},{"position":5,"ar":"أَنفُسَكُمْ","fr":"vous-mêmes","en":"yourselves","tr":"anfusakum","isWaqf":false},{"position":6,"ar":"وَأَهْلِيكُمْ","fr":"et votre familles","en":"and your families","tr":"wa-ahlīkum","isWaqf":false},{"position":7,"ar":"نَارًۭا","fr":"(de) un Feu","en":"(from) a Fire","tr":"nāran","isWaqf":false},{"position":8,"ar":"وَقُودُهَا","fr":"dont le combustible","en":"whose fuel","tr":"waqūduhā","isWaqf":false},{"position":9,"ar":"ٱلنَّاسُ","fr":"(est) gens","en":"(is) people","tr":"l-nāsu","isWaqf":false},{"position":10,"ar":"وَٱلْحِجَارَةُ","fr":"et pierres","en":"and stones","tr":"wal-ḥijāratu","isWaqf":false},{"position":11,"ar":"عَلَيْهَا","fr":"sur lui","en":"over it","tr":"ʿalayhā","isWaqf":false},{"position":12,"ar":"مَلَـٰٓئِكَةٌ","fr":"(sont) Anges","en":"(are) Angels","tr":"malāikatun","isWaqf":false},{"position":13,"ar":"غِلَاظٌۭ","fr":"sévère","en":"stern","tr":"ghilāẓun","isWaqf":false},{"position":14,"ar":"شِدَادٌۭ","fr":"sévère","en":"severe","tr":"shidādun","isWaqf":false},{"position":15,"ar":"لَّا","fr":"non","en":"not","tr":"lā","isWaqf":false},{"position":16,"ar":"يَعْصُونَ","fr":"ils désobéissent","en":"they disobey","tr":"yaʿṣūna","isWaqf":false},{"position":17,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":18,"ar":"مَآ","fr":"(dans) ce que","en":"(in) what","tr":"mā","isWaqf":false},{"position":19,"ar":"أَمَرَهُمْ","fr":"Il Ordonne eux","en":"He Commands them","tr":"amarahum","isWaqf":false},{"position":20,"ar":"وَيَفْعَلُونَ","fr":"mais ils font","en":"but they do","tr":"wayafʿalūna","isWaqf":false},{"position":21,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":22,"ar":"يُؤْمَرُونَ","fr":"ils sont ordonna","en":"they are commanded","tr":"yu'marūna","isWaqf":false}]},{"ayah":7,"verseKey":"66:7","juz":28,"arabic":"يَـٰٓأَيُّهَا ٱلَّذِينَ كَفَرُوا۟ لَا تَعْتَذِرُوا۟ ٱلْيَوْمَ ۖ إِنَّمَا تُجْزَوْنَ مَا كُنتُمْ تَعْمَلُونَ","fr":"Ô vous qui avez mécru ! N’invoquez aujourd’hui aucune excuse ! Car vous serez seulement rétribués selon ce que vous faisiez.","en":"O you who have disbelieved, make no excuses that Day. You will only be recompensed for what you used to do.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô","en":"O","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"(vous) qui","en":"(you) who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"كَفَرُوا۟","fr":"mécroire","en":"disbelieve","tr":"kafarū","isWaqf":false},{"position":4,"ar":"لَا","fr":"(Ne) fais pas","en":"(Do) not","tr":"lā","isWaqf":false},{"position":5,"ar":"تَعْتَذِرُوا۟","fr":"faire excuses","en":"make excuses","tr":"taʿtadhirū","isWaqf":false},{"position":6,"ar":"ٱلْيَوْمَ ۖ","fr":"aujourd'hui","en":"today","tr":"l-yawma","isWaqf":false},{"position":7,"ar":"إِنَّمَا","fr":"Seulement","en":"Only","tr":"innamā","isWaqf":false},{"position":8,"ar":"تُجْزَوْنَ","fr":"vous va être rétribué","en":"you will be recompensed","tr":"tuj'zawna","isWaqf":false},{"position":9,"ar":"مَا","fr":"(pour) ce que","en":"(for) what","tr":"mā","isWaqf":false},{"position":10,"ar":"كُنتُمْ","fr":"vous aviez l'habitude de","en":"you used to","tr":"kuntum","isWaqf":false},{"position":11,"ar":"تَعْمَلُونَ","fr":"faire","en":"do","tr":"taʿmalūna","isWaqf":false}]},{"ayah":8,"verseKey":"66:8","juz":28,"arabic":"يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ تُوبُوٓا۟ إِلَى ٱللَّهِ تَوْبَةً نَّصُوحًا عَسَىٰ رَبُّكُمْ أَن يُكَفِّرَ عَنكُمْ سَيِّـَٔاتِكُمْ وَيُدْخِلَكُمْ جَنَّـٰتٍ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَـٰرُ يَوْمَ لَا يُخْزِى ٱللَّهُ ٱلنَّبِىَّ وَٱلَّذِينَ ءَامَنُوا۟ مَعَهُۥ ۖ نُورُهُمْ يَسْعَىٰ بَيْنَ أَيْدِيهِمْ وَبِأَيْمَـٰنِهِمْ يَقُولُونَ رَبَّنَآ أَتْمِمْ لَنَا نُورَنَا وَٱغْفِرْ لَنَآ ۖ إِنَّكَ عَلَىٰ كُلِّ شَىْءٍ قَدِيرٌ","fr":"Ô vous qui avez cru ! Repentez-vous auprès d’Allah d’un repentir sincère, peut-être que votre Seigneur rachètera vos péchés et vous fera entrer dans des jardins sous lesquels coulent les rivières, en ce jour où Allah évitera l’humiliation au Prophète et à ceux qui auront cru avec lui. Leur lumière se déploiera devant eux et sur leur droite, et ils diront : « Seigneur, veuille parfaire notre lumière ! Pardonne-nous ! Tu es de Toute chose Infiniment Capable !","en":"O you who have believed, repent to Allāh with sincere repentance. Perhaps your Lord will remove from you your misdeeds and admit you into gardens beneath which rivers flow [on] the Day when Allāh will not disgrace the Prophet and those who believed with him. Their light will proceed before them and on their right; they will say, \"Our Lord, perfect for us our light and forgive us. Indeed, You are over all things competent.\"","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô","en":"O","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"(vous) qui croire","en":"(you) who believe","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"croire","en":"believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"تُوبُوٓا۟","fr":"Se détourner","en":"Turn","tr":"tūbū","isWaqf":false},{"position":5,"ar":"إِلَى","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":6,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":7,"ar":"تَوْبَةًۭ","fr":"(dans) repentir","en":"(in) repentance","tr":"tawbatan","isWaqf":false},{"position":8,"ar":"نَّصُوحًا","fr":"sincère","en":"sincere","tr":"naṣūḥan","isWaqf":false},{"position":9,"ar":"عَسَىٰ","fr":"Peut-être","en":"Perhaps","tr":"ʿasā","isWaqf":false},{"position":10,"ar":"رَبُّكُمْ","fr":"votre Seigneur","en":"your Lord","tr":"rabbukum","isWaqf":false},{"position":11,"ar":"أَن","fr":"va","en":"will","tr":"an","isWaqf":false},{"position":12,"ar":"يُكَفِّرَ","fr":"ôter","en":"remove","tr":"yukaffira","isWaqf":false},{"position":13,"ar":"عَنكُمْ","fr":"de vous","en":"from you","tr":"ʿankum","isWaqf":false},{"position":14,"ar":"سَيِّـَٔاتِكُمْ","fr":"votre mal actions","en":"your evil deeds","tr":"sayyiātikum","isWaqf":false},{"position":15,"ar":"وَيُدْخِلَكُمْ","fr":"et admettre vous","en":"and admit you","tr":"wayud'khilakum","isWaqf":false},{"position":16,"ar":"جَنَّـٰتٍۢ","fr":"(dans) Jardins","en":"(into) Gardens","tr":"jannātin","isWaqf":false},{"position":17,"ar":"تَجْرِى","fr":"coul