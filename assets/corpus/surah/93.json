[{"ayah":1,"verseKey":"93:1","juz":30,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ","fr":"Par la première clarté du jour !","en":"By the morning brightness","words":[{"position":1,"ar":"وَٱلضُّحَىٰ","fr":"Par le matin éclat","en":"By the morning brightness","tr":"wal-ḍuḥā","isWaqf":false}]},{"ayah":2,"verseKey":"93:2","juz":30,"arabic":"وَٱلَّيْلِ إِذَا سَجَىٰ","fr":"Par la nuit quand elle voile tout !","en":"And [by] the night when it covers with darkness,","words":[{"position":1,"ar":"وَٱلَّيْلِ","fr":"Et la nuit","en":"And the night","tr":"wa-al-layli","isWaqf":false},{"position":2,"ar":"إِذَا","fr":"quand","en":"when","tr":"idhā","isWaqf":false},{"position":3,"ar":"سَجَىٰ","fr":"cela couvre avec obscurité","en":"it covers with darkness","tr":"sajā","isWaqf":false}]},{"ayah":3,"verseKey":"93:3","juz":30,"arabic":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ","fr":"Ton Seigneur ne t’a point délaissé, ni ne t’a haï.","en":"Your Lord has not taken leave of you, [O Muḥammad], nor has He detested [you].","words":[{"position":1,"ar":"مَا","fr":"Non","en":"Not","tr":"mā","isWaqf":false},{"position":2,"ar":"وَدَّعَكَ","fr":"a délaissé vous","en":"has forsaken you","tr":"waddaʿaka","isWaqf":false},{"position":3,"ar":"رَبُّكَ","fr":"votre Seigneur","en":"your Lord","tr":"rabbuka","isWaqf":false},{"position":4,"ar":"وَمَا","fr":"et non","en":"and not","tr":"wamā","isWaqf":false},{"position":5,"ar":"قَلَىٰ","fr":"Il est displeased","en":"He is displeased","tr":"qalā","isWaqf":false}]},{"ayah":4,"verseKey":"93:4","juz":30,"arabic":"وَلَلْـَٔاخِرَةُ خَيْرٌ لَّكَ مِنَ ٱلْأُولَىٰ","fr":"Le monde dernier est pour toi meilleur que le premier.","en":"And the Hereafter is better for you than the first [life].","words":[{"position":1,"ar":"وَلَلْـَٔاخِرَةُ","fr":"Et assurément le Au-delà","en":"And surely the Hereafter","tr":"walalākhiratu","isWaqf":false},{"position":2,"ar":"خَيْرٌۭ","fr":"(est) meilleur","en":"(is) better","tr":"khayrun","isWaqf":false},{"position":3,"ar":"لَّكَ","fr":"pour vous","en":"for you","tr":"laka","isWaqf":false},{"position":4,"ar":"مِنَ","fr":"que","en":"than","tr":"mina","isWaqf":false},{"position":5,"ar":"ٱلْأُولَىٰ","fr":"le premier","en":"the first","tr":"l-ūlā","isWaqf":false}]},{"ayah":5,"verseKey":"93:5","juz":30,"arabic":"وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ","fr":"Ton Seigneur te donnera certes ce dont tu seras satisfait.","en":"And your Lord is going to give you, and you will be satisfied.","words":[{"position":1,"ar":"وَلَسَوْفَ","fr":"Et bientôt","en":"And soon","tr":"walasawfa","isWaqf":false},{"position":2,"ar":"يُعْطِيكَ","fr":"va donner vous","en":"will give you","tr":"yuʿ'ṭīka","isWaqf":false},{"position":3,"ar":"رَبُّكَ","fr":"votre Seigneur","en":"your Lord","tr":"rabbuka","isWaqf":false},{"position":4,"ar":"فَتَرْضَىٰٓ","fr":"puis vous va être satisfait","en":"then you will be satisfied","tr":"fatarḍā","isWaqf":false}]},{"ayah":6,"verseKey":"93:6","juz":30,"arabic":"أَلَمْ يَجِدْكَ يَتِيمًا فَـَٔاوَىٰ","fr":"Ne t’a-t-Il pas trouvé orphelin, et Il t’a alors donné asile ?","en":"Did He not find you an orphan and give [you] refuge?","words":[{"position":1,"ar":"أَلَمْ","fr":"N'a-t-il pas","en":"Did not","tr":"alam","isWaqf":false},{"position":2,"ar":"يَجِدْكَ","fr":"Il Trouve vous","en":"He find you","tr":"yajid'ka","isWaqf":false},{"position":3,"ar":"يَتِيمًۭا","fr":"un orphelin","en":"an orphan","tr":"yatīman","isWaqf":false},{"position":4,"ar":"فَـَٔاوَىٰ","fr":"et donner abri","en":"and give shelter","tr":"faāwā","isWaqf":false}]},{"ayah":7,"verseKey":"93:7","juz":30,"arabic":"وَوَجَدَكَ ضَآلًّا فَهَدَىٰ","fr":"Ne t’a-t-Il pas trouvé égaré, et Il t’a alors guidé ?","en":"And He found you lost and guided [you],","words":[{"position":1,"ar":"وَوَجَدَكَ","fr":"Et Il trouva vous","en":"And He found you","tr":"wawajadaka","isWaqf":false},{"position":2,"ar":"ضَآلًّۭا","fr":"perdu","en":"lost","tr":"ḍāllan","isWaqf":false},{"position":3,"ar":"فَهَدَىٰ","fr":"donc Il guidé","en":"so He guided","tr":"fahadā","isWaqf":false}]},{"ayah":8,"verseKey":"93:8","juz":30,"arabic":"وَوَجَدَكَ عَآئِلًا فَأَغْنَىٰ","fr":"Ne t’a-t-Il pas trouvé pauvre, et Il t’a alors enrichi ?","en":"And He found you poor and made [you] self-sufficient.","words":[{"position":1,"ar":"وَوَجَدَكَ","fr":"Et Il trouva vous","en":"And He found you","tr":"wawajadaka","isWaqf":false},{"position":2,"ar":"عَآئِلًۭا","fr":"dans besoin","en":"in need","tr":"ʿāilan","isWaqf":false},{"position":3,"ar":"فَأَغْنَىٰ","fr":"donc Il fait celui qui se suffit à Lui-même","en":"so He made self-sufficient","tr":"fa-aghnā","isWaqf":false}]},{"ayah":9,"verseKey":"93:9","juz":30,"arabic":"فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ","fr":"Quant à l’orphelin, ne le persécute point.","en":"So as for the orphan, do not oppress [him].","words":[{"position":1,"ar":"فَأَمَّا","fr":"Donc comme pour","en":"So as for","tr":"fa-ammā","isWaqf":false},{"position":2,"ar":"ٱلْيَتِيمَ","fr":"le orphelin","en":"the orphan","tr":"l-yatīma","isWaqf":false},{"position":3,"ar":"فَلَا","fr":"puis ne fais pas","en":"then (do) not","tr":"falā","isWaqf":false},{"position":4,"ar":"تَقْهَرْ","fr":"opprimer","en":"oppress","tr":"taqhar","isWaqf":false}]},{"ayah":10,"verseKey":"93:10","juz":30,"arabic":"وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ","fr":"Quant au mendiant, ne le malmène point.","en":"And as for the petitioner, do not repel [him].","words":[{"position":1,"ar":"وَأَمَّا","fr":"Et quant à","en":"And as for","tr":"wa-ammā","isWaqf":false},{"position":2,"ar":"ٱلسَّآئِلَ","fr":"un qui demande","en":"one who asks","tr":"l-sāila","isWaqf":false},{"position":3,"ar":"فَلَا","fr":"puis ne fais pas","en":"then (do) not","tr":"falā","isWaqf":false},{"position":4,"ar":"تَنْهَرْ","fr":"repousser","en":"repel","tr":"tanhar","isWaqf":false}]},{"ayah":11,"verseKey":"93:11","juz":30,"arabic":"وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ","fr":"Et quant aux bienfaits de ton Seigneur, proclame-les tout haut !","en":"But as for the favor of your Lord, report [it].","words":[{"position":1,"ar":"وَأَمَّا","fr":"Quant à","en":"But as for","tr":"wa-ammā","isWaqf":false},{"position":2,"ar":"بِنِعْمَةِ","fr":"(la) Grâce","en":"(the) Favor","tr":"biniʿ'mati","isWaqf":false},{"position":3,"ar":"رَبِّكَ","fr":"(de) votre Seigneur","en":"(of) your Lord","tr":"rabbika","isWaqf":false},{"position":4,"ar":"فَحَدِّثْ","fr":"raconter","en":"narrate","tr":"faḥaddith","isWaqf":false}]}]