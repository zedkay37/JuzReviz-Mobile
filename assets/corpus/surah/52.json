f":false}]},{"ayah":16,"verseKey":"52:16","juz":27,"arabic":"ٱصْلَوْهَا فَٱصْبِرُوٓا۟ أَوْ لَا تَصْبِرُوا۟ سَوَآءٌ عَلَيْكُمْ ۖ إِنَّمَا تُجْزَوْنَ مَا كُنتُمْ تَعْمَلُونَ","fr":"Entrez-y et brûlez! Que vous le supportiez ou que vous ne le supportiez pas, la chose sera pour vous égale. Vous n’êtes rétribués que pour ce que vous faisiez. »","en":"[Enter to] burn therein; then be patient or impatient - it is all the same for you. You are only being recompensed [for] what you used to do.\"","words":[{"position":1,"ar":"ٱصْلَوْهَا","fr":"Brûler dans cela","en":"Burn in it","tr":"iṣ'lawhā","isWaqf":false},{"position":2,"ar":"فَٱصْبِرُوٓا۟","fr":"puis être patient","en":"then be patient","tr":"fa-iṣ'birū","isWaqf":false},{"position":3,"ar":"أَوْ","fr":"ou","en":"or","tr":"aw","isWaqf":false},{"position":4,"ar":"لَا","fr":"(fais) non","en":"(do) not","tr":"lā","isWaqf":false},{"position":5,"ar":"تَصْبِرُوا۟","fr":"être patient","en":"be patient","tr":"taṣbirū","isWaqf":false},{"position":6,"ar":"سَوَآءٌ","fr":"(cela est) même","en":"(it is) same","tr":"sawāon","isWaqf":false},{"position":7,"ar":"عَلَيْكُمْ ۖ","fr":"pour vous","en":"for you","tr":"ʿalaykum","isWaqf":false},{"position":8,"ar":"إِنَّمَا","fr":"Seulement","en":"Only","tr":"innamā","isWaqf":false},{"position":9,"ar":"تُجْزَوْنَ","fr":"vous sont étant rétribué","en":"you are being recompensed","tr":"tuj'zawna","isWaqf":false},{"position":10,"ar":"مَا","fr":"(pour) ce que","en":"(for) what","tr":"mā","isWaqf":false},{"position":11,"ar":"كُنتُمْ","fr":"vous aviez l'habitude de","en":"you used to","tr":"kuntum","isWaqf":false},{"position":12,"ar":"تَعْمَلُونَ","fr":"faire","en":"do","tr":"taʿmalūna","isWaqf":false}]},{"ayah":17,"verseKey":"52:17","juz":27,"arabic":"إِنَّ ٱلْمُتَّقِينَ فِى جَنَّـٰتٍ وَنَعِيمٍ","fr":"Les gens pieux seront dans des jardins, (au milieu) des délices,","en":"Indeed, the righteous will be in gardens and pleasure,","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"ٱلْمُتَّقِينَ","fr":"les justes","en":"the righteous","tr":"l-mutaqīna","isWaqf":false},{"position":3,"ar":"فِى","fr":"(sera) dans","en":"(will be) in","tr":"fī","isWaqf":false},{"position":4,"ar":"جَنَّـٰتٍۢ","fr":"Jardins","en":"Gardens","tr":"jannātin","isWaqf":false},{"position":5,"ar":"وَنَعِيمٍۢ","fr":"et plaisir","en":"and pleasure","tr":"wanaʿīmin","isWaqf":false}]},{"ayah":18,"verseKey":"52:18","juz":27,"arabic":"فَـٰكِهِينَ بِمَآ ءَاتَىٰهُمْ رَبُّهُمْ وَوَقَىٰهُمْ رَبُّهُمْ عَذَابَ ٱلْجَحِيمِ","fr":"y jouissant de ce que leur Seigneur leur aura accordé, et (heureux) que leur Seigneur les ait préservés du supplice de la Fournaise.","en":"Enjoying what their Lord has given them, and their Lord protected them from the punishment of Hellfire.","words":[{"position":1,"ar":"فَـٰكِهِينَ","fr":"Jouissant","en":"Enjoying","tr":"fākihīna","isWaqf":false},{"position":2,"ar":"بِمَآ","fr":"en ce que","en":"in what","tr":"bimā","isWaqf":false},{"position":3,"ar":"ءَاتَىٰهُمْ","fr":"a donné eux","en":"has given them","tr":"ātāhum","isWaqf":false},{"position":4,"ar":"رَبُّهُمْ","fr":"leur Seigneur","en":"their Lord","tr":"rabbuhum","isWaqf":false},{"position":5,"ar":"وَوَقَىٰهُمْ","fr":"et protégé eux","en":"and protected them","tr":"wawaqāhum","isWaqf":false},{"position":6,"ar":"رَبُّهُمْ","fr":"leur Seigneur","en":"their Lord","tr":"rabbuhum","isWaqf":false},{"position":7,"ar":"عَذَابَ","fr":"(de le) châtiment","en":"(from the) punishment","tr":"ʿadhāba","isWaqf":false},{"position":8,"ar":"ٱلْجَحِيمِ","fr":"(de) le Feu","en":"(of) Hellfire","tr":"l-jaḥīmi","isWaqf":false}]},{"ayah":19,"verseKey":"52:19","juz":27,"arabic":"كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَا كُنتُمْ تَعْمَلُونَ","fr":"« Mangez et buvez en paix, c’est là le prix de vos œuvres ! »","en":"[They will be told], \"Eat and drink in satisfaction for what you used to do.\"","words":[{"position":1,"ar":"كُلُوا۟","fr":"Mange","en":"Eat","tr":"kulū","isWaqf":false},{"posit