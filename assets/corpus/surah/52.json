r":"walā","isWaqf":false},{"position":8,"ar":"تَأْثِيمٌۭ","fr":"péché","en":"sin","tr":"tathīmun","isWaqf":false}]},{"ayah":24,"verseKey":"52:24","juz":27,"arabic":"وَيَطُوفُ عَلَيْهِمْ غِلْمَانٌ لَّهُمْ كَأَنَّهُمْ لُؤْلُؤٌ مَّكْنُونٌ","fr":"De jeunes serviteurs à leurs ordres circuleront entre eux, tels des perles soigneusement conservées (dans leur coquillage).","en":"There will circulate among them [servant] boys [especially] for them, as if they were pearls well-protected.","words":[{"position":1,"ar":"۞ وَيَطُوفُ","fr":"Et va circuler","en":"And will circulate","tr":"wayaṭūfu","isWaqf":false},{"position":2,"ar":"عَلَيْهِمْ","fr":"parmi eux","en":"among them","tr":"ʿalayhim","isWaqf":false},{"position":3,"ar":"غِلْمَانٌۭ","fr":"garçons","en":"boys","tr":"ghil'mānun","isWaqf":false},{"position":4,"ar":"لَّهُمْ","fr":"pour eux","en":"for them","tr":"lahum","isWaqf":false},{"position":5,"ar":"كَأَنَّهُمْ","fr":"comme si ils (étaient)","en":"as if they (were)","tr":"ka-annahum","isWaqf":false},{"position":6,"ar":"لُؤْلُؤٌۭ","fr":"perles","en":"pearls","tr":"lu'lu-on","isWaqf":false},{"position":7,"ar":"مَّكْنُونٌۭ","fr":"bien gardé","en":"well-protected","tr":"maknūnun","isWaqf":false}]},{"ayah":25,"verseKey":"52:25","juz":27,"arabic":"وَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَآءَلُونَ","fr":"Ils s’élanceront les uns vers les autres, en s’interrogeant :","en":"And they will approach one another, inquiring of each other.","words":[{"position":1,"ar":"وَأَقْبَلَ","fr":"Et va approcher","en":"And will approach","tr":"wa-aqbala","isWaqf":false},{"position":2,"ar":"بَعْضُهُمْ","fr":"certains d'eux","en":"some of them","tr":"baʿḍuhum","isWaqf":false},{"position":3,"ar":"عَلَىٰ","fr":"à","en":"to","tr":"ʿalā","isWaqf":false},{"position":4,"ar":"بَعْضٍۢ","fr":"d'autres","en":"others","tr":"baʿḍin","isWaqf":false},{"position":5,"ar":"يَتَسَآءَلُونَ","fr":"s'enquérant","en":"inquiring","tr":"yatasāalūna","isWaqf":false}]},{"ayah":26,"verseKey":"52:26","juz":27,"arabic":"قَالُوٓا۟ إِنَّا كُنَّا قَبْلُ فِىٓ أَهْلِنَا مُشْفِقِينَ","fr":"« Quand nous étions autrefois parmi les nôtres, nous redoutions (le châtiment d’Allah).","en":"They will say, \"Indeed, we were previously among our people fearful [of displeasing Allāh].","words":[{"position":1,"ar":"قَالُوٓا۟","fr":"Ils diront","en":"They will say","tr":"qālū","isWaqf":false},{"position":2,"ar":"إِنَّا","fr":"Certes, nous","en":"Indeed, we","tr":"innā","isWaqf":false},{"position":3,"ar":"كُنَّا","fr":"[nous] étaient","en":"[we] were","tr":"kunnā","isWaqf":false},{"position":4,"ar":"قَبْلُ","fr":"avant","en":"before","tr":"qablu","isWaqf":false},{"position":5,"ar":"فِىٓ","fr":"parmi","en":"among","tr":"fī","isWaqf":false},{"position":6,"ar":"أَهْلِنَا","fr":"notre familles","en":"our families","tr":"ahlinā","isWaqf":false},{"position":7,"ar":"مُشْفِقِينَ","fr":"craintif","en":"fearful","tr":"mush'fiqīna","isWaqf":false}]},{"ayah":27,"verseKey":"52:27","juz":27,"arabic":"فَمَنَّ ٱللَّهُ عَلَيْنَا وَوَقَىٰنَا عَذَابَ ٱلسَّمُومِ","fr":"Allah nous a donc fait grâce en nous épargnant le tourment de As-Samûm.","en":"So Allāh conferred favor upon us and protected us from the punishment of the Scorching Fire.","words":[{"position":1,"ar":"فَمَنَّ","fr":"Mais Allah conféra faveur","en":"But Allah conferred favor","tr":"famanna","isWaqf":false},{"position":2,"ar":"ٱللَّهُ","fr":"Mais Allah conféra faveur","en":"But Allah conferred favor","tr":"l-lahu","isWaqf":false},{"position":3,"ar":"عَلَيْنَا","fr":"sur nous","en":"upon us","tr":"ʿalaynā","isWaqf":false},{"position":4,"ar":"وَوَقَىٰنَا","fr":"et protégé nous","en":"and protected us","tr":"wawaqānā","isWaqf":false},{"position":5,"ar":"عَذَابَ","fr":"(de le) châtiment","en":"(from the) punishment","tr":"ʿadhāba","isWaqf":false},{"position":6,"ar":"ٱلسَّمُومِ","fr":"(de) le Brûlant Feu","en":"(of) the Scorching Fire","tr":"l-samūmi","isWaqf":false}]},{"ayah":28,"verseKey":"52:28","juz":27,"arabic":"إِنَّا كُنَّا مِن قَبْلُ نَدْعُوهُ ۖ إِنَّهُۥ هُوَ ٱلْبَرُّ ٱلرَّحِيمُ","fr":"C’est Lui que Nous invoquions autrefois, car c’est Lui le Bienfaiteur, le Tout Miséricordieux.","en":"Indeed, we used to supplicate Him before. Indeed, it is He who is the Beneficent, the Merciful.\"","words":[{"position":1,"ar":"إِنَّا","fr":"Certes, nous","en":"Indeed, we","tr":"innā","isWaqf":false},{"position":2,"ar":"كُنَّا","fr":"[nous] utilisé à","en":"[we] used to","tr":"kunnā","isWaqf":false},{"position":3,"ar":"مِن","fr":"avant","en":"before","tr":"min","isWaqf":false},{"position":4,"ar":"قَبْلُ","fr":"avant","en":"before","tr":"qablu","isWaqf":false},{"position":5,"ar":"نَدْعُوهُ ۖ","fr":"appeler Lui","en":"call Him","tr":"nadʿūhu","isWaqf":false},{"position":6,"ar":"إِنَّهُۥ","fr":"Certes, Il","en":"Indeed, He","tr":"innahu","isWaqf":false},{"position":7,"ar":"هُوَ","fr":"[Il]","en":"[He]","tr":"huwa","isWaqf":false},{"position":8,"ar":"ٱلْبَرُّ","fr":"(est) le Très Bienveillant","en":"(is) the Most Kind","tr":"l-baru","isWaqf":false},{"position":9,"ar":"ٱلرَّحِيمُ","fr":"le Très-Miséricordieux","en":"the Most Merciful","tr":"l-raḥīmu","isWaqf":false}]},{"ayah":29,"verseKey":"52:29","juz":27,"arabic":"فَذَكِّرْ فَمَآ أَنتَ بِنِعْمَتِ رَبِّكَ بِكَاهِنٍ وَلَا مَجْنُونٍ","fr":"Adresse-leur donc un rappel car, par la grâce de ton Seigneur, tu n’es ni devin ni fou.","en":"So remind, [O Muḥammad], for you are not, by the favor of your Lord, a soothsayer or a madman.","words":[{"position":1,"ar":"فَذَكِّرْ","fr":"Donc rappeler","en":"Therefore remind","tr":"fadhakkir","isWaqf":false},{"position":2,"ar":"فَمَآ","fr":"pour non","en":"for not","tr":"famā","isWaqf":false},{"position":3,"ar":"أَنتَ","fr":"vous","en":"you","tr":"anta","isWaqf":false},{"position":4,"ar":"بِنِعْمَتِ","fr":"(sont) par (le) grâce","en":"(are) by (the) grace","tr":"biniʿ'mati","isWaqf":false},{"position":5,"ar":"رَبِّكَ","fr":"(de) votre Seigneur","en":"(of) your Lord","tr":"rabbika","isWaqf":false},{"position":6,"ar":"بِكَاهِنٍۢ","fr":"un devin","en":"a soothsayer","tr":"bikāhinin","isWaqf":false},{"position":7,"ar":"وَلَا","fr":"et non","en":"and not","tr":"walā","isWaqf":false},{"position":8,"ar":"مَجْنُونٍ","fr":"un fou","en":"a madman","tr":"majnūnin","isWaqf":false}]},{"ayah":30,"verseKey":"52:30","juz":27,"arabic":"أَمْ يَقُولُونَ شَاعِرٌ نَّتَرَبَّصُ بِهِۦ رَيْبَ ٱلْمَنُونِ","fr":"Or s’ils disent : « C’est un poète. Attendons que la mort vienne l’emporter (lui et son Message). »","en":"Or do they say [of you], \"A poet for whom we await a misfortune of time\"?","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"يَقُولُونَ","fr":"(fais) ils disent","en":"(do) they say","tr":"yaqūlūna","isWaqf":false},{"position":3,"ar":"شَاعِرٌۭ","fr":"Un poète","en":"A poet","tr":"shāʿirun","isWaqf":false},{"position":4,"ar":"نَّتَرَبَّصُ","fr":"nous attendre","en":"we wait","tr":"natarabbaṣu","isWaqf":false},{"position":5,"ar":"بِهِۦ","fr":"pour lui","en":"for him","tr":"bihi","isWaqf":false},{"position":6,"ar":"رَيْبَ","fr":"un malheur de temps","en":"a misfortune of time","tr":"rayba","isWaqf":false},{"position":7,"ar":"ٱلْمَنُونِ","fr":"un malheur de temps","en":"a misfortune of time","tr":"l-manūni","isWaqf":false}]},{"ayah":31,"verseKey":"52:31","juz":27,"arabic":"قُلْ تَرَبَّصُوا۟ فَإِنِّى مَعَكُم مِّنَ ٱلْمُتَرَبِّصِينَ","fr":"Réponds-leur : « Attendez donc ! Je serai avec vous à attendre. »","en":"Say, \"Wait, for indeed I am, with you, among the waiters.\"","words":[{"position":1,"ar":"قُلْ","fr":"Dis","en":"Say","tr":"qul","isWaqf":false},{"position":2,"ar":"تَرَبَّصُوا۟","fr":"Attendre","en":"Wait","tr":"tarabbaṣū","isWaqf":false},{"position":3,"ar":"فَإِنِّى","fr":"pour certes je suis","en":"for indeed I am","tr":"fa-innī","isWaqf":false},{"position":4,"ar":"مَعَكُم","fr":"avec vous","en":"with you","tr":"maʿakum","isWaqf":false},{"position":5,"ar":"مِّنَ","fr":"parmi","en":"among","tr":"mina","isWaqf":false},{"position":6,"ar":"ٱلْمُتَرَبِّصِينَ","fr":"ceux qui attendre","en":"those who wait","tr":"l-mutarabiṣīna","isWaqf":false}]},{"ayah":32,"verseKey":"52:32","juz":27,"arabic":"أَمْ تَأْمُرُهُمْ أَحْلَـٰمُهُم بِهَـٰذَآ ۚ أَمْ هُمْ قَوْمٌ طَاغُونَ","fr":"Serait-ce leur raison qui leur ordonne (de telles allégations) ? Ou bien sont-ils des gens enclins à la démesure ?","en":"Or do their minds command them to [say] this, or are they a transgressing people?","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"تَأْمُرُهُمْ","fr":"ordre eux","en":"command them","tr":"tamuruhum","isWaqf":false},{"position":3,"ar":"أَحْلَـٰمُهُم","fr":"leur minds","en":"their minds","tr":"aḥlāmuhum","isWaqf":false},{"position":4,"ar":"بِهَـٰذَآ ۚ","fr":"ceci","en":"this","tr":"bihādhā","isWaqf":false},{"position":5,"ar":"أَمْ","fr":"ou","en":"or","tr":"am","isWaqf":false},{"position":6,"ar":"هُمْ","fr":"ils","en":"they","tr":"hum","isWaqf":false},{"position":7,"ar":"قَوْمٌۭ","fr":"(sont) un peuple","en":"(are) a people","tr":"qawmun","isWaqf":false},{"position":8,"ar":"طَاغُونَ","fr":"transgressant","en":"transgressing","tr":"ṭāghūna","isWaqf":false}]},{"ayah":33,"verseKey":"52:33","juz":27,"arabic":"أَمْ يَقُولُونَ تَقَوَّلَهُۥ ۚ بَل لَّا يُؤْمِنُونَ","fr":"Ou alors diront-ils : « C’est lui qui l’a inventé. » Or ce sont eux qui n’y croient pas.","en":"Or do they say, \"He has made it up\"? Rather, they do not believe.","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"يَقُولُونَ","fr":"(fais) ils disent","en":"(do) they say","tr":"yaqūlūna","isWaqf":false},{"position":3,"ar":"تَقَوَّلَهُۥ ۚ","fr":"Il a fait cela haut","en":"He has made it up","tr":"taqawwalahu","isWaqf":false},{"position":4,"ar":"بَل","fr":"Non","en":"Nay","tr":"bal","isWaqf":false},{"position":5,"ar":"لَّا","fr":"non","en":"not","tr":"lā","isWaqf":false},{"position":6,"ar":"يُؤْمِنُونَ","fr":"ils croient","en":"they believe","tr":"yu'minūna","isWaqf":false}]},{"ayah":34,"verseKey":"52:34","juz":27,"arabic":"فَلْيَأْتُوا۟ بِحَدِيثٍ مِّثْلِهِۦٓ إِن كَانُوا۟ صَـٰدِقِينَ","fr":"Qu’ils apportent donc un discours qui lui soit semblable, si ce qu’ils disent est vrai.","en":"Then let them produce a statement like it, if they should be truthful.","words":[{"position":1,"ar":"فَلْيَأْتُوا۟","fr":"Puis laisser eux apporter","en":"Then let them bring","tr":"falyatū","isWaqf":false},{"position":2,"ar":"بِحَدِيثٍۢ","fr":"un parole","en":"a statement","tr":"biḥadīthin","isWaqf":false},{"position":3,"ar":"مِّثْلِهِۦٓ","fr":"comme cela","en":"like it","tr":"mith'lihi","isWaqf":false},{"position":4,"ar":"إِن","fr":"si","en":"if","tr":"in","isWaqf":false},{"position":5,"ar":"كَانُوا۟","fr":"ils sont","en":"they are","tr":"kānū","isWaqf":false},{"position":6,"ar":"صَـٰدِقِينَ","fr":"véridique","en":"truthful","tr":"ṣādiqīna","isWaqf":false}]},{"ayah":35,"verseKey":"52:35","juz":27,"arabic":"أَمْ خُلِقُوا۟ مِنْ غَيْرِ شَىْءٍ أَمْ هُمُ ٱلْخَـٰلِقُونَ","fr":"Ont-ils été créés de rien ou sont-ils leurs propres créateurs ?","en":"Or were they created by nothing, or were they the creators [of themselves]?","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"خُلِقُوا۟","fr":"ils étaient créé","en":"they were created","tr":"khuliqū","isWaqf":false},{"position":3,"ar":"مِنْ","fr":"de","en":"of","tr":"min","isWaqf":false},{"position":4,"ar":"غَيْرِ","fr":"rien","en":"nothing","tr":"ghayri","isWaqf":false},{"position":5,"ar":"شَىْءٍ","fr":"rien","en":"nothing","tr":"shayin","isWaqf":false},{"position":6,"ar":"أَمْ","fr":"ou","en":"or","tr":"am","isWaqf":false},{"position":7,"ar":"هُمُ","fr":"(sont) ils","en":"(are) they","tr":"humu","isWaqf":false},{"position":8,"ar":"ٱلْخَـٰلِقُونَ","fr":"le créateurs","en":"the creators","tr":"l-khāliqūna","isWaqf":false}]},{"ayah":36,"verseKey":"52:36","juz":27,"arabic":"أَمْ خَلَقُوا۟ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضَ ۚ بَل لَّا يُوقِنُونَ","fr":"Ou ont-ils (eux-mêmes) créé les cieux et la terre ? Non, ils n’ont aucune certitude.","en":"Or did they create the heavens and the earth? Rather, they are not certain.","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"خَلَقُوا۟","fr":"(fit) ils créent","en":"(did) they create","tr":"khalaqū","isWaqf":false},{"position":3,"ar":"ٱلسَّمَـٰوَٰتِ","fr":"les cieux","en":"the heavens","tr":"l-samāwāti","isWaqf":false},{"position":4,"ar":"وَٱلْأَرْضَ ۚ","fr":"et la terre","en":"and the earth","tr":"wal-arḍa","isWaqf":false},{"position":5,"ar":"بَل","fr":"Non","en":"Nay","tr":"bal","isWaqf":false},{"position":6,"ar":"لَّا","fr":"non","en":"not","tr":"lā","isWaqf":false},{"position":7,"ar":"يُوقِنُونَ","fr":"ils sont certain","en":"they are certain","tr":"yūqinūna","isWaqf":false}]},{"ayah":37,"verseKey":"52:37","juz":27,"arabic":"أَمْ عِندَهُمْ خَزَآئِنُ رَبِّكَ أَمْ هُمُ ٱلْمُصَۣيْطِرُونَ","fr":"Détiendraient-ils les trésors de ton Seigneur ? Seraient-ils, eux, les maîtres dominateurs ?","en":"Or have they the depositories [containing the provision] of your Lord? Or are they the controllers [of them]?","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"عِندَهُمْ","fr":"avec eux","en":"with them","tr":"ʿindahum","isWaqf":false},{"position":3,"ar":"خَزَآئِنُ","fr":"(sont le) trésors","en":"(are the) treasures","tr":"khazāinu","isWaqf":false},{"position":4,"ar":"رَبِّكَ","fr":"(de) votre Seigneur","en":"(of) your Lord","tr":"rabbika","isWaqf":false},{"position":5,"ar":"أَمْ","fr":"ou","en":"or","tr":"am","isWaqf":false},{"position":6,"ar":"هُمُ","fr":"(sont) ils","en":"(are) they","tr":"humu","isWaqf":false},{"position":7,"ar":"ٱلْمُصَۣيْطِرُونَ","fr":"le controllers","en":"the controllers","tr":"l-muṣayṭirūna","isWaqf":false}]},{"ayah":38,"verseKey":"52:38","juz":27,"arabic":"أَمْ لَهُمْ سُلَّمٌ يَسْتَمِعُونَ فِيهِ ۖ فَلْيَأْتِ مُسْتَمِعُهُم بِسُلْطَـٰنٍ مُّبِينٍ","fr":"Auraient-ils une échelle depuis laquelle ils écouteraient (les entretiens célestes) ? Que celui qui, parmi eux, est là à écouter apporte donc une évidente preuve d’autorité !","en":"Or have they a stairway [into the heaven] upon which they listen? Then let their listener produce a clear authority [i.e., proof].","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"لَهُمْ","fr":"pour eux","en":"for them","tr":"lahum","isWaqf":false},{"position":3,"ar":"سُلَّمٌۭ","fr":"(est) un stairway","en":"(is) a stairway","tr":"sullamun","isWaqf":false},{"position":4,"ar":"يَسْتَمِعُونَ","fr":"ils écoutent","en":"they listen","tr":"yastamiʿūna","isWaqf":false},{"position":5,"ar":"فِيهِ ۖ","fr":"avec cela","en":"therewith","tr":"fīhi","isWaqf":false},{"position":6,"ar":"فَلْيَأْتِ","fr":"Puis laisser apporter","en":"Then let bring","tr":"falyati","isWaqf":false},{"position":7,"ar":"مُسْتَمِعُهُم","fr":"leur listener","en":"their listener","tr":"mus'tamiʿuhum","isWaqf":false},{"position":8,"ar":"بِسُلْطَـٰنٍۢ","fr":"une autorité","en":"an authority","tr":"bisul'ṭānin","isWaqf":false},{"position":9,"ar":"مُّبِينٍ","fr":"clair","en":"clear","tr":"mubīnin","isWaqf":false}]},{"ayah":39,"verseKey":"52:39","juz":27,"arabic":"أَمْ لَهُ ٱلْبَنَـٰتُ وَلَكُمُ ٱلْبَنُونَ","fr":"(Allah) aurait donc les filles, alors que vous les fils ?","en":"Or has He daughters while you have sons?","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"لَهُ","fr":"pour Lui","en":"for Him","tr":"lahu","isWaqf":false},{"position":3,"ar":"ٱلْبَنَـٰتُ","fr":"(sont) filles","en":"(are) daughters","tr":"l-banātu","isWaqf":false},{"position":4,"ar":"وَلَكُمُ","fr":"tandis que pour vous","en":"while for you","tr":"walakumu","isWaqf":false},{"position":5,"ar":"ٱلْبَنُونَ","fr":"(sont) fils","en":"(are) sons","tr":"l-banūna","isWaqf":false}]},{"ayah":40,"verseKey":"52:40","juz":27,"arabic":"أَمْ تَسْـَٔلُهُمْ أَجْرًا فَهُم مِّن مَّغْرَمٍ مُّثْقَلُونَ","fr":"Leur réclamerais- tu une récompense dont ils seraient lourdement obérés ?","en":"Or do you, [O Muḥammad], ask of them a payment, so they are by debt burdened down?","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"تَسْـَٔلُهُمْ","fr":"(fais) vous demandez de eux","en":"(do) you ask from them","tr":"tasaluhum","isWaqf":false},{"position":3,"ar":"أَجْرًۭا","fr":"un paiement","en":"a payment","tr":"ajran","isWaqf":false},{"position":4,"ar":"فَهُم","fr":"donc ils","en":"so they","tr":"fahum","isWaqf":false},{"position":5,"ar":"مِّن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":6,"ar":"مَّغْرَمٍۢ","fr":"un dette","en":"a debt","tr":"maghramin","isWaqf":false},{"position":7,"ar":"مُّثْقَلُونَ","fr":"(sont) overburdened","en":"(are) overburdened","tr":"muth'qalūna","isWaqf":false}]},{"ayah":41,"verseKey":"52:41","juz":27,"arabic":"أَمْ عِندَهُمُ ٱلْغَيْبُ فَهُمْ يَكْتُبُونَ","fr":"Disposeraient-ils des clefs de l’Inconnaissable (ghayb) dont ils pourraient consigner par écrit (les secrets) ?","en":"Or have they [knowledge of] the unseen, so they write [it] down?","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"عِندَهُمُ","fr":"avec eux","en":"with them","tr":"ʿindahumu","isWaqf":false},{"position":3,"ar":"ٱلْغَيْبُ","fr":"(est) le invisible","en":"(is) the unseen","tr":"l-ghaybu","isWaqf":false},{"position":4,"ar":"فَهُمْ","fr":"donc ils","en":"so they","tr":"fahum","isWaqf":false},{"position":5,"ar":"يَكْتُبُونَ","fr":"écrire (cela) bas","en":"write (it) down","tr":"yaktubūna","isWaqf":false}]},{"ayah":42,"verseKey":"52:42","juz":27,"arabic":"أَمْ يُرِيدُونَ كَيْدًا ۖ فَٱلَّذِينَ كَفَرُوا۟ هُمُ ٱلْمَكِيدُونَ","fr":"Ou chercheraient-ils à tramer des intrigues ? Les mécréants seront alors les victimes de leurs propres intrigues.","en":"Or do they intend a plan? But those who disbelieve - they are the object of a plan.","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"يُرِيدُونَ","fr":"(fais) ils vouloent","en":"(do) they intend","tr":"yurīdūna","isWaqf":false},{"position":3,"ar":"كَيْدًۭا ۖ","fr":"un comploter","en":"a plot","tr":"kaydan","isWaqf":false},{"position":4,"ar":"فَٱلَّذِينَ","fr":"Mais ceux qui","en":"But those who","tr":"fa-alladhīna","isWaqf":false},{"position":5,"ar":"كَفَرُوا۟","fr":"mécroire","en":"disbelieve","tr":"kafarū","isWaqf":false},{"position":6,"ar":"هُمُ","fr":"eux-mêmes","en":"themselves","tr":"humu","isWaqf":false},{"position":7,"ar":"ٱلْمَكِيدُونَ","fr":"(sont dans) le comploter","en":"(are in) the plot","tr":"l-makīdūna","isWaqf":false}]},{"ayah":43,"verseKey":"52:43","juz":27,"arabic":"أَمْ لَهُمْ إِلَـٰهٌ غَيْرُ ٱللَّهِ ۚ سُبْحَـٰنَ ٱللَّهِ عَمَّا يُشْرِكُونَ","fr":"Auraient-ils une divinité autre qu’Allah ? Gloire soit rendue à Allah, (Il est bien plus Haut) que tout ce qu’ils Lui associent !","en":"Or have they a deity other than Allāh? Exalted is Allāh above whatever they associate with Him.","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"لَهُمْ","fr":"pour eux","en":"for them","tr":"lahum","isWaqf":false},{"position":3,"ar":"إِلَـٰهٌ","fr":"un dieu","en":"a god","tr":"ilāhun","isWaqf":false},{"position":4,"ar":"غَيْرُ","fr":"autre que","en":"other than","tr":"ghayru","isWaqf":false},{"position":5,"ar":"ٱللَّهِ ۚ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":6,"ar":"سُبْحَـٰنَ","fr":"Gloire être","en":"Glory be","tr":"sub'ḥāna","isWaqf":false},{"position":7,"ar":"ٱللَّهِ","fr":"(à) Allah","en":"(to) Allah","tr":"l-lahi","isWaqf":false},{"position":8,"ar":"عَمَّا","fr":"de ce que","en":"from what","tr":"ʿammā","isWaqf":false},{"position":9,"ar":"يُشْرِكُونَ","fr":"ils associent (avec Lui)","en":"they associate (with Him)","tr":"yush'rikūna","isWaqf":false}]},{"ayah":44,"verseKey":"52:44","juz":27,"arabic":"وَإِن يَرَوْا۟ كِسْفًا مِّنَ ٱلسَّمَآءِ سَاقِطًا يَقُولُوا۟ سَحَابٌ مَّرْكُومٌ","fr":"Quand bien même ils verraient choir des pans du ciel, ils diraient : « Ce ne sont là que nuages amoncelés. »","en":"And if they were to see a fragment from the sky falling, they would say, \"[It is merely] clouds heaped up.\"","words":[{"position":1,"ar":"وَإِن","fr":"Et si","en":"And if","tr":"wa-in","isWaqf":false},{"position":2,"ar":"يَرَوْا۟","fr":"ils étaient à voir","en":"they were to see","tr":"yaraw","isWaqf":false},{"position":3,"ar":"كِسْفًۭا","fr":"une partie","en":"a portion","tr":"kis'fan","isWaqf":false},{"position":4,"ar":"مِّنَ","fr":"de","en":"from","tr":"mina","isWaqf":false},{"position":5,"ar":"ٱلسَّمَآءِ","fr":"le ciel","en":"the sky","tr":"l-samāi","isWaqf":false},{"position":6,"ar":"سَاقِطًۭا","fr":"tombant","en":"falling","tr":"sāqiṭan","isWaqf":false},{"position":7,"ar":"يَقُولُوا۟","fr":"ils va dis","en":"they will say","tr":"yaqūlū","isWaqf":false},{"position":8,"ar":"سَحَابٌۭ","fr":"Nuages","en":"Clouds","tr":"saḥābun","isWaqf":false},{"position":9,"ar":"مَّرْكُومٌۭ","fr":"heaped haut","en":"heaped up","tr":"markūmun","isWaqf":false}]},{"ayah":45,"verseKey":"52:45","juz":27,"arabic":"فَذَرْهُمْ حَتَّىٰ يُلَـٰقُوا۟ يَوْمَهُمُ ٱلَّذِى فِيهِ يُصْعَقُونَ","fr":"Laisse-les donc attendre leur jour, où ils seront foudroyés.","en":"So leave them until they meet their Day in which they will be struck insensible -","words":[{"position":1,"ar":"فَذَرْهُمْ","fr":"Donc quitter eux","en":"So leave them","tr":"fadharhum","isWaqf":false},{"position":2,"ar":"حَتَّىٰ","fr":"jusqu'à","en":"until","tr":"ḥattā","isWaqf":false},{"position":3,"ar":"يُلَـٰقُوا۟","fr":"ils rencontrent","en":"they meet","tr":"yulāqū","isWaqf":false},{"position":4,"ar":"يَوْمَهُمُ","fr":"leur Jour","en":"their Day","tr":"yawmahumu","isWaqf":false},{"position":5,"ar":"ٱلَّذِى","fr":"que","en":"which","tr":"alladhī","isWaqf":false},{"position":6,"ar":"فِيهِ","fr":"dans cela","en":"in it","tr":"fīhi","isWaqf":false},{"position":7,"ar":"يُصْعَقُونَ","fr":"ils va défaillir","en":"they will faint","tr":"yuṣ'ʿaqūna","isWaqf":false}]},{"ayah":46,"verseKey":"52:46","juz":27,"arabic":"يَوْمَ لَا يُغْنِى عَنْهُمْ كَيْدُهُمْ شَيْـًٔا وَلَا هُمْ يُنصَرُونَ","fr":"Le jour où leurs intrigues ne leur seront utiles en rien, et où ils n’auront aucun secours.","en":"The Day their plan will not avail them at all, nor will they be helped.","words":[{"position":1,"ar":"يَوْمَ","fr":"(Le) Jour","en":"(The) Day","tr":"yawma","isWaqf":false},{"position":2,"ar":"لَا","fr":"non","en":"not","tr":"lā","isWaqf":false},{"position":3,"ar":"يُغْنِى","fr":"sera utile","en":"will avail","tr":"yugh'nī","isWaqf":false},{"position":4,"ar":"عَنْهُمْ","fr":"à eux","en":"to them","tr":"ʿanhum","isWaqf":false},{"position":5,"ar":"كَيْدُهُمْ","fr":"leur complotant","en":"their plotting","tr":"kayduhum","isWaqf":false},{"position":6,"ar":"شَيْـًۭٔا","fr":"(en) quoi que ce soit","en":"(in) anything","tr":"shayan","isWaqf":false},{"position":7,"ar":"وَلَا","fr":"et non","en":"and not","tr":"walā","isWaqf":false},{"position":8,"ar":"هُمْ","fr":"ils","en":"they","tr":"hum","isWaqf":false},{"position":9,"ar":"يُنصَرُونَ","fr":"va être aida","en":"will be helped","tr":"yunṣarūna","isWaqf":false}]},{"ayah":47,"verseKey":"52:47","juz":27,"arabic":"وَإِنَّ لِلَّذِينَ ظَلَمُوا۟ عَذَابًا دُونَ ذَٰلِكَ وَلَـٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ","fr":"Ceux qui auront commis des injustices auront (à subir) un supplice avancé, mais la plupart d’entre eux ne le savent pas.","en":"And indeed, for those who have wronged is a punishment before that, but most of them do not know.","words":[{"position":1,"ar":"وَإِنَّ","fr":"Et certes","en":"And indeed","tr":"wa-inna","isWaqf":false},{"position":2,"ar":"لِلَّذِينَ","fr":"pour ceux qui","en":"for those who","tr":"lilladhīna","isWaqf":false},{"position":3,"ar":"ظَلَمُوا۟","fr":"fais tort","en":"do wrong","tr":"ẓalamū","isWaqf":false},{"position":4,"ar":"عَذَابًۭا","fr":"(est) un châtiment","en":"(is) a punishment","tr":"ʿadhāban","isWaqf":false},{"position":5,"ar":"دُونَ","fr":"avant","en":"before","tr":"dūna","isWaqf":false},{"position":6,"ar":"ذَٰلِكَ","fr":"que","en":"that","tr":"dhālika","isWaqf":false},{"position":7,"ar":"وَلَـٰكِنَّ","fr":"mais","en":"but","tr":"walākinna","isWaqf":false},{"position":8,"ar":"أَكْثَرَهُمْ","fr":"la plupart d'eux","en":"most of them","tr":"aktharahum","isWaqf":false},{"position":9,"ar":"لَا","fr":"(fais) non","en":"(do) not","tr":"lā","isWaqf":false},{"position":10,"ar":"يَعْلَمُونَ","fr":"savoir","en":"know","tr":"yaʿlamūna","isWaqf":false}]},{"ayah":48,"verseKey":"52:48","juz":27,"arabic":"وَٱصْبِرْ لِحُكْمِ رَبِّكَ فَإِنَّكَ بِأَعْيُنِنَا ۖ وَسَبِّحْ بِحَمْدِ رَبِّكَ حِينَ تَقُومُ","fr":"Prends donc en patience le Jugement de ton Seigneur ! Car Nous t’avons sous Nos Yeux. Rends gloire à ton Seigneur et célèbre Ses louanges en te levant.","en":"And be patient, [O Muḥammad], for the decision of your Lord, for indeed, you are in Our eyes [i.e., sight]. And exalt [Allāh] with praise of your Lord when you arise","words":[{"position":1,"ar":"وَٱصْبِرْ","fr":"Sois donc patient","en":"So be patient","tr":"wa-iṣ'bir","isWaqf":false},{"position":2,"ar":"لِحُكْمِ","fr":"pour (le) Ordre","en":"for (the) Command","tr":"liḥuk'mi","isWaqf":false},{"position":3,"ar":"رَبِّكَ","fr":"(de) votre Seigneur","en":"(of) your Lord","tr":"rabbika","isWaqf":false},{"position":4,"ar":"فَإِنَّكَ","fr":"pour certes, vous","en":"for indeed, you","tr":"fa-innaka","isWaqf":false},{"position":5,"ar":"بِأَعْيُنِنَا ۖ","fr":"(sont) dans Notre Yeux","en":"(are) in Our Eyes","tr":"bi-aʿyuninā","isWaqf":false},{"position":6,"ar":"وَسَبِّحْ","fr":"Et glorifier","en":"And glorify","tr":"wasabbiḥ","isWaqf":false},{"position":7,"ar":"بِحَمْدِ","fr":"(le) louange","en":"(the) praise","tr":"biḥamdi","isWaqf":false},{"position":8,"ar":"رَبِّكَ","fr":"(de) votre Seigneur","en":"(of) your Lord","tr":"rabbika","isWaqf":false},{"position":9,"ar":"حِينَ","fr":"quand","en":"when","tr":"ḥīna","isWaqf":false},{"position":10,"ar":"تَقُومُ","fr":"vous se lever","en":"you arise","tr":"taqūmu","isWaqf":false}]},{"ayah":49,"verseKey":"52:49","juz":27,"arabic":"وَمِنَ ٱلَّيْلِ فَسَبِّحْهُ وَإِدْبَـٰرَ ٱلنُّجُومِ","fr":"Et glorifie-Le durant une (bonne) partie de la nuit et quand déclinent les étoiles.","en":"And in a part of the night exalt Him and after [the setting of] the stars.","words":[{"position":1,"ar":"وَمِنَ","fr":"Et de","en":"And of","tr":"wamina","isWaqf":false},{"position":2,"ar":"ٱلَّيْلِ","fr":"la nuit","en":"the night","tr":"al-layli","isWaqf":false},{"position":3,"ar":"فَسَبِّحْهُ","fr":"glorifier Lui","en":"glorify Him","tr":"fasabbiḥ'hu","isWaqf":false},{"position":4,"ar":"وَإِدْبَـٰرَ","fr":"et après","en":"and after","tr":"wa-id'bāra","isWaqf":false},{"position":5,"ar":"ٱلنُّجُومِ","fr":"le étoiles","en":"the stars","tr":"l-nujūmi","isWaqf":false}]}]