r":"(à) notre Seigneur","en":"(to) our Lord","tr":"rabbinā","isWaqf":false},{"position":4,"ar":"إِنَّا","fr":"Certes, nous","en":"Indeed, we","tr":"innā","isWaqf":false},{"position":5,"ar":"كُنَّا","fr":"[nous] étaient","en":"[we] were","tr":"kunnā","isWaqf":false},{"position":6,"ar":"ظَـٰلِمِينَ","fr":"injustes","en":"wrongdoers","tr":"ẓālimīna","isWaqf":false}]},{"ayah":30,"verseKey":"68:30","juz":29,"arabic":"فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَلَـٰوَمُونَ","fr":"Puis ils se mirent à s’agonir de reproches mutuels.","en":"Then they approached one another, blaming each other.","words":[{"position":1,"ar":"فَأَقْبَلَ","fr":"Puis approcha","en":"Then approached","tr":"fa-aqbala","isWaqf":false},{"position":2,"ar":"بَعْضُهُمْ","fr":"certains d'eux","en":"some of them","tr":"baʿḍuhum","isWaqf":false},{"position":3,"ar":"عَلَىٰ","fr":"à","en":"to","tr":"ʿalā","isWaqf":false},{"position":4,"ar":"بَعْضٍۢ","fr":"d'autres","en":"others","tr":"baʿḍin","isWaqf":false},{"position":5,"ar":"يَتَلَـٰوَمُونَ","fr":"blaming chacun autre","en":"blaming each other","tr":"yatalāwamūna","isWaqf":false}]},{"ayah":31,"verseKey":"68:31","juz":29,"arabic":"قَالُوا۟ يَـٰوَيْلَنَآ إِنَّا كُنَّا طَـٰغِينَ","fr":"« Malheur à nous, dirent-ils, nous sommes allés à la démesure !","en":"They said, \"O woe to us; indeed we were transgressors.","words":[{"position":1,"ar":"قَالُوا۟","fr":"Ils dirent","en":"They said","tr":"qālū","isWaqf":false},{"position":2,"ar":"يَـٰوَيْلَنَآ","fr":"Ô malheur à nous","en":"O woe to us","tr":"yāwaylanā","isWaqf":false},{"position":3,"ar":"إِنَّا","fr":"Certes, nous","en":"Indeed, we","tr":"innā","isWaqf":false},{"position":4,"ar":"كُنَّا","fr":"[nous] étaient","en":"[we] were","tr":"kunnā","isWaqf":false},{"position":5,"ar":"طَـٰغِينَ","fr":"transgresseurs","en":"transgressors","tr":"ṭāghīna","isWaqf":false}]},{"ayah":32,"verseKey":"68:32","juz":29,"arabic":"عَسَىٰ رَبُّنَآ أَن يُبْدِلَنَا خَيْرًا مِّنْهَآ إِنَّآ إِلَىٰ رَبِّنَا رَٰغِبُونَ","fr":"Que notre Seigneur nous accorde en échange mieux que (ce jardin) ! Car nous ne voulons plus rien désormais que l’agrément de notre Seigneur ! »","en":"Perhaps our Lord will substitute for us [one] better than it. Indeed, we are toward our Lord desirous.\"","words":[{"position":1,"ar":"عَسَىٰ","fr":"Peut-être","en":"Perhaps","tr":"ʿasā","isWaqf":false},{"position":2,"ar":"رَبُّنَآ","fr":"notre Seigneur","en":"our Lord","tr":"rabbunā","isWaqf":false},{"position":3,"ar":"أَن","fr":"[que]","en":"[that]","tr":"an","isWaqf":false},{"position":4,"ar":"يُبْدِلَنَا","fr":"va remplacer pour nous","en":"will substitute for us","tr":"yub'dilanā","isWaqf":false},{"position":5,"ar":"خَيْرًۭا","fr":"un meilleur","en":"a better","tr":"khayran","isWaqf":false},{"position":6,"ar":"مِّنْهَآ","fr":"que cela","en":"than it","tr":"min'hā","isWaqf":false},{"position":7,"ar":"إِنَّآ","fr":"Certes, nous","en":"Indeed, we","tr":"innā","isWaqf":false},{"position":8,"ar":"إِلَىٰ","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":9,"ar":"رَبِّنَا","fr":"notre Seigneur","en":"our Lord","tr":"rabbinā","isWaqf":false},{"position":10,"ar":"رَٰغِبُونَ","fr":"se détourner dévotement","en":"turn devoutly","tr":"rāghibūna","isWaqf":false}]},{"ayah":33,"verseKey":"68:33","juz":29,"arabic":"كَذَٰلِكَ ٱلْعَذَابُ ۖ وَلَعَذَابُ ٱلْـَٔاخِرَةِ أَكْبَرُ ۚ لَوْ كَانُوا۟ يَعْلَمُونَ","fr":"C’est ainsi qu’est le supplice. Mais le supplice de l’autre monde est plus grand encore. Ah, si seulement ils pouvaient savoir !","en":"Such is the punishment [of this world]. And the punishment of the Hereafter is greater, if they only knew.","words":[{"position":1,"ar":"كَذَٰلِكَ","fr":"Tel","en":"Such","tr":"kadhālika","isWaqf":false},{"position":2,"ar":"ٱلْعَذَابُ ۖ","fr":"(est) le châtiment","en":"(is) the punishment","tr":"l-ʿadhābu","isWaqf":false},{"position":3,"ar":"وَلَعَذَابُ","fr":"Et assurément le châtiment","en":"And surely the punishment","tr":"walaʿadhābu","isWaqf":false},{"position":4,"ar":"ٱلْـَٔاخِرَةِ","f