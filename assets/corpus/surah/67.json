[{"ayah":1,"verseKey":"67:1","juz":29,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ تَبَـٰرَكَ ٱلَّذِى بِيَدِهِ ٱلْمُلْكُ وَهُوَ عَلَىٰ كُلِّ شَىْءٍ قَدِيرٌ","fr":"Béni soit Celui Qui détient en Sa Main la Royauté et Qui de Toute chose est Infiniment Capable.","en":"Blessed is He in whose hand is dominion, and He is over all things competent -","words":[{"position":1,"ar":"تَبَـٰرَكَ","fr":"Béni est","en":"Blessed is","tr":"tabāraka","isWaqf":false},{"position":2,"ar":"ٱلَّذِى","fr":"Il","en":"He","tr":"alladhī","isWaqf":false},{"position":3,"ar":"بِيَدِهِ","fr":"dans Dont Main","en":"in Whose Hand","tr":"biyadihi","isWaqf":false},{"position":4,"ar":"ٱلْمُلْكُ","fr":"(est) le Royaume","en":"(is) the Dominion","tr":"l-mul'ku","isWaqf":false},{"position":5,"ar":"وَهُوَ","fr":"et Il","en":"and He","tr":"wahuwa","isWaqf":false},{"position":6,"ar":"عَلَىٰ","fr":"(est) sur","en":"(is) over","tr":"ʿalā","isWaqf":false},{"position":7,"ar":"كُلِّ","fr":"chaque","en":"every","tr":"kulli","isWaqf":false},{"position":8,"ar":"شَىْءٍۢ","fr":"chose","en":"thing","tr":"shayin","isWaqf":false},{"position":9,"ar":"قَدِيرٌ","fr":"Tout-Puissant","en":"All-Powerful","tr":"qadīrun","isWaqf":false}]},{"ayah":2,"verseKey":"67:2","juz":29,"arabic":"ٱلَّذِى خَلَقَ ٱلْمَوْتَ وَٱلْحَيَوٰةَ لِيَبْلُوَكُمْ أَيُّكُمْ أَحْسَنُ عَمَلًا ۚ وَهُوَ ٱلْعَزِيزُ ٱلْغَفُورُ","fr":"Celui Qui a créé la mort et la vie pour voir, en vous éprouvant, qui de vous fait meilleure œuvre ; et c’est Lui le Tout-Puissant, l’Absoluteur.","en":"[He] who created death and life to test you [as to] which of you is best in deed - and He is the Exalted in Might, the Forgiving -","words":[{"position":1,"ar":"ٱلَّذِى","fr":"Celui qui","en":"The One Who","tr":"alladhī","isWaqf":false},{"position":2,"ar":"خَلَقَ","fr":"créé","en":"created","tr":"khalaqa","isWaqf":false},{"position":3,"ar":"ٱلْمَوْتَ","fr":"mort","en":"death","tr":"l-mawta","isWaqf":false},{"position":4,"ar":"وَٱلْحَيَوٰةَ","fr":"et vie","en":"and life","tr":"wal-ḥayata","isWaqf":false},{"position":5,"ar":"لِيَبْلُوَكُمْ","fr":"que Il peut tester vous","en":"that He may test you","tr":"liyabluwakum","isWaqf":false},{"position":6,"ar":"أَيُّكُمْ","fr":"que de vous","en":"which of you","tr":"ayyukum","isWaqf":false},{"position":7,"ar":"أَحْسَنُ","fr":"(est) le meilleur","en":"(is) best","tr":"aḥsanu","isWaqf":false},{"position":8,"ar":"عَمَلًۭا ۚ","fr":"(dans) action","en":"(in) deed","tr":"ʿamalan","isWaqf":false},{"position":9,"ar":"وَهُوَ","fr":"Et Il","en":"And He","tr":"wahuwa","isWaqf":false},{"position":10,"ar":"ٱلْعَزِيزُ","fr":"(est) le Tout-Puissant","en":"(is) the All-Mighty","tr":"l-ʿazīzu","isWaqf":false},{"position":11,"ar":"ٱلْغَفُورُ","fr":"le Pardonneur","en":"the Oft-Forgiving","tr":"l-ghafūru","isWaqf":false}]},{"ayah":3,"verseKey":"67:3","juz":29,"arabic":"ٱلَّذِى خَلَقَ سَبْعَ سَمَـٰوَٰتٍ طِبَاقًا ۖ مَّا تَرَىٰ فِى خَلْقِ ٱلرَّحْمَـٰنِ مِن تَفَـٰوُتٍ ۖ فَٱرْجِعِ ٱلْبَصَرَ هَلْ تَرَىٰ مِن فُطُورٍ","fr":"Celui Qui a créé sept cieux qui se superposent. Aucune irrégularité ne se perçoit dans la création du Tout Clément. Lève à nouveau les yeux, y vois-tu la moindre fêlure ?","en":"[And] who created seven heavens in layers. You do not see in the creation of the Most Merciful any inconsistency. So return [your] vision [to the sky]; do you see any breaks?","words":[{"position":1,"ar":"ٱلَّذِى","fr":"Celui qui","en":"The One Who","tr":"alladhī","isWaqf":false},{"position":2,"ar":"خَلَقَ","fr":"créé","en":"created","tr":"khalaqa","isWaqf":false},{"position":3,"ar":"سَبْعَ","fr":"sept","en":"seven","tr":"sabʿa","isWaqf":false},{"position":4,"ar":"سَمَـٰوَٰتٍۢ","fr":"cieux","en":"heavens","tr":"samāwātin","isWaqf":false},{"position":5,"ar":"طِبَاقًۭا ۖ","fr":"un au-dessus un autre","en":"one above another","tr":"ṭibāqan","isWaqf":false},{"position":6,"ar":"مَّا","fr":"Non","en":"Not","tr":"mā","isWaqf":false},{"position":7,"ar":"تَرَىٰ","fr":"vous voyez","en":"you see","tr":"tarā","isWaqf":false},{"position":8,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":9,"ar":"خَلْقِ","fr":"(le) création","en":"(the) creation","tr":"khalqi","isWaqf":false},{"position":10,"ar":"ٱلرَّحْمَـٰنِ","fr":"(de) le Tout-Miséricordieux","en":"(of) the Most Gracious","tr":"l-raḥmāni","isWaqf":false},{"position":11,"ar":"مِن","fr":"tout","en":"any","tr":"min","isWaqf":false},{"position":12,"ar":"تَفَـٰوُتٍۢ ۖ","fr":"faute","en":"fault","tr":"tafāwutin","isWaqf":false},{"position":13,"ar":"فَٱرْجِعِ","fr":"Donc retourner","en":"So return","tr":"fa-ir'jiʿi","isWaqf":false},{"position":14,"ar":"ٱلْبَصَرَ","fr":"le vision","en":"the vision","tr":"l-baṣara","isWaqf":false},{"position":15,"ar":"هَلْ","fr":"peut","en":"can","tr":"hal","isWaqf":false},{"position":16,"ar":"تَرَىٰ","fr":"vous voyez","en":"you see","tr":"tarā","isWaqf":false},{"position":17,"ar":"مِن","fr":"tout","en":"any","tr":"min","isWaqf":false},{"position":18,"ar":"فُطُورٍۢ","fr":"défaut","en":"flaw","tr":"fuṭūrin","isWaqf":false}]},{"ayah":4,"verseKey":"67:4","juz":29,"arabic":"ثُمَّ ٱرْجِعِ ٱلْبَصَرَ كَرَّتَيْنِ يَنقَلِبْ إِلَيْكَ ٱلْبَصَرُ خَاسِئًا وَهُوَ حَسِيرٌ","fr":"Puis reviens-y par deux fois du regard. Ton regard retournera vers toi humilié et impuissant.","en":"Then return [your] vision twice again. [Your] vision will return to you humbled while it is fatigued.","words":[{"position":1,"ar":"ثُمَّ","fr":"Puis","en":"Then","tr":"thumma","isWaqf":false},{"position":2,"ar":"ٱرْجِعِ","fr":"retourner","en":"return","tr":"ir'jiʿi","isWaqf":false},{"position":3,"ar":"ٱلْبَصَرَ","fr":"le vision","en":"the vision","tr":"l-baṣara","isWaqf":false},{"position":4,"ar":"كَرَّتَيْنِ","fr":"deux fois (encore)","en":"twice (again)","tr":"karratayni","isWaqf":false},{"position":5,"ar":"يَنقَلِبْ","fr":"Va retourner","en":"Will return","tr":"yanqalib","isWaqf":false},{"position":6,"ar":"إِلَيْكَ","fr":"à vous","en":"to you","tr":"ilayka","isWaqf":false},{"position":7,"ar":"ٱلْبَصَرُ","fr":"le vision","en":"the vision","tr":"l-baṣaru","isWaqf":false},{"position":8,"ar":"خَاسِئًۭا","fr":"humilié","en":"humbled","tr":"khāsi-an","isWaqf":false},{"position":9,"ar":"وَهُوَ","fr":"tandis que","en":"while it","tr":"wahuwa","isWaqf":false},{"position":10,"ar":"حَسِيرٌۭ","fr":"(est) fatigued","en":"(is) fatigued","tr":"ḥasīrun","isWaqf":false}]},{"ayah":5,"verseKey":"67:5","juz":29,"arabic":"وَلَقَدْ زَيَّنَّا ٱلسَّمَآءَ ٱلدُّنْيَا بِمَصَـٰبِيحَ وَجَعَلْنَـٰهَا رُجُومًا لِّلشَّيَـٰطِينِ ۖ وَأَعْتَدْنَا لَهُمْ عَذَابَ ٱلسَّعِيرِ","fr":"Nous avons orné de luminaires (flamboyants) le ciel le plus proche de ce bas monde. Nous en avons fait des météores pour lapider les démons. Et Nous leur avons préparé le supplice du Brasier.","en":"And We have certainly beautified the nearest heaven with lamps [i.e., stars] and have made [from] them what is thrown at the devils and have prepared for them the punishment of the Blaze.","words":[{"position":1,"ar":"وَلَقَدْ","fr":"Et assurément","en":"And certainly","tr":"walaqad","isWaqf":false},{"position":2,"ar":"زَيَّنَّا","fr":"Nous ont embelli","en":"We have beautified","tr":"zayyannā","isWaqf":false},{"position":3,"ar":"ٱلسَّمَآءَ","fr":"le ciel","en":"the heaven","tr":"l-samāa","isWaqf":false},{"position":4,"ar":"ٱلدُّنْيَا","fr":"le plus proche","en":"nearest","tr":"l-dun'yā","isWaqf":false},{"position":5,"ar":"بِمَصَـٰبِيحَ","fr":"avec lampes","en":"with lamps","tr":"bimaṣābīḥa","isWaqf":false},{"position":6,"ar":"وَجَعَلْنَـٰهَا","fr":"et Nous ont fait eux","en":"and We have made them","tr":"wajaʿalnāhā","isWaqf":false},{"position":7,"ar":"رُجُومًۭا","fr":"(comme) missiles","en":"(as) missiles","tr":"rujūman","isWaqf":false},{"position":8,"ar":"لِّلشَّيَـٰطِينِ ۖ","fr":"pour les diables","en":"for the devils","tr":"lilshayāṭīni","isWaqf":false},{"position":9,"ar":"وَأَعْتَدْنَا","fr":"et Nous ont préparé","en":"and We have prepared","tr":"wa-aʿtadnā","isWaqf":false},{"position":10,"ar":"لَهُمْ","fr":"pour eux","en":"for them","tr":"lahum","isWaqf":false},{"position":11,"ar":"عَذَابَ","fr":"châtiment","en":"punishment","tr":"ʿadhāba","isWaqf":false},{"position":12,"ar":"ٱلسَّعِيرِ","fr":"(de) le Brasier","en":"(of) the Blaze","tr":"l-saʿīri","isWaqf":false}]},{"ayah":6,"verseKey":"67:6","juz":29,"arabic":"وَلِلَّذِينَ كَفَرُوا۟ بِرَبِّهِمْ عَذَابُ جَهَنَّمَ ۖ وَبِئْسَ ٱلْمَصِيرُ","fr":"À ceux qui auront renié leur Seigneur, (il sera réservé) le supplice de la Géhenne, et quel affreux destin !","en":"And for those who disbelieved in their Lord is the punishment of Hell, and wretched is the destination.","words":[{"position":1,"ar":"وَلِلَّذِينَ","fr":"Et pour ceux qui","en":"And for those who","tr":"walilladhīna","isWaqf":false},{"position":2,"ar":"كَفَرُوا۟","fr":"a mécru","en":"disbelieved","tr":"kafarū","isWaqf":false},{"position":3,"ar":"بِرَبِّهِمْ","fr":"dans leur Seigneur","en":"in their Lord","tr":"birabbihim","isWaqf":false},{"position":4,"ar":"عَذَابُ","fr":"(est le) châtiment","en":"(is the) punishment","tr":"ʿadhābu","isWaqf":false},{"position":5,"ar":"جَهَنَّمَ ۖ","fr":"(de) l'Enfer","en":"(of) Hell","tr":"jahannama","isWaqf":false},{"position":6,"ar":"وَبِئْسَ","fr":"et misérable est","en":"and wretched is","tr":"wabi'sa","isWaqf":false},{"position":7,"ar":"ٱلْمَصِيرُ","fr":"le destination","en":"the destination","tr":"l-maṣīru","isWaqf":false}]},{"ayah":7,"verseKey":"67:7","juz":29,"arabic":"إِذَآ أُلْقُوا۟ فِيهَا سَمِعُوا۟ لَهَا شَهِيقًا وَهِىَ تَفُورُ","fr":"Quand ils y seront précipités, ils en percevront un râle et un bouillonnement.","en":"When they are thrown into it, they hear from it a [dreadful] inhaling while it boils up.","words":[{"position":1,"ar":"إِذَآ","fr":"Quand","en":"When","tr":"idhā","isWaqf":false},{"position":2,"ar":"أُلْقُوا۟","fr":"ils sont jeté","en":"they are thrown","tr":"ul'qū","isWaqf":false},{"position":3,"ar":"فِيهَا","fr":"en cela","en":"therein","tr":"fīhā","isWaqf":false},{"position":4,"ar":"سَمِعُوا۟","fr":"ils va entendre","en":"they will hear","tr":"samiʿū","isWaqf":false},{"position":5,"ar":"لَهَا","fr":"de cela","en":"from it","tr":"lahā","isWaqf":false},{"position":6,"ar":"شَهِيقًۭا","fr":"un inhaling","en":"an inhaling","tr":"shahīqan","isWaqf":false},{"position":7,"ar":"وَهِىَ","fr":"tandis que","en":"while it","tr":"wahiya","isWaqf":false},{"position":8,"ar":"تَفُورُ","fr":"boils haut","en":"boils up","tr":"tafūru","isWaqf":false}]},{"ayah":8,"verseKey":"67:8","juz":29,"arabic":"تَكَادُ تَمَيَّزُ مِنَ ٱلْغَيْظِ ۖ كُلَّمَآ أُلْقِىَ فِيهَا فَوْجٌ سَأَلَهُمْ خَزَنَتُهَآ أَلَمْ يَأْتِكُمْ نَذِيرٌ","fr":"(La Géhenne) sera sur le point d’exploser de rage. Chaque fois qu’on y jettera un contingent (de damnés) ses gardiens leur demanderont : « N’est-il pas venu vers vous quelqu’un pour vous mettre en garde ? »","en":"It almost bursts with rage. Every time a company is thrown into it, its keepers ask them, \"Did there not come to you a warner?\"","words":[{"position":1,"ar":"تَكَادُ","fr":"Cela presque","en":"It almost","tr":"takādu","isWaqf":false},{"position":2,"ar":"تَمَيَّزُ","fr":"éclate","en":"bursts","tr":"tamayyazu","isWaqf":false},{"position":3,"ar":"مِنَ","fr":"de","en":"from","tr":"mina","isWaqf":false},{"position":4,"ar":"ٱلْغَيْظِ ۖ","fr":"rage","en":"rage","tr":"l-ghayẓi","isWaqf":false},{"position":5,"ar":"كُلَّمَآ","fr":"Chaque fois","en":"Every time","tr":"kullamā","isWaqf":false},{"position":6,"ar":"أُلْقِىَ","fr":"est jeté","en":"is thrown","tr":"ul'qiya","isWaqf":false},{"position":7,"ar":"فِيهَا","fr":"en cela","en":"therein","tr":"fīhā","isWaqf":false},{"position":8,"ar":"فَوْجٌۭ","fr":"un groupe","en":"a group","tr":"fawjun","isWaqf":false},{"position":9,"ar":"سَأَلَهُمْ","fr":"(va) demander eux","en":"(will) ask them","tr":"sa-alahum","isWaqf":false},{"position":10,"ar":"خَزَنَتُهَآ","fr":"son gardiens","en":"its keepers","tr":"khazanatuhā","isWaqf":false},{"position":11,"ar":"أَلَمْ","fr":"N'a-t-il pas","en":"Did not","tr":"alam","isWaqf":false},{"position":12,"ar":"يَأْتِكُمْ","fr":"venir à toi","en":"come to you","tr":"yatikum","isWaqf":false},{"position":13,"ar":"نَذِيرٌۭ","fr":"un avertisseur","en":"a warner","tr":"nadhīrun","isWaqf":false}]},{"ayah":9,"verseKey":"67:9","juz":29,"arabic":"قَالُوا۟ بَلَىٰ قَدْ جَآءَنَا نَذِيرٌ فَكَذَّبْنَا وَقُلْنَا مَا نَزَّلَ ٱللَّهُ مِن شَىْءٍ إِنْ أَنتُمْ إِلَّا فِى ضَلَـٰلٍ كَبِيرٍ","fr":"« Si, répondront-ils, il nous est bien venu un Envoyé pour nous avertir, mais nous l’avons traité de menteur en disant : “Allah n’a rien révélé et vous êtes, (toi Muhammad et tes partisans) en plein égarement. ” »","en":"They will say, \"Yes, a warner had come to us, but we denied and said, 'Allāh has not sent down anything. You are not but in great error.'\"","words":[{"position":1,"ar":"قَالُوا۟","fr":"Ils diront","en":"They will say","tr":"qālū","isWaqf":false},{"position":2,"ar":"بَلَىٰ","fr":"Oui","en":"Yes","tr":"balā","isWaqf":false},{"position":3,"ar":"قَدْ","fr":"certes","en":"indeed","tr":"qad","isWaqf":false},{"position":4,"ar":"جَآءَنَا","fr":"vint à nous","en":"came to us","tr":"jāanā","isWaqf":false},{"position":5,"ar":"نَذِيرٌۭ","fr":"un avertisseur","en":"a warner","tr":"nadhīrun","isWaqf":false},{"position":6,"ar":"فَكَذَّبْنَا","fr":"mais nous nia","en":"but we denied","tr":"fakadhabnā","isWaqf":false},{"position":7,"ar":"وَقُلْنَا","fr":"et nous dit","en":"and we said","tr":"waqul'nā","isWaqf":false},{"position":8,"ar":"مَا","fr":"Non","en":"Not","tr":"mā","isWaqf":false},{"position":9,"ar":"نَزَّلَ","fr":"a envoyé bas","en":"has sent down","tr":"nazzala","isWaqf":false},{"position":10,"ar":"ٱللَّهُ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":11,"ar":"مِن","fr":"tout","en":"any","tr":"min","isWaqf":false},{"position":12,"ar":"شَىْءٍ","fr":"chose","en":"thing","tr":"shayin","isWaqf":false},{"position":13,"ar":"إِنْ","fr":"Non","en":"Not","tr":"in","isWaqf":false},{"position":14,"ar":"أَنتُمْ","fr":"vous (sont)","en":"you (are)","tr":"antum","isWaqf":false},{"position":15,"ar":"إِلَّا","fr":"mais","en":"but","tr":"illā","isWaqf":false},{"position":16,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":17,"ar":"ضَلَـٰلٍۢ","fr":"égarement","en":"error","tr":"ḍalālin","isWaqf":false},{"position":18,"ar":"كَبِيرٍۢ","fr":"grand","en":"great","tr":"kabīrin","isWaqf":false}]},{"ayah":10,"verseKey":"67:10","juz":29,"arabic":"وَقَالُوا۟ لَوْ كُنَّا نَسْمَعُ أَوْ نَعْقِلُ مَا كُنَّا فِىٓ أَصْحَـٰبِ ٱلسَّعِيرِ","fr":"Ils diront encore : « Si nous avions su écouter ou raisonner, nous n’aurions pas été parmi les hôtes du Brasier ! »","en":"And they will say, \"If only we had been listening or reasoning, we would not be among the companions of the Blaze.\"","words":[{"position":1,"ar":"وَقَالُوا۟","fr":"Et ils va dis","en":"And they will say","tr":"waqālū","isWaqf":false},{"position":2,"ar":"لَوْ","fr":"Si","en":"If","tr":"law","isWaqf":false},{"position":3,"ar":"كُنَّا","fr":"nous avait","en":"we had","tr":"kunnā","isWaqf":false},{"position":4,"ar":"نَسْمَعُ","fr":"écouta","en":"listened","tr":"nasmaʿu","isWaqf":false},{"position":5,"ar":"أَوْ","fr":"ou","en":"or","tr":"aw","isWaqf":false},{"position":6,"ar":"نَعْقِلُ","fr":"raisonna","en":"reasoned","tr":"naʿqilu","isWaqf":false},{"position":7,"ar":"مَا","fr":"non","en":"not","tr":"mā","isWaqf":false},{"position":8,"ar":"كُنَّا","fr":"nous (irait) ont été","en":"we (would) have been","tr":"kunnā","isWaqf":false},{"position":9,"ar":"فِىٓ","fr":"parmi","en":"among","tr":"fī","isWaqf":false},{"position":10,"ar":"أَصْحَـٰبِ","fr":"(le) compagnons","en":"(the) companions","tr":"aṣḥābi","isWaqf":false},{"position":11,"ar":"ٱلسَّعِيرِ","fr":"(de) le Brasier","en":"(of) the Blaze","tr":"l-saʿīri","isWaqf":false}]},{"ayah":11,"verseKey":"67:11","juz":29,"arabic":"فَٱعْتَرَفُوا۟ بِذَنۢبِهِمْ فَسُحْقًا لِّأَصْحَـٰبِ ٱلسَّعِيرِ","fr":"Ils auront alors reconnu leurs péchés. Que périssent donc les damnés du Brasier !","en":"And they will admit their sin, so [it is] alienation for the companions of the Blaze.","words":[{"position":1,"ar":"فَٱعْتَرَفُوا۟","fr":"Puis ils (va) avouer","en":"Then they (will) confess","tr":"fa-iʿ'tarafū","isWaqf":false},{"position":2,"ar":"بِذَنۢبِهِمْ","fr":"leur péchés","en":"their sins","tr":"bidhanbihim","isWaqf":false},{"position":3,"ar":"فَسُحْقًۭا","fr":"donc au loin avec","en":"so away with","tr":"fasuḥ'qan","isWaqf":false},{"position":4,"ar":"لِّأَصْحَـٰبِ","fr":"(le) compagnons","en":"(the) companions","tr":"li-aṣḥābi","isWaqf":false},{"position":5,"ar":"ٱلسَّعِيرِ","fr":"(de) le Brasier","en":"(of) the Blaze","tr":"l-saʿīri","isWaqf":false}]},{"ayah":12,"verseKey":"67:12","juz":29,"arabic":"إِنَّ ٱلَّذِينَ يَخْشَوْنَ رَبَّهُم بِٱلْغَيْبِ لَهُم مَّغْفِرَةٌ وَأَجْرٌ كَبِيرٌ","fr":"Ceux qui craignent leur Seigneur sans même Le voir mériteront le pardon et une immense récompense.","en":"Indeed, those who fear their Lord unseen will have forgiveness and great reward.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"يَخْشَوْنَ","fr":"craindre","en":"fear","tr":"yakhshawna","isWaqf":false},{"position":4,"ar":"رَبَّهُم","fr":"leur Seigneur","en":"their Lord","tr":"rabbahum","isWaqf":false},{"position":5,"ar":"بِٱلْغَيْبِ","fr":"invisible","en":"unseen","tr":"bil-ghaybi","isWaqf":false},{"position":6,"ar":"لَهُم","fr":"pour eux","en":"for them","tr":"lahum","isWaqf":false},{"position":7,"ar":"مَّغْفِرَةٌۭ","fr":"(est) pardon","en":"(is) forgiveness","tr":"maghfiratun","isWaqf":false},{"position":8,"ar":"وَأَجْرٌۭ","fr":"et une récompense","en":"and a reward","tr":"wa-ajrun","isWaqf":false},{"position":9,"ar":"كَبِيرٌۭ","fr":"grand","en":"great","tr":"kabīrun","isWaqf":false}]},{"ayah":13,"verseKey":"67:13","juz":29,"arabic":"وَأَسِرُّوا۟ قَوْلَكُمْ أَوِ ٱجْهَرُوا۟ بِهِۦٓ ۖ إِنَّهُۥ عَلِيمٌۢ بِذَاتِ ٱلصُّدُورِ","fr":"Que vous teniez secrets vos propos ou que vous les révéliez au grand jour, Il Sait parfaitement ce qui est au fond des cœurs.","en":"And conceal your speech or publicize it; indeed, He is Knowing of that within the breasts.","words":[{"position":1,"ar":"وَأَسِرُّوا۟","fr":"Et dissimuler","en":"And conceal","tr":"wa-asirrū","isWaqf":false},{"position":2,"ar":"قَوْلَكُمْ","fr":"votre parole","en":"your speech","tr":"qawlakum","isWaqf":false},{"position":3,"ar":"أَوِ","fr":"ou","en":"or","tr":"awi","isWaqf":false},{"position":4,"ar":"ٱجْهَرُوا۟","fr":"proclamer","en":"proclaim","tr":"ij'harū","isWaqf":false},{"position":5,"ar":"بِهِۦٓ ۖ","fr":"cela","en":"it","tr":"bihi","isWaqf":false},{"position":6,"ar":"إِنَّهُۥ","fr":"Certes, Il","en":"Indeed, He","tr":"innahu","isWaqf":false},{"position":7,"ar":"عَلِيمٌۢ","fr":"(est le) L'Omniscient","en":"(is the) All-Knower","tr":"ʿalīmun","isWaqf":false},{"position":8,"ar":"بِذَاتِ","fr":"de ce que (est dans)","en":"of what (is in)","tr":"bidhāti","isWaqf":false},{"position":9,"ar":"ٱلصُّدُورِ","fr":"le poitrines","en":"the breasts","tr":"l-ṣudūri","isWaqf":false}]},{"ayah":14,"verseKey":"67:14","juz":29,"arabic":"أَلَا يَعْلَمُ مَنْ خَلَقَ وَهُوَ ٱللَّطِيفُ ٱلْخَبِيرُ","fr":"Ne connaîtrait-Il pas ceux qu’Il a créés quand Il est le Subtil et le parfaitement Informé ?","en":"Does He who created not know, while He is the Subtle, the Aware?","words":[{"position":1,"ar":"أَلَا","fr":"Fait non","en":"Does not","tr":"alā","isWaqf":false},{"position":2,"ar":"يَعْلَمُ","fr":"savoir","en":"know","tr":"yaʿlamu","isWaqf":false},{"position":3,"ar":"مَنْ","fr":"(celui) Qui","en":"(the One) Who","tr":"man","isWaqf":false},{"position":4,"ar":"خَلَقَ","fr":"créé","en":"created","tr":"khalaqa","isWaqf":false},{"position":5,"ar":"وَهُوَ","fr":"Et Il","en":"And He","tr":"wahuwa","isWaqf":false},{"position":6,"ar":"ٱللَّطِيفُ","fr":"(est) le Subtil","en":"(is) the Subtle","tr":"l-laṭīfu","isWaqf":false},{"position":7,"ar":"ٱلْخَبِيرُ","fr":"le Parfaitement informeré","en":"the All-Aware","tr":"l-khabīru","isWaqf":false}]},{"ayah":15,"verseKey":"67:15","juz":29,"arabic":"هُوَ ٱلَّذِى جَعَلَ لَكُمُ ٱلْأَرْضَ ذَلُولًا فَٱمْشُوا۟ فِى مَنَاكِبِهَا وَكُلُوا۟ مِن رِّزْقِهِۦ ۖ وَإِلَيْهِ ٱلنُّشُورُ","fr":"C’est Lui Qui fit pour vous la terre si soumise. Parcourez-la donc par monts et par vaux ! Nourrissez-vous des biens qu’Il vous dispense. C’est vers Lui que se fera la Résurrection.","en":"It is He who made the earth tame for you - so walk among its slopes and eat of His provision - and to Him is the resurrection.","words":[{"position":1,"ar":"هُوَ","fr":"Il","en":"He","tr":"huwa","isWaqf":false},{"position":2,"ar":"ٱلَّذِى","fr":"(est) Celui qui","en":"(is) the One Who","tr":"alladhī","isWaqf":false},{"position":3,"ar":"جَعَلَ","fr":"fait","en":"made","tr":"jaʿala","isWaqf":false},{"position":4,"ar":"لَكُمُ","fr":"pour vous","en":"for you","tr":"lakumu","isWaqf":false},{"position":5,"ar":"ٱلْأَرْضَ","fr":"la terre","en":"the earth","tr":"l-arḍa","isWaqf":false},{"position":6,"ar":"ذَلُولًۭا","fr":"soumis","en":"subservient","tr":"dhalūlan","isWaqf":false},{"position":7,"ar":"فَٱمْشُوا۟","fr":"donc marcher","en":"so walk","tr":"fa-im'shū","isWaqf":false},{"position":8,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":9,"ar":"مَنَاكِبِهَا","fr":"(le) sentiers de cela","en":"(the) paths thereof","tr":"manākibihā","isWaqf":false},{"position":10,"ar":"وَكُلُوا۟","fr":"et manger","en":"and eat","tr":"wakulū","isWaqf":false},{"position":11,"ar":"مِن","fr":"de","en":"of","tr":"min","isWaqf":false},{"position":12,"ar":"رِّزْقِهِۦ ۖ","fr":"Son subsistance","en":"His provision","tr":"riz'qihi","isWaqf":false},{"position":13,"ar":"وَإِلَيْهِ","fr":"et à Lui","en":"and to Him","tr":"wa-ilayhi","isWaqf":false},{"position":14,"ar":"ٱلنُّشُورُ","fr":"(est) le Résurrection","en":"(is) the Resurrection","tr":"l-nushūru","isWaqf":false}]},{"ayah":16,"verseKey":"67:16","juz":29,"arabic":"ءَأَمِنتُم مَّن فِى ٱلسَّمَآءِ أَن يَخْسِفَ بِكُمُ ٱلْأَرْضَ فَإِذَا هِىَ تَمُورُ","fr":"Êtes-vous donc si sûrs que Celui Qui est au ciel ne fasse pas crouler la terre sous vos pieds et ne la fasse pas trembler ?","en":"Do you feel secure that He who is above would not cause the earth to swallow you and suddenly it would sway?","words":[{"position":1,"ar":"ءَأَمِنتُم","fr":"Est-ce que tu sentis en sécurité","en":"Do you feel secure","tr":"a-amintum","isWaqf":false},{"position":2,"ar":"مَّن","fr":"(de Lui) Qui","en":"(from Him) Who","tr":"man","isWaqf":false},{"position":3,"ar":"فِى","fr":"(est) en","en":"(is) in","tr":"fī","isWaqf":false},{"position":4,"ar":"ٱلسَّمَآءِ","fr":"le ciel","en":"the heaven","tr":"l-samāi","isWaqf":false},{"position":5,"ar":"أَن","fr":"non","en":"not","tr":"an","isWaqf":false},{"position":6,"ar":"يَخْسِفَ","fr":"Il va faire à swallow","en":"He will cause to swallow","tr":"yakhsifa","isWaqf":false},{"position":7,"ar":"بِكُمُ","fr":"vous","en":"you","tr":"bikumu","isWaqf":false},{"position":8,"ar":"ٱلْأَرْضَ","fr":"la terre","en":"the earth","tr":"l-arḍa","isWaqf":false},{"position":9,"ar":"فَإِذَا","fr":"quand","en":"when","tr":"fa-idhā","isWaqf":false},{"position":10,"ar":"هِىَ","fr":"cela","en":"it","tr":"hiya","isWaqf":false},{"position":11,"ar":"تَمُورُ","fr":"vacille","en":"sways","tr":"tamūru","isWaqf":false}]},{"ayah":17,"verseKey":"67:17","juz":29,"arabic":"أَمْ أَمِنتُم مَّن فِى ٱلسَّمَآءِ أَن يُرْسِلَ عَلَيْكُمْ حَاصِبًا ۖ فَسَتَعْلَمُونَ كَيْفَ نَذِيرِ","fr":"Êtes- vous donc, (encore une fois), si sûrs que Celui Qui est au ciel ne fasse pas pleuvoir sur vous un torrent de pierres ? Ainsi saurez-vous la vérité de Ma Menace.","en":"Or do you feel secure that He who is above would not send against you a storm of stones? Then you would know how [severe] was My warning.","words":[{"position":1,"ar":"أَمْ","fr":"Ou","en":"Or","tr":"am","isWaqf":false},{"position":2,"ar":"أَمِنتُم","fr":"fais vous sentissez en sécurité","en":"do you feel secure","tr":"amintum","isWaqf":false},{"position":3,"ar":"مَّن","fr":"(de Lui) Qui","en":"(from Him) Who","tr":"man","isWaqf":false},{"position":4,"ar":"فِى","fr":"(est) en","en":"(is) in","tr":"fī","isWaqf":false},{"position":5,"ar":"ٱلسَّمَآءِ","fr":"le ciel","en":"the heaven","tr":"l-samāi","isWaqf":false},{"position":6,"ar":"أَن","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":7,"ar":"يُرْسِلَ","fr":"Il va envoyer","en":"He will send","tr":"yur'sila","isWaqf":false},{"position":8,"ar":"عَلَيْكُمْ","fr":"contre vous","en":"against you","tr":"ʿalaykum","isWaqf":false},{"position":9,"ar":"حَاصِبًۭا ۖ","fr":"un tempête de pierres","en":"a storm of stones","tr":"ḥāṣiban","isWaqf":false},{"position":10,"ar":"فَسَتَعْلَمُونَ","fr":"Puis vous irait savoir","en":"Then you would know","tr":"fasataʿlamūna","isWaqf":false},{"position":11,"ar":"كَيْفَ","fr":"comment","en":"how","tr":"kayfa","isWaqf":false},{"position":12,"ar":"نَذِيرِ","fr":"(était) Mon avertissement","en":"(was) My warning","tr":"nadhīri","isWaqf":false}]},{"ayah":18,"verseKey":"67:18","juz":29,"arabic":"وَلَقَدْ كَذَّبَ ٱلَّذِينَ مِن قَبْلِهِمْ فَكَيْفَ كَانَ نَكِيرِ","fr":"Ceux qui les ont précédés avaient déjà crié au mensonge. Quelles ne furent mes représailles !","en":"And already had those before them denied, and how [terrible] was My reproach.","words":[{"position":1,"ar":"وَلَقَدْ","fr":"Et certes","en":"And indeed","tr":"walaqad","isWaqf":false},{"position":2,"ar":"كَذَّبَ","fr":"nia","en":"denied","tr":"kadhaba","isWaqf":false},{"position":3,"ar":"ٱلَّذِينَ","fr":"ceux","en":"those","tr":"alladhīna","isWaqf":false},{"position":4,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":5,"ar":"قَبْلِهِمْ","fr":"avant eux","en":"before them","tr":"qablihim","isWaqf":false},{"position":6,"ar":"فَكَيْفَ","fr":"et comment","en":"and how","tr":"fakayfa","isWaqf":false},{"position":7,"ar":"كَانَ","fr":"était","en":"was","tr":"kāna","isWaqf":false},{"position":8,"ar":"نَكِيرِ","fr":"Mon rejet","en":"My rejection","tr":"nakīri","isWaqf":false}]},{"ayah":19,"verseKey":"67:19","juz":29,"arabic":"أَوَلَمْ يَرَوْا۟ إِلَى ٱلطَّيْرِ فَوْقَهُمْ صَـٰٓفَّـٰتٍ وَيَقْبِضْنَ ۚ مَا يُمْسِكُهُنَّ إِلَّا ٱلرَّحْمَـٰنُ ۚ إِنَّهُۥ بِكُلِّ شَىْءٍۭ بَصِيرٌ","fr":"Ne voient-ils pas les oiseaux au-dessus d’eux, toutes ailes tour à tour déployées et pliées ? Nul ne les soutient (dans les airs) hormis le Tout Clément, Lui Qui est de Toute chose Lucide.","en":"Do they not see the birds above them with wings outspread and [sometimes] folded in? None holds them [aloft] except the Most Merciful. Indeed He is, of all things, Seeing.","words":[{"position":1,"ar":"أَوَلَمْ","fr":"Ne fais pas","en":"Do not","tr":"awalam","isWaqf":false},{"position":2,"ar":"يَرَوْا۟","fr":"ils voient","en":"they see","tr":"yaraw","isWaqf":false},{"position":3,"ar":"إِلَى","fr":"[à]","en":"[to]","tr":"ilā","isWaqf":false},{"position":4,"ar":"ٱلطَّيْرِ","fr":"le oiseaux","en":"the birds","tr":"l-ṭayri","isWaqf":false},{"position":5,"ar":"فَوْقَهُمْ","fr":"au-dessus d'eux","en":"above them","tr":"fawqahum","isWaqf":false},{"position":6,"ar":"صَـٰٓفَّـٰتٍۢ","fr":"répandant (leur ailes)","en":"spreading (their wings)","tr":"ṣāffātin","isWaqf":false},{"position":7,"ar":"وَيَقْبِضْنَ ۚ","fr":"et pliant","en":"and folding","tr":"wayaqbiḍ'na","isWaqf":false},{"position":8,"ar":"مَا","fr":"Non","en":"Not","tr":"mā","isWaqf":false},{"position":9,"ar":"يُمْسِكُهُنَّ","fr":"tient eux","en":"holds them","tr":"yum'sikuhunna","isWaqf":false},{"position":10,"ar":"إِلَّا","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":11,"ar":"ٱلرَّحْمَـٰنُ ۚ","fr":"le Tout-Miséricordieux","en":"the Most Gracious","tr":"l-raḥmānu","isWaqf":false},{"position":12,"ar":"إِنَّهُۥ","fr":"Certes, Il","en":"Indeed, He","tr":"innahu","isWaqf":false},{"position":13,"ar":"بِكُلِّ","fr":"(est) de chaque","en":"(is) of every","tr":"bikulli","isWaqf":false},{"position":14,"ar":"شَىْءٍۭ","fr":"chose","en":"thing","tr":"shayin","isWaqf":false},{"position":15,"ar":"بَصِيرٌ","fr":"Clairvoyant","en":"All-Seer","tr":"baṣīrun","isWaqf":false}]},{"ayah":20,"verseKey":"67:20","juz":29,"arabic":"أَمَّنْ هَـٰذَا ٱلَّذِى هُوَ جُندٌ لَّكُمْ يَنصُرُكُم مِّن دُونِ ٱلرَّحْمَـٰنِ ۚ إِنِ ٱلْكَـٰفِرُونَ إِلَّا فِى غُرُورٍ","fr":"Quel est donc celui qui serait pour vous (à lui seul) une armée et vous secourrait en dehors du Tout Clément ? Les mécréants sont vraiment en pleine illusion.","en":"Or who is it that could be an army for you to aid you other than the Most Merciful? The disbelievers are not but in delusion.","words":[{"position":1,"ar":"أَمَّنْ","fr":"Qui est","en":"Who is","tr":"amman","isWaqf":false},{"position":2,"ar":"هَـٰذَا","fr":"ceci","en":"this","tr":"hādhā","isWaqf":false},{"position":3,"ar":"ٱلَّذِى","fr":"l'un","en":"the one","tr":"alladhī","isWaqf":false},{"position":4,"ar":"هُوَ","fr":"il","en":"he","tr":"huwa","isWaqf":false},{"position":5,"ar":"جُندٌۭ","fr":"(est) un armée","en":"(is) an army","tr":"jundun","isWaqf":false},{"position":6,"ar":"لَّكُمْ","fr":"pour vous","en":"for you","tr":"lakum","isWaqf":false},{"position":7,"ar":"يَنصُرُكُم","fr":"à aider vous","en":"to help you","tr":"yanṣurukum","isWaqf":false},{"position":8,"ar":"مِّن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":9,"ar":"دُونِ","fr":"hormis","en":"besides","tr":"dūni","isWaqf":false},{"position":10,"ar":"ٱلرَّحْمَـٰنِ ۚ","fr":"le Tout-Miséricordieux","en":"the Most Gracious","tr":"l-raḥmāni","isWaqf":false},{"position":11,"ar":"إِنِ","fr":"Non","en":"Not","tr":"ini","isWaqf":false},{"position":12,"ar":"ٱلْكَـٰفِرُونَ","fr":"(sont) les mécréants","en":"(are) the disbelievers","tr":"l-kāfirūna","isWaqf":false},{"position":13,"ar":"إِلَّا","fr":"mais","en":"but","tr":"illā","isWaqf":false},{"position":14,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":15,"ar":"غُرُورٍ","fr":"illusion","en":"delusion","tr":"ghurūrin","isWaqf":false}]},{"ayah":21,"verseKey":"67:21","juz":29,"arabic":"أَمَّنْ هَـٰذَا ٱلَّذِى يَرْزُقُكُمْ إِنْ أَمْسَكَ رِزْقَهُۥ ۚ بَل لَّجُّوا۟ فِى عُتُوٍّ وَنُفُورٍ","fr":"Et quel est donc celui qui pourrait vous dispenser une subsistance si (Allah) cesse de vous dispenser la Sienne ? Pourtant (les mécréants) persistent dans leur arrogance et leur rébellion.","en":"Or who is it that could provide for you if He withheld His provision? But they have persisted in insolence and aversion.","words":[{"position":1,"ar":"أَمَّنْ","fr":"Qui est","en":"Who is","tr":"amman","isWaqf":false},{"position":2,"ar":"هَـٰذَا","fr":"ceci","en":"this","tr":"hādhā","isWaqf":false},{"position":3,"ar":"ٱلَّذِى","fr":"l'un","en":"the one","tr":"alladhī","isWaqf":false},{"position":4,"ar":"يَرْزُقُكُمْ","fr":"à pourvoir vous","en":"to provide you","tr":"yarzuqukum","isWaqf":false},{"position":5,"ar":"إِنْ","fr":"si","en":"if","tr":"in","isWaqf":false},{"position":6,"ar":"أَمْسَكَ","fr":"Il retint","en":"He withheld","tr":"amsaka","isWaqf":false},{"position":7,"ar":"رِزْقَهُۥ ۚ","fr":"Son subsistance","en":"His provision","tr":"riz'qahu","isWaqf":false},{"position":8,"ar":"بَل","fr":"Non","en":"Nay","tr":"bal","isWaqf":false},{"position":9,"ar":"لَّجُّوا۟","fr":"ils persistent","en":"they persist","tr":"lajjū","isWaqf":false},{"position":10,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":11,"ar":"عُتُوٍّۢ","fr":"orgueil","en":"pride","tr":"ʿutuwwin","isWaqf":false},{"position":12,"ar":"وَنُفُورٍ","fr":"et aversion","en":"and aversion","tr":"wanufūrin","isWaqf":false}]},{"ayah":22,"verseKey":"67:22","juz":29,"arabic":"أَفَمَن يَمْشِى مُكِبًّا عَلَىٰ وَجْهِهِۦٓ أَهْدَىٰٓ أَمَّن يَمْشِى سَوِيًّا عَلَىٰ صِرَٰطٍ مُّسْتَقِيمٍ","fr":"Lequel tiendrait la direction la plus juste, celui qui se traîne, le front à même le sol, ou celui qui marche tout droit sur un chemin droit ?","en":"Then is one who walks fallen on his face better guided or one who walks erect on a straight path?","words":[{"position":1,"ar":"أَفَمَن","fr":"Puis est il qui","en":"Then is he who","tr":"afaman","isWaqf":false},{"position":2,"ar":"يَمْش