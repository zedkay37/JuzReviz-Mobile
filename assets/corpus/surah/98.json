[{"ayah":1,"verseKey":"98:1","juz":30,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ لَمْ يَكُنِ ٱلَّذِينَ كَفَرُوا۟ مِنْ أَهْلِ ٱلْكِتَـٰبِ وَٱلْمُشْرِكِينَ مُنفَكِّينَ حَتَّىٰ تَأْتِيَهُمُ ٱلْبَيِّنَةُ","fr":"Les mécréants, parmi les gens du Livre et les associâtres, n’allaient pas renoncer (à leur impiété) avant que ne leur parvînt la preuve évidente :","en":"Those who disbelieved among the People of the Scripture and the polytheists were not to be parted [from misbelief] until there came to them clear evidence","words":[{"position":1,"ar":"لَمْ","fr":"Non","en":"Not","tr":"lam","isWaqf":false},{"position":2,"ar":"يَكُنِ","fr":"étaient","en":"were","tr":"yakuni","isWaqf":false},{"position":3,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":4,"ar":"كَفَرُوا۟","fr":"a mécru","en":"disbelieved","tr":"kafarū","isWaqf":false},{"position":5,"ar":"مِنْ","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":6,"ar":"أَهْلِ","fr":"(les) Gens","en":"(the) People","tr":"ahli","isWaqf":false},{"position":7,"ar":"ٱلْكِتَـٰبِ","fr":"de le Livre","en":"of the Book","tr":"l-kitābi","isWaqf":false},{"position":8,"ar":"وَٱلْمُشْرِكِينَ","fr":"et les polythéistes","en":"and the polytheists","tr":"wal-mush'rikīna","isWaqf":false},{"position":9,"ar":"مُنفَكِّينَ","fr":"à être abandonné","en":"to be abandoned","tr":"munfakkīna","isWaqf":false},{"position":10,"ar":"حَتَّىٰ","fr":"jusqu'à","en":"until","tr":"ḥattā","isWaqf":false},{"position":11,"ar":"تَأْتِيَهُمُ","fr":"(là) vient à eux","en":"(there) comes to them","tr":"tatiyahumu","isWaqf":false},{"position":12,"ar":"ٱلْبَيِّنَةُ","fr":"le clair preuve","en":"the clear evidence","tr":"l-bayinatu","isWaqf":false}]},{"ayah":2,"verseKey":"98:2","juz":30,"arabic":"رَسُولٌ مِّنَ ٱللَّهِ يَتْلُوا۟ صُحُفًا مُّطَهَّرَةً","fr":"un Messager d’Allah qui récite des Feuillets purifiés,","en":"A Messenger from Allāh, reciting purified scriptures","words":[{"position":1,"ar":"رَسُولٌۭ","fr":"Un Messager","en":"A Messenger","tr":"rasūlun","isWaqf":false},{"position":2,"ar":"مِّنَ","fr":"de","en":"from","tr":"mina","isWaqf":false},{"position":3,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":4,"ar":"يَتْلُوا۟","fr":"récitant","en":"reciting","tr":"yatlū","isWaqf":false},{"position":5,"ar":"صُحُفًۭا","fr":"feuillets","en":"pages","tr":"ṣuḥufan","isWaqf":false},{"position":6,"ar":"مُّطَهَّرَةًۭ","fr":"purifié","en":"purified","tr":"muṭahharatan","isWaqf":false}]},{"ayah":3,"verseKey":"98:3","juz":30,"arabic":"فِيهَا كُتُبٌ قَيِّمَةٌ","fr":"dans lesquels se trouvent des Écritures parfaitement justes.","en":"Within which are correct writings [i.e., rulings and laws].","words":[{"position":1,"ar":"فِيهَا","fr":"Où","en":"Wherein","tr":"fīhā","isWaqf":false},{"position":2,"ar":"كُتُبٌۭ","fr":"(sont) writings","en":"(are) writings","tr":"kutubun","isWaqf":false},{"position":3,"ar":"قَيِّمَةٌۭ","fr":"correct","en":"correct","tr":"qayyimatun","isWaqf":false}]},{"ayah":4,"verseKey":"98:4","juz":30,"arabic":"وَمَا تَفَرَّقَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَـٰبَ إِلَّا مِنۢ بَعْدِ مَا جَآءَتْهُمُ ٱلْبَيِّنَةُ","fr":"Ceux à qui le Livre a été donné ne se sont divisés qu’après avoir reçu la preuve évidente.","en":"Nor did those who were given the Scripture become divided until after there had come to them clear evidence.","words":[{"position":1,"ar":"وَمَا","fr":"Et non","en":"And not","tr":"wamā","isWaqf":false},{"position":2,"ar":"تَفَرَّقَ","fr":"devint divisa","en":"became divided","tr":"tafarraqa","isWaqf":false},{"position":3,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":4,"ar":"أُوتُوا۟","fr":"ont été donnés","en":"were given","tr":"ūtū","isWaqf":false},{"position":5,"ar":"ٱلْكِتَـٰبَ","fr":"le Livre","en":"the Book","tr":"l-kitāba","isWaqf":false},{"position":6,"ar":"إِلَّا","fr":"jusqu'à","en":"until","tr":"illā","isWaqf":false},{"position":7,"ar":"مِنۢ","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":8,"ar":"بَعْدِ","fr":"après","en":"after","tr":"baʿdi","isWaqf":false},{"position":9,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":10,"ar":"جَآءَتْهُمُ","fr":"vint (à) eux","en":"came (to) them","tr":"jāathumu","isWaqf":false},{"position":11,"ar":"ٱلْبَيِّنَةُ","fr":"(de) le clair preuve","en":"(of) the clear evidence","tr":"l-bayinatu","isWaqf":false}]},{"ayah":5,"verseKey":"98:5","juz":30,"arabic":"وَمَآ أُمِرُوٓا۟ إِلَّا لِيَعْبُدُوا۟ ٱللَّهَ مُخْلِصِينَ لَهُ ٱلدِّينَ حُنَفَآءَ وَيُقِيمُوا۟ ٱلصَّلَوٰةَ وَيُؤْتُوا۟ ٱلزَّكَوٰةَ ۚ وَذَٰلِكَ دِينُ ٱلْقَيِّمَةِ","fr":"Il ne leur a été ordonné que d’adorer Allah en Lui vouant un culte sincère, d’accomplir la Çalât et de s’acquitter de la Zakât. Telle est la religion juste.","en":"And they were not commanded except to worship Allāh, [being] sincere to Him in religion, inclining to truth, and to establish prayer and to give zakāh. And that is the correct religion.","words":[{"position":1,"ar":"وَمَآ","fr":"Et non","en":"And not","tr":"wamā","isWaqf":false},{"position":2,"ar":"أُمِرُوٓا۟","fr":"ils étaient ordonna","en":"they were commanded","tr":"umirū","isWaqf":false},{"position":3,"ar":"إِلَّا","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":4,"ar":"لِيَعْبُدُوا۟","fr":"à adorer","en":"to worship","tr":"liyaʿbudū","isWaqf":false},{"position":5,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":6,"ar":"مُخْلِصِينَ","fr":"(étant) sincère","en":"(being) sincere","tr":"mukh'liṣīna","isWaqf":false},{"position":7,"ar":"لَهُ","fr":"à Lui","en":"to Him","tr":"lahu","isWaqf":false},{"position":8,"ar":"ٱلدِّينَ","fr":"(dans) la religion","en":"(in) the religion","tr":"l-dīna","isWaqf":false},{"position":9,"ar":"حُنَفَآءَ","fr":"droit","en":"upright","tr":"ḥunafāa","isWaqf":false},{"position":10,"ar":"وَيُقِيمُوا۟","fr":"et à établir","en":"and to establish","tr":"wayuqīmū","isWaqf":false},{"position":11,"ar":"ٱلصَّلَوٰةَ","fr":"la prière","en":"the prayer","tr":"l-ṣalata","isWaqf":false},{"position":12,"ar":"وَيُؤْتُوا۟","fr":"et à donner","en":"and to give","tr":"wayu'tū","isWaqf":false},{"position":13,"ar":"ٱلزَّكَوٰةَ ۚ","fr":"la zakat","en":"the zakah","tr":"l-zakata","isWaqf":false},{"position":14,"ar":"وَذَٰلِكَ","fr":"Et que","en":"And that","tr":"wadhālika","isWaqf":false},{"position":15,"ar":"دِينُ","fr":"(est le) religion","en":"(is the) religion","tr":"dīnu","isWaqf":false},{"position":16,"ar":"ٱلْقَيِّمَةِ","fr":"le correct","en":"the correct","tr":"l-qayimati","isWaqf":false}]},{"ayah":6,"verseKey":"98:6","juz":30,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ مِنْ أَهْلِ ٱلْكِتَـٰبِ وَٱلْمُشْرِكِينَ فِى نَارِ جَهَنَّمَ خَـٰلِدِينَ فِيهَآ ۚ أُو۟لَـٰٓئِكَ هُمْ شَرُّ ٱلْبَرِيَّةِ","fr":"Ceux qui ont mécru, parmi les gens du Livre et les associâtres, seront livrés au feu de la Géhenne, où ils demeureront pour l’éternité. Car ce sont les pires des créatures.","en":"Indeed, they who disbelieved among the People of the Scripture and the polytheists will be in the fire of Hell, abiding eternally therein. Those are the worst of creatures.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"كَفَرُوا۟","fr":"mécroire","en":"disbelieve","tr":"kafarū","isWaqf":false},{"position":4,"ar":"مِنْ","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":5,"ar":"أَهْلِ","fr":"(les) Gens","en":"(the) People","tr":"ahli","isWaqf":false},{"position":6,"ar":"ٱلْكِتَـٰبِ","fr":"(du) Livre","en":"(of) the Book","tr":"l-kitābi","isWaqf":false},{"position":7,"ar":"وَٱلْمُشْرِكِينَ","fr":"et les polythéistes","en":"and the polytheists","tr":"wal-mush'rikīna","isWaqf":false},{"position":8,"ar":"فِى","fr":"(sera) dans","en":"(will be) in","tr":"fī","isWaqf":false},{"position":9,"ar":"نَارِ","fr":"(le) Feu","en":"(the) Fire","tr":"nāri","isWaqf":false},{"position":10,"ar":"جَهَنَّمَ","fr":"(de) l'Enfer","en":"(of) Hell","tr":"jahannama","isWaqf":false},{"position":11,"ar":"خَـٰلِدِينَ","fr":"demeurant éternellement","en":"abiding eternally","tr":"khālidīna","isWaqf":false},{"position":12,"ar":"فِيهَآ ۚ","fr":"en cela","en":"therein","tr":"fīhā","isWaqf":false},{"position":13,"ar":"أُو۟لَـٰٓئِكَ","fr":"Ceux","en":"Those","tr":"ulāika","isWaqf":false},{"position":14,"ar":"هُمْ","fr":"ils","en":"they","tr":"hum","isWaqf":false},{"position":15,"ar":"شَرُّ","fr":"(sont le) le pire","en":"(are the) worst","tr":"sharru","isWaqf":false},{"position":16,"ar":"ٱلْبَرِيَّةِ","fr":"(de) le créatures","en":"(of) the creatures","tr":"l-bariyati","isWaqf":false}]},{"ayah":7,"verseKey":"98:7","juz":30,"arabic":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ أُو۟لَـٰٓئِكَ هُمْ خَيْرُ ٱلْبَرِيَّةِ","fr":"Ceux qui ont cru et accompli les bonnes œuvres, ceux là sont les meilleures de toutes les créatures.","en":"Indeed, they who have believed and done righteous deeds - those are the best of creatures.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"croire","en":"believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"وَعَمِلُوا۟","fr":"et faire","en":"and do","tr":"waʿamilū","isWaqf":false},{"position":5,"ar":"ٱلصَّـٰلِحَـٰتِ","fr":"bonnes œuvres","en":"righteous deeds","tr":"l-ṣāliḥāti","isWaqf":false},{"position":6,"ar":"أُو۟لَـٰٓئِكَ","fr":"ceux","en":"those","tr":"ulāika","isWaqf":false},{"position":7,"ar":"هُمْ","fr":"ils","en":"they","tr":"hum","isWaqf":false},{"position":8,"ar":"خَيْرُ","fr":"(sont le) le meilleur","en":"(are the) best","tr":"khayru","isWaqf":false},{"position":9,"ar":"ٱلْبَرِيَّةِ","fr":"(de) le créatures","en":"(of) the creatures","tr":"l-bariyati","isWaqf":false}]},{"ayah":8,"verseKey":"98:8","juz":30,"arabic":"جَزَآؤُهُمْ عِندَ رَبِّهِمْ جَنَّـٰتُ عَدْنٍ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَـٰرُ خَـٰلِدِينَ فِيهَآ أَبَدًا ۖ رَّضِىَ ٱللَّهُ عَنْهُمْ وَرَضُوا۟ عَنْهُ ۚ ذَٰلِكَ لِمَنْ خَشِىَ رَبَّهُۥ","fr":"Leur récompense, auprès de leur Seigneur, sera les Jardins d’Éden sous lesquels coulent les rivières, où ils séjourneront à tout jamais. Allah sera satisfait d’eux, et eux seront satisfaits de Lui. Voilà (ce qui attend) celui qui craint son Seigneur.","en":"Their reward with their Lord will be gardens of perpetual residence beneath which rivers flow, wherein they will abide forever, Allāh being pleased with them and they with Him. That is for whoever has feared his Lord.","words":[{"position":1,"ar":"جَزَآؤُهُمْ","fr":"Leur récompense","en":"Their reward","tr":"jazāuhum","isWaqf":false},{"position":2,"ar":"عِندَ","fr":"(est) avec","en":"(is) with","tr":"ʿinda","isWaqf":false},{"position":3,"ar":"رَبِّهِمْ","fr":"leur Seigneur","en":"their Lord","tr":"rabbihim","isWaqf":false},{"position":4,"ar":"جَنَّـٰتُ","fr":"Jardins","en":"Gardens","tr":"jannātu","isWaqf":false},{"position":5,"ar":"عَدْنٍۢ","fr":"(de) Éternité","en":"(of) Eternity","tr":"ʿadnin","isWaqf":false},{"position":6,"ar":"تَجْرِى","fr":"couler","en":"flow","tr":"tajrī","isWaqf":false},{"position":7,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":8,"ar":"تَحْتِهَا","fr":"en dessous d'eux","en":"underneath them","tr":"taḥtihā","isWaqf":false},{"position":9,"ar":"ٱلْأَنْهَـٰرُ","fr":"les rivières","en":"the rivers","tr":"l-anhāru","isWaqf":false},{"position":10,"ar":"خَـٰلِدِينَ","fr":"va demeurer","en":"will abide","tr":"khālidīna","isWaqf":false},{"position":11,"ar":"فِيهَآ","fr":"en cela","en":"therein","tr":"fīhā","isWaqf":false},{"position":12,"ar":"أَبَدًۭا ۖ","fr":"pour toujours","en":"forever","tr":"abadan","isWaqf":false},{"position":13,"ar":"رَّضِىَ","fr":"(va être) satisfait","en":"(will be) pleased","tr":"raḍiya","isWaqf":false},{"position":14,"ar":"ٱللَّهُ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":15,"ar":"عَنْهُمْ","fr":"avec eux","en":"with them","tr":"ʿanhum","isWaqf":false},{"position":16,"ar":"وَرَضُوا۟","fr":"et ils (va être) satisfait","en":"and they (will be) pleased","tr":"waraḍū","isWaqf":false},{"position":17,"ar":"عَنْهُ ۚ","fr":"avec Lui","en":"with Him","tr":"ʿanhu","isWaqf":false},{"position":18,"ar":"ذَٰلِكَ","fr":"Cela","en":"That","tr":"dhālika","isWaqf":false},{"position":19,"ar":"لِمَنْ","fr":"(est) pour quiconque","en":"(is) for whoever","tr":"liman","isWaqf":false},{"position":20,"ar":"خَشِىَ","fr":"craignit","en":"feared","tr":"khashiya","isWaqf":false},{"position":21,"ar":"رَبَّهُۥ","fr":"son Seigneur","en":"his Lord","tr":"rabbahu","isWaqf":false}]}]