[{"ayah":1,"verseKey":"49:1","juz":26,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تُقَدِّمُوا۟ بَيْنَ يَدَىِ ٱللَّهِ وَرَسُولِهِۦ ۖ وَٱتَّقُوا۟ ٱللَّهَ ۚ إِنَّ ٱللَّهَ سَمِيعٌ عَلِيمٌ","fr":"Ô vous qui avez cru ! Gardez-vous de précéder (les décisions) d’Allah et de Son Messager ! Craignez Allah, car Allah Entend et Sait Tout.","en":"O you who have believed, do not put [yourselves] before Allāh and His Messenger but fear Allāh. Indeed, Allāh is Hearing and Knowing.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô vous qui croient","en":"O you who believe","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"Ô vous qui croient","en":"O you who believe","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"Ô vous qui croient","en":"O you who believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"لَا","fr":"(Ne) fais pas","en":"(Do) not","tr":"lā","isWaqf":false},{"position":5,"ar":"تُقَدِّمُوا۟","fr":"mettre (vous-mêmes) en avant","en":"put (yourselves) forward","tr":"tuqaddimū","isWaqf":false},{"position":6,"ar":"بَيْنَ","fr":"avant Allah","en":"before Allah","tr":"bayna","isWaqf":false},{"position":7,"ar":"يَدَىِ","fr":"avant Allah","en":"before Allah","tr":"yadayi","isWaqf":false},{"position":8,"ar":"ٱللَّهِ","fr":"avant Allah","en":"before Allah","tr":"l-lahi","isWaqf":false},{"position":9,"ar":"وَرَسُولِهِۦ ۖ","fr":"et Son Messager","en":"and His Messenger","tr":"warasūlihi","isWaqf":false},{"position":10,"ar":"وَٱتَّقُوا۟","fr":"et craindre Allah","en":"and fear Allah","tr":"wa-ittaqū","isWaqf":false},{"position":11,"ar":"ٱللَّهَ ۚ","fr":"et craindre Allah","en":"and fear Allah","tr":"l-laha","isWaqf":false},{"position":12,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":13,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":14,"ar":"سَمِيعٌ","fr":"(est) Audient","en":"(is) All-Hearer","tr":"samīʿun","isWaqf":false},{"position":15,"ar":"عَلِيمٌۭ","fr":"Omniscient","en":"All-Knower","tr":"ʿalīmun","isWaqf":false}]},{"ayah":2,"verseKey":"49:2","juz":26,"arabic":"يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تَرْفَعُوٓا۟ أَصْوَٰتَكُمْ فَوْقَ صَوْتِ ٱلنَّبِىِّ وَلَا تَجْهَرُوا۟ لَهُۥ بِٱلْقَوْلِ كَجَهْرِ بَعْضِكُمْ لِبَعْضٍ أَن تَحْبَطَ أَعْمَـٰلُكُمْ وَأَنتُمْ لَا تَشْعُرُونَ","fr":"Ô vous qui avez cru ! N’élevez pas la voix au-dessus de celle du Prophète, ni ne haussez le ton en lui adressant la parole, comme vous le faites vous-mêmes les uns avec les autres. Ou alors vos œuvres deviendraient vaines sans que vous ne puissiez le sentir.","en":"O you who have believed, do not raise your voices above the voice of the Prophet or be loud to him in speech like the loudness of some of you to others, lest your deeds become worthless while you perceive not.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô vous qui croient","en":"O you who believe","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"Ô vous qui croient","en":"O you who believe","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"Ô vous qui croient","en":"O you who believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"لَا","fr":"(Ne) fais pas","en":"(Do) not","tr":"lā","isWaqf":false},{"position":5,"ar":"تَرْفَعُوٓا۟","fr":"élever","en":"raise","tr":"tarfaʿū","isWaqf":false},{"position":6,"ar":"أَصْوَٰتَكُمْ","fr":"votre voix","en":"your voices","tr":"aṣwātakum","isWaqf":false},{"position":7,"ar":"فَوْقَ","fr":"au-dessus de","en":"above","tr":"fawqa","isWaqf":false},{"position":8,"ar":"صَوْتِ","fr":"(le) voix","en":"(the) voice","tr":"ṣawti","isWaqf":false},{"position":9,"ar":"ٱلنَّبِىِّ","fr":"(de) le Prophète","en":"(of) the Prophet","tr":"l-nabiyi","isWaqf":false},{"position":10,"ar":"وَلَا","fr":"et (fais) non","en":"and (do) not","tr":"walā","isWaqf":false},{"position":11,"ar":"تَجْهَرُوا۟","fr":"être fort","en":"be loud","tr":"tajharū","isWaqf":false},{"position":12,"ar":"لَهُۥ","fr":"à lui","en":"to him","tr":"lahu","isWaqf":false},{"position":13,"ar":"بِٱلْقَوْلِ","fr":"dans parole","en":"in speech","tr":"bil-qawli","isWaqf":false},{"position":14,"ar":"كَجَهْرِ","fr":"comme (le) vacarme","en":"like (the) loudness","tr":"kajahri","isWaqf":false},{"position":15,"ar":"بَعْضِكُمْ","fr":"(de) certains d'entre vous","en":"(of) some of you","tr":"baʿḍikum","isWaqf":false},{"position":16,"ar":"لِبَعْضٍ","fr":"à d'autres","en":"to others","tr":"libaʿḍin","isWaqf":false},{"position":17,"ar":"أَن","fr":"de peur que","en":"lest","tr":"an","isWaqf":false},{"position":18,"ar":"تَحْبَطَ","fr":"devenir sans valeur","en":"become worthless","tr":"taḥbaṭa","isWaqf":false},{"position":19,"ar":"أَعْمَـٰلُكُمْ","fr":"votre actions","en":"your deeds","tr":"aʿmālukum","isWaqf":false},{"position":20,"ar":"وَأَنتُمْ","fr":"tandis que vous","en":"while you","tr":"wa-antum","isWaqf":false},{"position":21,"ar":"لَا","fr":"(fais) non","en":"(do) not","tr":"lā","isWaqf":false},{"position":22,"ar":"تَشْعُرُونَ","fr":"percevoir","en":"perceive","tr":"tashʿurūna","isWaqf":false}]},{"ayah":3,"verseKey":"49:3","juz":26,"arabic":"إِنَّ ٱلَّذِينَ يَغُضُّونَ أَصْوَٰتَهُمْ عِندَ رَسُولِ ٱللَّهِ أُو۟لَـٰٓئِكَ ٱلَّذِينَ ٱمْتَحَنَ ٱللَّهُ قُلُوبَهُمْ لِلتَّقْوَىٰ ۚ لَهُم مَّغْفِرَةٌ وَأَجْرٌ عَظِيمٌ","fr":"Ceux qui baissent la voix auprès du Messager d’Allah, sont ceux dont Allah a éprouvé les cœurs. Ils auront le pardon et une immense récompense.","en":"Indeed, those who lower their voices before the Messenger of Allāh - they are the ones whose hearts Allāh has tested for righteousness. For them is forgiveness and great reward.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"يَغُضُّونَ","fr":"plus bas","en":"lower","tr":"yaghuḍḍūna","isWaqf":false},{"position":4,"ar":"أَصْوَٰتَهُمْ","fr":"leur voix","en":"their voices","tr":"aṣwātahum","isWaqf":false},{"position":5,"ar":"عِندَ","fr":"(dans) présence","en":"(in) presence","tr":"ʿinda","isWaqf":false},{"position":6,"ar":"رَسُولِ","fr":"(du) Messager de Allah","en":"(of the) Messenger of Allah","tr":"rasūli","isWaqf":false},{"position":7,"ar":"ٱللَّهِ","fr":"(du) Messager de Allah","en":"(of the) Messenger of Allah","tr":"l-lahi","isWaqf":false},{"position":8,"ar":"أُو۟لَـٰٓئِكَ","fr":"ceux","en":"those","tr":"ulāika","isWaqf":false},{"position":9,"ar":"ٱلَّذِينَ","fr":"(sont) le ceux","en":"(are) the ones","tr":"alladhīna","isWaqf":false},{"position":10,"ar":"ٱمْتَحَنَ","fr":"Allah a éprouva","en":"Allah has tested","tr":"im'taḥana","isWaqf":false},{"position":11,"ar":"ٱللَّهُ","fr":"Allah a éprouva","en":"Allah has tested","tr":"l-lahu","isWaqf":false},{"position":12,"ar":"قُلُوبَهُمْ","fr":"leurs cœurs","en":"their hearts","tr":"qulūbahum","isWaqf":false},{"position":13,"ar":"لِلتَّقْوَىٰ ۚ","fr":"pour vertu","en":"for righteousness","tr":"lilttaqwā","isWaqf":false},{"position":14,"ar":"لَهُم","fr":"Pour eux","en":"For them","tr":"lahum","isWaqf":false},{"position":15,"ar":"مَّغْفِرَةٌۭ","fr":"(est) pardon","en":"(is) forgiveness","tr":"maghfiratun","isWaqf":false},{"position":16,"ar":"وَأَجْرٌ","fr":"et une récompense","en":"and a reward","tr":"wa-ajrun","isWaqf":false},{"position":17,"ar":"عَظِيمٌ","fr":"grand","en":"great","tr":"ʿaẓīmun","isWaqf":false}]},{"ayah":4,"verseKey":"49:4","juz":26,"arabic":"إِنَّ ٱلَّذِينَ يُنَادُونَكَ مِن وَرَآءِ ٱلْحُجُرَٰتِ أَكْثَرُهُمْ لَا يَعْقِلُونَ","fr":"Ceux qui t’interpellent de l’extérieur de (tes) appartements, pour la plupart, ne raisonnent point.","en":"Indeed, those who call you, [O Muḥammad], from behind the chambers - most of them do not use reason.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"يُنَادُونَكَ","fr":"appeler vous","en":"call you","tr":"yunādūnaka","isWaqf":false},{"position":4,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":5,"ar":"وَرَآءِ","fr":"derrière","en":"behind","tr":"warāi","isWaqf":false},{"position":6,"ar":"ٱلْحُجُرَٰتِ","fr":"le privé chambres","en":"the private chambers","tr":"l-ḥujurāti","isWaqf":false},{"position":7,"ar":"أَكْثَرُهُمْ","fr":"la plupart d'eux","en":"most of them","tr":"aktharuhum","isWaqf":false},{"position":8,"ar":"لَا","fr":"(fais) non","en":"(do) not","tr":"lā","isWaqf":false},{"position":9,"ar":"يَعْقِلُونَ","fr":"comprendre","en":"understand","tr":"yaʿqilūna","isWaqf":false}]},{"ayah":5,"verseKey":"49:5","juz":26,"arabic":"وَلَوْ أَنَّهُمْ صَبَرُوا۟ حَتَّىٰ تَخْرُجَ إِلَيْهِمْ لَكَانَ خَيْرًا لَّهُمْ ۚ وَٱللَّهُ غَفُورٌ رَّحِيمٌ","fr":"S’ils patientaient un peu jusqu’à ce que tu sortes au-devant d’eux, cela serait bien meilleur pour eux. Mais Allah est Absoluteur et Tout Miséricordieux.","en":"And if they had been patient until you [could] come out to them, it would have been better for them. But Allāh is Forgiving and Merciful.","words":[{"position":1,"ar":"وَلَوْ","fr":"Et si","en":"And if","tr":"walaw","isWaqf":false},{"position":2,"ar":"أَنَّهُمْ","fr":"ils","en":"they","tr":"annahum","isWaqf":false},{"position":3,"ar":"صَبَرُوا۟","fr":"avait été patient","en":"had been patient","tr":"ṣabarū","isWaqf":false},{"position":4,"ar":"حَتَّىٰ","fr":"jusqu'à","en":"until","tr":"ḥattā","isWaqf":false},{"position":5,"ar":"تَخْرُجَ","fr":"vous vint hors","en":"you came out","tr":"takhruja","isWaqf":false},{"position":6,"ar":"إِلَيْهِمْ","fr":"à eux","en":"to them","tr":"ilayhim","isWaqf":false},{"position":7,"ar":"لَكَانَ","fr":"certainement cela irait être","en":"certainly it would be","tr":"lakāna","isWaqf":false},{"position":8,"ar":"خَيْرًۭا","fr":"meilleur","en":"better","tr":"khayran","isWaqf":false},{"position":9,"ar":"لَّهُمْ ۚ","fr":"pour eux","en":"for them","tr":"lahum","isWaqf":false},{"position":10,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":11,"ar":"غَفُورٌۭ","fr":"(est) Pardonneur","en":"(is) Oft-Forgiving","tr":"ghafūrun","isWaqf":false},{"position":12,"ar":"رَّحِيمٌۭ","fr":"Très-Miséricordieux","en":"Most Merciful","tr":"raḥīmun","isWaqf":false}]},{"ayah":6,"verseKey":"49:6","juz":26,"arabic":"يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِن جَآءَكُمْ فَاسِقٌۢ بِنَبَإٍ فَتَبَيَّنُوٓا۟ أَن تُصِيبُوا۟ قَوْمًۢا بِجَهَـٰلَةٍ فَتُصْبِحُوا۟ عَلَىٰ مَا فَعَلْتُمْ نَـٰدِمِينَ","fr":"Ô vous qui avez cru ! Si un homme dépravé vous apporte une nouvelle, vérifiez-en d’abord (la crédibilité), de peur que, par ignorance, vous ne lésiez des gens, et que, par la suite, vous ne vous retrouviez rongés par le remords.","en":"O you who have believed, if there comes to you a disobedient one with information, investigate, lest you harm a people out of ignorance and become, over what you have done, regretful.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô vous qui croient","en":"O you who believe","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"Ô vous qui croient","en":"O you who believe","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوٓا۟","fr":"Ô vous qui croient","en":"O you who believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"إِن","fr":"Si","en":"If","tr":"in","isWaqf":false},{"position":5,"ar":"جَآءَكُمْ","fr":"te vient","en":"comes to you","tr":"jāakum","isWaqf":false},{"position":6,"ar":"فَاسِقٌۢ","fr":"un méchant personne","en":"a wicked person","tr":"fāsiqun","isWaqf":false},{"position":7,"ar":"بِنَبَإٍۢ","fr":"avec information","en":"with information","tr":"binaba-in","isWaqf":false},{"position":8,"ar":"فَتَبَيَّنُوٓا۟","fr":"enquêter","en":"investigate","tr":"fatabayyanū","isWaqf":false},{"position":9,"ar":"أَن","fr":"de peur que","en":"lest","tr":"an","isWaqf":false},{"position":10,"ar":"تُصِيبُوا۟","fr":"vous nuire","en":"you harm","tr":"tuṣībū","isWaqf":false},{"position":11,"ar":"قَوْمًۢا","fr":"un peuple","en":"a people","tr":"qawman","isWaqf":false},{"position":12,"ar":"بِجَهَـٰلَةٍۢ","fr":"dans ignorance","en":"in ignorance","tr":"bijahālatin","isWaqf":false},{"position":13,"ar":"فَتُصْبِحُوا۟","fr":"puis vous devenez","en":"then you become","tr":"fatuṣ'biḥū","isWaqf":false},{"position":14,"ar":"عَلَىٰ","fr":"sur","en":"over","tr":"ʿalā","isWaqf":false},{"position":15,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":16,"ar":"فَعَلْتُمْ","fr":"vous ont fait","en":"you have done","tr":"faʿaltum","isWaqf":false},{"position":17,"ar":"نَـٰدِمِينَ","fr":"plein de regret","en":"regretful","tr":"nādimīna","isWaqf":false}]},{"ayah":7,"verseKey":"49:7","juz":26,"arabic":"وَٱعْلَمُوٓا۟ أَنَّ فِيكُمْ رَسُولَ ٱللَّهِ ۚ لَوْ يُطِيعُكُمْ فِى كَثِيرٍ مِّنَ ٱلْأَمْرِ لَعَنِتُّمْ وَلَـٰكِنَّ ٱللَّهَ حَبَّبَ إِلَيْكُمُ ٱلْإِيمَـٰنَ وَزَيَّنَهُۥ فِى قُلُوبِكُمْ وَكَرَّهَ إِلَيْكُمُ ٱلْكُفْرَ وَٱلْفُسُوقَ وَٱلْعِصْيَانَ ۚ أُو۟لَـٰٓئِكَ هُمُ ٱلرَّٰشِدُونَ","fr":"Sachez que, parmi vous, se trouve le Messager d’Allah. S’il vous écoutait pour bon nombre de décisions, c’est vous qui en auriez à pâtir. Mais Allah vous a fait aimer la foi, l’a rendue belle au fond de vos cœurs, et Il vous a fait haïr la mécréance, la perversion et l’insoumission. C’est ainsi que se conduisent ceux qui sont sur le droit chemin,","en":"And know that among you is the Messenger of Allāh. If he were to obey you in much of the matter, you would be in difficulty, but Allāh has endeared to you the faith and has made it pleasing in your hearts and has made hateful to you disbelief, defiance and disobedience. Those are the [rightly] guided.","words":[{"position":1,"ar":"وَٱعْلَمُوٓا۟","fr":"Et sache","en":"And know","tr":"wa-iʿ'lamū","isWaqf":false},{"position":2,"ar":"أَنَّ","fr":"que","en":"that","tr":"anna","isWaqf":false},{"position":3,"ar":"فِيكُمْ","fr":"parmi vous","en":"among you","tr":"fīkum","isWaqf":false},{"position":4,"ar":"رَسُولَ","fr":"(est le) Messager de Allah","en":"(is the) Messenger of Allah","tr":"rasūla","isWaqf":false},{"position":5,"ar":"ٱللَّهِ ۚ","fr":"(est le) Messager de Allah","en":"(is the) Messenger of Allah","tr":"l-lahi","isWaqf":false},{"position":6,"ar":"لَوْ","fr":"Si","en":"If","tr":"law","isWaqf":false},{"position":7,"ar":"يُطِيعُكُمْ","fr":"il étaient à obéir vous","en":"he were to obey you","tr":"yuṭīʿukum","isWaqf":false},{"position":8,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":9,"ar":"كَثِيرٍۢ","fr":"beaucoup","en":"much","tr":"kathīrin","isWaqf":false},{"position":10,"ar":"مِّنَ","fr":"de","en":"of","tr":"mina","isWaqf":false},{"position":11,"ar":"ٱلْأَمْرِ","fr":"l'affaire","en":"the matter","tr":"l-amri","isWaqf":false},{"position":12,"ar":"لَعَنِتُّمْ","fr":"assurément vous irait être dans difficulté","en":"surely you would be in difficulty","tr":"laʿanittum","isWaqf":false},{"position":13,"ar":"وَلَـٰكِنَّ","fr":"mais","en":"but","tr":"walākinna","isWaqf":false},{"position":14,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":15,"ar":"حَبَّبَ","fr":"a endeared","en":"has endeared","tr":"ḥabbaba","isWaqf":false},{"position":16,"ar":"إِلَيْكُمُ","fr":"à vous","en":"to you","tr":"ilaykumu","isWaqf":false},{"position":17,"ar":"ٱلْإِيمَـٰنَ","fr":"le Foi","en":"the Faith","tr":"l-īmāna","isWaqf":false},{"position":18,"ar":"وَزَيَّنَهُۥ","fr":"et a fait cela plaisant","en":"and has made it pleasing","tr":"wazayyanahu","isWaqf":false},{"position":19,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":20,"ar":"قُلُوبِكُمْ","fr":"vos cœurs","en":"your hearts","tr":"qulūbikum","isWaqf":false},{"position":21,"ar":"وَكَرَّهَ","fr":"et a fait haïssable","en":"and has made hateful","tr":"wakarraha","isWaqf":false},{"position":22,"ar":"إِلَيْكُمُ","fr":"à vous","en":"to you","tr":"ilaykumu","isWaqf":false},{"position":23,"ar":"ٱلْكُفْرَ","fr":"mécréance","en":"disbelief","tr":"l-kuf'ra","isWaqf":false},{"position":24,"ar":"وَٱلْفُسُوقَ","fr":"et defiance","en":"and defiance","tr":"wal-fusūqa","isWaqf":false},{"position":25,"ar":"وَٱلْعِصْيَانَ ۚ","fr":"et désobéissance","en":"and disobedience","tr":"wal-ʿiṣ'yāna","isWaqf":false},{"position":26,"ar":"أُو۟لَـٰٓئِكَ","fr":"Ceux","en":"Those","tr":"ulāika","isWaqf":false},{"position":27,"ar":"هُمُ","fr":"(sont) ils","en":"(are) they","tr":"humu","isWaqf":false},{"position":28,"ar":"ٱلرَّٰشِدُونَ","fr":"le guidé ceux","en":"the guided ones","tr":"l-rāshidūna","isWaqf":false}]},{"ayah":8,"verseKey":"49:8","juz":26,"arabic":"فَضْلًا مِّنَ ٱللَّهِ وَنِعْمَةً ۚ وَٱللَّهُ عَلِيمٌ حَكِيمٌ","fr":"comme faveur et bienfait émanant d’Allah. Allah est Omniscient et Sage.","en":"[It is] as bounty from Allāh and favor. And Allāh is Knowing and Wise.","words":[{"position":1,"ar":"فَضْلًۭا","fr":"Un Grâce","en":"A Bounty","tr":"faḍlan","isWaqf":false},{"position":2,"ar":"مِّنَ","fr":"d'Allah","en":"from Allah","tr":"mina","isWaqf":false},{"position":3,"ar":"ٱللَّهِ","fr":"d'Allah","en":"from Allah","tr":"l-lahi","isWaqf":false},{"position":4,"ar":"وَنِعْمَةًۭ ۚ","fr":"et grâce","en":"and favor","tr":"waniʿ'matan","isWaqf":false},{"position":5,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":6,"ar":"عَلِيمٌ","fr":"(est) Omniscient","en":"(is) All-Knower","tr":"ʿalīmun","isWaqf":false},{"position":7,"ar":"حَكِيمٌۭ","fr":"Très-Sage","en":"All-Wise","tr":"ḥakīmun","isWaqf":false}]},{"ayah":9,"verseKey":"49:9","juz":26,"arabic":"وَإِن طَآئِفَتَانِ مِنَ ٱلْمُؤْمِنِينَ ٱقْتَتَلُوا۟ فَأَصْلِحُوا۟ بَيْنَهُمَا ۖ فَإِنۢ بَغَتْ إِحْدَىٰهُمَا عَلَى ٱلْأُخْرَىٰ فَقَـٰتِلُوا۟ ٱلَّتِى تَبْغِى حَتَّىٰ تَفِىٓءَ إِلَىٰٓ أَمْرِ ٱللَّهِ ۚ فَإِن فَآءَتْ فَأَصْلِحُوا۟ بَيْنَهُمَا بِٱلْعَدْلِ وَأَقْسِطُوٓا۟ ۖ إِنَّ ٱللَّهَ يُحِبُّ ٱلْمُقْسِطِينَ","fr":"Si deux groupes de croyants venaient à se combattre, faites qu’ils se réconcilient. Et si l’un (des deux groupes) agresse injustement l’autre, combattez (le groupe) agresseur tant qu’il ne se sera pas soumis à l’ordre d’Allah. S’il finit par s’y soumettre, réconciliez-les en toute équité et soyez justes, car Allah aime les justes.","en":"And if two factions among the believers should fight, then make settlement between the two. But if one of them oppresses the other, then fight against the one that oppresses until it returns to the ordinance of Allāh. And if it returns, then make settlement between them in justice and act justly. Indeed, Allāh loves those who act justly.","words":[{"position":1,"ar":"وَإِن","fr":"Et si","en":"And if","tr":"wa-in","isWaqf":false},{"position":2,"ar":"طَآئِفَتَانِ","fr":"deux partis","en":"two parties","tr":"ṭāifatāni","isWaqf":false},{"position":3,"ar":"مِنَ","fr":"parmi","en":"among","tr":"mina","isWaqf":false},{"position":4,"ar":"ٱلْمُؤْمِنِينَ","fr":"les croyants","en":"the believers","tr":"l-mu'minīna","isWaqf":false},{"position":5,"ar":"ٱقْتَتَلُوا۟","fr":"combattre","en":"fight","tr":"iq'tatalū","isWaqf":false},{"position":6,"ar":"فَأَصْلِحُوا۟","fr":"puis faire paix","en":"then make peace","tr":"fa-aṣliḥū","isWaqf":false},{"position":7,"ar":"بَيْنَهُمَا ۖ","fr":"entre les deux de eux","en":"between both of them","tr":"baynahumā","isWaqf":false},{"position":8,"ar":"فَإِنۢ","fr":"Mais si","en":"But if","tr":"fa-in","isWaqf":false},{"position":9,"ar":"بَغَتْ","fr":"opprime","en":"oppresses","tr":"baghat","isWaqf":false},{"position":10,"ar":"إِحْدَىٰهُمَا","fr":"un de eux","en":"one of them","tr":"iḥ'dāhumā","isWaqf":false},{"position":11,"ar":"عَلَى","fr":"sur","en":"on","tr":"ʿalā","isWaqf":false},{"position":12,"ar":"ٱلْأُخْرَىٰ","fr":"le autre","en":"the other","tr":"l-ukh'rā","isWaqf":false},{"position":13,"ar":"فَقَـٰتِلُوا۟","fr":"puis combattre","en":"then fight","tr":"faqātilū","isWaqf":false},{"position":14,"ar":"ٱلَّتِى","fr":"un que","en":"one which","tr":"allatī","isWaqf":false},{"position":15,"ar":"تَبْغِى","fr":"opprime","en":"oppresses","tr":"tabghī","isWaqf":false},{"position":16,"ar":"حَتَّىٰ","fr":"jusqu'à","en":"until","tr":"ḥattā","isWaqf":false},{"position":17,"ar":"تَفِىٓءَ","fr":"cela retourne","en":"it returns","tr":"tafīa","isWaqf":false},{"position":18,"ar":"إِلَىٰٓ","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":19,"ar":"أَمْرِ","fr":"(le) ordre","en":"(the) command","tr":"amri","isWaqf":false},{"position":20,"ar":"ٱللَّهِ ۚ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":21,"ar":"فَإِن","fr":"Puis si","en":"Then if","tr":"fa-in","isWaqf":false},{"position":22,"ar":"فَآءَتْ","fr":"cela retourne","en":"it returns","tr":"fāat","isWaqf":false},{"position":23,"ar":"فَأَصْلِحُوا۟","fr":"puis faire paix","en":"then make peace","tr":"fa-aṣliḥū","isWaqf":false},{"position":24,"ar":"بَيْنَهُمَا","fr":"entre eux","en":"between them","tr":"baynahumā","isWaqf":false},{"position":25,"ar":"بِٱلْعَدْلِ","fr":"avec justice","en":"with justice","tr":"bil-ʿadli","isWaqf":false},{"position":26,"ar":"وَأَقْسِطُوٓا۟ ۖ","fr":"et agir avec justice","en":"and act justly","tr":"wa-aqsiṭū","isWaqf":false},{"position":27,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":28,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":29,"ar":"يُحِبُّ","fr":"aime","en":"loves","tr":"yuḥibbu","isWaqf":false},{"position":30,"ar":"ٱلْمُقْسِطِينَ","fr":"ceux qui agir avec justice","en":"those who act justly","tr":"l-muq'siṭīna","isWaqf":false}]},{"ayah":10,"verseKey":"49:10","juz":26,"arabic":"إِنَّمَا ٱلْمُؤْمِنُونَ إِخْوَةٌ فَأَصْلِحُوا۟ بَيْنَ أَخَوَيْكُمْ ۚ وَٱتَّقُوا۟ ٱللَّهَ لَعَلَّكُمْ تُرْحَمُونَ","fr":"Les croyants ne sont rien moins que des frères. Réconciliez donc vos frères ! Craignez Allah ! Peut-être alors vous sera-t-il fait miséricorde !","en":"The believers are but brothers, so make settlement between your brothers. And fear Allāh that you may receive mercy.","words":[{"position":1,"ar":"إِنَّمَا","fr":"Seulement","en":"Only","tr":"innamā","isWaqf":false},{"position":2,"ar":"ٱلْمُؤْمِنُونَ","fr":"les croyants","en":"the believers","tr":"l-mu'minūna","isWaqf":false},{"position":3,"ar":"إِخْوَةٌۭ","fr":"(sont) frères","en":"(are) brothers","tr":"ikh'watun","isWaqf":false},{"position":4,"ar":"فَأَصْلِحُوا۟","fr":"donc faire paix","en":"so make peace","tr":"fa-aṣliḥū","isWaqf":false},{"position":5,"ar":"بَيْنَ","fr":"entre","en":"between","tr":"bayna","isWaqf":false},{"position":6,"ar":"أَخَوَيْكُمْ ۚ","fr":"votre frères","en":"your brothers","tr":"akhawaykum","isWaqf":false},{"position":7,"ar":"وَٱتَّقُوا۟","fr":"et craindre Allah","en":"and fear Allah","tr":"wa-ittaqū","isWaqf":false},{"position":8,"ar":"ٱللَّهَ","fr":"et craindre Allah","en":"and fear Allah","tr":"l-laha","isWaqf":false},{"position":9,"ar":"لَعَلَّكُمْ","fr":"afin que vous","en":"so that you may","tr":"laʿallakum","isWaqf":false},{"position":10,"ar":"تُرْحَمُونَ","fr":"recevoir miséricorde","en":"receive mercy","tr":"tur'ḥamūna","isWaqf":false}]},{"ayah":11,"verseKey":"49:11","juz":26,"arabic":"يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا يَسْخَرْ قَوْمٌ مِّن قَوْمٍ عَسَىٰٓ أَن يَكُونُوا۟ خَيْرًا مِّنْهُمْ وَلَا نِسَآءٌ مِّن نِّسَآءٍ عَسَىٰٓ أَن يَكُنَّ خَيْرًا مِّنْهُنَّ ۖ وَلَا تَلْمِزُوٓا۟ أَنفُسَكُمْ وَلَا تَنَابَزُوا۟ بِٱلْأَلْقَـٰبِ ۖ بِئْسَ ٱلِٱسْمُ ٱلْفُسُوقُ بَعْدَ ٱلْإِيمَـٰنِ ۚ وَمَن لَّمْ يَتُبْ فَأُو۟لَـٰٓئِكَ هُمُ ٱلظَّـٰلِمُونَ","fr":"Ô vous qui avez cru ! Que certains d’entre vous ne se moquent point des autres, car ceux-ci pourraient être meilleurs qu’eux. Et que les femmes ne se moquent point d’autres femmes, car celles-ci pourraient être meilleures qu’elles. Ne vous dénigrez point les uns les autres, et point ne vous vexez en vous attribuant mutuellement de (blessants) sobriquets. Quel pire nom que celui de perversion après qu’on a eu la foi ! Ceux qui ne se repentent pas, ce sont eux les injustes.","en":"O you who have believed, let not a people ridicule [another] people; perhaps they may be better than them; nor let women ridicule [other] women; perhaps they may be better than them. And do not insult one another and do not call each other by [offensive] nicknames. Wretched is the name [i.e., mention] of disobedience after [one's] faith. And whoever does not repent - then it is those who are the wrongdoers.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô vous qui croient","en":"O you who believe","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"Ô vous qui croient","en":"O you who believe","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"Ô vous qui croient","en":"O you who believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"لَا","fr":"(laisse) non","en":"(Let) not","tr":"lā","isWaqf":false},{"position":5,"ar":"يَسْخَرْ","fr":"raillerie","en":"ridicule","tr":"yaskhar","isWaqf":false},{"position":6,"ar":"قَوْمٌۭ","fr":"un peuple","en":"a people","tr":"qawmun","isWaqf":false},{"position":7,"ar":"مِّن","fr":"[de]","en":"[of]","tr":"min","isWaqf":false},{"position":8,"ar":"قَوْمٍ","fr":"(un autre) gens","en":"(another) people","tr":"qawmin","isWaqf":false},{"position":9,"ar":"عَسَىٰٓ","fr":"peut-être","en":"perhaps","tr":"ʿasā","isWaqf":false},{"position":10,"ar":"أَن","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":11,"ar":"يَكُونُوا۟","fr":"ils peut être","en":"they may be","tr":"yakūnū","isWaqf":false},{"position":12,"ar":"خَيْرًۭا","fr":"meilleur","en":"better","tr":"khayran","isWaqf":false},{"position":13,"ar":"مِّنْهُمْ","fr":"qu'eux","en":"than them","tr":"min'hum","isWaqf":false},{"position":14,"ar":"وَلَا","fr":"et (ne laisse) pas","en":"and (let) not","tr":"walā","isWaqf":false},{"position":15,"ar":"نِسَآءٌۭ","fr":"femmes","en":"women","tr":"nisāon","isWaqf":false},{"position":16,"ar":"مِّن","fr":"[de]","en":"[of]","tr":"min","isWaqf":false},{"position":17,"ar":"نِّسَآءٍ","fr":"(autre) femmes","en":"(other) women","tr":"nisāin","isWaqf":false},{"position":18,"ar":"عَسَىٰٓ","fr":"peut-être","en":"perhaps","tr":"ʿasā","isWaqf":false},{"position":19,"ar":"أَن","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":20,"ar":"يَكُنَّ","fr":"ils peut être","en":"they may be","tr":"yakunna","isWaqf":false},{"position":21,"ar":"خَيْرًۭا","fr":"meilleur","en":"better","tr":"khayran","isWaqf":false},{"position":22,"ar":"مِّنْهُنَّ ۖ","fr":"qu'eux","en":"than them","tr":"min'hunna","isWaqf":false},{"position":23,"ar":"وَلَا","fr":"Et (fais) non","en":"And (do) not","tr":"walā","isWaqf":false},{"position":24,"ar":"تَلْمِزُوٓا۟","fr":"insulter","en":"insult","tr":"talmizū","isWaqf":false},{"position":25,"ar":"أَنفُسَكُمْ","fr":"vous-mêmes","en":"yourselves","tr":"anfusakum","isWaqf":false},{"position":26,"ar":"وَلَا","fr":"et (fais) non","en":"and (do) not","tr":"walā","isWaqf":false},{"position":27,"ar":"تَنَابَزُوا۟","fr":"appeler chacun autre","en":"call each other","tr":"tanābazū","isWaqf":false},{"position":28,"ar":"بِٱلْأَلْقَـٰبِ ۖ","fr":"par nicknames","en":"by nicknames","tr":"bil-alqābi","isWaqf":false},{"position":29,"ar":"بِئْسَ","fr":"Misérable est","en":"Wretched is","tr":"bi'sa","isWaqf":false},{"position":30,"ar":"ٱلِٱسْمُ","fr":"le nom","en":"the name","tr":"l-s'mu","isWaqf":false},{"position":31,"ar":"ٱلْفُسُوقُ","fr":"(de) désobéissance","en":"(of) disobedience","tr":"l-fusūqu","isWaqf":false},{"position":32,"ar":"بَعْدَ","fr":"après","en":"after","tr":"baʿda","isWaqf":false},{"position":33,"ar":"ٱلْإِيمَـٰنِ ۚ","fr":"le foi","en":"the faith","tr":"l-īmāni","isWaqf":false},{"position":34,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":35,"ar":"لَّمْ","fr":"(ne) fait pas","en":"(does) not","tr":"lam","isWaqf":false},{"position":36,"ar":"يَتُبْ","fr":"se repentir","en":"repent","tr":"yatub","isWaqf":false},{"position":37,"ar":"فَأُو۟لَـٰٓئِكَ","fr":"puis ceux","en":"then those","tr":"fa-ulāika","isWaqf":false},{"position":38,"ar":"هُمُ","fr":"ils","en":"they","tr":"humu","isWaqf":false},{"position":39,"ar":"ٱلظَّـٰلِمُونَ","fr":"(sont) les injustes","en":"(are) the wrongdoers","tr":"l-ẓālimūna","isWaqf":false}]},{"ayah":12,"verseKey":"49:12","juz":26,"arabic":"يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱجْتَنِبُوا۟ كَثِيرًا مِّنَ ٱلظَّنِّ إِنَّ بَعْضَ ٱلظَّنِّ إِثْمٌ ۖ وَلَا تَجَسَّسُوا۟ وَلَا يَغْتَب بَّعْضُكُم بَعْضًا ۚ أَيُحِبُّ أَحَدُكُمْ أَن يَأْكُلَ لَحْمَ أَخِيهِ مَيْتًا فَكَرِهْتُمُوهُ ۚ وَٱتَّقُوا۟ ٱللَّهَ ۚ إِنَّ ٱللَّهَ تَوَّابٌ رَّحِيمٌ","fr":"Ô vous qui avez cru ! Évitez les suspicions fréquentes, car certaines suspicions peuvent être des péchés. Ne vous épiez pas (mutuellement) ! Ne médisez pas les uns des autres ! L’un de vous voudrait-il manger la chair de son frère mort ? Non, car vous l’auriez certainement en aversion. Craignez donc Allah ! Allah est Tout Absoluteur et Tout Miséricordieux !","en":"O you who have believed, avoid much [negative] assumption. Indeed, some assumption is sin. And do not spy or backbite each other. Would one of you like to eat the flesh of his brother when dead? You would detest it. And fear Allāh; indeed, Allāh is Accepting of Repentance and Merciful.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô vous qui croient","en":"O you who believe","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"Ô vous qui croient","en":"O you who believe","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"Ô vous qui croient","en":"O you who believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"ٱجْتَنِبُوا۟","fr":"Éviter","en":"Avoid","tr":"ij'tanibū","isWaqf":false},{"position":5,"ar":"كَثِيرًۭا","fr":"beaucoup","en":"much","tr":"kathīran","isWaqf":false},{"position":6,"ar":"مِّنَ","fr":"de","en":"of","tr":"mina","isWaqf":false},{"position":7,"ar":"ٱلظَّنِّ","fr":"le conjecture","en":"the assumption","tr":"l-ẓani","isWaqf":false},{"position":8,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":9,"ar":"بَعْضَ","fr":"certains","en":"some","tr":"baʿḍa","isWaqf":false},{"position":10,"ar":"ٱلظَّنِّ","fr":"conjecture","en":"assumption","tr":"l-ẓani","isWaqf":false},{"position":11,"ar":"إِثْمٌۭ ۖ","fr":"(est) péché","en":"(is) sin","tr":"ith'mun","isWaqf":false},{"position":12,"ar":"وَلَا","fr":"Et (fais) non","en":"And (do) not","tr":"walā","isWaqf":false},{"position":13,"ar":"تَجَسَّسُوا۟","fr":"espionner","en":"spy","tr":"tajassasū","isWaqf":false},{"position":14,"ar":"وَلَا","fr":"et (fais) non","en":"and (do) not","tr":"walā","isWaqf":false},{"position":15,"ar":"يَغْتَب","fr":"médire","en":"backbite","tr":"yaghtab","isWaqf":false},{"position":16,"ar":"بَّعْضُكُم","fr":"certains d'entre vous","en":"some of you","tr":"baʿḍukum","isWaqf":false},{"position":17,"ar":"بَعْضًا ۚ","fr":"(à) d'autres","en":"(to) others","tr":"baʿḍan","isWaqf":false},{"position":18,"ar":"أَيُحِبُّ","fr":"Irait comme","en":"Would like","tr":"ayuḥibbu","isWaqf":false},{"position":19,"ar":"أَحَدُكُمْ","fr":"un de vous","en":"one of you","tr":"aḥadukum","isWaqf":false},{"position":20,"ar":"أَن","fr":"à","en":"to","tr":"an","isWaqf":false},{"position":21,"ar":"يَأْكُلَ","fr":"manger","en":"eat","tr":"yakula","isWaqf":false},{"position":22,"ar":"لَحْمَ","fr":"(le) chair","en":"(the) flesh","tr":"laḥma","isWaqf":false},{"position":23,"ar":"أَخِيهِ","fr":"(de) son frère","en":"(of) his brother","tr":"akhīhi","isWaqf":false},{"position":24,"ar":"مَيْتًۭا","fr":"mort","en":"dead","tr":"maytan","isWaqf":false},{"position":25,"ar":"فَكَرِهْتُمُوهُ ۚ","fr":"Non, vous irait haïr cela","en":"Nay, you would hate it","tr":"fakarih'tumūhu","isWaqf":false},{"position":26,"ar":"وَٱتَّقُوا۟","fr":"Et craindre Allah","en":"And fear Allah","tr":"wa-ittaqū","isWaqf":false},{"position":27,"ar":"ٱللَّهَ ۚ","fr":"Et craindre Allah","en":"And fear Allah","tr":"l-laha","isWaqf":false},{"position":28,"ar":"إِنَّ","fr":"certes","en":"indeed","tr":"inna","isWaqf":false},{"position":29,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":30,"ar":"تَوَّابٌۭ","fr":"(est) Le Repentant","en":"(is) Oft-Returning","tr":"tawwābun","isWaqf":false},{"position":31,"ar":"رَّحِيمٌۭ","fr":"Très-Miséricordieux","en":"Most Merciful","tr":"raḥīmun","isWaqf":false}]},{"ayah":13,"verseKey":"49:13","juz":26,"arabic":"يَـٰٓأَيُّهَا ٱلنَّاسُ إِنَّا خَلَقْنَـٰكُم مِّن ذَكَرٍ وَأُنثَىٰ وَجَعَلْنَـٰكُمْ شُعُوبًا وَقَبَآئِلَ لِتَعَارَفُوٓا۟ ۚ إِنَّ أَكْرَمَكُمْ عِندَ ٱللَّهِ أَتْقَىٰكُمْ ۚ إِنَّ ٱللَّهَ عَلِيمٌ خَبِيرٌ","fr":"Ô hommes ! Nous vous avons créés d’un mâle et d’une femelle. Nous avons fait de vous des nations et des tribus pour que vous vous connaissiez entre vous. Le plus digne d’entre vous, auprès d’Allah, est le plus pieux. Allah est Omniscient et parfaitement Informé.","en":"O mankind, indeed We have created you from male and female and made you peoples and tribes that you may know one another. Indeed, the most noble of you in the sight of Allāh is the most righteous of you. Indeed, Allāh is Knowing and Aware.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô humanité","en":"O mankind","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلنَّاسُ","fr":"Ô humanité","en":"O mankind","tr":"l-nāsu","isWaqf":false},{"position":3,"ar":"إِنَّا","fr":"Certes, Nous","en":"Indeed, We","tr":"innā","isWaqf":false},{"position":4,"ar":"خَلَقْنَـٰكُم","fr":"vous a créés","en":"created you","tr":"khalaqnākum","isWaqf":false},{"position":5,"ar":"مِّن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":6,"ar":"ذَكَرٍۢ","fr":"un mâle","en":"a male","tr":"dhakarin","isWaqf":false},{"position":7,"ar":"وَأُنثَىٰ","fr":"et un femelle","en":"and a female","tr":"wa-unthā","isWaqf":false},{"position":8,"ar":"وَجَعَلْنَـٰكُمْ","fr":"et Nous fait vous","en":"and We made you","tr":"wajaʿalnākum","isWaqf":false},{"position":9,"ar":"شُعُوبًۭا","fr":"nations","en":"nations","tr":"shuʿūban","isWaqf":false},{"position":10,"ar":"وَقَبَآئِلَ","fr":"et tribus","en":"and tribes","tr":"waqabāila","isWaqf":false},{"position":11,"ar":"لِتَعَارَفُوٓا۟ ۚ","fr":"que vous peut savoir l'un l'autre","en":"that you may know one another","tr":"litaʿārafū","isWaqf":false},{"position":12,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":13,"ar":"أَكْرَمَكُمْ","fr":"(le) le plus noble de vous","en":"(the) most noble of you","tr":"akramakum","isWaqf":false},{"position":14,"ar":"عِندَ","fr":"proche","en":"near","tr":"ʿinda","isWaqf":false},{"position":15,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":16,"ar":"أَتْقَىٰكُمْ ۚ","fr":"(est le) le plus vertueux de vous","en":"(is the) most righteous of you","tr":"atqākum","isWaqf":false},{"position":17,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":18,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":19,"ar":"عَلِيمٌ","fr":"(est) Omniscient","en":"(is) All-Knower","tr":"ʿalīmun","isWaqf":false},{"position":20,"ar":"خَبِيرٌۭ","fr":"Parfaitement informeré","en":"All-Aware","tr":"khabīrun","isWaqf":false}]},{"ayah":14,"verseKey":"49:14","juz":26,"arabic":"قَالَتِ ٱلْأَعْرَابُ ءَامَنَّا ۖ قُل لَّمْ تُؤْمِنُوا۟ وَلَـٰكِن قُولُوٓا۟ أَسْلَمْنَا وَلَمَّا يَدْخُلِ ٱلْإِيمَـٰنُ فِى قُلُوبِكُمْ ۖ وَإِن تُطِيعُوا۟ ٱللَّهَ وَرَسُولَهُۥ لَا يَلِتْكُم مِّنْ أَعْمَـٰلِكُمْ شَيْـًٔا ۚ إِنَّ ٱللَّهَ غَفُورٌ رَّحِيمٌ","fr":"Les bédouins déclarent : « Nous avons cru (en Allah). » Dis : « Non, vous n’êtes pas encore croyants, dites plutôt : “Nous nous sommes soumis”, car la foi n’a pas encore pénétré vos cœurs. Mais si vous obéissez à Allah et à Son Messager, il ne vous privera en rien (de la récompense due à) vos œuvres. » Allah est Absoluteur et Tout Miséricordieux.","en":"The bedouins say, \"We have believed.\" Say, \"You have not [yet] believed; but say [instead], 'We have submitted,' for faith has not yet entered your hearts. And if you obey Allāh and His Messenger, He will not deprive you from your deeds of anything. Indeed, Allāh is Forgiving and Merciful.\"","words":[{"position":1,"ar":"۞ قَالَتِ","fr":"D