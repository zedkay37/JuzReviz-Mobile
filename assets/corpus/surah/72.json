:8,"ar":"مِنۢ","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":9,"ar":"بَيْنِ","fr":"avant","en":"before","tr":"bayni","isWaqf":false},{"position":10,"ar":"يَدَيْهِ","fr":"lui","en":"him","tr":"yadayhi","isWaqf":false},{"position":11,"ar":"وَمِنْ","fr":"et de","en":"and from","tr":"wamin","isWaqf":false},{"position":12,"ar":"خَلْفِهِۦ","fr":"derrière lui","en":"behind him","tr":"khalfihi","isWaqf":false},{"position":13,"ar":"رَصَدًۭا","fr":"un garder","en":"a guard","tr":"raṣadan","isWaqf":false}]},{"ayah":28,"verseKey":"72:28","juz":29,"arabic":"لِّيَعْلَمَ أَن قَدْ أَبْلَغُوا۟ رِسَـٰلَـٰتِ رَبِّهِمْ وَأَحَاطَ بِمَا لَدَيْهِمْ وَأَحْصَىٰ كُلَّ شَىْءٍ عَدَدًۢا","fr":"afin de savoir s’ils ont transmis les Messages de leur Seigneur. Il Cerne (de Sa Connaissance) tout ce qu’ils détiennent, et Dénombre Toute chose. »","en":"That he [i.e., Muḥammad (ﷺ)] may know that they have conveyed the messages of their Lord; and He has encompassed whatever is with them and has enumerated all things in number.","words":[{"position":1,"ar":"لِّيَعْلَمَ","fr":"C’Il peut faire évident","en":"That He may make evident","tr":"liyaʿlama","isWaqf":false},{"position":2,"ar":"أَن","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":3,"ar":"قَدْ","fr":"certes","en":"indeed","tr":"qad","isWaqf":false},{"position":4,"ar":"أَبْلَغُوا۟","fr":"ils ont transmit","en":"they have conveyed","tr":"ablaghū","isWaqf":false},{"position":5,"ar":"رِسَـٰلَـٰتِ","fr":"(le) Messages","en":"(the) Messages","tr":"risālāti","isWaqf":false},{"position":6,"ar":"رَبِّهِمْ","fr":"(de) leur Seigneur","en":"(of) their Lord","tr":"rabbihim","isWaqf":false},{"position":7,"ar":"وَأَحَاطَ","fr":"et Il a cerna","en":"and He has encompassed","tr":"wa-aḥāṭa","isWaqf":false},{"position":8,"ar":"بِمَا","fr":"ce que","en":"what","tr":"bimā","isWaqf":false},{"position":9,"ar":"لَدَيْهِمْ","fr":"(est) avec eux","en":"(is) with them","tr":"ladayhim","isWaqf":false},{"position":10,"ar":"وَأَحْصَىٰ","fr":"et Il pr