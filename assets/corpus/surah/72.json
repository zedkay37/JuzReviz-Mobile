[{"ayah":1,"verseKey":"72:1","juz":29,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ قُلْ أُوحِىَ إِلَىَّ أَنَّهُ ٱسْتَمَعَ نَفَرٌ مِّنَ ٱلْجِنِّ فَقَالُوٓا۟ إِنَّا سَمِعْنَا قُرْءَانًا عَجَبًا","fr":"Dis : « Il m’a été révélé qu’un groupe de djinns, ayant prêté l’oreille, ont dit : “Nous avons certes entendu une Lecture (Qur’ân) merveilleuse,","en":"Say, [O Muḥammad], \"It has been revealed to me that a group of the jinn listened and said, 'Indeed, we have heard an amazing Qur’ān [i.e., recitation].","words":[{"position":1,"ar":"قُلْ","fr":"Dis","en":"Say","tr":"qul","isWaqf":false},{"position":2,"ar":"أُوحِىَ","fr":"Cela a été révélé","en":"It has been revealed","tr":"ūḥiya","isWaqf":false},{"position":3,"ar":"إِلَىَّ","fr":"à moi","en":"to me","tr":"ilayya","isWaqf":false},{"position":4,"ar":"أَنَّهُ","fr":"que","en":"that","tr":"annahu","isWaqf":false},{"position":5,"ar":"ٱسْتَمَعَ","fr":"écouta","en":"listened","tr":"is'tamaʿa","isWaqf":false},{"position":6,"ar":"نَفَرٌۭ","fr":"un groupe","en":"a group","tr":"nafarun","isWaqf":false},{"position":7,"ar":"مِّنَ","fr":"de","en":"of","tr":"mina","isWaqf":false},{"position":8,"ar":"ٱلْجِنِّ","fr":"les djinns","en":"the jinn","tr":"l-jini","isWaqf":false},{"position":9,"ar":"فَقَالُوٓا۟","fr":"et ils dirent","en":"and they said","tr":"faqālū","isWaqf":false},{"position":10,"ar":"إِنَّا","fr":"Certes, nous","en":"Indeed, we","tr":"innā","isWaqf":false},{"position":11,"ar":"سَمِعْنَا","fr":"entendu","en":"heard","tr":"samiʿ'nā","isWaqf":false},{"position":12,"ar":"قُرْءَانًا","fr":"un Coran","en":"a Quran","tr":"qur'ānan","isWaqf":false},{"position":13,"ar":"عَجَبًۭا","fr":"étonnant","en":"amazing","tr":"ʿajaban","isWaqf":false}]},{"ayah":2,"verseKey":"72:2","juz":29,"arabic":"يَهْدِىٓ إِلَى ٱلرُّشْدِ فَـَٔامَنَّا بِهِۦ ۖ وَلَن نُّشْرِكَ بِرَبِّنَآ أَحَدًا","fr":"qui conduit vers la juste voie, et nous y avons cru. Nous n’attribuerons donc aucun associé à notre Seigneur !","en":"It guides to the right course, and we have believed in it. And we will never associate with our Lord anyone.","words":[{"position":1,"ar":"يَهْدِىٓ","fr":"Cela guide","en":"It guides","tr":"yahdī","isWaqf":false},{"position":2,"ar":"إِلَى","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":3,"ar":"ٱلرُّشْدِ","fr":"le droit voie","en":"the right way","tr":"l-rush'di","isWaqf":false},{"position":4,"ar":"فَـَٔامَنَّا","fr":"donc nous croire","en":"so we believe","tr":"faāmannā","isWaqf":false},{"position":5,"ar":"بِهِۦ ۖ","fr":"dans cela","en":"in it","tr":"bihi","isWaqf":false},{"position":6,"ar":"وَلَن","fr":"et jamais","en":"and never","tr":"walan","isWaqf":false},{"position":7,"ar":"نُّشْرِكَ","fr":"nous va associer","en":"we will associate","tr":"nush'rika","isWaqf":false},{"position":8,"ar":"بِرَبِّنَآ","fr":"avec notre Seigneur","en":"with our Lord","tr":"birabbinā","isWaqf":false},{"position":9,"ar":"أَحَدًۭا","fr":"quiconque","en":"anyone","tr":"aḥadan","isWaqf":false}]},{"ayah":3,"verseKey":"72:3","juz":29,"arabic":"وَأَنَّهُۥ تَعَـٰلَىٰ جَدُّ رَبِّنَا مَا ٱتَّخَذَ صَـٰحِبَةً وَلَا وَلَدًا","fr":"Notre Seigneur Très Haut ne S’est donné ni compagne ni fils.","en":"And [it teaches] that exalted is the nobleness of our Lord; He has not taken a wife or a son","words":[{"position":1,"ar":"وَأَنَّهُۥ","fr":"Et qu’Il","en":"And that He","tr":"wa-annahu","isWaqf":false},{"position":2,"ar":"تَعَـٰلَىٰ","fr":"Exalté est","en":"Exalted is","tr":"taʿālā","isWaqf":false},{"position":3,"ar":"جَدُّ","fr":"(le) Majesté","en":"(the) Majesty","tr":"jaddu","isWaqf":false},{"position":4,"ar":"رَبِّنَا","fr":"(de) notre Seigneur","en":"(of) our Lord","tr":"rabbinā","isWaqf":false},{"position":5,"ar":"مَا","fr":"non","en":"not","tr":"mā","isWaqf":false},{"position":6,"ar":"ٱتَّخَذَ","fr":"Il a pris","en":"He has taken","tr":"ittakhadha","isWaqf":false},{"position":7,"ar":"صَـٰحِبَةًۭ","fr":"un épouse","en":"a wife","tr":"ṣāḥibatan","isWaqf":false},{"position":8,"ar":"وَلَا","fr":"et non","en":"and not","tr":"walā","isWaqf":false},{"position":9,"ar":"وَلَدًۭا","fr":"un fils","en":"a son","tr":"waladan","isWaqf":false}]},{"ayah":4,"verseKey":"72:4","juz":29,"arabic":"وَأَنَّهُۥ كَانَ يَقُولُ سَفِيهُنَا عَلَى ٱللَّهِ شَطَطًا","fr":"Le plus ignorant d’entre nous proférait au sujet d’Allah les (pires) insanités.","en":"And that our foolish one [i.e., Iblees] has been saying about Allāh an excessive transgression.","words":[{"position":1,"ar":"وَأَنَّهُۥ","fr":"Et qu’il","en":"And that he","tr":"wa-annahu","isWaqf":false},{"position":2,"ar":"كَانَ","fr":"utilisé à","en":"used to","tr":"kāna","isWaqf":false},{"position":3,"ar":"يَقُولُ","fr":"parler","en":"speak","tr":"yaqūlu","isWaqf":false},{"position":4,"ar":"سَفِيهُنَا","fr":"l’insensé parmi nous","en":"the foolish among us","tr":"safīhunā","isWaqf":false},{"position":5,"ar":"عَلَى","fr":"contre","en":"against","tr":"ʿalā","isWaqf":false},{"position":6,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":7,"ar":"شَطَطًۭا","fr":"un excessive transgression","en":"an excessive transgression","tr":"shaṭaṭan","isWaqf":false}]},{"ayah":5,"verseKey":"72:5","juz":29,"arabic":"وَأَنَّا ظَنَنَّآ أَن لَّن تَقُولَ ٱلْإِنسُ وَٱلْجِنُّ عَلَى ٱللَّهِ كَذِبًا","fr":"Nous supposions que ni les hommes ni les djinns n’oseraient débiter des mensonges sur le compte d’Allah.","en":"And we had thought that mankind and the jinn would never speak about Allāh a lie.","words":[{"position":1,"ar":"وَأَنَّا","fr":"Et que nous","en":"And that we","tr":"wa-annā","isWaqf":false},{"position":2,"ar":"ظَنَنَّآ","fr":"pensée","en":"thought","tr":"ẓanannā","isWaqf":false},{"position":3,"ar":"أَن","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":4,"ar":"لَّن","fr":"jamais","en":"never","tr":"lan","isWaqf":false},{"position":5,"ar":"تَقُولَ","fr":"va dis","en":"will say","tr":"taqūla","isWaqf":false},{"position":6,"ar":"ٱلْإِنسُ","fr":"les hommes","en":"the men","tr":"l-insu","isWaqf":false},{"position":7,"ar":"وَٱلْجِنُّ","fr":"et les djinns","en":"and the jinn","tr":"wal-jinu","isWaqf":false},{"position":8,"ar":"عَلَى","fr":"contre","en":"against","tr":"ʿalā","isWaqf":false},{"position":9,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":10,"ar":"كَذِبًۭا","fr":"tout mensonge","en":"any lie","tr":"kadhiban","isWaqf":false}]},{"ayah":6,"verseKey":"72:6","juz":29,"arabic":"وَأَنَّهُۥ كَانَ رِجَالٌ مِّنَ ٱلْإِنسِ يَعُوذُونَ بِرِجَالٍ مِّنَ ٱلْجِنِّ فَزَادُوهُمْ رَهَقًا","fr":"Mais il y avait ceux, parmi les humains, qui cherchaient refuge auprès des djinns. Or ceux-ci ne firent qu’ajouter à leur perdition.","en":"And there were men from mankind who sought refuge in men from the jinn, so they [only] increased them in burden [i.e., sin].","words":[{"position":1,"ar":"وَأَنَّهُۥ","fr":"Et que","en":"And that","tr":"wa-annahu","isWaqf":false},{"position":2,"ar":"كَانَ","fr":"(là) étaient","en":"(there) were","tr":"kāna","isWaqf":false},{"position":3,"ar":"رِجَالٌۭ","fr":"hommes","en":"men","tr":"rijālun","isWaqf":false},{"position":4,"ar":"مِّنَ","fr":"parmi","en":"among","tr":"mina","isWaqf":false},{"position":5,"ar":"ٱلْإِنسِ","fr":"l'humanité","en":"mankind","tr":"l-insi","isWaqf":false},{"position":6,"ar":"يَعُوذُونَ","fr":"qui chercha refuge","en":"who sought refuge","tr":"yaʿūdhūna","isWaqf":false},{"position":7,"ar":"بِرِجَالٍۢ","fr":"dans (le) hommes","en":"in (the) men","tr":"birijālin","isWaqf":false},{"position":8,"ar":"مِّنَ","fr":"de","en":"from","tr":"mina","isWaqf":false},{"position":9,"ar":"ٱلْجِنِّ","fr":"les djinns","en":"the jinn","tr":"l-jini","isWaqf":false},{"position":10,"ar":"فَزَادُوهُمْ","fr":"donc ils accru eux","en":"so they increased them","tr":"fazādūhum","isWaqf":false},{"position":11,"ar":"رَهَقًۭا","fr":"(dans) fardeau","en":"(in) burden","tr":"rahaqan","isWaqf":false}]},{"ayah":7,"verseKey":"72:7","juz":29,"arabic":"وَأَنَّهُمْ ظَنُّوا۟ كَمَا ظَنَنتُمْ أَن لَّن يَبْعَثَ ٱللَّهُ أَحَدًا","fr":"Tout comme vous, ils pensaient qu’Allah n’enverrait nul (Messager).","en":"And they had thought, as you thought, that Allāh would never send anyone [as a messenger].","words":[{"position":1,"ar":"وَأَنَّهُمْ","fr":"Et qu'ils","en":"And that they","tr":"wa-annahum","isWaqf":false},{"position":2,"ar":"ظَنُّوا۟","fr":"pensée","en":"thought","tr":"ẓannū","isWaqf":false},{"position":3,"ar":"كَمَا","fr":"comme","en":"as","tr":"kamā","isWaqf":false},{"position":4,"ar":"ظَنَنتُمْ","fr":"vous pensée","en":"you thought","tr":"ẓanantum","isWaqf":false},{"position":5,"ar":"أَن","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":6,"ar":"لَّن","fr":"jamais","en":"never","tr":"lan","isWaqf":false},{"position":7,"ar":"يَبْعَثَ","fr":"va élever","en":"will raise","tr":"yabʿatha","isWaqf":false},{"position":8,"ar":"ٱللَّهُ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":9,"ar":"أَحَدًۭا","fr":"quiconque","en":"anyone","tr":"aḥadan","isWaqf":false}]},{"ayah":8,"verseKey":"72:8","juz":29,"arabic":"وَأَنَّا لَمَسْنَا ٱلسَّمَآءَ فَوَجَدْنَـٰهَا مُلِئَتْ حَرَسًا شَدِيدًا وَشُهُبًا","fr":"Nous nous sommes rapprochés du ciel et nous l’avons trouvé rempli de gardiens féroces et de météores.","en":"And we have sought [to reach] the heaven but found it filled with powerful guards and burning flames.","words":[{"position":1,"ar":"وَأَنَّا","fr":"Et que nous","en":"And that we","tr":"wa-annā","isWaqf":false},{"position":2,"ar":"لَمَسْنَا","fr":"chercha à toucher","en":"sought to touch","tr":"lamasnā","isWaqf":false},{"position":3,"ar":"ٱلسَّمَآءَ","fr":"le ciel","en":"the heaven","tr":"l-samāa","isWaqf":false},{"position":4,"ar":"فَوَجَدْنَـٰهَا","fr":"mais nous trouva cela","en":"but we found it","tr":"fawajadnāhā","isWaqf":false},{"position":5,"ar":"مُلِئَتْ","fr":"rempli (avec)","en":"filled (with)","tr":"muli-at","isWaqf":false},{"position":6,"ar":"حَرَسًۭا","fr":"garde","en":"guards","tr":"ḥarasan","isWaqf":false},{"position":7,"ar":"شَدِيدًۭا","fr":"sévère","en":"severe","tr":"shadīdan","isWaqf":false},{"position":8,"ar":"وَشُهُبًۭا","fr":"et flamboyant fires","en":"and flaming fires","tr":"washuhuban","isWaqf":false}]},{"ayah":9,"verseKey":"72:9","juz":29,"arabic":"وَأَنَّا كُنَّا نَقْعُدُ مِنْهَا مَقَـٰعِدَ لِلسَّمْعِ ۖ فَمَن يَسْتَمِعِ ٱلْـَٔانَ يَجِدْ لَهُۥ شِهَابًا رَّصَدًا","fr":"Nous pouvions nous y installer pour écouter (les secrets célestes), or quiconque prête l’oreille aujourd’hui verra fondre sur lui un météore à l’affût.","en":"And we used to sit therein in positions for hearing, but whoever listens now will find a burning flame lying in wait for him.","words":[{"position":1,"ar":"وَأَنَّا","fr":"Et que nous","en":"And that we","tr":"wa-annā","isWaqf":false},{"position":2,"ar":"كُنَّا","fr":"utilisé à","en":"used to","tr":"kunnā","isWaqf":false},{"position":3,"ar":"نَقْعُدُ","fr":"s'asseoir","en":"sit","tr":"naqʿudu","isWaqf":false},{"position":4,"ar":"مِنْهَا","fr":"là dans","en":"there in","tr":"min'hā","isWaqf":false},{"position":5,"ar":"مَقَـٰعِدَ","fr":"positions","en":"positions","tr":"maqāʿida","isWaqf":false},{"position":6,"ar":"لِلسَّمْعِ ۖ","fr":"pour ouïe","en":"for hearing","tr":"lilssamʿi","isWaqf":false},{"position":7,"ar":"فَمَن","fr":"mais (celui) qui","en":"but (he) who","tr":"faman","isWaqf":false},{"position":8,"ar":"يَسْتَمِعِ","fr":"écoute","en":"listens","tr":"yastamiʿi","isWaqf":false},{"position":9,"ar":"ٱلْـَٔانَ","fr":"maintenant","en":"now","tr":"l-āna","isWaqf":false},{"position":10,"ar":"يَجِدْ","fr":"va trouver","en":"will find","tr":"yajid","isWaqf":false},{"position":11,"ar":"لَهُۥ","fr":"pour lui","en":"for him","tr":"lahu","isWaqf":false},{"position":12,"ar":"شِهَابًۭا","fr":"un flamboyant feu","en":"a flaming fire","tr":"shihāban","isWaqf":false},{"position":13,"ar":"رَّصَدًۭا","fr":"attendant","en":"waiting","tr":"raṣadan","isWaqf":false}]},{"ayah":10,"verseKey":"72:10","juz":29,"arabic":"وَأَنَّا لَا نَدْرِىٓ أَشَرٌّ أُرِيدَ بِمَن فِى ٱلْأَرْضِ أَمْ أَرَادَ بِهِمْ رَبُّهُمْ رَشَدًا","fr":"Nous ne savons vraiment si un malheur est voulu à ceux qui sont sur terre, ou si leur Seigneur leur veut la voie de la droiture.","en":"And we do not know [therefore] whether evil is intended for those on earth or whether their Lord intends for them a right course.","words":[{"position":1,"ar":"وَأَنَّا","fr":"Et que nous","en":"And that we","tr":"wa-annā","isWaqf":false},{"position":2,"ar":"لَا","fr":"non","en":"not","tr":"lā","isWaqf":false},{"position":3,"ar":"نَدْرِىٓ","fr":"nous savoons","en":"we know","tr":"nadrī","isWaqf":false},{"position":4,"ar":"أَشَرٌّ","fr":"si mal","en":"whether evil","tr":"asharrun","isWaqf":false},{"position":5,"ar":"أُرِيدَ","fr":"est voulu","en":"is intended","tr":"urīda","isWaqf":false},{"position":6,"ar":"بِمَن","fr":"pour (ceux) qui","en":"for (those) who","tr":"biman","isWaqf":false},{"position":7,"ar":"فِى","fr":"(sont) dans","en":"(are) in","tr":"fī","isWaqf":false},{"position":8,"ar":"ٱلْأَرْضِ","fr":"la terre","en":"the earth","tr":"l-arḍi","isWaqf":false},{"position":9,"ar":"أَمْ","fr":"ou","en":"or","tr":"am","isWaqf":false},{"position":10,"ar":"أَرَادَ","fr":"vise","en":"intends","tr":"arāda","isWaqf":false},{"position":11,"ar":"بِهِمْ","fr":"pour eux","en":"for them","tr":"bihim","isWaqf":false},{"position":12,"ar":"رَبُّهُمْ","fr":"leur Seigneur","en":"their Lord","tr":"rabbuhum","isWaqf":false},{"position":13,"ar":"رَشَدًۭا","fr":"un droit chemin","en":"a right path","tr":"rashadan","isWaqf":false}]},{"ayah":11,"verseKey":"72:11","juz":29,"arabic":"وَأَنَّا مِنَّا ٱلصَّـٰلِحُونَ وَمِنَّا دُونَ ذَٰلِكَ ۖ كُنَّا طَرَآئِقَ قِدَدًا","fr":"Il en est parmi nous qui sont des gens de bien, et d’autres qui sont bien en deçà. C’est que nous sommes divisés en sectes différentes.","en":"And among us are the righteous, and among us are [others] not so; we were [of] divided ways.","words":[{"position":1,"ar":"وَأَنَّا","fr":"Et que [nous]","en":"And that [we]","tr":"wa-annā","isWaqf":false},{"position":2,"ar":"مِنَّا","fr":"parmi nous","en":"among us","tr":"minnā","isWaqf":false},{"position":3,"ar":"ٱلصَّـٰلِحُونَ","fr":"(sont) les justes","en":"(are) the righteous","tr":"l-ṣāliḥūna","isWaqf":false},{"position":4,"ar":"وَمِنَّا","fr":"et parmi nous","en":"and among us","tr":"waminnā","isWaqf":false},{"position":5,"ar":"دُونَ","fr":"(sont) autre que","en":"(are) other than","tr":"dūna","isWaqf":false},{"position":6,"ar":"ذَٰلِكَ ۖ","fr":"que","en":"that","tr":"dhālika","isWaqf":false},{"position":7,"ar":"كُنَّا","fr":"Nous","en":"We","tr":"kunnā","isWaqf":false},{"position":8,"ar":"طَرَآئِقَ","fr":"(sont sur) voies","en":"(are on) ways","tr":"ṭarāiqa","isWaqf":false},{"position":9,"ar":"قِدَدًۭا","fr":"différent","en":"different","tr":"qidadan","isWaqf":false}]},{"ayah":12,"verseKey":"72:12","juz":29,"arabic":"وَأَنَّا ظَنَنَّآ أَن لَّن نُّعْجِزَ ٱللَّهَ فِى ٱلْأَرْضِ وَلَن نُّعْجِزَهُۥ هَرَبًا","fr":"Nous savions pertinemment que nous ne saurions défier la puissance d’Allah sur terre, ni Le tenir en échec en prenant la fuite.","en":"And we have become certain that we will never cause failure to Allāh upon earth, nor can we escape Him by flight.","words":[{"position":1,"ar":"وَأَنَّا","fr":"Et que nous","en":"And that we","tr":"wa-annā","isWaqf":false},{"position":2,"ar":"ظَنَنَّآ","fr":"[nous] ont devenir certain","en":"[we] have become certain","tr":"ẓanannā","isWaqf":false},{"position":3,"ar":"أَن","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":4,"ar":"لَّن","fr":"jamais","en":"never","tr":"lan","isWaqf":false},{"position":5,"ar":"نُّعْجِزَ","fr":"nous va faire échec","en":"we will cause failure","tr":"nuʿ'jiza","isWaqf":false},{"position":6,"ar":"ٱللَّهَ","fr":"(à) Allah","en":"(to) Allah","tr":"l-laha","isWaqf":false},{"position":7,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":8,"ar":"ٱلْأَرْضِ","fr":"la terre","en":"the earth","tr":"l-arḍi","isWaqf":false},{"position":9,"ar":"وَلَن","fr":"et jamais","en":"and never","tr":"walan","isWaqf":false},{"position":10,"ar":"نُّعْجِزَهُۥ","fr":"nous peut échapper Lui","en":"we can escape Him","tr":"nuʿ'jizahu","isWaqf":false},{"position":11,"ar":"هَرَبًۭا","fr":"(par) fuite","en":"(by) flight","tr":"haraban","isWaqf":false}]},{"ayah":13,"verseKey":"72:13","juz":29,"arabic":"وَأَنَّا لَمَّا سَمِعْنَا ٱلْهُدَىٰٓ ءَامَنَّا بِهِۦ ۖ فَمَن يُؤْمِنۢ بِرَبِّهِۦ فَلَا يَخَافُ بَخْسًا وَلَا رَهَقًا","fr":"Lorsque nous avons entendu (le Livre) de la direction sûre (hudâ), nous y avons cru. Or, quiconque croit en son Seigneur n’aura à craindre nulle injustice et nul accablement.","en":"And when we heard the guidance [i.e., the Qur’ān], we believed in it. And whoever believes in his Lord will not fear deprivation or burden.","words":[{"position":1,"ar":"وَأَنَّا","fr":"Et que [nous]","en":"And that [we]","tr":"wa-annā","isWaqf":false},{"position":2,"ar":"لَمَّا","fr":"quand","en":"when","tr":"lammā","isWaqf":false},{"position":3,"ar":"سَمِعْنَا","fr":"nous entendu","en":"we heard","tr":"samiʿ'nā","isWaqf":false},{"position":4,"ar":"ٱلْهُدَىٰٓ","fr":"le Bonne direction","en":"the Guidance","tr":"l-hudā","isWaqf":false},{"position":5,"ar":"ءَامَنَّا","fr":"nous a cru","en":"we believed","tr":"āmannā","isWaqf":false},{"position":6,"ar":"بِهِۦ ۖ","fr":"dans cela","en":"in it","tr":"bihi","isWaqf":false},{"position":7,"ar":"فَمَن","fr":"Et quiconque","en":"And whoever","tr":"faman","isWaqf":false},{"position":8,"ar":"يُؤْمِنۢ","fr":"croit","en":"believes","tr":"yu'min","isWaqf":false},{"position":9,"ar":"بِرَبِّهِۦ","fr":"dans son Seigneur","en":"in his Lord","tr":"birabbihi","isWaqf":false},{"position":10,"ar":"فَلَا","fr":"puis non","en":"then not","tr":"falā","isWaqf":false},{"position":11,"ar":"يَخَافُ","fr":"il va craindre","en":"he will fear","tr":"yakhāfu","isWaqf":false},{"position":12,"ar":"بَخْسًۭا","fr":"tout perte","en":"any loss","tr":"bakhsan","isWaqf":false},{"position":13,"ar":"وَلَا","fr":"et non","en":"and not","tr":"walā","isWaqf":false},{"position":14,"ar":"رَهَقًۭا","fr":"tout fardeau","en":"any burden","tr":"rahaqan","isWaqf":false}]},{"ayah":14,"verseKey":"72:14","juz":29,"arabic":"وَأَنَّا مِنَّا ٱلْمُسْلِمُونَ وَمِنَّا ٱلْقَـٰسِطُونَ ۖ فَمَنْ أَسْلَمَ فَأُو۟لَـٰٓئِكَ تَحَرَّوْا۟ رَشَدًا","fr":"Certains d’entre nous sont Musulmans, tandis que d’autres sont injustes. Ceux qui ont embrassé l’islam, ceux-là ont choisi la voie la plus droite.","en":"And among us are Muslims [in submission to Allāh], and among us are the unjust. And whoever has become Muslim - those have sought out the right course.","words":[{"position":1,"ar":"وَأَنَّا","fr":"Et que nous","en":"And that we","tr":"wa-annā","isWaqf":false},{"position":2,"ar":"مِنَّا","fr":"parmi nous","en":"among us","tr":"minnā","isWaqf":false},{"position":3,"ar":"ٱلْمُسْلِمُونَ","fr":"(sont) Musulmans","en":"(are) Muslims","tr":"l-mus'limūna","isWaqf":false},{"position":4,"ar":"وَمِنَّا","fr":"et parmi nous","en":"and among us","tr":"waminnā","isWaqf":false},{"position":5,"ar":"ٱلْقَـٰسِطُونَ ۖ","fr":"(sont) injuste","en":"(are) unjust","tr":"l-qāsiṭūna","isWaqf":false},{"position":6,"ar":"فَمَنْ","fr":"Et quiconque","en":"And whoever","tr":"faman","isWaqf":false},{"position":7,"ar":"أَسْلَمَ","fr":"se soumet","en":"submits","tr":"aslama","isWaqf":false},{"position":8,"ar":"فَأُو۟لَـٰٓئِكَ","fr":"puis ceux","en":"then those","tr":"fa-ulāika","isWaqf":false},{"position":9,"ar":"تَحَرَّوْا۟","fr":"ont chercha","en":"have sought","tr":"taḥarraw","isWaqf":false},{"position":10,"ar":"رَشَدًۭا","fr":"(le) droit chemin","en":"(the) right path","tr":"rashadan","isWaqf":false}]},{"ayah":15,"verseKey":"72:15","juz":29,"arabic":"وَأَمَّا ٱلْقَـٰسِطُونَ فَكَانُوا۟ لِجَهَنَّمَ حَطَبًا","fr":"Quant aux injustes, ils seront le bois qui alimentera la Géhenne.” »","en":"But as for the unjust, they will be, for Hell, firewood.'","words":[{"position":1,"ar":"وَأَمَّا","fr":"Et quant à","en":"And as for","tr":"wa-ammā","isWaqf":false},{"position":2,"ar":"ٱلْقَـٰسِطُونَ","fr":"l’injuste","en":"the unjust","tr":"l-qāsiṭūna","isWaqf":false},{"position":3,"ar":"فَكَانُوا۟","fr":"ils sera","en":"they will be","tr":"fakānū","isWaqf":false},{"position":4,"ar":"لِجَهَنَّمَ","fr":"pour l'Enfer","en":"for Hell","tr":"lijahannama","isWaqf":false},{"position":5,"ar":"حَطَبًۭا","fr":"bois de chauffage","en":"firewood","tr":"ḥaṭaban","isWaqf":false}]},{"ayah":16,"verseKey":"72:16","juz":29,"arabic":"وَأَلَّوِ ٱسْتَقَـٰمُوا۟ عَلَى ٱلطَّرِيقَةِ لَأَسْقَيْنَـٰهُم مَّآءً غَدَقًا","fr":"Or, s’ils s’étaient engagés sur la voie droite, Nous les aurions certes abreuvés d’une eau généreuse,","en":"And [Allāh revealed] that if they had remained straight on the way, We would have given them abundant rain [i.e., provision].","words":[{"position":1,"ar":"وَأَلَّوِ","fr":"Et que si","en":"And that if","tr":"wa-allawi","isWaqf":false},{"position":2,"ar":"ٱسْتَقَـٰمُوا۟","fr":"ils avait demeura","en":"they had remained","tr":"is'taqāmū","isWaqf":false},{"position":3,"ar":"عَلَى","fr":"sur","en":"on","tr":"ʿalā","isWaqf":false},{"position":4,"ar":"ٱلطَّرِيقَةِ","fr":"le Voie","en":"the Way","tr":"l-ṭarīqati","isWaqf":false},{"position":5,"ar":"لَأَسْقَيْنَـٰهُم","fr":"assurément Nous (irait) ont donné eux à boire","en":"surely We (would) have given them to drink","tr":"la-asqaynāhum","isWaqf":false},{"position":6,"ar":"مَّآءً","fr":"eau","en":"water","tr":"māan","isWaqf":false},{"position":7,"ar":"غَدَقًۭا","fr":"(dans) abondance","en":"(in) abundance","tr":"ghadaqan","isWaqf":false}]},{"ayah":17,"verseKey":"72:17","juz":29,"arabic":"لِّنَفْتِنَهُمْ فِيهِ ۚ وَمَن يُعْرِضْ عَن ذِكْرِ رَبِّهِۦ يَسْلُكْهُ عَذَابًا صَعَدًا","fr":"qui eût été pour eux une épreuve. Mais quiconque se détourne du rappel de son Seigneur, Celui-ci le fera conduire vers un supplice sans cesse augmentant.","en":"So We might test them therein. And whoever turns away from the remembrance of his Lord He will put into arduous punishment.","words":[{"position":1,"ar":"لِّنَفْتِنَهُمْ","fr":"Ce Nous pourrait tester eux","en":"That We might test them","tr":"linaftinahum","isWaqf":false},{"position":2,"ar":"فِيهِ ۚ","fr":"en cela","en":"therein","tr":"fīhi","isWaqf":false},{"position":3,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":4,"ar":"يُعْرِضْ","fr":"se détourne","en":"turns away","tr":"yuʿ'riḍ","isWaqf":false},{"position":5,"ar":"عَن","fr":"de","en":"from","tr":"ʿan","isWaqf":false},{"position":6,"ar":"ذِكْرِ","fr":"le Rappel","en":"the Remembrance","tr":"dhik'ri","isWaqf":false},{"position":7,"ar":"رَبِّهِۦ","fr":"(de) son Seigneur","en":"(of) his Lord","tr":"rabbihi","isWaqf":false},{"position":8,"ar":"يَسْلُكْهُ","fr":"Il va faire lui entrer","en":"He will make him enter","tr":"yasluk'hu","isWaqf":false},{"position":9,"ar":"عَذَابًۭا","fr":"un châtiment","en":"a punishment","tr":"ʿadhāban","isWaqf":false},{"position":10,"ar":"صَعَدًۭا","fr":"sévère","en":"severe","tr":"ṣaʿadan","isWaqf":false}]},{"ayah":18,"verseKey":"72:18","juz":29,"arabic":"وَأَنَّ ٱلْمَسَـٰجِدَ لِلَّهِ فَلَا تَدْعُوا۟ مَعَ ٱللَّهِ أَحَدًا","fr":"Les mosquées sont à Allah Seul ; n’y invoquez donc personne avec Lui.","en":"And [He revealed] that the masjids are for Allāh, so do not invoke with Allāh anyone.","words":[{"position":1,"ar":"وَأَنَّ","fr":"Et que","en":"And that","tr":"wa-anna","isWaqf":false},{"position":2,"ar":"ٱلْمَسَـٰجِدَ","fr":"le masjids","en":"the masjids","tr":"l-masājida","isWaqf":false},{"position":3,"ar":"لِلَّهِ","fr":"(sont) pour Allah","en":"(are) for Allah","tr":"lillahi","isWaqf":false},{"position":4,"ar":"فَلَا","fr":"donc (ne) fais pas","en":"so (do) not","tr":"falā","isWaqf":false},{"position":5,"ar":"تَدْعُوا۟","fr":"appeler","en":"call","tr":"tadʿū","isWaqf":false},{"position":6,"ar":"مَعَ","fr":"avec","en":"with","tr":"maʿa","isWaqf":false},{"position":7,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":8,"ar":"أَحَدًۭا","fr":"quiconque","en":"anyone","tr":"aḥadan","isWaqf":false}]},{"ayah":19,"verseKey":"72:19","juz":29,"arabic":"وَأَنَّهُۥ لَمَّا قَامَ عَبْدُ ٱللَّهِ يَدْعُوهُ كَادُوا۟ يَكُونُونَ عَلَيْهِ لِبَدًا","fr":"Et lorsque le serviteur d’Allah se fut levé pour L’invoquer, ils (les djinns) se bousculèrent vers lui.","en":"And that when the Servant [i.e., Prophet] of Allāh stood up supplicating Him, they almost became about him a compacted mass.\"","words":[{"position":1,"ar":"وَأَنَّهُۥ","fr":"Et que","en":"And that","tr":"wa-annahu","isWaqf":false},{"position":2,"ar":"لَمَّا","fr":"quand","en":"when","tr":"lammā","isWaqf":false},{"position":3,"ar":"قَامَ","fr":"se tint haut","en":"stood up","tr":"qāma","isWaqf":false},{"position":4,"ar":"عَبْدُ","fr":"(le) serviteur","en":"(the) slave","tr":"ʿabdu","isWaqf":false},{"position":5,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":6,"ar":"يَدْعُوهُ","fr":"appelant (sur) Lui","en":"calling (upon) Him","tr":"yadʿūhu","isWaqf":false},{"position":7,"ar":"كَادُوا۟","fr":"ils presque","en":"they almost","tr":"kādū","isWaqf":false},{"position":8,"ar":"يَكُونُونَ","fr":"devint","en":"became","tr":"yakūnūna","isWaqf":false},{"position":9,"ar":"عَلَيْهِ","fr":"autour lui","en":"around him","tr":"ʿalayhi","isWaqf":false},{"position":10,"ar":"لِبَدًۭا","fr":"un compacted masse","en":"a compacted mass","tr":"libadan","isWaqf":false}]},{"ayah":20,"verseKey":"72:20","juz":29,"arabic":"قُلْ إِنَّمَآ أَدْعُوا۟ رَبِّى وَلَآ أُشْرِكُ بِهِۦٓ أَحَدًا","fr":"Dis : « Je ne fais que prier mon Seigneur, et je ne Lui prête aucun associé. »","en":"Say, [O Muḥammad], \"I only invoke my Lord and do not associate with Him anyone.\"","words":[{"position":1,"ar":"قُلْ","fr":"Dis","en":"Say","tr":"qul","isWaqf":false},{"position":2,"ar":"إِنَّمَآ","fr":"Seulement","en":"Only","tr":"innamā","isWaqf":false},{"position":3,"ar":"أَدْعُوا۟","fr":"J’Appele sur","en":"I call upon","tr":"adʿū","isWaqf":false},{"position":4,"ar":"رَبِّى","fr":"mon Seigneur","en":"my Lord","tr":"rabbī","isWaqf":false},{"position":5,"ar":"وَلَآ","fr":"et non","en":"and not","tr":"walā","isWaqf":false},{"position":6,"ar":"أُشْرِكُ","fr":"J’Associe","en":"I associate","tr":"ush'riku","isWaqf":false},{"position":7,"ar":"بِهِۦٓ","fr":"avec Lui","en":"with Him","tr":"bihi","isWaqf":false},{"position":8,"ar":"أَحَدًۭا","fr":"quiconque","en":"anyone","tr":"aḥadan","isWaqf":false}]},{"ayah":21,"verseKey":"72:21","juz":29,"arabic":"قُلْ إِنِّى لَآ أَمْلِكُ لَكُمْ ضَرًّا وَلَا رَشَدًا","fr":"Dis : « Je ne saurais ni vous nuire ni vous conduire vers le chemin de la droiture. »","en":"Say, \"Indeed, I do not possess for you [the power of] harm or right direction.\"","words":[{"position":1,"ar":"قُلْ","fr":"Dis","en":"Say","tr":"qul","isWaqf":false},{"position":2,"ar":"إِنِّى","fr":"Certes, je","en":"Indeed, I","tr":"innī","isWaqf":false},{"position":3,"ar":"لَآ","fr":"(fais) non","en":"(do) not","tr":"lā","isWaqf":false},{"position":4,"ar":"أَمْلِكُ","fr":"posséder","en":"possess","tr":"amliku","isWaqf":false},{"position":5,"ar":"لَكُمْ","fr":"pour vous","en":"for you","tr":"lakum","isWaqf":false},{"position":6,"ar":"ضَرًّۭا","fr":"aucun mal","en":"any harm","tr":"ḍarran","isWaqf":false},{"position":7,"ar":"وَلَا","fr":"et non","en":"and not","tr":"walā","isWaqf":false},{"position":8,"ar":"رَشَدًۭا","fr":"droit chemin","en":"right path","tr":"rashadan","isWaqf":false}]},{"ayah":22,"verseKey":"72:22","juz":29,"arabic":"قُلْ إِنِّى لَن يُجِيرَنِى مِنَ ٱللَّهِ أَحَدٌ وَلَنْ أَجِدَ مِن دُونِهِۦ مُلْتَحَدًا","fr":"Dis encore : « Nul ne saurait me protéger contre Allah, et je ne saurais (à mon tour) trouver refuge en dehors de Lui.","en":"Say, \"Indeed, there will never protect me from Allāh anyone [if I should disobey], nor will I find in other than Him a refuge.","words":[{"position":1,"ar":"قُلْ","fr":"Dis","en":"Say","tr":"qul","isWaqf":false},{"position":2,"ar":"إِنِّى","fr":"Certes je","en":"Indeed I","tr":"innī","isWaqf":false},{"position":3,"ar":"لَن","fr":"jamais","en":"never","tr":"lan","isWaqf":false},{"position":4,"ar":"يُجِيرَنِى","fr":"peut protéger moi","en":"can protect me","tr":"yujīranī","isWaqf":false},{"position":5,"ar":"مِنَ","fr":"de","en":"from","tr":"mina","isWaqf":false},{"position":6,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":7,"ar":"أَحَدٌۭ","fr":"quiconque","en":"anyone","tr":"aḥadun","isWaqf":false},{"position":8,"ar":"وَلَنْ","fr":"et jamais","en":"and never","tr":"walan","isWaqf":false},{"position":9,"ar":"أَجِدَ","fr":"peut Je Trouve","en":"can I find","tr":"ajida","isWaqf":false},{"position":10,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":11,"ar":"دُونِهِۦ","fr":"hormis Lui","en":"besides Him","tr":"dūnihi","isWaqf":false},{"position":12,"ar":"مُلْتَحَدًا","fr":"tout refuge","en":"any refuge","tr":"mul'taḥadan","isWaqf":false}]},{"ayah":23,"verseKey":"72:23","juz":29,"arabic":"إِلَّا بَلَـٰغًا مِّنَ ٱللَّهِ وَرِسَـٰلَـٰتِهِۦ ۚ وَمَن يَعْصِ ٱللَّهَ وَرَسُولَهُۥ فَإِنَّ لَهُۥ نَارَ جَهَنَّمَ خَـٰلِدِينَ فِيهَآ أَبَدًا","fr":"(Seul est en mon pouvoir) de transmettre des informations de la part d’Allah et (de vous communiquer) Ses Messages. Et quiconque désobéit à Allah et à Son Messager aura la Géhenne pour y séjourner à tout jamais. »","en":"But [I have for you] only notification from Allāh, and His messages.\" And whoever disobeys Allāh and His Messenger - then indeed, for him is the fire of Hell; they will abide therein forever.","words":[{"position":1,"ar":"إِلَّا","fr":"Mais","en":"But","tr":"illā","isWaqf":false},{"position":2,"ar":"بَلَـٰغًۭا","fr":"(le) annonce","en":"(the) notification","tr":"balāghan","isWaqf":false},{"position":3,"ar":"مِّنَ","fr":"de","en":"from","tr":"mina","isWaqf":false},{"position":4,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":5,"ar":"وَرِسَـٰلَـٰتِهِۦ ۚ","fr":"et Son Messages","en":"and His Messages","tr":"warisālātihi","isWaqf":false},{"position":6,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":7,"ar":"يَعْصِ","fr":"désobéit","en":"disobeys","tr":"yaʿṣi","isWaqf":false},{"position":8,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":9,"ar":"وَرَسُولَهُۥ","fr":"et Son Messager","en":"and His Messenger","tr":"warasūlahu","isWaqf":false},{"position":10,"ar":"فَإِنَّ","fr":"puis certes","en":"then indeed","tr":"fa-inna","isWaqf":false},{"position":11,"ar":"لَهُۥ","fr":"pour lui","en":"for him","tr":"lahu","isWaqf":false},{"position":12,"ar":"نَارَ","fr":"(est le) Feu","en":"(is the) Fire","tr":"nāra","isWaqf":false},{"position":13,"ar":"جَهَنَّمَ","fr":"(de) l'Enfer","en":"(of) Hell","tr":"jahannama","isWaqf":false},{"position":14,"ar":"خَـٰلِدِينَ","fr":"(ils va) demeurer","en":"(they will) abide","tr":"khālidīna","isWaqf":false},{"position":15,"ar":"فِيهَآ","fr":"en cela","en":"therein","tr":"fīhā","isWaqf":false},{"position":16,"ar":"أَبَدًا","fr":"pour toujours","en":"forever","tr":"abadan","isWaqf":false}]},{"ayah":24,"verseKey":"72:24","juz":29,"arabic":"حَتَّىٰٓ إِذَا رَأَوْا۟ مَا يُوعَدُونَ فَسَيَعْلَمُونَ مَنْ أَضْعَفُ نَاصِرًا وَأَقَلُّ عَدَدًا","fr":"Lorsqu’ils auront vu ce dont ils sont menacés, ils sauront qui sera plus faible en soutien et moins pourvu en nombre.","en":"[The disbelievers continue] until, when they see that which they are promised, then they will know who is weaker in helpers and less in number.","words":[{"position":1,"ar":"حَتَّىٰٓ","fr":"Jusqu'à","en":"Until","tr":"ḥattā","isWaqf":false},{"position":2,"ar":"إِذَا","fr":"quand","en":"when","tr":"idhā","isWaqf":false},{"position":3,"ar":"رَأَوْا۟","fr":"ils voient","en":"they see","tr":"ra-aw","isWaqf":false},{"position":4,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":5,"ar":"يُوعَدُونَ","fr":"ils sont promis","en":"they are promised","tr":"yūʿadūna","isWaqf":false},{"position":6,"ar":"فَسَيَعْلَمُونَ","fr":"puis ils va savoir","en":"then they will know","tr":"fasayaʿlamūna","isWaqf":false},{"position":7,"ar":"مَنْ","fr":"qui","en":"who","tr":"man","isWaqf":false},{"position":8,"ar":"أَضْعَفُ","fr":"(est) plus faible","en":"(is) weaker","tr":"aḍʿafu","isWaqf":false},{"position":9,"ar":"نَاصِرًۭا","fr":"(dans) auxiliaires","en":"(in) helpers","tr":"nāṣiran","isWaqf":false},{"position":10,"ar":"وَأَقَلُّ","fr":"et fewer","en":"and fewer","tr":"wa-aqallu","isWaqf":false},{"position":11,"ar":"عَدَدًۭا","fr":"(dans) nombre","en":"(in) number","tr":"ʿadadan","isWaqf":false}]},{"ayah":25,"verseKey":"72:25","juz":29,"arabic":"قُلْ إِنْ أَدْرِىٓ أَقَرِيبٌ مَّا تُوعَدُونَ أَمْ يَجْعَلُ لَهُۥ رَبِّىٓ أَمَدًا","fr":"Dis : « Je ne sais si ce dont vous êtes menacés est imminent, ou si mon Seigneur lui a fixé un terme différé.","en":"Say, \"I do not know if what you are promised is near or if my Lord will grant for it a [long] period.\"","words":[{"position":1,"ar":"قُلْ","fr":"Dis","en":"Say","tr":"qul","isWaqf":false},{"position":2,"ar":"إِنْ","fr":"Non","en":"Not","tr":"in","isWaqf":false},{"position":3,"ar":"أَدْرِىٓ","fr":"Je Savoe","en":"I know","tr":"adrī","isWaqf":false},{"position":4,"ar":"أَقَرِيبٌۭ","fr":"si est proche","en":"whether is near","tr":"aqarībun","isWaqf":false},{"position":5,"ar":"مَّا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":6,"ar":"تُوعَدُونَ","fr":"vous sont promis","en":"you are promised","tr":"tūʿadūna","isWaqf":false},{"position":7,"ar":"أَمْ","fr":"ou (si)","en":"or (whether)","tr":"am","isWaqf":false},{"position":8,"ar":"يَجْعَلُ","fr":"va désigner","en":"will appoint","tr":"yajʿalu","isWaqf":false},{"position":9,"ar":"لَهُۥ","fr":"pour cela","en":"for it","tr":"lahu","isWaqf":false},{"position":10,"ar":"رَبِّىٓ","fr":"mon Seigneur","en":"my Lord","tr":"rabbī","isWaqf":false},{"position":11,"ar":"أَمَدًا","fr":"un (lointain) terme","en":"a (distant) term","tr":"amadan","isWaqf":false}]},{"ayah":26,"verseKey":"72:26","juz":29,"arabic":"عَـٰلِمُ ٱلْغَيْبِ فَلَا يُظْهِرُ عَلَىٰ غَيْ