[{"ayah":1,"verseKey":"95:1","juz":30,"arabic":"بِّسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلتِّينِ وَٱلزَّيْتُونِ","fr":"Par le figuier et l’olivier !","en":"By the fig and the olive","words":[{"position":1,"ar":"وَٱلتِّينِ","fr":"Par le fig","en":"By the fig","tr":"wal-tīni","isWaqf":false},{"position":2,"ar":"وَٱلزَّيْتُونِ","fr":"et l’olive","en":"and the olive","tr":"wal-zaytūni","isWaqf":false}]},{"ayah":2,"verseKey":"95:2","juz":30,"arabic":"وَطُورِ سِينِينَ","fr":"Par le mont Sinaï !","en":"And [by] Mount Sinai","words":[{"position":1,"ar":"وَطُورِ","fr":"Et (le) Monter","en":"And (the) Mount","tr":"waṭūri","isWaqf":false},{"position":2,"ar":"سِينِينَ","fr":"Sinai","en":"Sinai","tr":"sīnīna","isWaqf":false}]},{"ayah":3,"verseKey":"95:3","juz":30,"arabic":"وَهَـٰذَا ٱلْبَلَدِ ٱلْأَمِينِ","fr":"Par cette cité si sûre !","en":"And [by] this secure city [i.e., Makkah],","words":[{"position":1,"ar":"وَهَـٰذَا","fr":"Et ceci","en":"And this","tr":"wahādhā","isWaqf":false},{"position":2,"ar":"ٱلْبَلَدِ","fr":"[le] cité","en":"[the] city","tr":"l-baladi","isWaqf":false},{"position":3,"ar":"ٱلْأَمِينِ","fr":"[le] en sécurité","en":"[the] secure","tr":"l-amīni","isWaqf":false}]},{"ayah":4,"verseKey":"95:4","juz":30,"arabic":"لَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ فِىٓ أَحْسَنِ تَقْوِيمٍ","fr":"Nous avons créé l’homme dans la meilleure forme qui soit.","en":"We have certainly created man in the best of stature;","words":[{"position":1,"ar":"لَقَدْ","fr":"Certes","en":"Indeed","tr":"laqad","isWaqf":false},{"position":2,"ar":"خَلَقْنَا","fr":"Nous avons créé","en":"We created","tr":"khalaqnā","isWaqf":false},{"position":3,"ar":"ٱلْإِنسَـٰنَ","fr":"homme","en":"man","tr":"l-insāna","isWaqf":false},{"position":4,"ar":"فِىٓ","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":5,"ar":"أَحْسَنِ","fr":"(le) le meilleur","en":"(the) best","tr":"aḥsani","isWaqf":false},{"position":6,"ar":"تَقْوِيمٍۢ","fr":"moule","en":"mould","tr":"taqwīmin","isWaqf":false}]},{"ayah":5,"verseKey":"