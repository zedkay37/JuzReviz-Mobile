":false},{"position":2,"ar":"عَلَيْنَا","fr":"sur Nous","en":"upon Us","tr":"ʿalaynā","isWaqf":false},{"position":3,"ar":"لَلْهُدَىٰ","fr":"(est) la bonne direction","en":"(is) the guidance","tr":"lalhudā","isWaqf":false}]},{"ayah":13,"verseKey":"92:13","juz":30,"arabic":"وَإِنَّ لَنَا لَلْـَٔاخِرَةَ وَٱلْأُولَىٰ","fr":"À Nous appartiennent la vie dans l’autre monde et la vie en ce bas monde.","en":"And indeed, to us belongs the Hereafter and the first [life].","words":[{"position":1,"ar":"وَإِنَّ","fr":"Et certes","en":"And indeed","tr":"wa-inna","isWaqf":false},{"position":2,"ar":"لَنَا","fr":"pour Nous","en":"for Us","tr":"lanā","isWaqf":false},{"position":3,"ar":"لَلْـَٔاخِرَةَ","fr":"(est) l'Au-delà","en":"(is) the Hereafter","tr":"lalākhirata","isWaqf":false},{"position":4,"ar":"وَٱلْأُولَىٰ","fr":"et le premier (vie)","en":"and the first (life)","tr":"wal-ūlā","isWaqf":false}]},{"ayah":14,"verseKey":"92:14","juz":30,"arabic":"فَأَنذَرْتُكُمْ نَارًا تَلَظَّىٰ","fr":"Je vous mets en garde contre un Feu dévorant,","en":"So I have warned you of a Fire which is blazing.","words":[{"position":1,"ar":"فَأَنذَرْتُكُمْ","fr":"Donc J’Avertis vous","en":"So I warn you","tr":"fa-andhartukum","isWaqf":false},{"position":2,"ar":"نَارًۭا","fr":"(de) un Feu","en":"(of) a Fire","tr":"nāran","isWaqf":false},{"position":3,"ar":"تَلَظَّىٰ","fr":"ardent","en":"blazing","tr":"talaẓẓā","isWaqf":false}]},{"ayah":15,"verseKey":"92:15","juz":30,"arabic":"لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى","fr":"où ne brûlera que le réprouvé,","en":"None will [enter to] burn therein except the most wretched one","words":[{"position":1,"ar":"لَا","fr":"Non","en":"Not","tr":"lā","isWaqf":false},{"position":2,"ar":"يَصْلَىٰهَآ","fr":"va brûler (dans) cela","en":"will burn (in) it","tr":"yaṣlāhā","isWaqf":false},{"position":3,"ar":"إِلَّا","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":4,"ar":"ٱلْأَشْقَى","fr":"le plus misérable","en":"the most wretched","tr":"l-ashqā","isWaqf":false}]