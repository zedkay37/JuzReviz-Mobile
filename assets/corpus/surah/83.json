that Day","tr":"yawma-idhin","isWaqf":false},{"position":3,"ar":"لِّلْمُكَذِّبِينَ","fr":"aux négateurs","en":"to the deniers","tr":"lil'mukadhibīna","isWaqf":false}]},{"ayah":11,"verseKey":"83:11","juz":30,"arabic":"ٱلَّذِينَ يُكَذِّبُونَ بِيَوْمِ ٱلدِّينِ","fr":"qui tiennent pour imposture le Jour de la Rétribution.","en":"Who deny the Day of Recompense.","words":[{"position":1,"ar":"ٱلَّذِينَ","fr":"Ceux qui","en":"Those who","tr":"alladhīna","isWaqf":false},{"position":2,"ar":"يُكَذِّبُونَ","fr":"nier","en":"deny","tr":"yukadhibūna","isWaqf":false},{"position":3,"ar":"بِيَوْمِ","fr":"(le) Jour","en":"(the) Day","tr":"biyawmi","isWaqf":false},{"position":4,"ar":"ٱلدِّينِ","fr":"(du) Jugement","en":"(of) the Judgment","tr":"l-dīni","isWaqf":false}]},{"ayah":12,"verseKey":"83:12","juz":30,"arabic":"وَمَا يُكَذِّبُ بِهِۦٓ إِلَّا كُلُّ مُعْتَدٍ أَثِيمٍ","fr":"Or seul (l’homme pervers), livré à ses abus et à ses péchés, tient ce jour pour mensonge.","en":"And none deny it except every sinful transgressor.","words":[{"position":1,"ar":"وَمَا","fr":"Et non","en":"And not","tr":"wamā","isWaqf":false},{"position":2,"ar":"يُكَذِّبُ","fr":"peut nier","en":"can deny","tr":"yukadhibu","isWaqf":false},{"position":3,"ar":"بِهِۦٓ","fr":"[de] cela","en":"[of] it","tr":"bihi","isWaqf":false},{"position":4,"ar":"إِلَّا","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":5,"ar":"كُلُّ","fr":"chaque","en":"every","tr":"kullu","isWaqf":false},{"position":6,"ar":"مُعْتَدٍ","fr":"transgresseur","en":"transgressor","tr":"muʿ'tadin","isWaqf":false},{"position":7,"ar":"أَثِيمٍ","fr":"pécheur","en":"sinful","tr":"athīmin","isWaqf":false}]},{"ayah":13,"verseKey":"83:13","juz":30,"arabic":"إِذَا تُتْلَىٰ عَلَيْهِ ءَايَـٰتُنَا قَالَ أَسَـٰطِيرُ ٱلْأَوَّلِينَ","fr":"Quand Nos versets lui sont récités, il dit : « Ce ne sont que fables d’anciens ! »","en":"When Our verses are recited to him, he says, \"Legends of the former peoples.\"","words":[{"position":1,"ar":"إِذَا","fr":"Quan