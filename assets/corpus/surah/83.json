","en":"(the) radiance","tr":"naḍrata","isWaqf":false},{"position":5,"ar":"ٱلنَّعِيمِ","fr":"(de) félicité","en":"(of) bliss","tr":"l-naʿīmi","isWaqf":false}]},{"ayah":25,"verseKey":"83:25","juz":30,"arabic":"يُسْقَوْنَ مِن رَّحِيقٍ مَّخْتُومٍ","fr":"Il leur sera servi à boire d’un nectar cacheté.","en":"They will be given to drink [pure] wine [which was] sealed.","words":[{"position":1,"ar":"يُسْقَوْنَ","fr":"Ils va être donné à boire","en":"They will be given to drink","tr":"yus'qawna","isWaqf":false},{"position":2,"ar":"مِن","fr":"de","en":"of","tr":"min","isWaqf":false},{"position":3,"ar":"رَّحِيقٍۢ","fr":"un pur vin","en":"a pure wine","tr":"raḥīqin","isWaqf":false},{"position":4,"ar":"مَّخْتُومٍ","fr":"scella","en":"sealed","tr":"makhtūmin","isWaqf":false}]},{"ayah":26,"verseKey":"83:26","juz":30,"arabic":"خِتَـٰمُهُۥ مِسْكٌ ۚ وَفِى ذَٰلِكَ فَلْيَتَنَافَسِ ٱلْمُتَنَـٰفِسُونَ","fr":"Son cachet sera de musc : voilà (un objectif) pour ceux qui voudraient rivaliser (de ferveur pour l’atteindre) !","en":"The last of it is musk. So for this let the competitors compete.","words":[{"position":1,"ar":"خِتَـٰمُهُۥ","fr":"Son sceau","en":"Its seal","tr":"khitāmuhu","isWaqf":false},{"position":2,"ar":"مِسْكٌۭ ۚ","fr":"(va être de) musk","en":"(will be of) musk","tr":"mis'kun","isWaqf":false},{"position":3,"ar":"وَفِى","fr":"Et pour","en":"And for","tr":"wafī","isWaqf":false},{"position":4,"ar":"ذَٰلِكَ","fr":"que","en":"that","tr":"dhālika","isWaqf":false},{"position":5,"ar":"فَلْيَتَنَافَسِ","fr":"laisser aspire","en":"let aspire","tr":"falyatanāfasi","isWaqf":false},{"position":6,"ar":"ٱلْمُتَنَـٰفِسُونَ","fr":"les aspirants","en":"the aspirers","tr":"l-mutanāfisūna","isWaqf":false}]},{"ayah":27,"verseKey":"83:27","juz":30,"arabic":"وَمِزَاجُهُۥ مِن تَسْنِيمٍ","fr":"(Et ce nectar) sera mélangé à l’eau de Tasnîm,","en":"And its mixture is of Tasneem,","words":[{"position":1,"ar":"وَمِزَاجُهُۥ","fr":"Et son mélange","en":"And its mixture","tr":"wamizājuhu","isWaqf":false}