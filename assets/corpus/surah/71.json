[{"ayah":1,"verseKey":"71:1","juz":29,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِنَّآ أَرْسَلْنَا نُوحًا إِلَىٰ قَوْمِهِۦٓ أَنْ أَنذِرْ قَوْمَكَ مِن قَبْلِ أَن يَأْتِيَهُمْ عَذَابٌ أَلِيمٌ","fr":"Nous envoyâmes Noé vers son peuple en lui disant : « Avertis ton peuple avant que ne fonde sur eux un supplice très douloureux ! »","en":"Indeed, We sent Noah to his people, [saying], \"Warn your people before there comes to them a painful punishment.\"","words":[{"position":1,"ar":"إِنَّآ","fr":"Certes, Nous","en":"Indeed, We","tr":"innā","isWaqf":false},{"position":2,"ar":"أَرْسَلْنَا","fr":"[Nous] envoyé","en":"[We] sent","tr":"arsalnā","isWaqf":false},{"position":3,"ar":"نُوحًا","fr":"Nuh","en":"Nuh","tr":"nūḥan","isWaqf":false},{"position":4,"ar":"إِلَىٰ","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":5,"ar":"قَوْمِهِۦٓ","fr":"son peuple","en":"his people","tr":"qawmihi","isWaqf":false},{"position":6,"ar":"أَنْ","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":7,"ar":"أَنذِرْ","fr":"Avertir","en":"Warn","tr":"andhir","isWaqf":false},{"position":8,"ar":"قَوْمَكَ","fr":"votre peuple","en":"your people","tr":"qawmaka","isWaqf":false},{"position":9,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":10,"ar":"قَبْلِ","fr":"avant","en":"before","tr":"qabli","isWaqf":false},{"position":11,"ar":"أَن","fr":"[que]","en":"[that]","tr":"an","isWaqf":false},{"position":12,"ar":"يَأْتِيَهُمْ","fr":"leur vient","en":"comes to them","tr":"yatiyahum","isWaqf":false},{"position":13,"ar":"عَذَابٌ","fr":"un châtiment","en":"a punishment","tr":"ʿadhābun","isWaqf":false},{"position":14,"ar":"أَلِيمٌۭ","fr":"douloureux","en":"painful","tr":"alīmun","isWaqf":false}]},{"ayah":2,"verseKey":"71:2","juz":29,"arabic":"قَالَ يَـٰقَوْمِ إِنِّى لَكُمْ نَذِيرٌ مُّبِينٌ","fr":"« Ô peuple mien, dit-il, je suis là pour vous avertir en toute clarté !","en":"He said, \"O my people, indeed I am to you a clear warner -","words":[{"position":1,"ar":"قَالَ","fr":"Il dit","en":"He said","tr":"qāla","isWaqf":false},{"position":2,"ar":"يَـٰقَوْمِ","fr":"Ô mon peuple","en":"O my people","tr":"yāqawmi","isWaqf":false},{"position":3,"ar":"إِنِّى","fr":"Certes, je suis","en":"Indeed, I am","tr":"innī","isWaqf":false},{"position":4,"ar":"لَكُمْ","fr":"à vous","en":"to you","tr":"lakum","isWaqf":false},{"position":5,"ar":"نَذِيرٌۭ","fr":"un avertisseur","en":"a warner","tr":"nadhīrun","isWaqf":false},{"position":6,"ar":"مُّبِينٌ","fr":"clair","en":"clear","tr":"mubīnun","isWaqf":false}]},{"ayah":3,"verseKey":"71:3","juz":29,"arabic":"أَنِ ٱعْبُدُوا۟ ٱللَّهَ وَٱتَّقُوهُ وَأَطِيعُونِ","fr":"Adorez Allah ! Craignez-Le ! Obéissez-moi !","en":"To worship Allāh, fear Him and obey me.","words":[{"position":1,"ar":"أَنِ","fr":"Cela","en":"That","tr":"ani","isWaqf":false},{"position":2,"ar":"ٱعْبُدُوا۟","fr":"Adore","en":"Worship","tr":"uʿ'budū","isWaqf":false},{"position":3,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":4,"ar":"وَٱتَّقُوهُ","fr":"et craindre Lui","en":"and fear Him","tr":"wa-ittaqūhu","isWaqf":false},{"position":5,"ar":"وَأَطِيعُونِ","fr":"et obéis-moi","en":"and obey me","tr":"wa-aṭīʿūni","isWaqf":false}]},{"ayah":4,"verseKey":"71:4","juz":29,"arabic":"يَغْفِرْ لَكُم مِّن ذُنُوبِكُمْ وَيُؤَخِّرْكُمْ إِلَىٰٓ أَجَلٍ مُّسَمًّى ۚ إِنَّ أَجَلَ ٱللَّهِ إِذَا جَآءَ لَا يُؤَخَّرُ ۖ لَوْ كُنتُمْ تَعْلَمُونَ","fr":"Il vous pardonnera alors vos péchés et surseoira (à votre jugement) pour un terme déjà nommé. Car le terme décrété par Allah ne pourra être retardé, si seulement vous saviez ! »","en":"He [i.e., Allāh] will forgive you of your sins and delay you for a specified term. Indeed, the time [set by] Allāh, when it comes, will not be delayed, if you only knew.\"","words":[{"position":1,"ar":"يَغْفِرْ","fr":"Il va pardonner","en":"He will forgive","tr":"yaghfir","isWaqf":false},{"position":2,"ar":"لَكُم","fr":"pour vous","en":"for you","tr":"lakum","isWaqf":false},{"position":3,"ar":"مِّن","fr":"[de]","en":"[of]","tr":"min","isWaqf":false},{"position":4,"ar":"ذُنُوبِكُمْ","fr":"vos péchés","en":"your sins","tr":"dhunūbikum","isWaqf":false},{"position":5,"ar":"وَيُؤَخِّرْكُمْ","fr":"et donner vous répit","en":"and give you respite","tr":"wayu-akhir'kum","isWaqf":false},{"position":6,"ar":"إِلَىٰٓ","fr":"pour","en":"for","tr":"ilā","isWaqf":false},{"position":7,"ar":"أَجَلٍۢ","fr":"un terme","en":"a term","tr":"ajalin","isWaqf":false},{"position":8,"ar":"مُّسَمًّى ۚ","fr":"déterminé","en":"specified","tr":"musamman","isWaqf":false},{"position":9,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":10,"ar":"أَجَلَ","fr":"(le) terme","en":"(the) term","tr":"ajala","isWaqf":false},{"position":11,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":12,"ar":"إِذَا","fr":"quand","en":"when","tr":"idhā","isWaqf":false},{"position":13,"ar":"جَآءَ","fr":"cela vient","en":"it comes","tr":"jāa","isWaqf":false},{"position":14,"ar":"لَا","fr":"non","en":"not","tr":"lā","isWaqf":false},{"position":15,"ar":"يُؤَخَّرُ ۖ","fr":"est retarda","en":"is delayed","tr":"yu-akharu","isWaqf":false},{"position":16,"ar":"لَوْ","fr":"si","en":"if","tr":"law","isWaqf":false},{"position":17,"ar":"كُنتُمْ","fr":"vous","en":"you","tr":"kuntum","isWaqf":false},{"position":18,"ar":"تَعْلَمُونَ","fr":"savoir","en":"know","tr":"taʿlamūna","isWaqf":false}]},{"ayah":5,"verseKey":"71:5","juz":29,"arabic":"قَالَ رَبِّ إِنِّى دَعَوْتُ قَوْمِى لَيْلًا وَنَهَارًا","fr":"« Seigneur, (dit-il plus tard), je n’ai fait qu’exhorter mon peuple nuit et jour,","en":"He said, \"My Lord, indeed I invited my people [to truth] night and day.","words":[{"position":1,"ar":"قَالَ","fr":"Il dit","en":"He said","tr":"qāla","isWaqf":false},{"position":2,"ar":"رَبِّ","fr":"Mon Seigneur","en":"My Lord","tr":"rabbi","isWaqf":false},{"position":3,"ar":"إِنِّى","fr":"Certes, je","en":"Indeed, I","tr":"innī","isWaqf":false},{"position":4,"ar":"دَعَوْتُ","fr":"invité","en":"invited","tr":"daʿawtu","isWaqf":false},{"position":5,"ar":"قَوْمِى","fr":"mon gens","en":"my people","tr":"qawmī","isWaqf":false},{"position":6,"ar":"لَيْلًۭا","fr":"nuit","en":"night","tr":"laylan","isWaqf":false},{"position":7,"ar":"وَنَهَارًۭا","fr":"et jour","en":"and day","tr":"wanahāran","isWaqf":false}]},{"ayah":6,"verseKey":"71:6","juz":29,"arabic":"فَلَمْ يَزِدْهُمْ دُعَآءِىٓ إِلَّا فِرَارًا","fr":"mais mon appel n’a fait que les faire fuir davantage.","en":"But my invitation increased them not except in flight [i.e., aversion].","words":[{"position":1,"ar":"فَلَمْ","fr":"Mais non","en":"But not","tr":"falam","isWaqf":false},{"position":2,"ar":"يَزِدْهُمْ","fr":"accru eux","en":"increased them","tr":"yazid'hum","isWaqf":false},{"position":3,"ar":"دُعَآءِىٓ","fr":"mon invitation","en":"my invitation","tr":"duʿāī","isWaqf":false},{"position":4,"ar":"إِلَّا","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":5,"ar":"فِرَارًۭا","fr":"(dans) fuite","en":"(in) flight","tr":"firāran","isWaqf":false}]},{"ayah":7,"verseKey":"71:7","juz":29,"arabic":"وَإِنِّى كُلَّمَا دَعَوْتُهُمْ لِتَغْفِرَ لَهُمْ جَعَلُوٓا۟ أَصَـٰبِعَهُمْ فِىٓ ءَاذَانِهِمْ وَٱسْتَغْشَوْا۟ ثِيَابَهُمْ وَأَصَرُّوا۟ وَٱسْتَكْبَرُوا۟ ٱسْتِكْبَارًا","fr":"Chaque fois que je les appelais pour que Tu leur pardonnes (leurs péchés), ils se bouchaient les oreilles avec leurs doigts, s’emmitouflaient dans leurs vêtements, et s’obstinaient, orgueilleux et dédaigneux.","en":"And indeed, every time I invited them that You may forgive them, they put their fingers in their ears, covered themselves with their garments, persisted, and were arrogant with [great] arrogance.","words":[{"position":1,"ar":"وَإِنِّى","fr":"Et certes, je","en":"And indeed, I","tr":"wa-innī","isWaqf":false},{"position":2,"ar":"كُلَّمَا","fr":"chaque fois","en":"every time","tr":"kullamā","isWaqf":false},{"position":3,"ar":"دَعَوْتُهُمْ","fr":"J’invité eux","en":"I invited them","tr":"daʿawtuhum","isWaqf":false},{"position":4,"ar":"لِتَغْفِرَ","fr":"que Vous peut pardonner","en":"that You may forgive","tr":"litaghfira","isWaqf":false},{"position":5,"ar":"لَهُمْ","fr":"eux","en":"them","tr":"lahum","isWaqf":false},{"position":6,"ar":"جَعَلُوٓا۟","fr":"ils mettre","en":"they put","tr":"jaʿalū","isWaqf":false},{"position":7,"ar":"أَصَـٰبِعَهُمْ","fr":"leur doigts","en":"their fingers","tr":"aṣābiʿahum","isWaqf":false},{"position":8,"ar":"فِىٓ","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":9,"ar":"ءَاذَانِهِمْ","fr":"leur oreilles","en":"their ears","tr":"ādhānihim","isWaqf":false},{"position":10,"ar":"وَٱسْتَغْشَوْا۟","fr":"et couvert eux-mêmes","en":"and covered themselves","tr":"wa-is'taghshaw","isWaqf":false},{"position":11,"ar":"ثِيَابَهُمْ","fr":"(avec) leur vêtements","en":"(with) their garments","tr":"thiyābahum","isWaqf":false},{"position":12,"ar":"وَأَصَرُّوا۟","fr":"et persisted","en":"and persisted","tr":"wa-aṣarrū","isWaqf":false},{"position":13,"ar":"وَٱسْتَكْبَرُوا۟","fr":"et étaient orgueilleux","en":"and were arrogant","tr":"wa-is'takbarū","isWaqf":false},{"position":14,"ar":"ٱسْتِكْبَارًۭا","fr":"(avec) orgueil","en":"(with) pride","tr":"is'tik'bāran","isWaqf":false}]},{"ayah":8,"verseKey":"71:8","juz":29,"arabic":"ثُمَّ إِنِّى دَعَوْتُهُمْ جِهَارًا","fr":"Je les ai alors exhortés publiquement.","en":"Then I invited them publicly.","words":[{"position":1,"ar":"ثُمَّ","fr":"Puis","en":"Then","tr":"thumma","isWaqf":false},{"position":2,"ar":"إِنِّى","fr":"certes, je","en":"indeed, I","tr":"innī","isWaqf":false},{"position":3,"ar":"دَعَوْتُهُمْ","fr":"invité eux","en":"invited them","tr":"daʿawtuhum","isWaqf":false},{"position":4,"ar":"جِهَارًۭا","fr":"publiquement","en":"publicly","tr":"jihāran","isWaqf":false}]},{"ayah":9,"verseKey":"71:9","juz":29,"arabic":"ثُمَّ إِنِّىٓ أَعْلَنتُ لَهُمْ وَأَسْرَرْتُ لَهُمْ إِسْرَارًا","fr":"Puis je me suis adressé à eux tantôt ouvertement, tantôt sur le ton de la confidence.","en":"Then I announced to