4","juz":29,"arabic":"بَلَىٰ قَـٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّىَ بَنَانَهُۥ","fr":"Que si ! Nous sommes Capable même de reconstituer tel quel le bout de ses doigts.","en":"Yes. [We are] Able [even] to proportion his fingertips.","words":[{"position":1,"ar":"بَلَىٰ","fr":"Non","en":"Nay","tr":"balā","isWaqf":false},{"position":2,"ar":"قَـٰدِرِينَ","fr":"(Nous sont) Capable","en":"(We are) Able","tr":"qādirīna","isWaqf":false},{"position":3,"ar":"عَلَىٰٓ","fr":"sur","en":"on","tr":"ʿalā","isWaqf":false},{"position":4,"ar":"أَن","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":5,"ar":"نُّسَوِّىَ","fr":"Nous peut restituer","en":"We can restore","tr":"nusawwiya","isWaqf":false},{"position":6,"ar":"بَنَانَهُۥ","fr":"son fingertips","en":"his fingertips","tr":"banānahu","isWaqf":false}]},{"ayah":5,"verseKey":"75:5","juz":29,"arabic":"بَلْ يُرِيدُ ٱلْإِنسَـٰنُ لِيَفْجُرَ أَمَامَهُۥ","fr":"L’homme préfèrerait poursuivre sa vie en rebelle et pervers.","en":"But man desires to continue in sin.","words":[{"position":1,"ar":"بَلْ","fr":"Non","en":"Nay","tr":"bal","isWaqf":false},{"position":2,"ar":"يُرِيدُ","fr":"Désirs","en":"Desires","tr":"yurīdu","isWaqf":false},{"position":3,"ar":"ٱلْإِنسَـٰنُ","fr":"[l']homme","en":"[the] man","tr":"l-insānu","isWaqf":false},{"position":4,"ar":"لِيَفْجُرَ","fr":"à donner (le) mensonge","en":"to give (the) lie","tr":"liyafjura","isWaqf":false},{"position":5,"ar":"أَمَامَهُۥ","fr":"(à) quoi est avant lui","en":"(to) what is before him","tr":"amāmahu","isWaqf":false}]},{"ayah":6,"verseKey":"75:6","juz":29,"arabic":"يَسْـَٔلُ أَيَّانَ يَوْمُ ٱلْقِيَـٰمَةِ","fr":"Il demande : « À quand donc le Jour de la Résurrection ? »","en":"He asks, \"When is the Day of Resurrection?\"","words":[{"position":1,"ar":"يَسْـَٔلُ","fr":"Il demande","en":"He asks","tr":"yasalu","isWaqf":false},{"position":2,"ar":"أَيَّانَ","fr":"Quand","en":"When","tr":"ayyāna","isWaqf":false},{"position":3,"ar":"يَوْمُ","fr":"(est le) Jour","en":"(is the) Day","tr":"yawmu","isWaqf":false},{"position":4,"ar":"ٱلْقِيَـٰمَةِ","fr":"(de la) Résurrection","en":"(of) the Resurrection","tr":"l-qiyāmati","isWaqf":false}]},{"ayah":7,"verseKey":"75:7","juz":29,"arabic":"فَإِذَا بَرِقَ ٱلْبَصَرُ","fr":"Puis lorsque l’œil sera hagard,","en":"So when vision is dazzled.","words":[{"position":1,"ar":"فَإِذَا","fr":"Donc quand","en":"So when","tr":"fa-idhā","isWaqf":false},{"position":2,"ar":"بَرِقَ","fr":"est éblouit","en":"is dazzled","tr":"bariqa","isWaqf":false},{"position":3,"ar":"ٱلْبَصَرُ","fr":"le vision","en":"the vision","tr":"l-baṣaru","isWaqf":false}]},{"ayah":8,"verseKey":"75:8","juz":29,"arabic":"وَخَسَفَ ٱلْقَمَرُ","fr":"et que la lune se sera éclipsée,","en":"And the moon darkens.","words":[{"position":1,"ar":"وَخَسَفَ","fr":"Et devient sombre","en":"And becomes dark","tr":"wakhasafa","isWaqf":false},{"position":2,"ar":"ٱلْقَمَرُ","fr":"la lune","en":"the moon","tr":"l-qamaru","isWaqf":false}]},{"ayah":9,"verseKey":"75:9","juz":29,"arabic":"وَجُمِعَ ٱلشَّمْسُ وَٱلْقَمَرُ","fr":"et que le soleil et la lune auront été réunis,","en":"And the sun and the moon are joined,","words":[{"position":1,"ar":"وَجُمِعَ","fr":"Et sont joint","en":"And are joined","tr":"wajumiʿa","isWaqf":false},{"position":2,"ar":"ٱلشَّمْسُ","fr":"le soleil","en":"the sun","tr":"l-shamsu","isWaqf":false},{"position":3,"ar":"وَٱلْقَمَرُ","fr":"et la lune","en":"and the moon","tr":"wal-qamaru","isWaqf":false}]},{"ayah":10,"verseKey":"75:10","juz":29,"arabic":"يَقُولُ ٱلْإِنسَـٰنُ يَوْمَئِذٍ أَيْنَ ٱلْمَفَرُّ","fr":"l’homme dira, ce jour-là : « Où fuir ? »","en":"Man will say on that Day, \"Where is the [place of] escape?\"","words":[{"position":1,"ar":"يَقُولُ","fr":"Dira","en":"Will say","tr":"yaqūlu","isWaqf":false},{"position":2,"ar":"ٱلْإِنسَـٰنُ","fr":"[l']homme","en":"[the] man","tr":"l-insānu","isWaqf":false},{"position":3,"ar":"يَوْمَئِذٍ","fr":"ce Jour","en":"that Day","tr":"yawma-idhin","isWaqf":false},{"position":4,"ar":"أَيْنَ","fr":"Où","en":"Where","tr":"ayna","isWaqf":false},{"position":5,"ar":"ٱلْمَفَرُّ","fr":"(est) le échapper","en":"(is) the escape","tr":"l-mafaru","isWaqf":false}]},{"ayah":11,"verseKey":"75:11","juz":29,"arabic":"كَلَّا لَا وَزَرَ","fr":"Non ! Il n’y aura point d’issue.","en":"No! There is no refuge.","words":[{"position":1,"ar":"كَلَّا","fr":"Par non moyen","en":"By no means","tr":"kallā","isWaqf":false},{"position":2,"ar":"لَا","fr":"(Il n'y a) pas","en":"(There is) no","tr":"lā","isWaqf":false},{"position":3,"ar":"وَزَرَ","fr":"refuge","en":"refuge","tr":"wazara","isWaqf":false}]},{"ayah":12,"verseKey":"75:12","juz":29,"arabic":"إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمُسْتَقَرُّ","fr":"C’est vers ton Seigneur que, ce jour-là, sera l’aboutissement.","en":"To your Lord, that Day, is the [place of] permanence.","words":[{"position":1,"ar":"إِلَىٰ","fr":"À","en":"To","tr":"ilā","isWaqf":false},{"position":2,"ar":"رَبِّكَ","fr":"votre Seigneur","en":"your Lord","tr":"rabbika","isWaqf":false},{"position":3,"ar":"يَوْمَئِذٍ","fr":"ce Jour","en":"that Day","tr":"yawma-idhin","isWaqf":false},{"position":4,"ar":"ٱلْمُسْتَقَرُّ","fr":"(est) le lieu de repos","en":"(is) the place of rest","tr":"l-mus'taqaru","isWaqf":false}]},{"ayah":13,"verseKey":"75:13","juz":29,"arabic":"يُنَبَّؤُا۟ ٱلْإِنسَـٰنُ يَوْمَئِذٍۭ بِمَا قَدَّمَ وَأَخَّرَ","fr":"Et ce jour-là, l’homme sera informé de ce qu’il aura avancé (comme acte) et de ce qu’il aura renvoyé à plus tard.","en":"Man will be informed that Day of what he sent ahead and kept back.","words":[{"position":1,"ar":"يُنَبَّؤُا۟","fr":"Va être informa","en":"Will be informed","tr":"yunabba-u","isWaqf":false},{"position":2,"ar":"ٱلْإِنسَـٰنُ","fr":"[l']homme","en":"[the] man","tr":"l-insānu","isWaqf":false},{"position":3,"ar":"يَوْمَئِذٍۭ","fr":"ce Jour","en":"that Day","tr":"yawma-idhin","isWaqf":false},{"position":4,"ar":"بِمَا","fr":"de ce que","en":"of what","tr":"bimā","isWaqf":false},{"position":5,"ar":"قَدَّمَ","fr":"il envoyé en avant","en":"he sent forth","tr":"qaddama","isWaqf":false},{"position":6,"ar":"وَأَخَّرَ","fr":"et garda en arrière","en":"and kept back","tr":"wa-akhara","isWaqf":false}]},{"ayah":14,"verseKey":"75:14","juz":29,"arabic":"بَلِ ٱلْإِنسَـٰنُ عَلَىٰ نَفْسِهِۦ بَصِيرَةٌ","fr":"L’homme se dressera plutôt contre lui-même en témoin oculaire,","en":"Rather, man, against himself, will be a witness,","words":[{"position":1,"ar":"بَلِ","fr":"Non","en":"Nay","tr":"bali","isWaqf":false},{"position":2,"ar":"ٱلْإِنسَـٰنُ","fr":"[le] homme","en":"[The] man","tr":"l-insānu","isWaqf":false},{"position":3,"ar":"عَلَىٰ","fr":"contre","en":"against","tr":"ʿalā","isWaqf":false},{"position":4,"ar":"نَفْسِهِۦ","fr":"lui-même","en":"himself","tr":"nafsihi","isWaqf":false},{"position":5,"ar":"بَصِيرَةٌۭ","fr":"(va être) un témoin","en":"(will be) a witness","tr":"baṣīratun","isWaqf":false}]},{"ayah":15,"verseKey":"75:15","juz":29,"arabic":"وَلَوْ أَلْقَىٰ مَعَاذِيرَهُۥ","fr":"quand bien même il invoquerait ses excuses.","en":"Even if he presents his excuses.","words":[{"position":1,"ar":"وَلَوْ","fr":"Même si","en":"Even if","tr":"walaw","isWaqf":false},{"position":2,"ar":"أَلْقَىٰ","fr":"il presents","en":"he presents","tr":"alqā","isWaqf":false},{"position":3,"ar":"مَعَاذِيرَهُۥ","fr":"son excuses","en":"his excuses","tr":"maʿādhīrahu","isWaqf":false}]},{"ayah":16,"verseKey":"75:16","juz":29,"arabic":"لَا تُحَرِّكْ بِهِۦ لِسَانَكَ لِتَعْجَلَ بِهِۦٓ","fr":"Ne le tourne pas (plusieurs fois) dans ta langue, pressé que tu es de le retenir.","en":"Move not your tongue with it, [O Muḥammad], to hasten with it [i.e., recitation of the Qur’ān].","words":[{"position":1,"ar":"لَا","fr":"Non","en":"Not","tr":"lā","isWaqf":false},{"position":2,"ar":"تُحَرِّكْ","fr":"bouger","en":"move","tr":"tuḥarrik","isWaqf":false},{"position":3,"ar":"بِهِۦ","fr":"avec cela","en":"with it","tr":"bihi","isWaqf":false},{"position":4,"ar":"لِسَانَكَ","fr":"votre langue","en":"your tongue","tr":"lisānaka","isWaqf":false},{"position":5,"ar":"لِتَعْجَلَ