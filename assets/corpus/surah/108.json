[{"ayah":1,"verseKey":"108:1","juz":30,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِنَّآ أَعْطَيْنَـٰكَ ٱلْكَوْثَرَ","fr":"Nous t’avons certes donné un Fleuve d’Abondance.","en":"Indeed, We have granted you, [O Muḥammad], al-Kawthar.","words":[{"position":1,"ar":"إِنَّآ","fr":"Certes, Nous","en":"Indeed, We","tr":"innā","isWaqf":false},{"position":2,"ar":"أَعْطَيْنَـٰكَ","fr":"Nous ont donné vous","en":"We have given you","tr":"aʿṭaynāka","isWaqf":false},{"position":3,"ar":"ٱلْكَوْثَرَ","fr":"Al-Kauthar","en":"Al-Kauthar","tr":"l-kawthara","isWaqf":false}]},{"ayah":2,"verseKey":"108:2","juz":30,"arabic":"فَصَلِّ لِرَبِّكَ وَٱنْحَرْ","fr":"Observe donc la Çalât pour ton Seigneur, et sacrifie !","en":"So pray to your Lord and offer sacrifice [to Him alone].","words":[{"position":1,"ar":"فَصَلِّ","fr":"Donc prier","en":"So pray","tr":"faṣalli","isWaqf":false},{"position":2,"ar":"لِرَبِّكَ","fr":"à votre Seigneur","en":"to your Lord","tr":"lirabbika","isWaqf":false},{"position":3,"ar":"وَٱنْحَرْ","fr":"et sacrifice","en":"and sacrifice","tr":"wa-in'ḥar","isWaqf":false}]},{"ayah":3,"verseKey":"108:3","juz":30,"arabic":"إِنَّ شَانِئَكَ هُوَ ٱلْأَبْتَرُ","fr":"C’est celui qui te hait qui sera sans postérité.","en":"Indeed, your enemy is the one cut off.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"شَانِئَكَ","fr":"votre ennemi","en":"your enemy","tr":"shāni-aka","isWaqf":false},{"position":3,"ar":"هُوَ","fr":"il (est)","en":"he (is)","tr":"huwa","isWaqf":false},{"position":4,"ar":"ٱلْأَبْتَرُ","fr":"l'un couper loin","en":"the one cut off","tr":"l-abtaru","isWaqf":false}]}]