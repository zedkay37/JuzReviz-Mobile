[{"ayah":1,"verseKey":"73:1","juz":29,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ يَـٰٓأَيُّهَا ٱلْمُزَّمِّلُ","fr":"Ô toi qui t’emmitoufles dans tes vêtements !","en":"O you who wraps himself [in clothing]","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô vous","en":"O you","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلْمُزَّمِّلُ","fr":"qui enveloppe lui-même","en":"who wraps himself","tr":"l-muzamilu","isWaqf":false}]},{"ayah":2,"verseKey":"73:2","juz":29,"arabic":"قُمِ ٱلَّيْلَ إِلَّا قَلِيلًا","fr":"Lève-toi la nuit (pour prier), et n’en excepte qu’une petite partie.","en":"Arise [to pray] the night, except for a little -","words":[{"position":1,"ar":"قُمِ","fr":"Se tenir","en":"Stand","tr":"qumi","isWaqf":false},{"position":2,"ar":"ٱلَّيْلَ","fr":"(dans) la nuit","en":"(in) the night","tr":"al-layla","isWaqf":false},{"position":3,"ar":"إِلَّا","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":4,"ar":"قَلِيلًۭا","fr":"un peu","en":"a little","tr":"qalīlan","isWaqf":false}]},{"ayah":3,"verseKey":"73:3","juz":29,"arabic":"نِّصْفَهُۥٓ أَوِ ٱنقُصْ مِنْهُ قَلِيلًا","fr":"Ce sera sa moitié, un peu moins,","en":"Half of it - or subtract from it a little","words":[{"position":1,"ar":"نِّصْفَهُۥٓ","fr":"Moitié de cela","en":"Half of it","tr":"niṣ'fahu","isWaqf":false},{"position":2,"ar":"أَوِ","fr":"ou","en":"or","tr":"awi","isWaqf":false},{"position":3,"ar":"ٱنقُصْ","fr":"diminuer","en":"lessen","tr":"unquṣ","isWaqf":false},{"position":4,"ar":"مِنْهُ","fr":"de cela","en":"from it","tr":"min'hu","isWaqf":false},{"position":5,"ar":"قَلِيلًا","fr":"un peu","en":"a little","tr":"qalīlan","isWaqf":false}]},{"ayah":4,"verseKey":"73:4","juz":29,"arabic":"أَوْ زِدْ عَلَيْهِ وَرَتِّلِ ٱلْقُرْءَانَ تَرْتِيلًا","fr":"ou un peu plus. Et récite le Coran de ta plus belle récitation.","en":"Or add to it, and recite the Qur’ān with measured recitation.","words":[{"position":1,"ar":"أَوْ","fr":"Ou","en":"Or","tr":"aw","isWaqf":false},{"position":2,"ar":"زِدْ","fr":"ajouter","en":"add","tr":"zid","isWaqf":false},{"position":3,"ar":"عَلَيْهِ","fr":"à cela","en":"to it","tr":"ʿalayhi","isWaqf":false},{"position":4,"ar":"وَرَتِّلِ","fr":"et réciter","en":"and recite","tr":"warattili","isWaqf":false},{"position":5,"ar":"ٱلْقُرْءَانَ","fr":"le Coran","en":"the Quran","tr":"l-qur'āna","isWaqf":false},{"position":6,"ar":"تَرْتِيلًا","fr":"(avec) mesuré rhythmic récitation","en":"(with) measured rhythmic recitation","tr":"tartīlan","isWaqf":false}]},{"ayah":5,"verseKey":"73:5","juz":29,"arabic":"إِنَّا سَنُلْقِى عَلَيْكَ قَوْلًا ثَقِيلًا","fr":"Nous allons bientôt te faire porter de lourdes paroles.","en":"Indeed, We will cast upon you a heavy word.","words":[{"position":1,"ar":"إِنَّا","fr":"Certes, Nous","en":"Indeed, We","tr":"innā","isWaqf":false},{"position":2,"ar":"سَنُلْقِى","fr":"va jeta","en":"will cast","tr":"sanul'qī","isWaqf":false},{"position":3,"ar":"عَلَيْكَ","fr":"sur vous","en":"upon you","tr":"ʿalayka","isWaqf":false},{"position":4,"ar":"قَوْلًۭا","fr":"un Parole","en":"a Word","tr":"qawlan","isWaqf":false},{"position":5,"ar":"ثَقِيلًا","fr":"lourd","en":"heavy","tr":"thaqīlan","isWaqf":false}]},{"ayah":6,"verseKey":"73:6","juz":29,"arabic":"إِنَّ نَاشِئَةَ ٱلَّيْلِ هِىَ أَشَدُّ وَطْـًٔا وَأَقْوَمُ قِيلًا","fr":"La prière du réveil nocturne est d’un impact plus profond et les paroles en sont plus justes.","en":"Indeed, the hours of the night are more effective for concurrence [of heart and tongue] and more suitable for words.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"نَاشِئَةَ","fr":"(le) levant","en":"(the) rising","tr":"nāshi-ata","isWaqf":false},{"position":3,"ar":"ٱلَّيْلِ","fr":"(à) le nuit","en":"(at) the night","tr":"al-layli","isWaqf":false},{"position":4,"ar":"هِىَ","fr":"cela","en":"it","tr":"hiya","isWaqf":false},{"position":5,"ar":"أَشَدُّ","fr":"(est) très dur","en":"(is) very hard","tr":"ashaddu","isWaqf":false},{"position":6,"ar":"وَطْـًۭٔا","fr":"et le plus puissant","en":"and most potent","tr":"waṭan","isWaqf":false},{"position":7,"ar":"وَأَقْوَمُ","fr":"et plus convenable","en":"and more suitable","tr":"wa-aqwamu","isWaqf":false},{"position":8,"ar":"قِيلًا","fr":"(pour) Parole","en":"(for) Word","tr":"qīlan","isWaqf":false}]},{"ayah":7,"verseKey":"73:7","juz":29,"arabic":"إِنَّ لَكَ فِى ٱلنَّهَارِ سَبْحًا طَوِيلًا","fr":"Tu as, en vérité, de longs moments d’activité pendant la journée.","en":"Indeed, for you by day is prolonged occupation.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"لَكَ","fr":"pour vous","en":"for you","tr":"laka","isWaqf":false},{"position":3,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":4,"ar":"ٱلنَّهَارِ","fr":"le jour","en":"the day","tr":"l-nahāri","isWaqf":false},{"position":5,"ar":"سَبْحًۭا","fr":"(est) occupation","en":"(is) occupation","tr":"sabḥan","isWaqf":false},{"position":6,"ar":"طَوِيلًۭا","fr":"prolongé","en":"prolonged","tr":"ṭawīlan","isWaqf":false}]},{"ayah":8,"verseKey":"73:8","juz":29,"arabic":"وَٱذْكُرِ ٱسْمَ رَبِّكَ وَتَبَتَّلْ إِلَيْهِ تَبْتِيلًا","fr":"Évoque le Nom de ton Seigneur ! Voue-toi exclusivement à Son culte !","en":"And remember the name of your Lord and devote yourself to Him with [complete] devotion.","words":[{"position":1,"ar":"وَٱذْكُرِ","fr":"Et rappelle-toi","en":"And remember","tr":"wa-udh'kuri","isWaqf":false},{"position":2,"ar":"ٱسْمَ","fr":"(le) nom","en":"(the) name","tr":"is'ma","isWaqf":false},{"position":3,"ar":"رَبِّكَ","fr":"(de) votre Seigneur","en":"(of) your Lord","tr":"rabbika","isWaqf":false},{"position":4,"ar":"وَتَبَتَّلْ","fr":"et devote vous-même","en":"and devote yourself","tr":"watabattal","isWaqf":false},{"position":5,"ar":"إِلَيْهِ","fr":"à Lui","en":"to Him","tr":"ilayhi","isWaqf":false},{"position":6,"ar":"تَبْتِيلًۭا","fr":"(avec) dévotion","en":"(with) devotion","tr":"tabtīlan","isWaqf":false}]},{"ayah":9,"verseKey":"73:9","juz":29,"arabic":"رَّبُّ ٱلْمَشْرِقِ وَٱلْمَغْرِبِ لَآ إِلَـٰهَ إِلَّا هُوَ فَٱتَّخِذْهُ وَكِيلًا","fr":"Il est le Seigneur du Levant et du Couchant. Il n’est point d’autre divinité que Lui. Prends-Le donc pour unique Protecteur !","en":"[He is] the Lord of the East and the West; there is no deity except Him, so take Him as Disposer of [your] affairs.","words":[{"position":1,"ar":"رَّبُّ","fr":"(Le) Seigneur","en":"(The) Lord","tr":"rabbu","isWaqf":false},{"position":2,"ar":"ٱلْمَشْرِقِ","fr":"(de) le est","en":"(of) the east","tr":"l-mashriqi","isWaqf":false},{"position":3,"ar":"وَٱلْمَغْرِبِ","fr":"et le ouest","en":"and the west","tr":"wal-maghribi","isWaqf":false},{"position":4,"ar":"لَآ","fr":"(il n'y a) pas","en":"(there is) no","tr":"lā","isWaqf":false},{"position":5,"ar":"إِلَـٰهَ","fr":"dieu","en":"god","tr":"ilāha","isWaqf":false},{"position":6,"ar":"إِلَّا","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":7,"ar":"هُوَ","fr":"Lui","en":"Him","tr":"huwa","isWaqf":false},{"position":8,"ar":"فَٱتَّخِذْهُ","fr":"donc prendre Lui","en":"so take Him","tr":"fa-ittakhidh'hu","isWaqf":false},{"position":9,"ar":"وَكِيلًۭا","fr":"(comme) Garant de Affaires","en":"(as) Disposer of Affairs","tr":"wakīlan","isWaqf":false}]},{"ayah":10,"verseKey":"73:10","juz":29,"arabic":"وَٱصْبِرْ عَلَىٰ مَا يَقُولُونَ وَٱهْجُرْهُمْ هَجْرًا جَمِيلًا","fr":"Prends en patience ce qu’ils disent et déserte-les de la désertion la plus sereine !","en":"And be patient over what they say and avoid them with gracious avoidance.","words":[{"position":1,"ar":"وَٱصْبِرْ","fr":"Et être patient","en":"And be patient","tr":"wa-iṣ'bir","isWaqf":false},{"position":2,"ar":"عَلَىٰ","fr":"sur","en":"over","tr":"ʿalā","isWaqf":false},{"position":3,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":4,"ar":"يَقُولُونَ","fr":"ils disent","en":"they say","tr":"yaqūlūna","isWaqf":false},{"position":5,"ar":"وَٱهْجُرْهُمْ","fr":"et éviter eux","en":"and avoid them","tr":"wa-uh'jur'hum","isWaqf":false},{"position":6,"ar":"هَجْرًۭا","fr":"un avoidance","en":"an avoidance","tr":"hajran","isWaqf":false},{"position":7,"ar":"جَمِيلًۭا","fr":"gracieux","en":"gracious","tr":"jamīlan","isWaqf":false}]},{"ayah":11,"verseKey":"73:11","juz":29,"arabic":"وَذَرْنِى وَٱلْمُكَذِّبِينَ أُو۟لِى ٱلنَّعْمَةِ وَمَهِّلْهُمْ قَلِيلًا","fr":"Laisse-Moi avec les contradicteurs, qui sont privilégiés par les biens (de ce monde). Accorde-leur quelque répit.","en":"And leave Me with [the matter of] the deniers, those of ease [in life], and allow them respite a little.","words":[{"position":1,"ar":"وَذَرْنِى","fr":"Et quitter Moi","en":"And leave Me","tr":"wadharnī","isWaqf":false},{"position":2,"ar":"وَٱلْمُكَذِّبِينَ","fr":"et le négateurs","en":"and the deniers","tr":"wal-mukadhibīna","isWaqf":false},{"position":3,"ar":"أُو۟لِى","fr":"possesseurs","en":"possessors","tr":"ulī","isWaqf":false},{"position":4,"ar":"ٱلنَّعْمَةِ","fr":"(de) le aisance","en":"(of) the ease","tr":"l-naʿmati","isWaqf":false},{"position":5,"ar":"وَمَهِّلْهُمْ","fr":"et permettre eux répit","en":"and allow them respite","tr":"wamahhil'hum","isWaqf":false},{"position":6,"ar":"قَلِيلًا","fr":"un peu","en":"a little","tr":"qalīlan","isWaqf":false}]},{"ayah":12,"verseKey":"73:12","juz":29,"arabic":"إِنَّ لَدَيْنَآ أَنكَالًا وَجَحِيمًا","fr":"Nous disposons (pour eux) de lourdes chaînes et d’un ardent Brasier,","en":"Indeed, with Us [for them] are shackles and burning fire.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"لَدَيْنَآ","fr":"avec Nous","en":"with Us","tr":"ladaynā","isWaqf":false},{"position":3,"ar":"أَنكَالًۭا","fr":"(sont) entraves","en":"(are) shackles","tr":"ankālan","isWaqf":false},{"position":4,"ar":"وَجَحِيمًۭا","fr":"et brûlant feu","en":"and burning fire","tr":"wajaḥīman","isWaqf":false}]},{"ayah":13,"verseKey":"73:13","juz":29,"arabic":"وَطَعَامًا ذَا غُصَّةٍ وَعَذَابًا أَلِيمًا","fr":"d’une nourriture qui étouffe et d’un supplice très douloureux.","en":"And food that chokes and a painful punishment -","words":[{"position":1,"ar":"وَطَعَامًۭا","fr":"Et nourriture","en":"And food","tr":"waṭaʿāman","isWaqf":false},{"position":2,"ar":"ذَا","fr":"que","en":"that","tr":"dhā","isWaqf":false},{"position":3,"ar":"غُصَّةٍۢ","fr":"étrangle","en":"chokes","tr":"ghuṣṣatin","isWaqf":false},{"position":4,"ar":"وَعَذَابًا","fr":"et un châtiment","en":"and a punishment","tr":"waʿadhāban","isWaqf":false},{"position":5,"ar":"أَلِيمًۭا","fr":"douloureux","en":"painful","tr":"alīman","isWaqf":false}]},{"ayah":14,"verseKey":"73:14","juz":29,"arabic":"يَوْمَ تَرْجُفُ ٱلْأَرْضُ وَٱلْجِبَالُ وَكَانَتِ ٱلْجِبَالُ كَثِيبًا مَّهِيلًا","fr":"Ce jour-là, la terre et les montagnes s’ébranleront ; et les massifs se mueront en dunes de terre mouvante.","en":"On the Day the earth and the mountains will convulse and the mountains will become a heap of sand pouring down.","words":[{"position":1,"ar":"يَوْمَ","fr":"(Au) Jour","en":"(On the) Day","tr":"yawma","isWaqf":false},{"position":2,"ar":"تَرْجُفُ","fr":"va trembler","en":"will quake","tr":"tarjufu","isWaqf":false},{"position":3,"ar":"ٱلْأَرْضُ","fr":"la terre","en":"the earth","tr":"l-arḍu","isWaqf":false},{"position":4,"ar":"وَٱلْجِبَالُ","fr":"et les montagnes","en":"and the mountains","tr":"wal-jibālu","isWaqf":false},{"position":5,"ar":"وَكَانَتِ","fr":"et va devenir","en":"and will become","tr":"wakānati","isWaqf":false},{"position":6,"ar":"ٱلْجِبَالُ","fr":"les montagnes","en":"the mountains","tr":"l-jibālu","isWaqf":false},{"position":7,"ar":"كَثِيبًۭا","fr":"un amas de sand","en":"a heap of sand","tr":"kathīban","isWaqf":false},{"position":8,"ar":"مَّهِيلًا","fr":"versant bas","en":"pouring down","tr":"mahīlan","isWaqf":false}]},{"ayah":15,"verseKey":"73:15","juz":29,"arabic":"إِنَّآ أَرْسَلْنَآ إِلَيْكُمْ رَسُولًا شَـٰهِدًا عَلَيْكُمْ كَمَآ أَرْسَلْنَآ إِلَىٰ فِرْعَوْنَ رَسُولًا","fr":"Nous vous avons envoyé un Messager qui témoignera contre vous, comme Nous avions déjà envoyé un Messager à Pharaon.","en":"Indeed, We have sent to you a Messenger as a witness upon you just as We sent to Pharaoh a messenger.","words":[{"position":1,"ar":"إِنَّآ","fr":"Certes, Nous","en":"Indeed, We","tr":"innā","isWaqf":false},{"position":2,"ar":"أَرْسَلْنَآ","fr":"[Nous] ont envoyé","en":"[We] have sent","tr":"arsalnā","isWaqf":false},{"position":3,"ar":"إِلَيْكُمْ","fr":"à vous","en":"to you","tr":"ilaykum","isWaqf":false},{"position":4,"ar":"رَسُولًۭا","fr":"un Messager","en":"a Messenger","tr":"rasūlan","isWaqf":false},{"position":5,"ar":"شَـٰهِدًا","fr":"(comme) un témoin","en":"(as) a witness","tr":"shāhidan","isWaqf":false},{"position":6,"ar":"عَلَيْكُمْ","fr":"sur vous","en":"upon you","tr":"ʿalaykum","isWaqf":false},{"position":7,"ar":"كَمَآ","fr":"comme","en":"as","tr":"kamā","isWaqf":false},{"position":8,"ar":"أَرْسَلْنَآ","fr":"Nous avons envoyé","en":"We sent","tr":"arsalnā","isWaqf":false},{"position":9,"ar":"إِلَىٰ","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":10,"ar":"فِرْعَوْنَ","fr":"Fir'aun","en":"Firaun","tr":"fir'ʿawna","isWaqf":false},{"position":11,"ar":"رَسُولًۭا","fr":"un Messager","en":"a Messenger","tr":"rasūlan","isWaqf":false}]},{"ayah":16,"verseKey":"73:16","juz":29,"arabic":"فَعَصَىٰ فِرْعَوْنُ ٱلرَّسُولَ فَأَخَذْنَـٰهُ أَخْذًا وَبِيلًا","fr":"Pharaon ayant désobéi au Messager, Nous sévîmes contre lui d’une façon implacable.","en":"But Pharaoh disobeyed the messenger, so We seized him with a ruinous seizure.","words":[{"position":1,"ar":"فَعَصَىٰ","fr":"Mais désobéit","en":"But disobeyed","tr":"faʿaṣā","isWaqf":false},{"position":2,"ar":"فِرْعَوْنُ","fr":"Fir'aun","en":"Firaun","tr":"fir'ʿawnu","isWaqf":false},{"position":3,"ar":"ٱلرَّسُولَ","fr":"le Messager","en":"the Messenger","tr":"l-rasūla","isWaqf":false},{"position":4,"ar":"فَأَخَذْنَـٰهُ","fr":"donc Nous saisit lui","en":"so We seized him","tr":"fa-akhadhnāhu","isWaqf":false},{"position":5,"ar":"أَخْذًۭا","fr":"(avec) un saisie","en":"(with) a seizure","tr":"akhdhan","isWaqf":false},{"position":6,"ar":"وَبِيلًۭا","fr":"ruineux","en":"ruinous","tr":"wabīlan","isWaqf":false}]},{"ayah":17,"verseKey":"73:17","juz":29,"arabic":"فَكَيْفَ تَتَّقُونَ إِن كَفَرْتُمْ يَوْمًا يَجْعَلُ ٱلْوِلْدَٰنَ شِيبًا","fr":"Comment, si vous mécroyez, pourrez-vous donc vous protéger d’un jour où les enfants seront chenus ?","en":"Then how can you fear, if you disbelieve, a Day that will make the children white-haired?","words":[{"position":1,"ar":"فَكَيْفَ","fr":"Puis comment","en":"Then how","tr":"fakayfa","isWaqf":false},{"position":2,"ar":"تَتَّقُونَ","fr":"va vous gardez vous-mêmes","en":"will you guard yourselves","tr":"tattaqūna","isWaqf":false},{"position":3,"ar":"إِن","fr":"si","en":"if","tr":"in","isWaqf":false},{"position":4,"ar":"كَفَرْتُمْ","fr":"vous mécroire","en":"you disbelieve","tr":"kafartum","isWaqf":false},{"position":5,"ar":"يَوْمًۭا","fr":"un Jour","en":"a Day","tr":"yawman","isWaqf":false},{"position":6,"ar":"يَجْعَلُ","fr":"(que) va faire","en":"(that) will make","tr":"yajʿalu","isWaqf":false},{"position":7,"ar":"ٱلْوِلْدَٰنَ","fr":"le enfants","en":"the children","tr":"l-wil'dāna","isWaqf":false},{"position":8,"ar":"شِيبًا","fr":"aux cheveux gris","en":"gray-haired","tr":"shīban","isWaqf":false}]},{"ayah":18,"verseKey":"73:18","juz":29,"arabic":"ٱلسَّمَآءُ مُنفَطِرٌۢ بِهِۦ ۚ كَانَ وَعْدُهُۥ مَفْعُولًا","fr":"Le ciel, alors, en sera fendu, car Sa promesse à Lui se sera accomplie.","en":"The heaven will break apart therefrom; ever is His promise fulfilled.","words":[{"position":1,"ar":"ٱلسَّمَآءُ","fr":"Le ciel","en":"The heaven","tr":"al-samāu","isWaqf":false},{"position":2,"ar":"مُنفَطِرٌۢ","fr":"(va) briser à part","en":"(will) break apart","tr":"munfaṭirun","isWaqf":false},{"position":3,"ar":"بِهِۦ ۚ","fr":"de là","en":"therefrom","tr":"bihi","isWaqf":false},{"position":4,"ar":"كَانَ","fr":"est","en":"is","tr":"kāna","isWaqf":false},{"position":5,"ar":"وَعْدُهُۥ","fr":"Son Promesse","en":"His Promise","tr":"waʿduhu","isWaqf":false},{"position":6,"ar":"مَفْعُولًا","fr":"à être accompli","en":"to be fulfilled","tr":"mafʿūlan","isWaqf":false}]},{"ayah":19,"verseKey":"73:19","juz":29,"arabic":"إِنَّ هَـٰذِهِۦ تَذْكِرَةٌ ۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ سَبِيلًا","fr":"Voilà qui est un rappel. Prenne donc qui voudra le chemin vers son Seigneur !","en":"Indeed, this is a reminder, so whoever wills may take to his Lord a way.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"هَـٰذِهِۦ","fr":"ceci","en":"this","tr":"hādhihi","isWaqf":false},{"position":3,"ar":"تَذْكِرَةٌۭ ۖ","fr":"(est) un Rappel","en":"(is) a Reminder","tr":"tadhkiratun","isWaqf":false},{"position":4,"ar":"فَمَن","fr":"puis quiconque","en":"then whoever","tr":"faman","isWaqf":false},{"position":5,"ar":"شَآءَ","fr":"veut","en":"wills","tr":"shāa","isWaqf":false},{"position":6,"ar":"ٱتَّخَذَ","fr":"(laisser lui) prendre","en":"(let him) take","tr":"ittakhadha","isWaqf":false},{"position":7,"ar":"إِلَىٰ","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":8,"ar":"رَبِّهِۦ","fr":"son Seigneur","en":"his Lord","tr":"rabbihi","isWaqf":false},{"position":9,"ar":"سَبِيلًا","fr":"une voie","en":"a way","tr":"sabīlan","isWaqf":false}]},{"ayah":20,"verseKey":"73:20","juz":29,"arabic":"إِنَّ رَبَّكَ يَعْلَمُ أَنَّكَ تَقُومُ أَدْنَىٰ مِن ثُلُثَىِ ٱلَّيْلِ وَنِصْفَهُۥ وَثُلُثَهُۥ وَطَآئِفَةٌ مِّنَ ٱلَّذِينَ مَعَكَ ۚ وَٱللَّهُ يُقَدِّرُ ٱلَّيْلَ وَٱلنَّهَارَ ۚ عَلِمَ أَن لَّن تُحْصُوهُ فَتَابَ عَلَيْكُمْ ۖ فَٱقْرَءُوا۟ مَا تَيَسَّرَ مِنَ ٱلْقُرْءَانِ ۚ عَلِمَ أَن سَيَكُونُ مِنكُم مَّرْضَىٰ ۙ وَءَاخَرُونَ يَضْرِبُونَ فِى ٱلْأَرْضِ يَبْتَغُونَ مِن فَضْلِ ٱللَّهِ ۙ وَءَاخَرُونَ يُقَـٰتِلُونَ فِى سَبِيلِ ٱللَّهِ ۖ فَٱقْرَءُوا۟ مَا تَيَسَّرَ مِنْهُ ۚ وَأَقِيمُوا۟ ٱلصَّلَوٰةَ وَءَاتُوا۟ ٱلزَّكَوٰةَ وَأَقْرِضُوا۟ ٱللَّهَ قَرْضًا حَسَنًا ۚ وَمَا تُقَدِّمُوا۟ لِأَنفُسِكُم مِّنْ خَيْرٍ تَجِدُوهُ عِندَ ٱللَّهِ هُوَ خَيْرًا وَأَعْظَمَ أَجْرًا ۚ وَٱسْتَغْفِرُوا۟ ٱللَّهَ ۖ إِنَّ ٱللَّهَ غَفُورٌ رَّحِيمٌۢ","fr":"Ton Seigneur Sait que, toi et quelques-uns de ceux qui t’accompagnent, vous vous levez (pour prier) durant les deux tiers, parfois la moitié et parfois le tiers, de la nuit. Or c’est Allah Qui Sait estimer (la durée) de la nuit et du jour. Il Sait que vous ne pourrez passer toute la nuit à prier et vous pardonne. Récitez donc ce que vous pourrez du Coran, car (Allah) Sait que parmi vous il y a des malades, que d’autres ont à parcourir la terre pour quêter les faveurs d’Allah ; que d’autres encore combattent pour la cause d’Allah. Récitez-en donc ce que vous pourrez ! Accomplissez la Çalât ! Acquittez-vous de la Zakât ! Faites à Allah un prêt de bonne volonté ! Tout ce que vous aurez avancé comme bien pour vous-mêmes (en ce bas monde), vous le trouverez bien meilleur auprès d’Allah et bien mieux récompensé. Implorez le pardon d’Allah, car Allah est Absoluteur et Tout Miséricordieux.","en":"Indeed, your Lord knows, [O Muḥammad], that you stand [in prayer] almost two thirds of the night or half of it or a third of it, and [so do] a group of those with you. And Allāh determines [the extent of] the night and the day. He has known that you [Muslims] will not be able to do it and has turned to you in forgiveness, so recite what is easy [for you] of the Qur’ān. He has known that there will be among you those who are ill and others traveling throughout the land seeking [something] of the bounty of Allāh and others fighting for the cause of Allāh. So recite what is easy from it and establish prayer and give zakāh and loan Allāh a goodly loan. And whatever good you put forward for yourselves - you will find it with Allāh. It is better and greater in reward. And seek forgiveness of Allāh. Indeed, Allāh is Forgiving and Merciful.","words":[{"position":1,"ar":"۞ إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"رَبَّكَ","fr":