,"en":"(of) fine silk","tr":"sundusin","isWaqf":false},{"position":4,"ar":"خُضْرٌۭ","fr":"vert","en":"green","tr":"khuḍ'run","isWaqf":false},{"position":5,"ar":"وَإِسْتَبْرَقٌۭ ۖ","fr":"et lourd brocart","en":"and heavy brocade","tr":"wa-is'tabraqun","isWaqf":false},{"position":6,"ar":"وَحُلُّوٓا۟","fr":"Et ils va être orné","en":"And they will be adorned","tr":"waḥullū","isWaqf":false},{"position":7,"ar":"أَسَاوِرَ","fr":"(avec) bracelets","en":"(with) bracelets","tr":"asāwira","isWaqf":false},{"position":8,"ar":"مِن","fr":"de","en":"of","tr":"min","isWaqf":false},{"position":9,"ar":"فِضَّةٍۢ","fr":"argent","en":"silver","tr":"fiḍḍatin","isWaqf":false},{"position":10,"ar":"وَسَقَىٰهُمْ","fr":"et va donner eux à boire","en":"and will give them to drink","tr":"wasaqāhum","isWaqf":false},{"position":11,"ar":"رَبُّهُمْ","fr":"leur Seigneur","en":"their Lord","tr":"rabbuhum","isWaqf":false},{"position":12,"ar":"شَرَابًۭا","fr":"un boire","en":"a drink","tr":"sharāban","isWaqf":false},{"position":13,"ar":"طَهُورًا","fr":"pur","en":"pure","tr":"ṭahūran","isWaqf":false}]},{"ayah":22,"verseKey":"76:22","juz":29,"arabic":"إِنَّ هَـٰذَا كَانَ لَكُمْ جَزَآءً وَكَانَ سَعْيُكُم مَّشْكُورًا","fr":"Telle sera votre récompense, et tels seront reconnus vos efforts.","en":"[And it will be said], \"Indeed, this is for you a reward, and your effort has been appreciated.\"","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"هَـٰذَا","fr":"ceci","en":"this","tr":"hādhā","isWaqf":false},{"position":3,"ar":"كَانَ","fr":"est","en":"is","tr":"kāna","isWaqf":false},{"position":4,"ar":"لَكُمْ","fr":"pour vous","en":"for you","tr":"lakum","isWaqf":false},{"position":5,"ar":"جَزَآءًۭ","fr":"une récompense","en":"a reward","tr":"jazāan","isWaqf":false},{"position":6,"ar":"وَكَانَ","fr":"et a été","en":"and has been","tr":"wakāna","isWaqf":false},{"position":7,"ar":"سَعْيُكُم","fr":"votre effort","en":"your effort","tr":"saʿyukum","isWaqf":false},{"position":8,"ar":"مَّشْكُورًا","fr":"apprécié","en":"appreciated","tr":"mashkūran","isWaqf":false}]},{"ayah":23,"verseKey":"76:23","juz":29,"arabic":"إِنَّا نَحْنُ نَزَّلْنَا عَلَيْكَ ٱلْقُرْءَانَ تَنزِيلًا","fr":"C’est Nous Qui avons graduellement fait descendre vers toi le Coran.","en":"Indeed, it is We who have sent down to you, [O Muḥammad], the Qur’ān progressively.","words":[{"position":1,"ar":"إِنَّا","fr":"Certes, Nous","en":"Indeed, We","tr":"innā","isWaqf":false},{"position":2,"ar":"نَحْنُ","fr":"[Nous]","en":"[We]","tr":"naḥnu","isWaqf":false},{"position":3,"ar":"نَزَّلْنَا","fr":"[Nous] révélé","en":"[We] revealed","tr":"nazzalnā","isWaqf":false},{"position":4,"ar":"عَلَيْكَ","fr":"à vous","en":"to you","tr":"ʿalayka","isWaqf":false},{"position":5,"ar":"ٱلْقُرْءَانَ","fr":"le Coran","en":"the Quran","tr":"l-qur'āna","isWaqf":false},{"position":6,"ar":"تَنزِيلًۭا","fr":"progressivement","en":"progressively","tr":"tanzīlan","isWaqf":false}]},{"ayah":24,"verseKey":"76:24","juz":29,"arabic":"فَٱصْبِرْ لِحُكْمِ رَبِّكَ وَلَا تُطِعْ مِنْهُمْ ءَاثِمًا أَوْ كَفُورًا","fr":"Prends donc en patience le Jugement de ton Seigneur ! N’obéis pas au pécheur d’entre eux ni à aucun mécréant obstiné.","en":"So be patient for the decision of your Lord and do not obey from among them a sinner or ungrateful [disbeliever].","words":[{"position":1,"ar":"فَٱصْبِرْ","fr":"Sois donc patient","en":"So be patient","tr":"fa-iṣ'bir","isWaqf":false},{"position":2,"ar":"لِحُكْمِ","fr":"pour (le) Ordre","en":"for (the) Command","tr":"liḥuk'mi","isWaqf":false},{"position":3,"ar":"رَبِّكَ","fr":"(de) votre Seigneur","en":"(of) your Lord","tr":"rabbika","isWaqf":false},{"position":4,"ar":"وَلَا","fr":"et (fais) non","en":"and (do) not","tr":"walā","isWaqf":false},{"position":5,"ar":"تُطِعْ","fr":"obéir","en":"obey","tr":"tuṭiʿ","isWaqf":false},{"position":6,"ar":"مِنْهُمْ","fr":"d'eux","en":"from them","tr":"min'hum","isWaqf":false},{"position":7,"ar":"ءَاثِمًا","fr":"tout pécheur","en":"any sinner","tr":"āthiman","isWaqf":false},{"position":8,"ar":"أَوْ","fr":"ou","en":"or","tr":"aw","isWaqf":false},{"position":9,"ar":"كَفُورًۭا","fr":"mécréant","en":"disbeliever","tr":"kafūran","isWaqf":false}]},{"ayah":25,"verseKey":"76:25","juz":29,"arabic":"وَٱذْكُرِ ٱسْمَ رَبِّكَ بُكْرَةً وَأَصِيلًا","fr":"Évoque le Nom de ton Seigneur au lever et au déclin du jour.","en":"And mention the name of your Lord [in prayer] morning and evening","words":[{"position":1,"ar":"وَٱذْكُرِ","fr":"Et rappelle-toi","en":"And remember","tr":"wa-udh'kuri","isWaqf":false},{"position":2,"ar":"ٱسْمَ","fr":"(le) nom","en":"(the) name","tr":"is'ma","isWaqf":false},{"position":3,"ar":"رَبِّكَ","fr":"(de) votre Seigneur","en":"(of) your Lord","tr":"rabbika","isWaqf":false},{"position":4,"ar":"بُكْرَةًۭ","fr":"matin","en":"morning","tr":"buk'ratan","isWaqf":false},{"position":5,"ar":"وَأَصِيلًۭا","fr":"et soir","en":"and evening","tr":"wa-aṣīlan","isWaqf":false}]},{"ayah":26,"verseKey":"76:26","juz":29,"arabic":"وَمِنَ ٱلَّيْلِ فَٱسْجُدْ لَهُۥ وَسَبِّحْهُ لَيْلًا طَوِيلًا","fr":"Pendant une partie de la nuit, prosterne-toi devant Lui, et rends-Lui alors longuement gloire.","en":"And during the night prostrate to Him and exalt [i.e., praise] Him a long [part of the] night.","words":[{"position":1,"ar":"وَمِنَ","fr":"Et de","en":"And of","tr":"wamina","isWaqf":false},{"position":2,"ar":"ٱلَّيْلِ","fr":"la nuit","en":"the night","tr":"al-layli","isWaqf":false},{"position":3,"ar":"فَٱسْجُدْ","fr":"se prosterner","en":"prostrate","tr":"fa-us'jud","isWaqf":false},{"position":4,"ar":"لَهُۥ","fr":"à Lui","en":"to Him","tr":"lahu","isWaqf":false},{"position":5,"ar":"وَسَبِّحْهُ","fr":"et glorifier Lui","en":"and glorify Him","tr":"wasabbiḥ'hu","isWaqf":false},{"position":6,"ar":"لَيْلًۭا","fr":"un nuit","en":"a night","tr":"laylan","isWaqf":false},{"position":7,"ar":"طَوِيلًا","fr":"long","en":"long","tr":"ṭawīlan","isWaqf":false}]},{"ayah":27,"verseKey":"76:27","juz":29,"arabic":"إِنَّ هَـٰٓؤُلَآءِ يُحِبُّونَ ٱلْعَاجِلَةَ وَيَذَرُونَ وَرَآءَهُمْ يَوْمًا ثَقِيلًا","fr":"Ceux-là aiment cette vie fugace et jettent derrière eux un jour lourd (de conséquences).","en":"Indeed, these [disbelievers] love the immediate and leave behind them a grave Day.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"هَـٰٓؤُلَآءِ","fr":"ces","en":"these","tr":"hāulāi","isWaqf":false},{"position":3,"ar":"يُحِبُّونَ","fr":"aimer","en":"love","tr":"yuḥibbūna","isWaqf":false},{"position":4,"ar":"ٱلْعَاجِلَةَ","fr":"le immédiat","en":"the immediate","tr":"l-ʿājilata","isWaqf":false},{"position":5,"ar":"وَيَذَرُونَ","fr":"et quitter","en":"and leave","tr":"wayadharūna","isWaqf":false},{"position":6,"ar":"وَرَآءَهُمْ","fr":"derrière eux","en":"behind them","tr":"warāahum","isWaqf":false},{"position":7,"ar":"يَوْمًۭا","fr":"un Jour","en":"a Day","tr":"yawman","isWaqf":false},{"position":8,"ar":"ثَقِيلًۭا","fr":"tombe","en":"grave","tr":"thaqīlan","isWaqf":false}]},{"ayah":28,"verseKey":"76:28","juz":29,"arabic":"نَّحْنُ خَلَقْنَـٰهُمْ وَشَدَدْنَآ أَسْرَهُمْ ۖ وَإِذَا شِئْنَا بَدَّلْنَآ أَمْثَـٰلَهُمْ تَبْدِيلًا","fr":"C’est Nous Qui les avons créés et Qui les avons soutenus, et si Nous voulions, Nous les remplacerions par d’autres (êtres) similaires.","en":"We have created them and strengthened their forms, and when We will, We can change their likenesses with [complete] alteration.","words":[{"position":1,"ar":"نَّحْنُ","fr":"Nous","en":"We","tr":"naḥnu","isWaqf":false},{"position":2,"ar":"خَلَقْنَـٰهُمْ","fr":"créé eux","en":"created them","tr":"khalaqnāhum","isWaqf":false},{"position":3,"ar":"وَشَدَدْنَآ","fr":"et Nous renforça","en":"and We strengthened","tr":"washadadnā","isWaqf":false},{"position":4,"ar":"أَسْرَهُمْ ۖ","fr":"leur formes","en":"their forms","tr":"asrahum","isWaqf":false},{"position":5,"ar":"وَإِذَا","fr":"et quand","en":"and when","tr":"wa-idhā","isWaqf":false},{"position":6,"ar":"شِئْنَا","fr":"Nous allons","en":"We will","tr":"shi'nā","isWaqf":false},{"position":7,"ar":"بَدَّلْنَآ","fr":"Nous peut changer","en":"We can change","tr":"baddalnā","isWaqf":false},{"position":8,"ar":"أَمْثَـٰلَهُمْ","fr":"leur ressemblance[es]","en":"their likeness[es]","tr":"amthālahum","isWaqf":false},{"position":9,"ar":"تَبْدِيلًا","fr":"(avec) un changer","en":"(with) a change","tr":"tabdīlan","isWaqf":false}]},{"ayah":29,"verseKey":"76:29","juz":29,"arabic":"إِنَّ هَـٰذِهِۦ تَذْكِرَةٌ ۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ سَبِيلًا","fr":"Voilà qui est un rappel ! Suive donc qui voudra la voie de son Seigneur !","en":"Indeed, this is a reminder, so he who wills may take to his Lord a way.","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"هَـٰذِهِۦ","fr":"ceci","en":"this","tr":"hādhihi","isWaqf":false},{"position":3,"ar":"تَذْكِرَةٌۭ ۖ","fr":"(est) un rappel","en":"(is) a reminder","tr":"tadhkiratun","isWaqf":false},{"position":4,"ar":"فَمَن","fr":"donc quiconque","en":"so whoever","tr":"faman","isWaqf":false},{"position":5,"ar":"شَآءَ","fr":"veut","en":"wills","tr":"shāa","isWaqf":false},{"position":6,"ar":"ٱتَّخَذَ","fr":"laisser lui prendre","en":"let him take","tr":"ittakhadha","isWaqf":false},{"position":7,"ar":"إِلَىٰ","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":8,"ar":"رَبِّهِۦ","fr":"son Seigneur","en":"his Lord","tr":"rabbihi","isWaqf":false},{"position":9,"ar":"سَبِيلًۭا","fr":"une voie","en":"a way","tr":"sabīlan","isWaqf":false}]},{"ayah":30,"verseKey":"76:30","juz":29,"arabic":"وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ ۚ إِنَّ ٱللَّهَ كَانَ عَلِيمًا حَكِيمًا","fr":"Mais vous ne voudrez rien qu’Allah n’ait voulu, car Allah est Omniscient et Sage.","en":"And you do not will except that Allāh wills. Indeed, Allāh is ever Knowing and Wise.","words":[{"position":1,"ar":"وَمَا","fr":"Et non","en":"And not","tr":"wamā","isWaqf":false},{"position":2,"ar":"تَشَآءُونَ","fr":"vous va","en":"you will","tr":"tashāūna","isWaqf":false},{"position":3,"ar":"إِلَّآ","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":4,"ar":"أَن","fr":"que","en":"that","tr":"an","isWaqf":false},{"position":5,"ar":"يَشَآءَ","fr":"veut","en":"wills","tr":"yashāa","isWaqf":false},{"position":6,"ar":"ٱللَّهُ ۚ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":7,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":8,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":9,"ar":"كَانَ","fr":"est","en":"is","tr":"kāna","isWaqf":false},{"position":10,"ar":"عَلِيمًا","fr":"Omniscient","en":"All-Knower","tr":"ʿalīman","isWaqf":false},{"position":11,"ar":"حَكِيمًۭا","fr":"Très-Sage","en":"All-Wise","tr":"ḥakīman","isWaqf":false}]},{"ayah":31,"verseKey":"76:31","juz":29,"arabic":"يُدْخِلُ مَن يَشَآءُ فِى رَحْمَتِهِۦ ۚ وَٱلظَّـٰلِمِينَ أَعَدَّ لَهُمْ عَذَابًا أَلِيمًۢا","fr":"Il reçoit en Sa miséricorde qui Il veut, et aux injustes, Il prévoit un supplice très douloureux.","en":"He admits whom He wills into His mercy; but the wrongdoers - He has prepared for them a painful punishment.","words":[{"position":1,"ar":"يُدْخِلُ","fr":"Il admet","en":"He admits","tr":"yud'khilu","isWaqf":false},{"position":2,"ar":"مَن","fr":"qui","en":"whom","tr":"man","isWaqf":false},{"position":3,"ar":"يَشَآءُ","fr":"Il veut","en":"He wills","tr":"yashāu","isWaqf":false},{"position":4,"ar":"فِى","fr":"dans","en":"into","tr":"fī","isWaqf":false},{"position":5,"ar":"رَحْمَتِهِۦ ۚ","fr":"Son miséricorde","en":"His mercy","tr":"raḥmatihi","isWaqf":false},{"position":6,"ar":"وَٱلظَّـٰلِمِينَ","fr":"mais (pour) les injustes","en":"but (for) the wrongdoers","tr":"wal-ẓālimīna","isWaqf":false},{"position":7,"ar":"أَعَدَّ","fr":"Il a préparé","en":"He has prepared","tr":"aʿadda","isWaqf":false},{"position":8,"ar":"لَهُمْ","fr":"pour eux","en":"for them","tr":"lahum","isWaqf":false},{"position":9,"ar":"عَذَابًا","fr":"un châtiment","en":"a punishment","tr":"ʿadhāban","isWaqf":false},{"position":10,"ar":"أَلِيمًۢا","fr":"douloureux","en":"painful","tr":"alīman","isWaqf":false}]}]