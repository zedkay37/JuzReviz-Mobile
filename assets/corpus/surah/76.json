[{"ayah":1,"verseKey":"76:1","juz":29,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰ عَلَى ٱلْإِنسَـٰنِ حِينٌ مِّنَ ٱلدَّهْرِ لَمْ يَكُن شَيْـًٔا مَّذْكُورًا","fr":"Ne s’est-il pas écoulé un temps très long durant lequel l’homme ne méritait même pas d’être cité ?","en":"Has there [not] come upon man a period of time when he was not a thing [even] mentioned?","words":[{"position":1,"ar":"هَلْ","fr":"A","en":"Has","tr":"hal","isWaqf":false},{"position":2,"ar":"أَتَىٰ","fr":"(là) venir","en":"(there) come","tr":"atā","isWaqf":false},{"position":3,"ar":"عَلَى","fr":"sur","en":"upon","tr":"ʿalā","isWaqf":false},{"position":4,"ar":"ٱلْإِنسَـٰنِ","fr":"homme","en":"man","tr":"l-insāni","isWaqf":false},{"position":5,"ar":"حِينٌۭ","fr":"un délai","en":"a period","tr":"ḥīnun","isWaqf":false},{"position":6,"ar":"مِّنَ","fr":"de","en":"of","tr":"mina","isWaqf":false},{"position":7,"ar":"ٱلدَّهْرِ","fr":"temps","en":"time","tr":"l-dahri","isWaqf":false},{"position":8,"ar":"لَمْ","fr":"non","en":"not","tr":"lam","isWaqf":false},{"position":9,"ar":"يَكُن","fr":"il était","en":"he was","tr":"yakun","isWaqf":false},{"position":10,"ar":"شَيْـًۭٔا","fr":"une chose","en":"a thing","tr":"shayan","isWaqf":false},{"position":11,"ar":"مَّذْكُورًا","fr":"mentionné","en":"mentioned","tr":"madhkūran","isWaqf":false}]},{"ayah":2,"verseKey":"76:2","juz":29,"arabic":"إِنَّا خَلَقْنَا ٱلْإِنسَـٰنَ مِن نُّطْفَةٍ أَمْشَاجٍ نَّبْتَلِيهِ فَجَعَلْنَـٰهُ سَمِيعًۢا بَصِيرًا","fr":"Nous avons créé l’homme d’une goutte de sperme combinée à d’autres éléments, pour l’éprouver, et Nous l’avons fait qui entend et qui voit.","en":"Indeed, We created man from a sperm-drop mixture that We may try him; and We made him hearing and seeing.","words":[{"position":1,"ar":"إِنَّا","fr":"Certes, Nous","en":"Indeed, We","tr":"innā","isWaqf":false},{"position":2,"ar":"خَلَقْنَا","fr":"[Nous] créé","en":"[We] created","tr":"khalaqnā","isWaqf":false},{"position":3,"ar":"ٱلْإِنسَـٰنَ","fr":"homme","en":"man","tr":"l-insāna","isWaqf":false},{"position":4,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":5,"ar":"نُّطْفَةٍ","fr":"un goutte de sperme","en":"a semen-drop","tr":"nuṭ'fatin","isWaqf":false},{"position":6,"ar":"أَمْشَاجٍۢ","fr":"un mélange","en":"a mixture","tr":"amshājin","isWaqf":false},{"position":7,"ar":"نَّبْتَلِيهِ","fr":"(que) Nous Testons lui","en":"(that) We test him","tr":"nabtalīhi","isWaqf":false},{"position":8,"ar":"فَجَعَلْنَـٰهُ","fr":"donc Nous fait (pour) lui","en":"so We made (for) him","tr":"fajaʿalnāhu","isWaqf":false},{"position":9,"ar":"سَمِيعًۢا","fr":"ouïe","en":"hearing","tr":"samīʿan","isWaqf":false},{"position":10,"ar":"بَصِيرًا","fr":"et vue","en":"and sight","tr":"baṣīran","isWaqf":false}]},{"ayah":3,"verseKey":"76:3","juz":29,"arabic":"إِنَّا هَدَيْنَـٰهُ ٱلسَّبِيلَ إِمَّا شَاكِرًا وَإِمَّا كَفُورًا","fr":"Nous lui avons indiqué le droit chemin, qu’il fût reconnaissant ou ingrat.","en":"Indeed, We guided him to the way, be he grateful or be he ungrateful.","words":[{"position":1,"ar":"إِنَّا","fr":"Certes, Nous","en":"Indeed, We","tr":"innā","isWaqf":false},{"position":2,"ar":"هَدَيْنَـٰهُ","fr":"guidé lui","en":"guided him","tr":"hadaynāhu","isWaqf":false},{"position":3,"ar":"ٱلسَّبِيلَ","fr":"(à) la voie","en":"(to) the way","tr":"l-sabīla","isWaqf":false},{"position":4,"ar":"إِمَّا","fr":"si","en":"whether","tr":"immā","isWaqf":false},{"position":5,"ar":"شَاكِرًۭا","fr":"(il) être reconnaissant","en":"(he) be grateful","tr":"shākiran","isWaqf":false},{"position":6,"ar":"وَإِمَّا","fr":"et si","en":"and whether","tr":"wa-immā","isWaqf":false},{"position":7,"ar":"كَفُورًا","fr":"(il) être ingrat","en":"(he) be ungrateful","tr":"kafūran","isWaqf":false}]},{"ayah":4,"verseKey":"76:4","juz":29,"arabic":"إِنَّآ أَعْتَدْنَا لِلْكَـٰفِرِينَ سَلَـٰسِلَا۟ وَأَغْلَـٰلًا وَسَعِيرًا","fr":"Nous avons préparé pour les mécréants des chaînes, des carcans et un Brasier ardent.","en":"Indeed, We have prepared for the disbelievers chains and shackles and a blaze.","words":[{"position":1,"ar":"إِنَّآ","fr":"Certes, Nous","en":"Indeed, We","tr":"innā","isWaqf":false},{"position":2,"ar":"أَعْتَدْنَا","fr":"[Nous] ont préparé","en":"[We] have prepared","tr":"aʿtadnā","isWaqf":false},{"position":3,"ar":"لِلْكَـٰفِرِينَ","fr":"pour les mécréants","en":"for the disbelievers","tr":"lil'kāfirīna","isWaqf":false},{"position":4,"ar":"سَلَـٰسِلَا۟","fr":"chaînes","en":"chains","tr":"salāsilā","isWaqf":false},{"position":5,"ar":"وَأَغْلَـٰلًۭا","fr":"et entraves","en":"and shackles","tr":"wa-aghlālan","isWaqf":false},{"position":6,"ar":"وَسَعِيرًا","fr":"et un Ardent Feu","en":"and a Blazing Fire","tr":"wasaʿīran","isWaqf":false}]},{"ayah":5,"verseKey":"76:5","juz":29,"arabic":"إِنَّ ٱلْأَبْرَارَ يَشْرَبُونَ مِن كَأْسٍ كَانَ مِزَاجُهَا كَافُورًا","fr":"Les vertueux boiront dans une coupe dont la mixture sera d’un camphre","en":"Indeed, the righteous will drink from a cup [of wine] whose mixture is of Kāfūr,","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"ٱلْأَبْرَارَ","fr":"les justes","en":"the righteous","tr":"l-abrāra","isWaqf":false},{"position":3,"ar":"يَشْرَبُونَ","fr":"va boire","en":"will drink","tr":"yashrabūna","isWaqf":false},{"position":4,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":5,"ar":"كَأْسٍۢ","fr":"un coupe","en":"a cup","tr":"kasin","isWaqf":false},{"position":6,"ar":"كَانَ","fr":"est","en":"is","tr":"kāna","isWaqf":false},{"position":7,"ar":"مِزَاجُهَا","fr":"son mélange","en":"its mixture","tr":"mizājuhā","isWaqf":false},{"position":8,"ar":"كَافُورًا","fr":"(de) Kafur","en":"(of) Kafur","tr":"kāfūran","isWaqf":false}]},{"ayah":6,"verseKey":"76:6","juz":29,"arabic":"عَيْنًا يَشْرَبُ بِهَا عِبَادُ ٱللَّهِ يُفَجِّرُونَهَا تَفْجِيرًا","fr":"puisé à une source dont boiront les serviteurs d’Allah et qu’ils feront jaillir comme ils le voudront.","en":"A spring of which the [righteous] servants of Allāh will drink; they will make it gush forth in force [and abundance].","words":[{"position":1,"ar":"عَيْنًۭا","fr":"Un source","en":"A spring","tr":"ʿaynan","isWaqf":false},{"position":2,"ar":"يَشْرَبُ","fr":"va boire","en":"will drink","tr":"yashrabu","isWaqf":false},{"position":3,"ar":"بِهَا","fr":"de cela","en":"from it","tr":"bihā","isWaqf":false},{"position":4,"ar":"عِبَادُ","fr":"(le) serviteurs","en":"(the) slaves","tr":"ʿibādu","isWaqf":false},{"position":5,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":6,"ar":"يُفَجِّرُونَهَا","fr":"faisant cela à jaillir en avant","en":"causing it to gush forth","tr":"yufajjirūnahā","isWaqf":false},{"position":7,"ar":"تَفْجِيرًۭا","fr":"abondamment","en":"abundantly","tr":"tafjīran","isWaqf":false}]},{"ayah":7,"verseKey":"76:7","juz":29,"arabic":"يُوفُونَ بِٱلنَّذْرِ وَيَخَافُونَ يَوْمًا كَانَ شَرُّهُۥ مُسْتَطِيرًا","fr":"(Durant leur vie en ce bas monde), ils respectaient leurs vœux et redoutaient un jour au mal envahissant.","en":"They [are those who] fulfill [their] vows and fear a Day whose evil will be widespread.","words":[{"position":1,"ar":"يُوفُونَ","fr":"Ils Accomplissent","en":"They fulfill","tr":"yūfūna","isWaqf":false},{"position":2,"ar":"بِٱلنَّذْرِ","fr":"le vœux","en":"the vows","tr":"bil-nadhri","isWaqf":false},{"position":3,"ar":"وَيَخَافُونَ","fr":"et craindre","en":"and fear","tr":"wayakhāfūna","isWaqf":false},{"position":4,"ar":"يَوْمًۭا","fr":"un Jour","en":"a Day","tr":"yawman","isWaqf":false},{"position":5,"ar":"كَانَ","fr":"(que) est","en":"(which) is","tr":"kāna","isWaqf":false},{"position":6,"ar":"شَرُّهُۥ","fr":"son mal","en":"its evil","tr":"sharruhu","isWaqf":false},{"position":7,"ar":"مُسْتَطِيرًۭا","fr":"répandu","en":"widespread","tr":"mus'taṭīran","isWaqf":false}]},{"ayah":8,"verseKey":"76:8","juz":29,"arabic":"وَيُطْعِمُونَ ٱلطَّعَامَ عَلَىٰ حُبِّهِۦ مِسْكِينًا وَيَتِيمًا وَأَسِيرًا","fr":"Ils donnaient la nourriture, qui leur était pourtant chère, au pauvre, à l’orphelin et au prisonnier.","en":"And they give food in spite of love for it to the needy, the orphan, and the captive,","words":[{"position":1,"ar":"وَيُطْعِمُونَ","fr":"Et ils nourrissent","en":"And they feed","tr":"wayuṭ'ʿimūna","isWaqf":false},{"position":2,"ar":"ٱلطَّعَامَ","fr":"le nourriture","en":"the food","tr":"l-ṭaʿāma","isWaqf":false},{"position":3,"ar":"عَلَىٰ","fr":"dans rancune de","en":"in spite of","tr":"ʿalā","isWaqf":false},{"position":4,"ar":"حُبِّهِۦ","fr":"aimer (pour) cela","en":"love (for) it","tr":"ḥubbihi","isWaqf":false},{"position":5,"ar":"مِسْكِينًۭا","fr":"(à le) nécessiteux","en":"(to the) needy","tr":"mis'kīnan","isWaqf":false},{"position":6,"ar":"وَيَتِيمًۭا","fr":"et (le) orphelin","en":"and (the) orphan","tr":"wayatīman","isWaqf":false},{"position":7,"ar":"وَأَسِيرًا","fr":"et (le) captif","en":"and (the) captive","tr":"wa-asīran","isWaqf":false}]},{"ayah":9,"verseKey":"76:9","juz":29,"arabic":"إِنَّمَا نُطْعِمُكُمْ لِوَجْهِ ٱللَّهِ لَا نُرِيدُ مِنكُمْ جَزَآءً وَلَا شُكُورًا","fr":"(et ils disaient) : « Nous ne vous donnons à manger que pour obtenir l’agrément d’Allah. Nous ne voulons de vous ni récompense ni reconnaissance.","en":"[Saying], \"We feed you only for the face [i.e., approval] of Allāh. We wish not from you reward or gratitude.","words":[{"position":1,"ar":"إِنَّمَا","fr":"Seulement","en":"Only","tr":"innamā","isWaqf":false},{"position":2,"ar":"نُطْعِمُكُمْ","fr":"nous nourrissons vous","en":"we feed you","tr":"nuṭ'ʿimukum","isWaqf":false},{"position":3,"ar":"لِوَجْهِ","fr":"pour (le) Visage","en":"for (the) Countenance","tr":"liwajhi","isWaqf":false},{"position":4,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":5,"ar":"لَا","fr":"Non","en":"Not","tr":"lā","isWaqf":false},{"position":6,"ar":"نُرِيدُ","fr":"nous désissons","en":"we desire","tr":"nurīdu","isWaqf":false},{"position":7,"ar":"مِنكُمْ","fr":"de vous","en":"from you","tr":"minkum","isWaqf":false},{"position":8,"ar":"جَزَآءًۭ","fr":"tout récompense","en":"any reward","tr":"jazāan","isWaqf":false},{"position":9,"ar":"وَلَا","fr":"et non","en":"and not","tr":"walā","isWaqf":false},{"position":10,"ar":"شُكُورًا","fr":"remerciements","en":"thanks","tr":"shukūran","isWaqf":false}]},{"ayah":10,"verseKey":"76:10","juz":29,"arabic":"إِنَّا نَخَافُ مِن رَّبِّنَا يَوْمًا عَبُوسًا قَمْطَرِيرًا","fr":"Nous redoutons seulement, de la part de notre Seigneur, la venue d’un jour sombre et terrible.","en":"Indeed, We fear from our Lord a Day austere and distressful.\"","words":[{"position":1,"ar":"إِنَّا","fr":"Certes, nous","en":"Indeed, we","tr":"innā","isWaqf":false},{"position":2,"ar":"نَخَافُ","fr":"craindre","en":"fear","tr":"nakhāfu","isWaqf":false},{"position":3,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":4,"ar":"رَّبِّنَا","fr":"notre Seigneur","en":"our Lord","tr":"rabbinā","isWaqf":false},{"position":5,"ar":"يَوْمًا","fr":"un Jour","en":"a Day","tr":"yawman","isWaqf":false},{"position":6,"ar":"عَبُوسًۭا","fr":"rude","en":"harsh","tr":"ʿabūsan","isWaqf":false},{"position":7,"ar":"قَمْطَرِيرًۭا","fr":"et pénible","en":"and distressful","tr":"qamṭarīran","isWaqf":false}]},{"ayah":11,"verseKey":"76:11","juz":29,"arabic":"فَوَقَىٰهُمُ ٱللَّهُ شَرَّ ذَٰلِكَ ٱلْيَوْمِ وَلَقَّىٰهُمْ نَضْرَةً وَسُرُورًا","fr":"Allah les préservera donc des calamités de ce jour, et leur destinera l’épanouissement et la joie.","en":"So Allāh will protect them from the evil of that Day and give them radiance and happiness","words":[{"position":1,"ar":"فَوَقَىٰهُمُ","fr":"Mais va protéger eux","en":"But will protect them","tr":"fawaqāhumu","isWaqf":false},{"position":2,"ar":"ٱللَّهُ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":3,"ar":"شَرَّ","fr":"(de le) mal","en":"(from the) evil","tr":"sharra","isWaqf":false},{"position":4,"ar":"ذَٰلِكَ","fr":"(de) que","en":"(of) that","tr":"dhālika","isWaqf":false},{"position":5,"ar":"ٱلْيَوْمِ","fr":"Jour","en":"Day","tr":"l-yawmi","isWaqf":false},{"position":6,"ar":"وَلَقَّىٰهُمْ","fr":"et va faire eux à rencontrer","en":"and will cause them to meet","tr":"walaqqāhum","isWaqf":false},{"position":7,"ar":"نَضْرَةًۭ","fr":"éclat","en":"radiance","tr":"naḍratan","isWaqf":false},{"position":8,"ar":"وَسُرُورًۭا","fr":"et happiness","en":"and happiness","tr":"wasurūran","isWaqf":false}]},{"ayah":12,"verseKey":"76:12","juz":29,"arabic":"وَجَزَىٰهُم بِمَا صَبَرُوا۟ جَنَّةً وَحَرِيرًا","fr":"Pour leur patience, Il leur accordera en récompense le jardin du Paradis et (des vêtements) en soie.","en":"And will reward them for what they patiently endured [with] a garden [in Paradise] and silk [garments].","words":[{"position":1,"ar":"وَجَزَىٰهُم","fr":"Et va récompense eux","en":"And will reward them","tr":"wajazāhum","isWaqf":false},{"position":2,"ar":"بِمَا","fr":"car","en":"because","tr":"bimā","isWaqf":false},{"position":3,"ar":"صَبَرُوا۟","fr":"ils étaient patient","en":"they were patient","tr":"ṣabarū","isWaqf":false},{"position":4,"ar":"جَنَّةًۭ","fr":"(avec) un Jardin","en":"(with) a Garden","tr":"jannatan","isWaqf":false},{"position":5,"ar":"وَحَرِيرًۭا","fr":"et soie","en":"and silk","tr":"waḥarīran","isWaqf":false}]},{"ayah":13,"verseKey":"76:13","juz":29,"arabic":"مُّتَّكِـِٔينَ فِيهَا عَلَى ٱلْأَرَآئِكِ ۖ لَا يَرَوْنَ فِيهَا شَمْسًا وَلَا زَمْهَرِيرًا","fr":"Accoudés sur des couches, ils n’y sentiront ni la chaleur du soleil ni la rigueur du froid.","en":"[They will be] reclining therein on adorned couches. They will not see therein any [burning] sun or [freezing] cold.","words":[{"position":1,"ar":"مُّتَّكِـِٔينَ","fr":"Accoudés","en":"Reclining","tr":"muttakiīna","isWaqf":false},{"position":2,"ar":"فِيهَا","fr":"en cela","en":"therein","tr":"fīhā","isWaqf":false},{"position":3,"ar":"عَلَى","fr":"sur","en":"on","tr":"ʿalā","isWaqf":false},{"position":4,"ar":"ٱلْأَرَآئِكِ ۖ","fr":"lits","en":"couches","tr":"l-arāiki","isWaqf":false},{"position":5,"ar":"لَا","fr":"Non","en":"Not","tr":"lā","isWaqf":false},{"position":6,"ar":"يَرَوْنَ","fr":"ils va voir","en":"they will see","tr":"yarawna","isWaqf":false},{"position":7,"ar":"فِيهَا","fr":"en cela","en":"therein","tr":"fīhā","isWaqf":false},{"position":8,"ar":"شَمْسًۭا","fr":"soleil","en":"sun","tr":"shamsan","isWaqf":false},{"position":9,"ar":"وَلَا","fr":"et non","en":"and not","tr":"walā","isWaqf":false},{"position":10,"ar":"زَمْهَرِيرًۭا","fr":"froid glacial","en":"freezing cold","tr":"zamharīran","isWaqf":false}]},{"ayah":14,"verseKey":"76:14","juz":29,"arabic":"وَدَانِيَةً عَلَيْهِمْ ظِلَـٰلُهَا وَذُلِّلَتْ قُطُوفُهَا تَذْلِيلًا","fr":"Les ombres (du Paradis) s’étendront sur eux toutes proches, et ses fruits seront à portée de leurs mains.","en":"And near above them are its shades, and its [fruit] to be picked will be lowered in compliance.","words":[{"position":1,"ar":"وَدَانِيَةً","fr":"Et proche","en":"And near","tr":"wadāniyatan","isWaqf":false},{"position":2,"ar":"عَلَيْهِمْ","fr":"au-dessus d'eux","en":"above them","tr":"ʿalayhim","isWaqf":false},{"position":3,"ar":"ظِلَـٰلُهَا","fr":"(sont) son ombres","en":"(are) its shades","tr":"ẓilāluhā","isWaqf":false},{"position":4,"ar":"وَذُلِّلَتْ","fr":"et va suspendre bas","en":"and will hang low","tr":"wadhullilat","isWaqf":false},{"position":5,"ar":"قُطُوفُهَا","fr":"son cluster de fruits","en":"its cluster of fruits","tr":"quṭūfuhā","isWaqf":false},{"position":6,"ar":"تَذْلِيلًۭا","fr":"dangling bas","en":"dangling low","tr":"tadhlīlan","isWaqf":false}]},{"ayah":15,"verseKey":"76:15","juz":29,"arabic":"وَيُطَافُ عَلَيْهِم بِـَٔانِيَةٍ مِّن فِضَّةٍ وَأَكْوَابٍ كَانَتْ قَوَارِيرَا۠","fr":"Parmi eux circuleront des plats d’argent et des coupes en cristal,","en":"And there will be circulated among them vessels of silver and cups having been [created] clear [as glass],","words":[{"position":1,"ar":"وَيُطَافُ","fr":"Et va être fit circuler","en":"And will be circulated","tr":"wayuṭāfu","isWaqf":false},{"position":2,"ar":"عَلَيْهِم","fr":"parmi eux","en":"among them","tr":"ʿalayhim","isWaqf":false},{"position":3,"ar":"بِـَٔانِيَةٍۢ","fr":"récipients","en":"vessels","tr":"biāniyatin","isWaqf":false},{"position":4,"ar":"مِّن","fr":"de","en":"of","tr":"min","isWaqf":false},{"position":5,"ar":"فِضَّةٍۢ","fr":"argent","en":"silver","tr":"fiḍḍatin","isWaqf":false},{"position":6,"ar":"وَأَكْوَابٍۢ","fr":"et coupes","en":"and cups","tr":"wa-akwābin","isWaqf":false},{"position":7,"ar":"كَانَتْ","fr":"(que) sont","en":"(that) are","tr":"kānat","isWaqf":false},{"position":8,"ar":"قَوَارِيرَا۠","fr":"(de) crystal","en":"(of) crystal","tr":"qawārīrā","isWaqf":false}]},{"ayah":16,"verseKey":"76:16","juz":29,"arabic":"قَوَارِيرَا۟ مِن فِضَّةٍ قَدَّرُوهَا تَقْدِيرًا","fr":"(des coupes) en argent translucide et à la capacité bien déterminée.","en":"Clear glasses [made] from silver of which they have determined the measure.","words":[{"position":1,"ar":"قَوَارِيرَا۟","fr":"Cristallin","en":"Crystal-clear","tr":"qawārīrā","isWaqf":false},{"position":2,"ar":"مِن","fr":"de","en":"of","tr":"min","isWaqf":false},{"position":3,"ar":"فِضَّةٍۢ","fr":"argent","en":"silver","tr":"fiḍḍatin","isWaqf":false},{"position":4,"ar":"قَدَّرُوهَا","fr":"Ils va determine son","en":"They will determine its","tr":"qaddarūhā","isWaqf":false},{"position":5,"ar":"تَقْدِيرًۭا","fr":"mesure","en":"measure","tr":"taqdīran","isWaqf":false}]},{"ayah":17,"verseKey":"76:17","juz":29,"arabic":"وَيُسْقَوْنَ فِيهَا كَأْسًا كَانَ مِزَاجُهَا زَنجَبِيلًا","fr":"Ils seront abreuvés d’une coupe dont (la boisson) sera de gingembre mêlée,","en":"And they will be given to drink a cup [of wine] whose mixture is of ginger","words":[{"position":1,"ar":"وَيُسْقَوْنَ","fr":"Et ils va être donné à boire","en":"And they will be given to drink","tr":"wayus'qawna","isWaqf":false},{"position":2,"ar":"فِيهَا","fr":"en cela","en":"therein","tr":"fīhā","isWaqf":false},{"position":3,"ar":"كَأْسًۭا","fr":"un coupe","en":"a cup","tr":"kasan","isWaqf":false},{"position":4,"ar":"كَانَ","fr":"est","en":"is","tr":"kāna","isWaqf":false},{"position":5,"ar":"مِزَاجُهَا","fr":"son mélange","en":"its mixture","tr":"mizājuhā","isWaqf":false},{"position":6,"ar":"زَنجَبِيلًا","fr":"(de) Zanjabil","en":"(of) Zanjabil","tr":"zanjabīlan","isWaqf":false}]},{"ayah":18,"verseKey":"76:18","juz":29,"arabic":"عَيْنًا فِيهَا تُسَمَّىٰ سَلْسَبِيلًا","fr":"puisée à une source du nom de Salsabîl.","en":"[From] a fountain within it [i.e., Paradise] named Salsabeel.","words":[{"position":1,"ar":"عَيْنًۭا","fr":"Un source","en":"A spring","tr":"ʿaynan","isWaqf":false},{"position":2,"ar":"فِيهَا","fr":"en cela","en":"therein","tr":"fīhā","isWaqf":false},{"position":3,"ar":"تُسَمَّىٰ","fr":"nommé","en":"named","tr":"tusammā","isWaqf":false},{"position":4,"ar":"سَلْسَبِيلًۭا","fr":"Salsabil","en":"Salsabil","tr":"salsabīlan","isWaqf":false}]},{"ayah":19,"verseKey":"76:19","juz":29,"arabic":"وَيَطُوفُ عَلَيْهِمْ وِلْدَٰنٌ مُّخَلَّدُونَ إِذَا رَأَيْتَهُمْ حَسِبْتَهُمْ لُؤْلُؤًا مَّنثُورًا","fr":"Parmi eux, circuleront des serviteurs à la jeunesse éternelle. Quand tu les verras, tu les prendras pour des perles éparpillées.","en":"There will circulate among them young boys made eternal. When you see them, you would think them [as beautiful as] scattered pearls.","words":[{"position":1,"ar":"۞ وَيَطُوفُ","fr":"Et va circuler","en":"And will circulate","tr":"wayaṭūfu","isWaqf":false},{"position":2,"ar":"عَلَيْهِمْ","fr":"parmi eux","en":"among them","tr":"ʿalayhim","isWaqf":false},{"position":3,"ar":"وِلْدَٰنٌۭ","fr":"jeunes garçons","en":"young boys","tr":"wil'dānun","isWaqf":false},{"position":4,"ar":"مُّخَلَّدُونَ","fr":"fait Éternel","en":"made eternal","tr":"mukhalladūna","isWaqf":false},{"position":5,"ar":"إِذَا","fr":"Quand","en":"When","tr":"idhā","isWaqf":false},{"position":6,"ar":"رَأَيْتَهُمْ","fr":"vous voez eux","en":"you see them","tr":"ra-aytahum","isWaqf":false},{"position":7,"ar":"حَسِبْتَهُمْ","fr":"vous irait penser eux","en":"you