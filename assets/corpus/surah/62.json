[{"ayah":1,"verseKey":"62:1","juz":28,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ يُسَبِّحُ لِلَّهِ مَا فِى ٱلسَّمَـٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ٱلْمَلِكِ ٱلْقُدُّوسِ ٱلْعَزِيزِ ٱلْحَكِيمِ","fr":"Tout ce qui est dans les cieux et ce qui est sur terre rend gloire à Allah, le Souverain, le Très Pur, le Puissant, le Sage.","en":"Whatever is in the heavens and whatever is on the earth is exalting Allāh, the Sovereign, the Pure, the Exalted in Might, the Wise.","words":[{"position":1,"ar":"يُسَبِّحُ","fr":"Glorifie","en":"Glorifies","tr":"yusabbiḥu","isWaqf":false},{"position":2,"ar":"لِلَّهِ","fr":"Allah","en":"Allah","tr":"lillahi","isWaqf":false},{"position":3,"ar":"مَا","fr":"quoi que","en":"whatever","tr":"mā","isWaqf":false},{"position":4,"ar":"فِى","fr":"(est) en","en":"(is) in","tr":"fī","isWaqf":false},{"position":5,"ar":"ٱلسَّمَـٰوَٰتِ","fr":"les cieux","en":"the heavens","tr":"l-samāwāti","isWaqf":false},{"position":6,"ar":"وَمَا","fr":"et quoi que","en":"and whatever","tr":"wamā","isWaqf":false},{"position":7,"ar":"فِى","fr":"(est) en","en":"(is) in","tr":"fī","isWaqf":false},{"position":8,"ar":"ٱلْأَرْضِ","fr":"la terre","en":"the earth","tr":"l-arḍi","isWaqf":false},{"position":9,"ar":"ٱلْمَلِكِ","fr":"le Souverain","en":"the Sovereign","tr":"l-maliki","isWaqf":false},{"position":10,"ar":"ٱلْقُدُّوسِ","fr":"le Saint","en":"the Holy","tr":"l-qudūsi","isWaqf":false},{"position":11,"ar":"ٱلْعَزِيزِ","fr":"le Tout-Puissant","en":"the All-Mighty","tr":"l-ʿazīzi","isWaqf":false},{"position":12,"ar":"ٱلْحَكِيمِ","fr":"le Très-Sage","en":"the All-Wise","tr":"l-ḥakīmi","isWaqf":false}]},{"ayah":2,"verseKey":"62:2","juz":28,"arabic":"هُوَ ٱلَّذِى بَعَثَ فِى ٱلْأُمِّيِّـۧنَ رَسُولًا مِّنْهُمْ يَتْلُوا۟ عَلَيْهِمْ ءَايَـٰتِهِۦ وَيُزَكِّيهِمْ وَيُعَلِّمُهُمُ ٱلْكِتَـٰبَ وَٱلْحِكْمَةَ وَإِن كَانُوا۟ مِن قَبْلُ لَفِى ضَلَـٰلٍ مُّبِينٍ","fr":"C’est Lui Qui envoya parmi les illettrés un Messager issu de leur peuple, qui leur récite Ses versets, les purifie et les initie au Livre et à la sagesse, même si, autrefois, ils étaient dans un égarement manifeste.","en":"It is He who has sent among the unlettered [Arabs] a Messenger from themselves reciting to them His verses and purifying them and teaching them the Book [i.e., the Qur’ān] and wisdom [i.e., the sunnah] - although they were before in clear error -","words":[{"position":1,"ar":"هُوَ","fr":"Il","en":"He","tr":"huwa","isWaqf":false},{"position":2,"ar":"ٱلَّذِى","fr":"(est) Celui qui","en":"(is) the One Who","tr":"alladhī","isWaqf":false},{"position":3,"ar":"بَعَثَ","fr":"envoyé","en":"sent","tr":"baʿatha","isWaqf":false},{"position":4,"ar":"فِى","fr":"parmi","en":"among","tr":"fī","isWaqf":false},{"position":5,"ar":"ٱلْأُمِّيِّـۧنَ","fr":"l’illettré","en":"the unlettered","tr":"l-umiyīna","isWaqf":false},{"position":6,"ar":"رَسُولًۭا","fr":"un Messager","en":"a Messenger","tr":"rasūlan","isWaqf":false},{"position":7,"ar":"مِّنْهُمْ","fr":"des eux-mêmes","en":"from themselves","tr":"min'hum","isWaqf":false},{"position":8,"ar":"يَتْلُوا۟","fr":"récitant","en":"reciting","tr":"yatlū","isWaqf":false},{"position":9,"ar":"عَلَيْهِمْ","fr":"à eux","en":"to them","tr":"ʿalayhim","isWaqf":false},{"position":10,"ar":"ءَايَـٰتِهِۦ","fr":"Ses Versets","en":"His Verses","tr":"āyātihi","isWaqf":false},{"position":11,"ar":"وَيُزَكِّيهِمْ","fr":"et purifiant eux","en":"and purifying them","tr":"wayuzakkīhim","isWaqf":false},{"position":12,"ar":"وَيُعَلِّمُهُمُ","fr":"et enseignant eux","en":"and teaching them","tr":"wayuʿallimuhumu","isWaqf":false},{"position":13,"ar":"ٱلْكِتَـٰبَ","fr":"le Livre","en":"the Book","tr":"l-kitāba","isWaqf":false},{"position":14,"ar":"وَٱلْحِكْمَةَ","fr":"et la sagesse","en":"and the wisdom","tr":"wal-ḥik'mata","isWaqf":false},{"position":15,"ar":"وَإِن","fr":"bien que","en":"although","tr":"wa-in","isWaqf":false},{"position":16,"ar":"كَانُوا۟","fr":"ils étaient","en":"they were","tr":"kānū","isWaqf":false},{"position":17,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":18,"ar":"قَبْلُ","fr":"avant","en":"before","tr":"qablu","isWaqf":false},{"position":19,"ar":"لَفِى","fr":"assurément dans","en":"surely in","tr":"lafī","isWaqf":false},{"position":20,"ar":"ضَلَـٰلٍۢ","fr":"un égarement","en":"an error","tr":"ḍalālin","isWaqf":false},{"position":21,"ar":"مُّبِينٍۢ","fr":"clair","en":"clear","tr":"mubīnin","isWaqf":false}]},{"ayah":3,"verseKey":"62:3","juz":28,"arabic":"وَءَاخَرِينَ مِنْهُمْ لَمَّا يَلْحَقُوا۟ بِهِمْ ۚ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","fr":"(Il l’envoya aussi) à d’autres qui ne les ont pas encore rejoints. C’est Lui le Tout-Puissant, le Sage.","en":"And [to] others of them who have not yet joined them. And He is the Exalted in Might, the Wise.","words":[{"position":1,"ar":"وَءَاخَرِينَ","fr":"Et d'autres","en":"And others","tr":"waākharīna","isWaqf":false},{"position":2,"ar":"مِنْهُمْ","fr":"parmi eux","en":"among them","tr":"min'hum","isWaqf":false},{"position":3,"ar":"لَمَّا","fr":"qui ont non encore","en":"who have not yet","tr":"lammā","isWaqf":false},{"position":4,"ar":"يَلْحَقُوا۟","fr":"joint","en":"joined","tr":"yalḥaqū","isWaqf":false},{"position":5,"ar":"بِهِمْ ۚ","fr":"eux","en":"them","tr":"bihim","isWaqf":false},{"position":6,"ar":"وَهُوَ","fr":"et Il","en":"and He","tr":"wahuwa","isWaqf":false},{"position":7,"ar":"ٱلْعَزِيزُ","fr":"(est) le Tout-Puissant","en":"(is) the All-Mighty","tr":"l-ʿazīzu","isWaqf":false},{"position":8,"ar":"ٱلْحَكِيمُ","fr":"le Très-Sage","en":"the All-Wise","tr":"l-ḥakīmu","isWaqf":false}]},{"ayah":4,"verseKey":"62:4","juz":28,"arabic":"ذَٰلِكَ فَضْلُ ٱللَّهِ يُؤْتِيهِ مَن يَشَآءُ ۚ وَٱللَّهُ ذُو ٱلْفَضْلِ ٱلْعَظِيمِ","fr":"Telle est la faveur d’Allah, qu’Il accorde à qui Il veut. Allah est le Détenteur de la Faveur Suprême.","en":"That is the bounty of Allāh, which He gives to whom He wills, and Allāh is the possessor of great bounty.","words":[{"position":1,"ar":"ذَٰلِكَ","fr":"Cela","en":"That","tr":"dhālika","isWaqf":false},{"position":2,"ar":"فَضْلُ","fr":"(est le) Grâce","en":"(is the) Bounty","tr":"faḍlu","isWaqf":false},{"position":3,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":4,"ar":"يُؤْتِيهِ","fr":"Il donne cela","en":"He gives it","tr":"yu'tīhi","isWaqf":false},{"position":5,"ar":"مَن","fr":"(à) qui","en":"(to) whom","tr":"man","isWaqf":false},{"position":6,"ar":"يَشَآءُ ۚ","fr":"Il veut","en":"He wills","tr":"yashāu","isWaqf":false},{"position":7,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":8,"ar":"ذُو","fr":"(est le) Possesseur","en":"(is the) Possessor","tr":"dhū","isWaqf":false},{"position":9,"ar":"ٱلْفَضْلِ","fr":"(de) Grâce","en":"(of) Bounty","tr":"l-faḍli","isWaqf":false},{"position":10,"ar":"ٱلْعَظِيمِ","fr":"le Grand","en":"the Great","tr":"l-ʿaẓīmi","isWaqf":false}]},{"ayah":5,"verseKey":"62:5","juz":28,"arabic":"مَثَلُ ٱلَّذِينَ حُمِّلُوا۟ ٱلتَّوْرَىٰةَ ثُمَّ لَمْ يَحْمِلُوهَا كَمَثَلِ ٱلْحِمَارِ يَحْمِلُ أَسْفَارًۢا ۚ بِئْسَ مَثَلُ ٱلْقَوْمِ ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَـٰتِ ٱللَّهِ ۚ وَٱللَّهُ لَا يَهْدِى ٱلْقَوْمَ ٱلظَّـٰلِمِينَ","fr":"Ceux qui eurent à assumer (le Message de) la Torah et qui ne l’assumèrent point sont à l’image d’un âne (lourdement) chargé de livres. Piètre exemple que celui des gens qui tiennent pour mensonges les Signes d’Allah. Allah ne guide pas les gens injustes.","en":"The example of those who were entrusted with the Torah and then did not take it on is like that of a donkey who carries volumes [of books]. Wretched is the example of the people who deny the signs of Allāh. And Allāh does not guide the wrongdoing people.","words":[{"position":1,"ar":"مَثَلُ","fr":"(le) ressemblance","en":"(The) likeness","tr":"mathalu","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"(de) ceux qui","en":"(of) those who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"حُمِّلُوا۟","fr":"étaient confia","en":"were entrusted","tr":"ḥummilū","isWaqf":false},{"position":4,"ar":"ٱلتَّوْرَىٰةَ","fr":"(avec) la Torah","en":"(with) the Taurat","tr":"l-tawrāta","isWaqf":false},{"position":5,"ar":"ثُمَّ","fr":"puis","en":"then","tr":"thumma","isWaqf":false},{"position":6,"ar":"لَمْ","fr":"non","en":"not","tr":"lam","isWaqf":false},{"position":7,"ar":"يَحْمِلُوهَا","fr":"ils porta cela","en":"they bore it","tr":"yaḥmilūhā","isWaqf":false},{"position":8,"ar":"كَمَثَلِ","fr":"(est) comme","en":"(is) like","tr":"kamathali","isWaqf":false},{"position":9,"ar":"ٱلْحِمَارِ","fr":"l’âne","en":"the donkey","tr":"l-ḥimāri","isWaqf":false},{"position":10,"ar":"يَحْمِلُ","fr":"qui porte","en":"who carries","tr":"yaḥmilu","isWaqf":false},{"position":11,"ar":"أَسْفَارًۢا ۚ","fr":"livres","en":"books","tr":"asfāran","isWaqf":false},{"position":12,"ar":"بِئْسَ","fr":"Misérable est","en":"Wretched is","tr":"bi'sa","isWaqf":false},{"position":13,"ar":"مَثَلُ","fr":"(le) exemple","en":"(the) example","tr":"mathalu","isWaqf":false},{"position":14,"ar":"ٱلْقَوْمِ","fr":"(des) gens","en":"(of) the people","tr":"l-qawmi","isWaqf":false},{"position":15,"ar":"ٱلَّذِينَ","fr":"qui","en":"who","tr":"alladhīna","isWaqf":false},{"position":16,"ar":"كَذَّبُوا۟","fr":"nier","en":"deny","tr":"kadhabū","isWaqf":false},{"position":17,"ar":"بِـَٔايَـٰتِ","fr":"(les) Signes","en":"(the) Signs","tr":"biāyāti","isWaqf":false},{"position":18,"ar":"ٱللَّهِ ۚ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":19,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":20,"ar":"لَا","fr":"(ne) fait pas","en":"(does) not","tr":"lā","isWaqf":false},{"position":21,"ar":"يَهْدِى","fr":"guide","en":"guide","tr":"yahdī","isWaqf":false},{"position":22,"ar":"ٱلْقَوْمَ","fr":"les gens","en":"the people","tr":"l-qawma","isWaqf":false},{"position":23,"ar":"ٱلظَّـٰلِمِينَ","fr":"les injustes","en":"the wrongdoers","tr":"l-ẓālimīna","isWaqf":false}]},{"ayah":6,"verseKey":"62:6","juz":28,"arabic":"قُلْ يَـٰٓأَيُّهَا ٱلَّذِينَ هَادُوٓا۟ إِن زَعَمْتُمْ أَنَّكُمْ أَوْلِيَآءُ لِلَّهِ مِن دُونِ ٱلنَّاسِ فَتَمَنَّوُا۟ ٱلْمَوْتَ إِن كُنتُمْ صَـٰدِقِينَ","fr":"Dis : « Ô vous qui professez le judaïsme ! Si vous prétendez être les aimés d’Allah, en dehors de tous les hommes, alors souhaitez la mort si ce que vous dites est vrai. »","en":"Say, \"O you who are Jews, if you claim that you are allies of Allāh, excluding the [other] people, then wish for death, if you should be truthful.\"","words":[{"position":1,"ar":"قُلْ","fr":"Dis","en":"Say","tr":"qul","isWaqf":false},{"position":2,"ar":"يَـٰٓأَيُّهَا","fr":"Ô","en":"O","tr":"yāayyuhā","isWaqf":false},{"position":3,"ar":"ٱلَّذِينَ","fr":"vous (qui)","en":"you (who)","tr":"alladhīna","isWaqf":false},{"position":4,"ar":"هَادُوٓا۟","fr":"(sont) Juifs","en":"(are) Jews","tr":"hādū","isWaqf":false},{"position":5,"ar":"إِن","fr":"Si","en":"If","tr":"in","isWaqf":false},{"position":6,"ar":"زَعَمْتُمْ","fr":"vous prétendre","en":"you claim","tr":"zaʿamtum","isWaqf":false},{"position":7,"ar":"أَنَّكُمْ","fr":"que vous","en":"that you","tr":"annakum","isWaqf":false},{"position":8,"ar":"أَوْلِيَآءُ","fr":"(sont) alliés","en":"(are) allies","tr":"awliyāu","isWaqf":false},{"position":9,"ar":"لِلَّهِ","fr":"d’Allah","en":"of Allah","tr":"lillahi","isWaqf":false},{"position":10,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":11,"ar":"دُونِ","fr":"hormis","en":"excluding","tr":"dūni","isWaqf":false},{"position":12,"ar":"ٱلنَّاسِ","fr":"les gens","en":"the people","tr":"l-nāsi","isWaqf":false},{"position":13,"ar":"فَتَمَنَّوُا۟","fr":"puis souhaiter","en":"then wish","tr":"fatamannawū","isWaqf":false},{"position":14,"ar":"ٱلْمَوْتَ","fr":"(pour) la mort","en":"(for) the death","tr":"l-mawta","isWaqf":false},{"position":15,"ar":"إِن","fr":"si","en":"if","tr":"in","isWaqf":false},{"position":16,"ar":"كُنتُمْ","fr":"vous êtes","en":"you are","tr":"kuntum","isWaqf":false},{"position":17,"ar":"صَـٰدِقِينَ","fr":"véridique","en":"truthful","tr":"ṣādiqīna","isWaqf":false}]},{"ayah":7,"verseKey":"62:7","juz":28,"arabic":"وَلَا يَتَمَنَّوْنَهُۥٓ أَبَدًۢا بِمَا قَدَّمَتْ أَيْدِيهِمْ ۚ وَٱللَّهُ عَلِيمٌۢ بِٱلظَّـٰلِمِينَ","fr":"Mais ils ne la souhaiteront jamais, en raison de tout ce qu’ils ont commis de leurs propres mains. Allah en Sait Infiniment sur les injustes.","en":"But they will not wish for it, ever, because of what their hands have put forth. And Allāh is Knowing of the wrongdoers.","words":[{"position":1,"ar":"وَلَا","fr":"Mais non","en":"But not","tr":"walā","isWaqf":false},{"position":2,"ar":"يَتَمَنَّوْنَهُۥٓ","fr":"ils va souhaiter pour cela","en":"they will wish for it","tr":"yatamannawnahu","isWaqf":false},{"position":3,"ar":"أَبَدًۢا","fr":"à jamais","en":"ever","tr":"abadan","isWaqf":false},{"position":4,"ar":"بِمَا","fr":"pour ce que","en":"for what","tr":"bimā","isWaqf":false},{"position":5,"ar":"قَدَّمَتْ","fr":"(ont) envoyé en avant","en":"(have) sent forth","tr":"qaddamat","isWaqf":false},{"position":6,"ar":"أَيْدِيهِمْ ۚ","fr":"leurs mains","en":"their hands","tr":"aydīhim","isWaqf":false},{"position":7,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":8,"ar":"عَلِيمٌۢ","fr":"(est) Omniscient","en":"(is) All-Knowing","tr":"ʿalīmun","isWaqf":false},{"position":9,"ar":"بِٱلظَّـٰلِمِينَ","fr":"des injustes","en":"of the wrongdoers","tr":"bil-ẓālimīna","isWaqf":false}]},{"ayah":8,"verseKey":"62:8","juz":28,"arabic":"قُلْ إِنَّ ٱلْمَوْتَ ٱلَّذِى تَفِرُّونَ مِنْهُ فَإِنَّهُۥ مُلَـٰقِيكُمْ ۖ ثُمَّ تُرَدُّونَ إِلَىٰ عَـٰلِمِ ٱلْغَيْبِ وَٱلشَّهَـٰدَةِ فَيُنَبِّئُكُم بِمَا كُنتُمْ تَعْمَلُونَ","fr":"Dis : « La mort que vous fuyez vous trouvera, puis vous serez ramenés vers Celui Qui Connaît aussi bien les choses insondables que les choses observables. Alors, Il vous informera de ce que vous faisiez.","en":"Say, \"Indeed, the death from which you flee - indeed, it will meet you. Then you will be returned to the Knower of the unseen and the witnessed, and He will inform you about what you used to do.\"","words":[{"position":1,"ar":"قُلْ","fr":"Dis","en":"Say","tr":"qul","isWaqf":false},{"position":2,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":3,"ar":"ٱلْمَوْتَ","fr":"la mort","en":"the death","tr":"l-mawta","isWaqf":false},{"position":4,"ar":"ٱلَّذِى","fr":"que","en":"which","tr":"alladhī","isWaqf":false},{"position":5,"ar":"تَفِرُّونَ","fr":"vous fuissez","en":"you flee","tr":"tafirrūna","isWaqf":false},{"position":6,"ar":"مِنْهُ","fr":"de cela","en":"from it","tr":"min'hu","isWaqf":false},{"position":7,"ar":"فَإِنَّهُۥ","fr":"puis assurément cela","en":"then surely it","tr":"fa-innahu","isWaqf":false},{"position":8,"ar":"مُلَـٰقِيكُمْ ۖ","fr":"(va) rencontrer vous","en":"(will) meet you","tr":"mulāqīkum","isWaqf":false},{"position":9,"ar":"ثُمَّ","fr":"Puis","en":"Then","tr":"thumma","isWaqf":false},{"position":10,"ar":"تُرَدُّونَ","fr":"vous va être envoyé en arrière","en":"you will be sent back","tr":"turaddūna","isWaqf":false},{"position":11,"ar":"إِلَىٰ","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":12,"ar":"عَـٰلِمِ","fr":"(le) Omniscient","en":"(the) All-Knower","tr":"ʿālimi","isWaqf":false},{"position":13,"ar":"ٱلْغَيْبِ","fr":"(de) l'Invisible","en":"(of) the unseen","tr":"l-ghaybi","isWaqf":false},{"position":14,"ar":"وَٱلشَّهَـٰدَةِ","fr":"et le témoigna","en":"and the witnessed","tr":"wal-shahādati","isWaqf":false},{"position":15,"ar":"فَيُنَبِّئُكُم","fr":"et Il va informer vous","en":"and He will inform you","tr":"fayunabbi-ukum","isWaqf":false},{"position":16,"ar":"بِمَا","fr":"[de] ce que","en":"[of] what","tr":"bimā","isWaqf":false},{"position":17,"ar":"كُنتُمْ","fr":"vous aviez l'habitude de","en":"you used to","tr":"kuntum","isWaqf":false},{"position":18,"ar":"تَعْمَلُونَ","fr":"faire","en":"do","tr":"taʿmalūna","isWaqf":false}]},{"ayah":9,"verseKey":"62:9","juz":28,"arabic":"يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِذَا نُودِىَ لِلصَّلَوٰةِ مِن يَوْمِ ٱلْجُمُعَةِ فَٱسْعَوْا۟ إِلَىٰ ذِكْرِ ٱللَّهِ وَذَرُوا۟ ٱلْبَيْعَ ۚ ذَٰلِكُمْ خَيْرٌ لَّكُمْ إِن كُنتُمْ تَعْلَمُونَ","fr":"Ô vous qui avez cru ! Lorsqu’il est appelé à la Çalât du vendredi, hâtez-vous pour évoquer Allah ! Laissez là tout commerce ! Cela est bien meilleur pour vous, si vous saviez !","en":"O you who have believed, when [the adhān] is called for the prayer on the day of Jumuʿah [Friday], then proceed to the remembrance of Allāh and leave trade. That is better for you, if you only knew.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô","en":"O","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"(vous) qui","en":"(you) who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوٓا۟","fr":"croire","en":"believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"إِذَا","fr":"Quand","en":"When","tr":"idhā","isWaqf":false},{"position":5,"ar":"نُودِىَ","fr":"(le) appeler est fait","en":"(the) call is made","tr":"nūdiya","isWaqf":false},{"position":6,"ar":"لِلصَّلَوٰةِ","fr":"pour (le) prière","en":"for (the) prayer","tr":"lilṣṣalati","isWaqf":false},{"position":7,"ar":"مِن","fr":"sur","en":"on","tr":"min","isWaqf":false},{"position":8,"ar":"يَوْمِ","fr":"(le) jour","en":"(the) day","tr":"yawmi","isWaqf":false},{"position":9,"ar":"ٱلْجُمُعَةِ","fr":"(de) Friday","en":"(of) Friday","tr":"l-jumuʿati","isWaqf":false},{"position":10,"ar":"فَٱسْعَوْا۟","fr":"puis se hâter","en":"then hasten","tr":"fa-is'ʿaw","isWaqf":false},{"position":11,"ar":"إِلَىٰ","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":12,"ar":"ذِكْرِ","fr":"(le) rappel","en":"(the) remembrance","tr":"dhik'ri","isWaqf":false},{"position":13,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":14,"ar":"وَذَرُوا۟","fr":"et quitter","en":"and leave","tr":"wadharū","isWaqf":false},{"position":15,"ar":"ٱلْبَيْعَ ۚ","fr":"le négoce","en":"the business","tr":"l-bayʿa","isWaqf":false},{"position":16,"ar":"ذَٰلِكُمْ","fr":"Cela","en":"That","tr":"dhālikum","isWaqf":false},{"position":17,"ar":"خَيْرٌۭ","fr":"(est) meilleur","en":"(is) better","tr":"khayrun","isWaqf":false},{"position":18,"ar":"لَّكُمْ","fr":"pour vous","en":"for you","tr":"lakum","isWaqf":false},{"position":19,"ar":"إِن","fr":"si","en":"if","tr":"in","isWaqf":false},{"position":20,"ar":"كُنتُمْ","fr":"vous","en":"you","tr":"kuntum","isWaqf":false},{"position":21,"ar":"تَعْلَمُونَ","fr":"savoir","en":"know","tr":"taʿlamūna","isWaqf":false}]},{"ayah":10,"verseKey":"62:10","juz":28,"arabic":"فَإِذَا قُضِيَتِ ٱلصَّلَوٰةُ فَٱنتَشِرُوا۟ فِى ٱلْأَرْضِ وَٱبْتَغُوا۟ مِن فَضْلِ ٱللَّهِ وَٱذْكُرُوا۟ ٱللَّهَ كَثِيرًا لَّعَلَّكُمْ تُفْلِحُونَ","fr":"Puis la Çalât finie, dispersez-vous partout ailleurs ! Espérez les faveurs d’Allah ! Évoquez abondamment (le nom d’)Allah, peut-être réussirez-vous !","en":"And when the prayer has been concluded, disperse within the land and seek from the bounty of Allāh, and remember Allāh often that you may succeed.","words":[{"position":1,"ar":"فَإِذَا","fr":"Puis quand","en":"Then when","tr":"fa-idhā","isWaqf":false},{"position":2,"ar":"قُضِيَتِ","fr":"est conclut","en":"is concluded","tr":"quḍiyati","isWaqf":false},{"position":3,"ar":"ٱلصَّلَوٰةُ","fr":"la prière","en":"the prayer","tr":"l-ṣalatu","isWaqf":false},{"position":4,"ar":"فَٱنتَشِرُوا۟","fr":"puis disperser","en":"then disperse","tr":"fa-intashirū","isWaqf":false},{"position":5,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":6,"ar":"ٱلْأَرْضِ","fr":"la terre","en":"the land","tr":"l-arḍi","isWaqf":false},{"position":7,"ar":"وَٱبْتَغُوا۟","fr":"et chercher","en":"and seek","tr":"wa-ib'taghū","isWaqf":false},{"position":8,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":9,"ar":"فَضْلِ","fr":"(le) Grâce","en":"(the) Bounty","tr":"faḍli","isWaqf":false},{"position":10,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":11,"ar":"وَٱذْكُرُوا۟","fr":"et se souvenir","en":"and remember","tr":"wa-udh'kurū","isWaqf":false},{"position":12,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":13,"ar":"كَثِيرًۭا","fr":"beaucoup","en":"much","tr":"kathīran","isWaqf":false},{"position":14,"ar":"لَّعَلَّكُمْ","fr":"afin que vous","en":"so that you may","tr":"laʿallakum","isWaqf":false},{"position":15,"ar":"تُفْلِحُونَ","fr":"réussir","en":"succeed","tr":"tuf'liḥūna","isWaqf":false}]},{"ayah":11,"verseKey":"62:11","juz":28,"arabic":"وَإِذَا رَأَوْا۟ تِجَـٰرَةً أَوْ لَهْوًا ٱنفَضُّوٓا۟ إِلَيْهَا وَتَرَكُوكَ قَآئِمًا ۚ قُلْ مَا عِندَ ٱللَّهِ خَيْرٌ مِّنَ ٱللَّهْوِ وَمِنَ ٱلتِّجَـٰرَةِ ۚ وَٱللَّهُ خَيْرُ ٱلرَّٰزِقِينَ","fr":"Dès qu’ils entraperçoivent quelque commerce ou quelque divertissement, ils se dispersent d’autour de toi et te laissent là, debout. Dis : « Ce qui se trouve auprès d’Allah est bien meilleur que le divertissement et le commerce. Allah est, certes, le Meilleur des dispensateurs. »","en":"But [on one occasion] when they saw a transaction or a diversion, [O Muḥammad], they rushed to it and left you standing. Say, \"What is with Allāh is better than diversion and than a transaction, and Allāh is the best of providers.\"","words":[{"position":1,"ar":"وَإِذَا","fr":"Et quand","en":"And when","tr":"wa-idhā","isWaqf":false},{"position":2,"ar":"رَأَوْا۟","fr":"ils vit","en":"they saw","tr":"ra-aw","isWaqf":false},{"position":3,"ar":"تِجَـٰرَةً","fr":"un transaction","en":"a transaction","tr":"tijāratan","isWaqf":false},{"position":4,"ar":"أَوْ","fr":"ou","en":"or","tr":"aw","isWaqf":false},{"position":5,"ar":"لَهْوًا","fr":"un sport","en":"a sport","tr":"lahwan","isWaqf":false},{"position":6,"ar":"ٱنفَضُّوٓا۟","fr":"ils se précipita","en":"they rushed","tr":"infaḍḍū","isWaqf":false},{"position":7,"ar":"إِلَيْهَا","fr":"à cela","en":"to it","tr":"ilayhā","isWaqf":false},{"position":8,"ar":"وَتَرَكُوكَ","fr":"et quitté vous","en":"and left you","tr":"watarakūka","isWaqf":false},{"position":9,"ar":"قَآئِمًۭا ۚ","fr":"debout","en":"standing","tr":"qāiman","isWaqf":false},{"position":10,"ar":"قُلْ","fr":"Dis","en":"Say","tr":"qul","isWaqf":false},{"position":11,"ar":"مَا","fr":"Quoi","en":"What","tr":"mā","isWaqf":false},{"position":12,"ar":"عِندَ","fr":"(est) avec","en":"(is) with","tr":"ʿinda","isWaqf":false},{"position":13,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":14,"ar":"خَيْرٌۭ","fr":"(est) meilleur","en":"(is) better","tr":"khayrun","isWaqf":false},{"position":15,"ar":"مِّنَ","fr":"que","en":"than","tr":"mina","isWaqf":false},{"position":16,"ar":"ٱللَّهْوِ","fr":"le sport","en":"the sport","tr":"l-lahwi","isWaqf":false},{"position":17,"ar":"وَمِنَ","fr":"et de","en":"and from","tr":"wamina","isWaqf":false},{"position":18,"ar":"ٱلتِّجَـٰرَةِ ۚ","fr":"(tout) transaction","en":"(any) transaction","tr":"l-tijārati","isWaqf":false},{"position":19,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":20,"ar":"خَيْرُ","fr":"(est le) Le meilleur","en":"(is the) Best","tr":"khayru","isWaqf":false},{"position":21,"ar":"ٱلرَّٰزِقِينَ","fr":"(de) le Pourvoyeurs","en":"(of) the Providers","tr":"l-rāziqīna","isWaqf":false}]}]