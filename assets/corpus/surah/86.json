[{"ayah":1,"verseKey":"86:1","juz":30,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ","fr":"Par le ciel et l’étoile nocturne !","en":"By the sky and the night comer","words":[{"position":1,"ar":"وَٱلسَّمَآءِ","fr":"Par le ciel","en":"By the sky","tr":"wal-samāi","isWaqf":false},{"position":2,"ar":"وَٱلطَّارِقِ","fr":"et le nuit venant","en":"and the night comer","tr":"wal-ṭāriqi","isWaqf":false}]},{"ayah":2,"verseKey":"86:2","juz":30,"arabic":"وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ","fr":"Et qui te fera jamais savoir ce qu’est l’étoile nocturne ?","en":"And what can make you know what is the night comer?","words":[{"position":1,"ar":"وَمَآ","fr":"Et quoi","en":"And what","tr":"wamā","isWaqf":false},{"position":2,"ar":"أَدْرَىٰكَ","fr":"peut faire vous savoez","en":"can make you know","tr":"adrāka","isWaqf":false},{"position":3,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":4,"ar":"ٱلطَّارِقُ","fr":"le nuit venant (est)","en":"the night comer (is)","tr":"l-ṭāriqu","isWaqf":false}]},{"ayah":3,"verseKey":"86:3","juz":30,"arabic":"ٱلنَّجْمُ ٱلثَّاقِبُ","fr":"L’étoile (à la lumière) pénétrante.","en":"It is the piercing star","words":[{"position":1,"ar":"ٱلنَّجْمُ","fr":"(Cela est) le étoile","en":"(It is) the star","tr":"al-najmu","isWaqf":false},{"position":2,"ar":"ٱلثَّاقِبُ","fr":"le perçant","en":"the piercing","tr":"l-thāqibu","isWaqf":false}]},{"ayah":4,"verseKey":"86:4","juz":30,"arabic":"إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ","fr":"Il n’est pas d’âme qui n’ait son (Ange) gardien.","en":"There is no soul but that it has over it a protector.","words":[{"position":1,"ar":"إِن","fr":"Non","en":"Not","tr":"in","isWaqf":false},{"position":2,"ar":"كُلُّ","fr":"(est) chaque","en":"(is) every","tr":"kullu","isWaqf":false},{"position":3,"ar":"نَفْسٍۢ","fr":"âme","en":"soul","tr":"nafsin","isWaqf":false},{"position":4,"ar":"لَّمَّا","fr":"mais","en":"but","tr":"lammā","isWaqf":false},{"position":5,"ar":"عَلَيْهَا",