"isWaqf":false}]},{"ayah":36,"verseKey":"79:36","juz":30,"arabic":"وَبُرِّزَتِ ٱلْجَحِيمُ لِمَن يَرَىٰ","fr":"et que l’Enfer sera mis en évidence devant quiconque peut voir,","en":"And Hellfire will be exposed for [all] those who see -","words":[{"position":1,"ar":"وَبُرِّزَتِ","fr":"Et va être fait manifeste","en":"And will be made manifest","tr":"waburrizati","isWaqf":false},{"position":2,"ar":"ٱلْجَحِيمُ","fr":"le Feu","en":"the Hellfire","tr":"l-jaḥīmu","isWaqf":false},{"position":3,"ar":"لِمَن","fr":"à (celui) qui","en":"to (him) who","tr":"liman","isWaqf":false},{"position":4,"ar":"يَرَىٰ","fr":"voit","en":"sees","tr":"yarā","isWaqf":false}]},{"ayah":37,"verseKey":"79:37","juz":30,"arabic":"فَأَمَّا مَن طَغَىٰ","fr":"alors, celui qui se sera livré à la démesure,","en":"So as for he who transgressed","words":[{"position":1,"ar":"فَأَمَّا","fr":"Quant à","en":"Then as for","tr":"fa-ammā","isWaqf":false},{"position":2,"ar":"مَن","fr":"(celui) qui","en":"(him) who","tr":"man","isWaqf":false},{"position":3,"ar":"طَغَىٰ","fr":"transgressé","en":"transgressed","tr":"ṭaghā","isWaqf":false}]},{"ayah":38,"verseKey":"79:38","juz":30,"arabic":"وَءَاثَرَ ٱلْحَيَوٰةَ ٱلدُّنْيَا","fr":"et qui aura préféré la vie en ce bas monde,","en":"And preferred the life of the world,","words":[{"position":1,"ar":"وَءَاثَرَ","fr":"Et préféra","en":"And preferred","tr":"waāthara","isWaqf":false},{"position":2,"ar":"ٱلْحَيَوٰةَ","fr":"la vie","en":"the life","tr":"l-ḥayata","isWaqf":false},{"position":3,"ar":"ٱلدُّنْيَا","fr":"(de) le monde","en":"(of) the world","tr":"l-dun'yā","isWaqf":false}]},{"ayah":39,"verseKey":"79:39","juz":30,"arabic":"فَإِنَّ ٱلْجَحِيمَ هِىَ ٱلْمَأْوَىٰ","fr":"aura pour seul refuge l’Enfer !","en":"Then indeed, Hellfire will be [his] refuge.","words":[{"position":1,"ar":"فَإِنَّ","fr":"Puis certes","en":"Then indeed","tr":"fa-inna","isWaqf":false},{"position":2,"ar":"ٱلْجَحِيمَ","fr":"le Feu","en":"the Hellfire","tr":"l-jaḥīma","isWaqf":false},{"position":3,"ar":"هِىَ","fr":"cela","en":"it","tr":"hiya","isWaqf":false},{"position":4,"ar":"ٱلْمَأْوَىٰ","fr":"(est) le refuge","en":"(is) the refuge","tr":"l-mawā","isWaqf":false}]},{"ayah":40,"verseKey":"79:40","juz":30,"arabic":"وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى ٱلنَّفْسَ عَنِ ٱلْهَوَىٰ","fr":"Quant à celui que le statut suprême de son Seigneur (faisait trembler) de crainte, (celui qui) s’interdisait de succomber aux passions,","en":"But as for he who feared the position of his Lord and prevented the soul from [unlawful] inclination,","words":[{"position":1,"ar":"وَأَمَّا","fr":"Quant à","en":"But as for","tr":"wa-ammā","isWaqf":false},{"position":2,"ar":"مَنْ","fr":"(celui) qui","en":"(him) who","tr":"man","isWaqf":false},{"position":3,"ar":"خَافَ","fr":"craignit","en":"feared","tr":"khāfa","isWaqf":false},{"position":4,"ar":"مَقَامَ","fr":"debout","en":"standing","tr":"maqāma","isWaqf":false},{"position":5,"ar":"رَبِّهِۦ","fr":"(avant) son Seigneur","en":"(before) his Lord","tr":"rabbihi","isWaqf":false},{"position":6,"ar":"وَنَهَى","fr":"et retenu","en":"and restrained","tr":"wanahā","isWaqf":false},{"position":7,"ar":"ٱلنَّفْسَ","fr":"son âme","en":"his soul","tr":"l-nafsa","isWaqf":false},{"position":8,"ar":"عَنِ","fr":"de","en":"from","tr":"ʿani","isWaqf":false},{"position":9,"ar":"ٱلْهَوَىٰ","fr":"le vain désirs","en":"the vain desires","tr":"l-hawā","isWaqf":false}]},{"ayah":41,"verseKey":"79:41","juz":30,"arabic":"فَإِنَّ ٱلْجَنَّةَ هِىَ ٱلْمَأْوَىٰ","fr":"le Paradis sera son séjour.","en":"Then indeed, Paradise will be [his] refuge.","words":[{"position":1,"ar":"فَإِنَّ","fr":"Puis certes","en":"Then indeed","tr":"fa-inna","isWaqf":false},{"position":2,"ar":"ٱلْجَنَّةَ","fr":"le Paradis","en":"Paradise","tr":"l-janata","isWaqf":false},{"position":3,"ar":"هِىَ","fr":"c'(est)","en":"it (is)","tr":"hiya","isWaqf":false},{"position":4,"ar":"ٱلْمَأْوَىٰ","fr":"le refuge","en":"the refuge","tr":"l-mawā","isWaqf":false}]},{"ayah":42,"verseKey":"79:42","juz":30,"ar