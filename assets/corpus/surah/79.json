"ar":"إِنَّمَآ","fr":"Seulement","en":"Only","tr":"innamā","isWaqf":false},{"position":2,"ar":"أَنتَ","fr":"vous","en":"you","tr":"anta","isWaqf":false},{"position":3,"ar":"مُنذِرُ","fr":"(sont) un avertisseur","en":"(are) a warner","tr":"mundhiru","isWaqf":false},{"position":4,"ar":"مَن","fr":"(pour lui) qui","en":"(for him) who","tr":"man","isWaqf":false},{"position":5,"ar":"يَخْشَىٰهَا","fr":"craint cela","en":"fears it","tr":"yakhshāhā","isWaqf":false}]},{"ayah":46,"verseKey":"79:46","juz":30,"arabic":"كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوٓا۟ إِلَّا عَشِيَّةً أَوْ ضُحَىٰهَا","fr":"Le jour où ils la verront, ce sera comme s’ils n’étaient restés (sur terre) qu’un après-midi ou une matinée !","en":"It will be, on the Day they see it, as though they had not remained [in the world] except for an afternoon or a morning thereof.","words":[{"position":1,"ar":"كَأَنَّهُمْ","fr":"Comme s’ils","en":"As though they","tr":"ka-annahum","isWaqf":false},{"position":2,"ar":"يَوْمَ","fr":"(le) Jour","en":"(the) Day","tr":"yawma","isWaqf":false},{"position":3,"ar":"يَرَوْنَهَا","fr":"ils voent cela","en":"they see it","tr":"yarawnahā","isWaqf":false},{"position":4,"ar":"لَمْ","fr":"non","en":"not","tr":"lam","isWaqf":false},{"position":5,"ar":"يَلْبَثُوٓا۟","fr":"ils avait demeura","en":"they had remained","tr":"yalbathū","isWaqf":false},{"position":6,"ar":"إِلَّا","fr":"sauf","en":"except","tr":"illā","isWaqf":false},{"position":7,"ar":"عَشِيَّةً","fr":"un soir","en":"an evening","tr":"ʿashiyyatan","isWaqf":false},{"position":8,"ar":"أَوْ","fr":"ou","en":"or","tr":"aw","isWaqf":false},{"position":9,"ar":"ضُحَىٰهَا","fr":"un matin de cela","en":"a morning thereof","tr":"ḍuḥāhā","isWaqf":false}]}]