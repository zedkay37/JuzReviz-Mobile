"est venu","en":"has come","tr":"jāa","isWaqf":false},{"position":7,"ar":"أَجَلُهَا ۚ","fr":"son terme","en":"its term","tr":"ajaluhā","isWaqf":false},{"position":8,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":9,"ar":"خَبِيرٌۢ","fr":"(est) Parfaitement informeré","en":"(is) All-Aware","tr":"khabīrun","isWaqf":false},{"position":10,"ar":"بِمَا","fr":"de ce que","en":"of what","tr":"bimā","isWaqf":false},{"position":11,"ar":"تَعْمَلُونَ","fr":"vous faire","en":"you do","tr":"taʿmalūna","isWaqf":false}]}]