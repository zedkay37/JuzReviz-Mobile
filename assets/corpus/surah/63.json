[{"ayah":1,"verseKey":"63:1","juz":28,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِذَا جَآءَكَ ٱلْمُنَـٰفِقُونَ قَالُوا۟ نَشْهَدُ إِنَّكَ لَرَسُولُ ٱللَّهِ ۗ وَٱللَّهُ يَعْلَمُ إِنَّكَ لَرَسُولُهُۥ وَٱللَّهُ يَشْهَدُ إِنَّ ٱلْمُنَـٰفِقِينَ لَكَـٰذِبُونَ","fr":"Quand les hypocrites viennent te trouver, ils disent : « Nous attestons que tu es le Messager d’Allah. » Mais Allah Sait que tu es Son Messager, et Il atteste que les hypocrites sont des menteurs.","en":"When the hypocrites come to you, [O Muḥammad], they say, \"We testify that you are the Messenger of Allāh.\" And Allāh knows that you are His Messenger, and Allāh testifies that the hypocrites are liars.","words":[{"position":1,"ar":"إِذَا","fr":"Quand","en":"When","tr":"idhā","isWaqf":false},{"position":2,"ar":"جَآءَكَ","fr":"venir à toi","en":"come to you","tr":"jāaka","isWaqf":false},{"position":3,"ar":"ٱلْمُنَـٰفِقُونَ","fr":"les hypocrites","en":"the hypocrites","tr":"l-munāfiqūna","isWaqf":false},{"position":4,"ar":"قَالُوا۟","fr":"ils disent","en":"they say","tr":"qālū","isWaqf":false},{"position":5,"ar":"نَشْهَدُ","fr":"Nous Témoignons","en":"We testify","tr":"nashhadu","isWaqf":false},{"position":6,"ar":"إِنَّكَ","fr":"que vous","en":"that you","tr":"innaka","isWaqf":false},{"position":7,"ar":"لَرَسُولُ","fr":"(sont) assurément (le) Messager","en":"(are) surely (the) Messenger","tr":"larasūlu","isWaqf":false},{"position":8,"ar":"ٱللَّهِ ۗ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":9,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":10,"ar":"يَعْلَمُ","fr":"sait","en":"knows","tr":"yaʿlamu","isWaqf":false},{"position":11,"ar":"إِنَّكَ","fr":"que vous","en":"that you","tr":"innaka","isWaqf":false},{"position":12,"ar":"لَرَسُولُهُۥ","fr":"(sont) assurément Son Messager","en":"(are) surely His Messenger","tr":"larasūluhu","isWaqf":false},{"position":13,"ar":"وَٱللَّهُ","fr":"et Allah","en":"and Allah","tr":"wal-lahu","isWaqf":false},{"position":14,"ar":"يَشْهَدُ","fr":"témoigne","en":"testifies","tr":"yashhadu","isWaqf":false},{"position":15,"ar":"إِنَّ","fr":"que","en":"that","tr":"inna","isWaqf":false},{"position":16,"ar":"ٱلْمُنَـٰفِقِينَ","fr":"les hypocrites","en":"the hypocrites","tr":"l-munāfiqīna","isWaqf":false},{"position":17,"ar":"لَكَـٰذِبُونَ","fr":"(sont) assurément menteurs","en":"(are) surely liars","tr":"lakādhibūna","isWaqf":false}]},{"ayah":2,"verseKey":"63:2","juz":28,"arabic":"ٱتَّخَذُوٓا۟ أَيْمَـٰنَهُمْ جُنَّةً فَصَدُّوا۟ عَن سَبِيلِ ٱللَّهِ ۚ إِنَّهُمْ سَآءَ مَا كَانُوا۟ يَعْمَلُونَ","fr":"Ils ont pris leur serment comme bouclier protecteur, et ont repoussé (les autres) loin du chemin d’Allah. Comme étaient détestables les choses qu’ils faisaient !","en":"They have taken their oaths as a cover, so they averted [people] from the way of Allāh. Indeed, it was evil that they were doing.","words":[{"position":1,"ar":"ٱتَّخَذُوٓا۟","fr":"Ils prendre","en":"They take","tr":"ittakhadhū","isWaqf":false},{"position":2,"ar":"أَيْمَـٰنَهُمْ","fr":"leur serments","en":"their oaths","tr":"aymānahum","isWaqf":false},{"position":3,"ar":"جُنَّةًۭ","fr":"(comme) un couvrir","en":"(as) a cover","tr":"junnatan","isWaqf":false},{"position":4,"ar":"فَصَدُّوا۟","fr":"donc ils se détournent","en":"so they turn away","tr":"faṣaddū","isWaqf":false},{"position":5,"ar":"عَن","fr":"de","en":"from","tr":"ʿan","isWaqf":false},{"position":6,"ar":"سَبِيلِ","fr":"(le) Voie","en":"(the) Way","tr":"sabīli","isWaqf":false},{"position":7,"ar":"ٱللَّهِ ۚ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":8,"ar":"إِنَّهُمْ","fr":"Certes, [ils]","en":"Indeed, [they]","tr":"innahum","isWaqf":false},{"position":9,"ar":"سَآءَ","fr":"mal est","en":"evil is","tr":"sāa","isWaqf":false},{"position":10,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":11,"ar":"كَانُوا۟","fr":"ils avaient l'habitude de","en":"they used to","tr":"kānū","isWaqf":false},{"position":12,"ar":"يَعْمَلُونَ","fr":"faire","en":"do","tr":"yaʿmalūna","isWaqf":false}]},{"ayah":3,"verseKey":"63:3","juz":28,"arabic":"ذَٰلِكَ بِأَنَّهُمْ ءَامَنُوا۟ ثُمَّ كَفَرُوا۟ فَطُبِعَ عَلَىٰ قُلُوبِهِمْ فَهُمْ لَا يَفْقَهُونَ","fr":"Cela, parce qu’ils ont cru, puis mécru. Leurs cœurs en sont alors scellés, et ils ne comprennent plus rien.","en":"That is because they believed, and then they disbelieved; so their hearts were sealed over, and they do not understand.","words":[{"position":1,"ar":"ذَٰلِكَ","fr":"Cela","en":"That","tr":"dhālika","isWaqf":false},{"position":2,"ar":"بِأَنَّهُمْ","fr":"(est) parce que","en":"(is) because","tr":"bi-annahum","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"ils a cru","en":"they believed","tr":"āmanū","isWaqf":false},{"position":4,"ar":"ثُمَّ","fr":"puis","en":"then","tr":"thumma","isWaqf":false},{"position":5,"ar":"كَفَرُوا۟","fr":"ils a mécru","en":"they disbelieved","tr":"kafarū","isWaqf":false},{"position":6,"ar":"فَطُبِعَ","fr":"donc étaient scella","en":"so were sealed","tr":"faṭubiʿa","isWaqf":false},{"position":7,"ar":"عَلَىٰ","fr":"[sur]","en":"[upon]","tr":"ʿalā","isWaqf":false},{"position":8,"ar":"قُلُوبِهِمْ","fr":"leurs cœurs","en":"their hearts","tr":"qulūbihim","isWaqf":false},{"position":9,"ar":"فَهُمْ","fr":"donc ils","en":"so they","tr":"fahum","isWaqf":false},{"position":10,"ar":"لَا","fr":"(fais) non","en":"(do) not","tr":"lā","isWaqf":false},{"position":11,"ar":"يَفْقَهُونَ","fr":"comprendre","en":"understand","tr":"yafqahūna","isWaqf":false}]},{"ayah":4,"verseKey":"63:4","juz":28,"arabic":"وَإِذَا رَأَيْتَهُمْ تُعْجِبُكَ أَجْسَامُهُمْ ۖ وَإِن يَقُولُوا۟ تَسْمَعْ لِقَوْلِهِمْ ۖ كَأَنَّهُمْ خُشُبٌ مُّسَنَّدَةٌ ۖ يَحْسَبُونَ كُلَّ صَيْحَةٍ عَلَيْهِمْ ۚ هُمُ ٱلْعَدُوُّ فَٱحْذَرْهُمْ ۚ قَـٰتَلَهُمُ ٱللَّهُ ۖ أَنَّىٰ يُؤْفَكُونَ","fr":"Quand tu les vois, leur apparence physique te plaît, et s’ils parlent tu écoutes (volontiers) ce qu’ils disent. Ils sont tels des poutres appuyées (contre le mur). Ils pensent que le moindre cri les concerne. Ce sont eux l’ennemi. Méfie-toi d’eux ! Qu’Allah les combatte ! Comme ils se détournent (du droit chemin) !","en":"And when you see them, their forms please you, and if they speak, you listen to their speech. [They are] as if they were pieces of wood propped up - they think that every shout is against them. They are the enemy, so beware of them. May Allāh destroy them; how are they deluded?","words":[{"position":1,"ar":"۞ وَإِذَا","fr":"Et quand","en":"And when","tr":"wa-idhā","isWaqf":false},{"position":2,"ar":"رَأَيْتَهُمْ","fr":"vous voez eux","en":"you see them","tr":"ra-aytahum","isWaqf":false},{"position":3,"ar":"تُعْجِبُكَ","fr":"plaît vous","en":"pleases you","tr":"tuʿ'jibuka","isWaqf":false},{"position":4,"ar":"أَجْسَامُهُمْ ۖ","fr":"leur corps","en":"their bodies","tr":"ajsāmuhum","isWaqf":false},{"position":5,"ar":"وَإِن","fr":"et si","en":"and if","tr":"wa-in","isWaqf":false},{"position":6,"ar":"يَقُولُوا۟","fr":"ils parlent","en":"they speak","tr":"yaqūlū","isWaqf":false},{"position":7,"ar":"تَسْمَعْ","fr":"vous écoutez","en":"you listen","tr":"tasmaʿ","isWaqf":false},{"position":8,"ar":"لِقَوْلِهِمْ ۖ","fr":"à leur parole","en":"to their speech","tr":"liqawlihim","isWaqf":false},{"position":9,"ar":"كَأَنَّهُمْ","fr":"comme si ils (étaient)","en":"as if they (were)","tr":"ka-annahum","isWaqf":false},{"position":10,"ar":"خُشُبٌۭ","fr":"morceaux de bois","en":"pieces of wood","tr":"khushubun","isWaqf":false},{"position":11,"ar":"مُّسَنَّدَةٌۭ ۖ","fr":"propped haut","en":"propped up","tr":"musannadatun","isWaqf":false},{"position":12,"ar":"يَحْسَبُونَ","fr":"Ils Pensent","en":"They think","tr":"yaḥsabūna","isWaqf":false},{"position":13,"ar":"كُلَّ","fr":"chaque","en":"every","tr":"kulla","isWaqf":false},{"position":14,"ar":"صَيْحَةٍ","fr":"cri","en":"shout","tr":"ṣayḥatin","isWaqf":false},{"position":15,"ar":"عَلَيْهِمْ ۚ","fr":"(est) contre eux","en":"(is) against them","tr":"ʿalayhim","isWaqf":false},{"position":16,"ar":"هُمُ","fr":"Ils","en":"They","tr":"humu","isWaqf":false},{"position":17,"ar":"ٱلْعَدُوُّ","fr":"(sont) le ennemi","en":"(are) the enemy","tr":"l-ʿaduwu","isWaqf":false},{"position":18,"ar":"فَٱحْذَرْهُمْ ۚ","fr":"donc prends garde de eux","en":"so beware of them","tr":"fa-iḥ'dharhum","isWaqf":false},{"position":19,"ar":"قَـٰتَلَهُمُ","fr":"Peut détruire eux","en":"May destroy them","tr":"qātalahumu","isWaqf":false},{"position":20,"ar":"ٱللَّهُ ۖ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":21,"ar":"أَنَّىٰ","fr":"Comment","en":"How","tr":"annā","isWaqf":false},{"position":22,"ar":"يُؤْفَكُونَ","fr":"sont ils abusé","en":"are they deluded","tr":"yu'fakūna","isWaqf":false}]},{"ayah":5,"verseKey":"63:5","juz":28,"arabic":"وَإِذَا قِيلَ لَهُمْ تَعَالَوْا۟ يَسْتَغْفِرْ لَكُمْ رَسُولُ ٱللَّهِ لَوَّوْا۟ رُءُوسَهُمْ وَرَأَيْتَهُمْ يَصُدُّونَ وَهُم مُّسْتَكْبِرُونَ","fr":"Quand il leur est dit : « Venez ! Le Messager d’Allah va implorer le pardon pour vous », ils détournent la tête, et tu les vois se retirer, dédaigneux, pleins de morgue.","en":"And when it is said to them, \"Come, the Messenger of Allāh will ask forgiveness for you,\" they turn their heads aside and you see them evading while they are arrogant.","words":[{"position":1,"ar":"وَإِذَا","fr":"Et quand","en":"And when","tr":"wa-idhā","isWaqf":false},{"position":2,"ar":"قِيلَ","fr":"il est dit","en":"it is said","tr":"qīla","isWaqf":false},{"position":3,"ar":"لَهُمْ","fr":"à eux","en":"to them","tr":"lahum","isWaqf":false},{"position":4,"ar":"تَعَالَوْا۟","fr":"Venir","en":"Come","tr":"taʿālaw","isWaqf":false},{"position":5,"ar":"يَسْتَغْفِرْ","fr":"va demander pardon","en":"will ask forgiveness","tr":"yastaghfir","isWaqf":false},{"position":6,"ar":"لَكُمْ","fr":"pour vous","en":"for you","tr":"lakum","isWaqf":false},{"position":7,"ar":"رَسُولُ","fr":"(le) Messager","en":"(the) Messenger","tr":"rasūlu","isWaqf":false},{"position":8,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":9,"ar":"لَوَّوْا۟","fr":"Ils se détourner de côté","en":"They turn aside","tr":"lawwaw","isWaqf":false},{"position":10,"ar":"رُءُوسَهُمْ","fr":"leur têtes","en":"their heads","tr":"ruūsahum","isWaqf":false},{"position":11,"ar":"وَرَأَيْتَهُمْ","fr":"et vous voez eux","en":"and you see them","tr":"wara-aytahum","isWaqf":false},{"position":12,"ar":"يَصُدُّونَ","fr":"se détournant au loin","en":"turning away","tr":"yaṣuddūna","isWaqf":false},{"position":13,"ar":"وَهُم","fr":"tandis qu'ils","en":"while they","tr":"wahum","isWaqf":false},{"position":14,"ar":"مُّسْتَكْبِرُونَ","fr":"(sont) orgueilleux","en":"(are) arrogant","tr":"mus'takbirūna","isWaqf":false}]},{"ayah":6,"verseKey":"63:6","juz":28,"arabic":"سَوَآءٌ عَلَيْهِمْ أَسْتَغْفَرْتَ لَهُمْ أَمْ لَمْ تَسْتَغْفِرْ لَهُمْ لَن يَغْفِرَ ٱللَّهُ لَهُمْ ۚ إِنَّ ٱللَّهَ لَا يَهْدِى ٱلْقَوْمَ ٱلْفَـٰسِقِينَ","fr":"Que tu implores pour eux le pardon ou que tu ne l’implores pas, cela est égal. Car Allah ne leur pardonnera pas. Allah ne guide pas les gens pervers.","en":"It is all the same for them whether you ask forgiveness for them or do not ask forgiveness for them; never will Allāh forgive them. Indeed, Allāh does not guide the defiantly disobedient people.","words":[{"position":1,"ar":"سَوَآءٌ","fr":"(Cela) est même","en":"(It) is same","tr":"sawāon","isWaqf":false},{"position":2,"ar":"عَلَيْهِمْ","fr":"pour eux","en":"for them","tr":"ʿalayhim","isWaqf":false},{"position":3,"ar":"أَسْتَغْفَرْتَ","fr":"si vous demandez pardon","en":"whether you ask forgiveness","tr":"astaghfarta","isWaqf":false},{"position":4,"ar":"لَهُمْ","fr":"pour eux","en":"for them","tr":"lahum","isWaqf":false},{"position":5,"ar":"أَمْ","fr":"ou","en":"or","tr":"am","isWaqf":false},{"position":6,"ar":"لَمْ","fr":"(fais) non","en":"(do) not","tr":"lam","isWaqf":false},{"position":7,"ar":"تَسْتَغْفِرْ","fr":"demander pardon","en":"ask forgiveness","tr":"tastaghfir","isWaqf":false},{"position":8,"ar":"لَهُمْ","fr":"pour eux","en":"for them","tr":"lahum","isWaqf":false},{"position":9,"ar":"لَن","fr":"Jamais","en":"Never","tr":"lan","isWaqf":false},{"position":10,"ar":"يَغْفِرَ","fr":"va pardonner","en":"will forgive","tr":"yaghfira","isWaqf":false},{"position":11,"ar":"ٱللَّهُ","fr":"Allah","en":"Allah","tr":"l-lahu","isWaqf":false},{"position":12,"ar":"لَهُمْ ۚ","fr":"[à] eux","en":"[to] them","tr":"lahum","isWaqf":false},{"position":13,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":14,"ar":"ٱللَّهَ","fr":"Allah","en":"Allah","tr":"l-laha","isWaqf":false},{"position":15,"ar":"لَا","fr":"(ne) fait pas","en":"(does) not","tr":"lā","isWaqf":false},{"position":16,"ar":"يَهْدِى","fr":"guide","en":"guide","tr":"yahdī","isWaqf":false},{"position":17,"ar":"ٱلْقَوْمَ","fr":"les gens","en":"the people","tr":"l-qawma","isWaqf":false},{"position":18,"ar":"ٱلْفَـٰسِقِينَ","fr":"les rebelles","en":"the defiantly disobedient","tr":"l-fāsiqīna","isWaqf":false}]},{"ayah":7,"verseKey":"63:7","juz":28,"arabic":"هُمُ ٱلَّذِينَ يَقُولُونَ لَا تُنفِقُوا۟ عَلَىٰ مَنْ عِندَ رَسُولِ ٱللَّهِ حَتَّىٰ يَنفَضُّوا۟ ۗ وَلِلَّهِ خَزَآئِنُ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ وَلَـٰكِنَّ ٱلْمُنَـٰفِقِينَ لَا يَفْقَهُونَ","fr":"Ce sont eux qui disent : « Ne dépensez plus (de vos biens) en faveur de ceux qui sont (toujours) auprès du Messager d’Allah. C’est ainsi seulement qu’ils finiront par se disperser (d’autour de lui.) » C’est à Allah qu’appartiennent les trésors des cieux et de la terre, mais les hypocrites, eux, ne (le) comprennent pas.","en":"They are the ones who say, \"Do not spend on those who are with the Messenger of Allāh until they disband.\" And to Allāh belong the depositories of the heavens and the earth, but the hypocrites do not understand.","words":[{"position":1,"ar":"هُمُ","fr":"Ils","en":"They","tr":"humu","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"(sont) ceux qui","en":"(are) those who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"يَقُولُونَ","fr":"dis","en":"say","tr":"yaqūlūna","isWaqf":false},{"position":4,"ar":"لَا","fr":"(Ne) fais pas","en":"(Do) not","tr":"lā","isWaqf":false},{"position":5,"ar":"تُنفِقُوا۟","fr":"dépenser","en":"spend","tr":"tunfiqū","isWaqf":false},{"position":6,"ar":"عَلَىٰ","fr":"sur","en":"on","tr":"ʿalā","isWaqf":false},{"position":7,"ar":"مَنْ","fr":"(ceux) qui","en":"(those) who","tr":"man","isWaqf":false},{"position":8,"ar":"عِندَ","fr":"(sont) avec","en":"(are) with","tr":"ʿinda","isWaqf":false},{"position":9,"ar":"رَسُولِ","fr":"(le) Messager","en":"(the) Messenger","tr":"rasūli","isWaqf":false},{"position":10,"ar":"ٱللَّهِ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":11,"ar":"حَتَّىٰ","fr":"jusqu'à","en":"until","tr":"ḥattā","isWaqf":false},{"position":12,"ar":"يَنفَضُّوا۟ ۗ","fr":"ils disband","en":"they disband","tr":"yanfaḍḍū","isWaqf":false},{"position":13,"ar":"وَلِلَّهِ","fr":"Et pour Allah","en":"And for Allah","tr":"walillahi","isWaqf":false},{"position":14,"ar":"خَزَآئِنُ","fr":"(sont le) trésors","en":"(are the) treasures","tr":"khazāinu","isWaqf":false},{"position":15,"ar":"ٱلسَّمَـٰوَٰتِ","fr":"(de) les cieux","en":"(of) the heavens","tr":"l-samāwāti","isWaqf":false},{"position":16,"ar":"وَٱلْأَرْضِ","fr":"et la terre","en":"and the earth","tr":"wal-arḍi","isWaqf":false},{"position":17,"ar":"وَلَـٰكِنَّ","fr":"mais","en":"but","tr":"walākinna","isWaqf":false},{"position":18,"ar":"ٱلْمُنَـٰفِقِينَ","fr":"les hypocrites","en":"the hypocrites","tr":"l-munāfiqīna","isWaqf":false},{"position":19,"ar":"لَا","fr":"(fais) non","en":"(do) not","tr":"lā","isWaqf":false},{"position":20,"ar":"يَفْقَهُونَ","fr":"comprendre","en":"understand","tr":"yafqahūna","isWaqf":false}]},{"ayah":8,"verseKey":"63:8","juz":28,"arabic":"يَقُولُونَ لَئِن رَّجَعْنَآ إِلَى ٱلْمَدِينَةِ لَيُخْرِجَنَّ ٱلْأَعَزُّ مِنْهَا ٱلْأَذَلَّ ۚ وَلِلَّهِ ٱلْعِزَّةُ وَلِرَسُولِهِۦ وَلِلْمُؤْمِنِينَ وَلَـٰكِنَّ ٱلْمُنَـٰفِقِينَ لَا يَعْلَمُونَ","fr":"Ils disent : « Si nous revenons à Médine, le plus puissant en chassera le plus humble. » C’est pourtant à Allah qu’appartient la Puissance, à Son Messager et aux croyants. Mais les hypocrites ne (le) savent pas.","en":"They say, \"If we return to al-Madīnah, the more honored [for power] will surely expel therefrom the more humble.\" And to Allāh belongs [all] honor, and to His Messenger, and to the believers, but the hypocrites do not know.","words":[{"position":1,"ar":"يَقُولُونَ","fr":"Ils disent","en":"They say","tr":"yaqūlūna","isWaqf":false},{"position":2,"ar":"لَئِن","fr":"Si","en":"If","tr":"la-in","isWaqf":false},{"position":3,"ar":"رَّجَعْنَآ","fr":"nous retournons","en":"we return","tr":"rajaʿnā","isWaqf":false},{"position":4,"ar":"إِلَى","fr":"à","en":"to","tr":"ilā","isWaqf":false},{"position":5,"ar":"ٱلْمَدِينَةِ","fr":"Al-Madinah","en":"Al-Madinah","tr":"l-madīnati","isWaqf":false},{"position":6,"ar":"لَيُخْرِجَنَّ","fr":"assurément, va expulser","en":"surely, will expel","tr":"layukh'rijanna","isWaqf":false},{"position":7,"ar":"ٱلْأَعَزُّ","fr":"le plus honorable","en":"the more honorable","tr":"l-aʿazu","isWaqf":false},{"position":8,"ar":"مِنْهَا","fr":"de cela","en":"from it","tr":"min'hā","isWaqf":false},{"position":9,"ar":"ٱلْأَذَلَّ ۚ","fr":"le plus humble","en":"the more humble","tr":"l-adhala","isWaqf":false},{"position":10,"ar":"وَلِلَّهِ","fr":"Mais pour Allah","en":"But for Allah","tr":"walillahi","isWaqf":false},{"position":11,"ar":"ٱلْعِزَّةُ","fr":"(est) le honneur","en":"(is) the honor","tr":"l-ʿizatu","isWaqf":false},{"position":12,"ar":"وَلِرَسُولِهِۦ","fr":"et pour Son Messager","en":"and for His Messenger","tr":"walirasūlihi","isWaqf":false},{"position":13,"ar":"وَلِلْمُؤْمِنِينَ","fr":"et pour les croyants","en":"and for the believers","tr":"walil'mu'minīna","isWaqf":false},{"position":14,"ar":"وَلَـٰكِنَّ","fr":"mais","en":"but","tr":"walākinna","isWaqf":false},{"position":15,"ar":"ٱلْمُنَـٰفِقِينَ","fr":"les hypocrites","en":"the hypocrites","tr":"l-munāfiqīna","isWaqf":false},{"position":16,"ar":"لَا","fr":"(fais) non","en":"(do) not","tr":"lā","isWaqf":false},{"position":17,"ar":"يَعْلَمُونَ","fr":"savoir","en":"know","tr":"yaʿlamūna","isWaqf":false}]},{"ayah":9,"verseKey":"63:9","juz":28,"arabic":"يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تُلْهِكُمْ أَمْوَٰلُكُمْ وَلَآ أَوْلَـٰدُكُمْ عَن ذِكْرِ ٱللَّهِ ۚ وَمَن يَفْعَلْ ذَٰلِكَ فَأُو۟لَـٰٓئِكَ هُمُ ٱلْخَـٰسِرُونَ","fr":"Ô vous qui avez cru ! Que vos biens et vos enfants ne vous distraient point de l’Invocation d’Allah. Ceux qui le font sont eux les perdants.","en":"O you who have believed, let not your wealth and your children divert you from the remembrance of Allāh. And whoever does that - then those are the losers.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô","en":"O","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"vous (qui)","en":"you (who)","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"croire","en":"believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"لَا","fr":"(laisse) non","en":"(Let) not","tr":"lā","isWaqf":false},{"position":5,"ar":"تُلْهِكُمْ","fr":"divert vous","en":"divert you","tr":"tul'hikum","isWaqf":false},{"position":6,"ar":"أَمْوَٰلُكُمْ","fr":"votre richesse","en":"your wealth","tr":"amwālukum","isWaqf":false},{"position":7,"ar":"وَلَآ","fr":"et non","en":"and not","tr":"walā","isWaqf":false},{"position":8,"ar":"أَوْلَـٰدُكُمْ","fr":"votre enfants","en":"your children","tr":"awlādukum","isWaqf":false},{"position":9,"ar":"عَن","fr":"de","en":"from","tr":"ʿan","isWaqf":false},{"position":10,"ar":"ذِكْرِ","fr":"(le) rappel","en":"(the) remembrance","tr":"dhik'ri","isWaqf":false},{"position":11,"ar":"ٱللَّهِ ۚ","fr":"(d') Allah","en":"(of) Allah","tr":"l-lahi","isWaqf":false},{"position":12,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":13,"ar":"يَفْعَلْ","fr":"fait","en":"does","tr":"yafʿal","isWaqf":false},{"position":14,"