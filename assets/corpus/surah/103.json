[{"ayah":1,"verseKey":"103:1","juz":30,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلْعَصْرِ","fr":"Par le Temps!","en":"By time,","words":[{"position":1,"ar":"وَٱلْعَصْرِ","fr":"Par le temps","en":"By the time","tr":"wal-ʿaṣri","isWaqf":false}]},{"ayah":2,"verseKey":"103:2","juz":30,"arabic":"إِنَّ ٱلْإِنسَـٰنَ لَفِى خُسْرٍ","fr":"L’homme, en vérité, est en perdition,","en":"Indeed, mankind is in loss,","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"ٱلْإِنسَـٰنَ","fr":"l'humanité","en":"mankind","tr":"l-insāna","isWaqf":false},{"position":3,"ar":"لَفِى","fr":"(est) assurément, dans","en":"(is) surely, in","tr":"lafī","isWaqf":false},{"position":4,"ar":"خُسْرٍ","fr":"perte","en":"loss","tr":"khus'rin","isWaqf":false}]},{"ayah":3,"verseKey":"103:3","juz":30,"arabic":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ وَتَوَاصَوْا۟ بِٱلْحَقِّ وَتَوَاصَوْا۟ بِٱلصَّبْرِ","fr":"à l’exception de ceux qui ont cru, ont accompli les bonnes œuvres, se sont recommandé la vérité, et se sont recommandé la patience.","en":"Except for those who have believed and done righteous deeds and advised each other to truth and advised each other to patience.","words":[{"position":1,"ar":"إِلَّا","fr":"Sauf","en":"Except","tr":"illā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"ceux qui","en":"those who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"croire","en":"believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"وَعَمِلُوا۟","fr":"et faire","en":"and do","tr":"waʿamilū","isWaqf":false},{"position":5,"ar":"ٱلصَّـٰلِحَـٰتِ","fr":"bonnes œuvres","en":"righteous deeds","tr":"l-ṣāliḥāti","isWaqf":false},{"position":6,"ar":"وَتَوَاصَوْا۟","fr":"et enjoindre (chacun autre)","en":"and enjoin (each other)","tr":"watawāṣaw","isWaqf":false},{"position":7,"ar":"بِٱلْحَقِّ","fr":"à la vérité","en":"to the truth","tr":"bil-ḥaqi","isWaqf":false},{"position":8,"ar":"وَتَوَاصَوْا۟","fr":"et enjoindre (chacun autre)","en":"and enjoin (each other)","tr":"watawāṣaw","isWaqf":false},{"position":9,"ar":"بِٱلصَّبْرِ","fr":"à [le] patience","en":"to [the] patience","tr":"bil-ṣabri","isWaqf":false}]}]