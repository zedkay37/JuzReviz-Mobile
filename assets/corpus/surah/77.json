at","isWaqf":false}]},{"ayah":10,"verseKey":"77:10","juz":29,"arabic":"وَإِذَا ٱلْجِبَالُ نُسِفَتْ","fr":"et que les montagnes seront désintégrées,","en":"And when the mountains are blown away","words":[{"position":1,"ar":"وَإِذَا","fr":"Et quand","en":"And when","tr":"wa-idhā","isWaqf":false},{"position":2,"ar":"ٱلْجِبَالُ","fr":"les montagnes","en":"the mountains","tr":"l-jibālu","isWaqf":false},{"position":3,"ar":"نُسِفَتْ","fr":"sont soufflé au loin","en":"are blown away","tr":"nusifat","isWaqf":false}]},{"ayah":11,"verseKey":"77:11","juz":29,"arabic":"وَإِذَا ٱلرُّسُلُ أُقِّتَتْ","fr":"et que le moment sera venu pour les Messagers de comparaître,","en":"And when the messengers' time has come...","words":[{"position":1,"ar":"وَإِذَا","fr":"Et quand","en":"And when","tr":"wa-idhā","isWaqf":false},{"position":2,"ar":"ٱلرُّسُلُ","fr":"les Messagers","en":"the Messengers","tr":"l-rusulu","isWaqf":false},{"position":3,"ar":"أُقِّتَتْ","fr":"sont rassembla à leur désigné temps","en":"are gathered to their appointed time","tr":"uqqitat","isWaqf":false}]},{"ayah":12,"verseKey":"77:12","juz":29,"arabic":"لِأَىِّ يَوْمٍ أُجِّلَتْ","fr":"à quel jour cela est-il donc différé ?","en":"For what Day was it postponed?","words":[{"position":1,"ar":"لِأَىِّ","fr":"Pour ce que","en":"For what","tr":"li-ayyi","isWaqf":false},{"position":2,"ar":"يَوْمٍ","fr":"Jour","en":"Day","tr":"yawmin","isWaqf":false},{"position":3,"ar":"أُجِّلَتْ","fr":"sont (ces) postponed","en":"are (these) postponed","tr":"ujjilat","isWaqf":false}]},{"ayah":13,"verseKey":"77:13","juz":29,"arabic":"لِيَوْمِ ٱلْفَصْلِ","fr":"Au jour de la Décision.","en":"For the Day of Judgement.","words":[{"position":1,"ar":"لِيَوْمِ","fr":"Pour (le) Jour","en":"For (the) Day","tr":"liyawmi","isWaqf":false},{"position":2,"ar":"ٱلْفَصْلِ","fr":"(de) Jugement","en":"(of) Judgment","tr":"l-faṣli","isWaqf":false}]},{"ayah":14,"verseKey":"77:14","juz":29,"arabic":"وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلْفَصْلِ","fr":"Et qui te fera jamai