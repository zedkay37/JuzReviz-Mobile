[{"ayah":1,"verseKey":"97:1","juz":30,"arabic":"بِّسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِنَّآ أَنزَلْنَـٰهُ فِى لَيْلَةِ ٱلْقَدْرِ","fr":"Nous l’avons révélé en la nuit du Destin.","en":"Indeed, We sent it [i.e., the Qur’ān] down during the Night of Decree.","words":[{"position":1,"ar":"إِنَّآ","fr":"Certes, Nous","en":"Indeed, We","tr":"innā","isWaqf":false},{"position":2,"ar":"أَنزَلْنَـٰهُ","fr":"révélé cela","en":"revealed it","tr":"anzalnāhu","isWaqf":false},{"position":3,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":4,"ar":"لَيْلَةِ","fr":"(le) Nuit","en":"(the) Night","tr":"laylati","isWaqf":false},{"position":5,"ar":"ٱلْقَدْرِ","fr":"(de) Puissance","en":"(of) Power","tr":"l-qadri","isWaqf":false}]},{"ayah":2,"verseKey":"97:2","juz":30,"arabic":"وَمَآ أَدْرَىٰكَ مَا لَيْلَةُ ٱلْقَدْرِ","fr":"Et qui te fera jamais savoir ce qu’est la nuit du Destin ?","en":"And what can make you know what is the Night of Decree?","words":[{"position":1,"ar":"وَمَآ","fr":"Et quoi","en":"And what","tr":"wamā","isWaqf":false},{"position":2,"ar":"أَدْرَىٰكَ","fr":"peut faire vous savoez","en":"can make you know","tr":"adrāka","isWaqf":false},{"position":3,"ar":"مَا","fr":"ce que","en":"what","tr":"mā","isWaqf":false},{"position":4,"ar":"لَيْلَةُ","fr":"(le) Nuit","en":"(the) Night","tr":"laylatu","isWaqf":false},{"position":5,"ar":"ٱلْقَدْرِ","fr":"(de) Puissance (est)","en":"(of) Power (is)","tr":"l-qadri","isWaqf":false}]},{"ayah":3,"verseKey":"97:3","juz":30,"arabic":"لَيْلَةُ ٱلْقَدْرِ خَيْرٌ مِّنْ أَلْفِ شَهْرٍ","fr":"La nuit du Destin vaut mieux que mille mois.","en":"The Night of Decree is better than a thousand months.","words":[{"position":1,"ar":"لَيْلَةُ","fr":"(le) Nuit","en":"(The) Night","tr":"laylatu","isWaqf":false},{"position":2,"ar":"ٱلْقَدْرِ","fr":"(de) Puissance","en":"(of) Power","tr":"l-qadri","isWaqf":false},{"position":3,"ar":"خَيْرٌۭ","fr":"(est) meilleur","en":"(is) better","tr":"khayrun","isWaqf":false},{"position":4,"ar":"