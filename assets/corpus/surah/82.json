":false}]},{"ayah":11,"verseKey":"82:11","juz":30,"arabic":"كِرَامًا كَـٰتِبِينَ","fr":"qui sont de nobles scripteurs,","en":"Noble and recording;","words":[{"position":1,"ar":"كِرَامًۭا","fr":"Noble","en":"Noble","tr":"kirāman","isWaqf":false},{"position":2,"ar":"كَـٰتِبِينَ","fr":"consignant","en":"recording","tr":"kātibīna","isWaqf":false}]},{"ayah":12,"verseKey":"82:12","juz":30,"arabic":"يَعْلَمُونَ مَا تَفْعَلُونَ","fr":"sachant bien ce que vous faites.","en":"They know whatever you do.","words":[{"position":1,"ar":"يَعْلَمُونَ","fr":"Ils Savoent","en":"They know","tr":"yaʿlamūna","isWaqf":false},{"position":2,"ar":"مَا","fr":"quoi que","en":"whatever","tr":"mā","isWaqf":false},{"position":3,"ar":"تَفْعَلُونَ","fr":"vous faire","en":"you do","tr":"tafʿalūna","isWaqf":false}]},{"ayah":13,"verseKey":"82:13","juz":30,"arabic":"إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ","fr":"Les vertueux auront droit au délice absolu.","en":"Indeed, the righteous will be in pleasure,","words":[{"position":1,"ar":"إِنَّ","fr":"Certes","en":"Indeed","tr":"inna","isWaqf":false},{"position":2,"ar":"ٱلْأَبْرَارَ","fr":"les justes","en":"the righteous","tr":"l-abrāra","isWaqf":false},{"position":3,"ar":"لَفِى","fr":"(va être) assurément dans","en":"(will be) surely in","tr":"lafī","isWaqf":false},{"position":4,"ar":"نَعِيمٍۢ","fr":"félicité","en":"bliss","tr":"naʿīmin","isWaqf":false}]},{"ayah":14,"verseKey":"82:14","juz":30,"arabic":"وَإِنَّ ٱلْفُجَّارَ لَفِى جَحِيمٍ","fr":"Les scélérats seront en Enfer.","en":"And indeed, the wicked will be in Hellfire.","words":[{"position":1,"ar":"وَإِنَّ","fr":"Et certes","en":"And indeed","tr":"wa-inna","isWaqf":false},{"position":2,"ar":"ٱلْفُجَّارَ","fr":"le méchant","en":"the wicked","tr":"l-fujāra","isWaqf":false},{"position":3,"ar":"لَفِى","fr":"(va être) assurément dans","en":"(will be) surely in","tr":"lafī","isWaqf":false},{"position":4,"ar":"جَحِيمٍۢ","fr":"le Feu","en":"Hellfire","tr":"jaḥīmin","isWaqf":false}]},{"ayah":15,"verseKey":"82:15","ju