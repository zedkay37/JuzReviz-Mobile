[{"ayah":1,"verseKey":"60:1","juz":28,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ يَـٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تَتَّخِذُوا۟ عَدُوِّى وَعَدُوَّكُمْ أَوْلِيَآءَ تُلْقُونَ إِلَيْهِم بِٱلْمَوَدَّةِ وَقَدْ كَفَرُوا۟ بِمَا جَآءَكُم مِّنَ ٱلْحَقِّ يُخْرِجُونَ ٱلرَّسُولَ وَإِيَّاكُمْ ۙ أَن تُؤْمِنُوا۟ بِٱللَّهِ رَبِّكُمْ إِن كُنتُمْ خَرَجْتُمْ جِهَـٰدًا فِى سَبِيلِى وَٱبْتِغَآءَ مَرْضَاتِى ۚ تُسِرُّونَ إِلَيْهِم بِٱلْمَوَدَّةِ وَأَنَا۠ أَعْلَمُ بِمَآ أَخْفَيْتُمْ وَمَآ أَعْلَنتُمْ ۚ وَمَن يَفْعَلْهُ مِنكُمْ فَقَدْ ضَلَّ سَوَآءَ ٱلسَّبِيلِ","fr":"Ô vous qui avez cru ! Ne faites pas de Mon ennemi et du vôtre des alliés, auxquels vous proposez votre amitié alors qu’ils ont mécru à la vérité qui vous est parvenue. Ils vous ont expulsés, le Messager et vous, parce que vous croyez en Allah, votre Seigneur. Si vous êtes sortis pour vraiment combattre dans Mon chemin et obtenir Mon agrément, leur montreriez-vous secrètement quelque affinité, alors que Je Connais ce que vous tenez caché et ce que vous révélez ? Quiconque parmi vous le fait s’égare du droit chemin.","en":"O you who have believed, do not take My enemies and your enemies as allies, extending to them affection while they have disbelieved in what came to you of the truth, having driven out the Prophet and yourselves [only] because you believe in Allāh, your Lord. If you have come out for jihād [i.e., fighting or striving] in My cause and seeking means to My approval, [take them not as friends]. You confide to them affection [i.e., instruction], but I am most knowing of what you have concealed and what you have declared. And whoever does it among you has certainly strayed from the soundness of the way.","words":[{"position":1,"ar":"يَـٰٓأَيُّهَا","fr":"Ô vous","en":"O you","tr":"yāayyuhā","isWaqf":false},{"position":2,"ar":"ٱلَّذِينَ","fr":"qui","en":"who","tr":"alladhīna","isWaqf":false},{"position":3,"ar":"ءَامَنُوا۟","fr":"croire","en":"believe","tr":"āmanū","isWaqf":false},{"position":4,"ar":"لَا","fr":"(Ne) fais pas","en":"(Do) not","tr":"lā","isWaqf":false},{"position":5,"ar":"تَتَّخِذُوا۟","fr":"prendre","en":"take","tr":"tattakhidhū","isWaqf":false},{"position":6,"ar":"عَدُوِّى","fr":"Mon ennemis","en":"My enemies","tr":"ʿaduwwī","isWaqf":false},{"position":7,"ar":"وَعَدُوَّكُمْ","fr":"et votre ennemis","en":"and your enemies","tr":"waʿaduwwakum","isWaqf":false},{"position":8,"ar":"أَوْلِيَآءَ","fr":"(comme) alliés","en":"(as) allies","tr":"awliyāa","isWaqf":false},{"position":9,"ar":"تُلْقُونَ","fr":"offrande","en":"offering","tr":"tul'qūna","isWaqf":false},{"position":10,"ar":"إِلَيْهِم","fr":"eux","en":"them","tr":"ilayhim","isWaqf":false},{"position":11,"ar":"بِٱلْمَوَدَّةِ","fr":"aimer","en":"love","tr":"bil-mawadati","isWaqf":false},{"position":12,"ar":"وَقَدْ","fr":"tandis que","en":"while","tr":"waqad","isWaqf":false},{"position":13,"ar":"كَفَرُوا۟","fr":"ils ont a mécru","en":"they have disbelieved","tr":"kafarū","isWaqf":false},{"position":14,"ar":"بِمَا","fr":"en ce que","en":"in what","tr":"bimā","isWaqf":false},{"position":15,"ar":"جَآءَكُم","fr":"te vint","en":"came to you","tr":"jāakum","isWaqf":false},{"position":16,"ar":"مِّنَ","fr":"de","en":"of","tr":"mina","isWaqf":false},{"position":17,"ar":"ٱلْحَقِّ","fr":"la vérité","en":"the truth","tr":"l-ḥaqi","isWaqf":false},{"position":18,"ar":"يُخْرِجُونَ","fr":"chassant hors","en":"driving out","tr":"yukh'rijūna","isWaqf":false},{"position":19,"ar":"ٱلرَّسُولَ","fr":"le Messager","en":"the Messenger","tr":"l-rasūla","isWaqf":false},{"position":20,"ar":"وَإِيَّاكُمْ ۙ","fr":"et vous-mêmes","en":"and yourselves","tr":"wa-iyyākum","isWaqf":false},{"position":21,"ar":"أَن","fr":"car","en":"because","tr":"an","isWaqf":false},{"position":22,"ar":"تُؤْمِنُوا۟","fr":"vous croire","en":"you believe","tr":"tu'minū","isWaqf":false},{"position":23,"ar":"بِٱللَّهِ","fr":"dans Allah","en":"in Allah","tr":"bil-lahi","isWaqf":false},{"position":24,"ar":"رَبِّكُمْ","fr":"votre Seigneur","en":"your Lord","tr":"rabbikum","isWaqf":false},{"position":25,"ar":"إِن","fr":"Si","en":"If","tr":"in","isWaqf":false},{"position":26,"ar":"كُنتُمْ","fr":"vous","en":"you","tr":"kuntum","isWaqf":false},{"position":27,"ar":"خَرَجْتُمْ","fr":"venir en avant","en":"come forth","tr":"kharajtum","isWaqf":false},{"position":28,"ar":"جِهَـٰدًۭا","fr":"(à) lutter","en":"(to) strive","tr":"jihādan","isWaqf":false},{"position":29,"ar":"فِى","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":30,"ar":"سَبِيلِى","fr":"Mon voie","en":"My way","tr":"sabīlī","isWaqf":false},{"position":31,"ar":"وَٱبْتِغَآءَ","fr":"et (à) chercher","en":"and (to) seek","tr":"wa-ib'tighāa","isWaqf":false},{"position":32,"ar":"مَرْضَاتِى ۚ","fr":"Mon Plaisir","en":"My Pleasure","tr":"marḍātī","isWaqf":false},{"position":33,"ar":"تُسِرُّونَ","fr":"Vous Confiez","en":"You confide","tr":"tusirrūna","isWaqf":false},{"position":34,"ar":"إِلَيْهِم","fr":"à eux","en":"to them","tr":"ilayhim","isWaqf":false},{"position":35,"ar":"بِٱلْمَوَدَّةِ","fr":"aimer","en":"love","tr":"bil-mawadati","isWaqf":false},{"position":36,"ar":"وَأَنَا۠","fr":"mais Je Suis","en":"but I Am","tr":"wa-anā","isWaqf":false},{"position":37,"ar":"أَعْلَمُ","fr":"le plus savant","en":"most knowing","tr":"aʿlamu","isWaqf":false},{"position":38,"ar":"بِمَآ","fr":"de ce que","en":"of what","tr":"bimā","isWaqf":false},{"position":39,"ar":"أَخْفَيْتُمْ","fr":"vous dissimulez","en":"you conceal","tr":"akhfaytum","isWaqf":false},{"position":40,"ar":"وَمَآ","fr":"et ce que","en":"and what","tr":"wamā","isWaqf":false},{"position":41,"ar":"أَعْلَنتُمْ ۚ","fr":"vous déclarez","en":"you declare","tr":"aʿlantum","isWaqf":false},{"position":42,"ar":"وَمَن","fr":"Et quiconque","en":"And whoever","tr":"waman","isWaqf":false},{"position":43,"ar":"يَفْعَلْهُ","fr":"fait cela","en":"does it","tr":"yafʿalhu","isWaqf":false},{"position":44,"ar":"مِنكُمْ","fr":"parmi vous","en":"among you","tr":"minkum","isWaqf":false},{"position":45,"ar":"فَقَدْ","fr":"puis certainement","en":"then certainly","tr":"faqad","isWaqf":false},{"position":46,"ar":"ضَلَّ","fr":"il a s'égara","en":"he has strayed","tr":"ḍalla","isWaqf":false},{"position":47,"ar":"سَوَآءَ","fr":"(de le) droit","en":"(from the) straight","tr":"sawāa","isWaqf":false},{"position":48,"ar":"ٱلسَّبِيلِ","fr":"chemin","en":"path","tr":"l-sabīli","isWaqf":false}]},{"ayah":2,"verseKey":"60:2","juz":28,"arabic":"إِن يَثْقَفُوكُمْ يَكُونُوا۟ لَكُمْ أَعْدَآءً وَيَبْسُطُوٓا۟ إِلَيْكُمْ أَيْدِيَهُمْ وَأَلْسِنَتَهُم بِٱلسُّوٓءِ وَوَدُّوا۟ لَوْ تَكْفُرُونَ","fr":"S’ils (parviennent jamais) à prendre le dessus sur vous, ils vous seront des ennemis, lèveront les mains contre vous et feront usage de leurs langues pour vous faire du mal, souhaitant vous voir apostasier.","en":"If they gain dominance over you, they would be [i.e., behave] to you as enemies and extend against you their hands and their tongues with evil, and they wish you would disbelieve.","words":[{"position":1,"ar":"إِن","fr":"Si","en":"If","tr":"in","isWaqf":false},{"position":2,"ar":"يَثْقَفُوكُمْ","fr":"ils gain domination sur vous","en":"they gain dominance over you","tr":"yathqafūkum","isWaqf":false},{"position":3,"ar":"يَكُونُوا۟","fr":"ils irait être","en":"they would be","tr":"yakūnū","isWaqf":false},{"position":4,"ar":"لَكُمْ","fr":"à vous","en":"to you","tr":"lakum","isWaqf":false},{"position":5,"ar":"أَعْدَآءًۭ","fr":"ennemis","en":"enemies","tr":"aʿdāan","isWaqf":false},{"position":6,"ar":"وَيَبْسُطُوٓا۟","fr":"et étendre","en":"and extend","tr":"wayabsuṭū","isWaqf":false},{"position":7,"ar":"إِلَيْكُمْ","fr":"contre vous","en":"against you","tr":"ilaykum","isWaqf":false},{"position":8,"ar":"أَيْدِيَهُمْ","fr":"leurs mains","en":"their hands","tr":"aydiyahum","isWaqf":false},{"position":9,"ar":"وَأَلْسِنَتَهُم","fr":"et leur langues","en":"and their tongues","tr":"wa-alsinatahum","isWaqf":false},{"position":10,"ar":"بِٱلسُّوٓءِ","fr":"avec mauvais","en":"with evil","tr":"bil-sūi","isWaqf":false},{"position":11,"ar":"وَوَدُّوا۟","fr":"et ils désissent","en":"and they desire","tr":"wawaddū","isWaqf":false},{"position":12,"ar":"لَوْ","fr":"que","en":"that","tr":"law","isWaqf":false},{"position":13,"ar":"تَكْفُرُونَ","fr":"vous irait mécroire","en":"you would disbelieve","tr":"takfurūna","isWaqf":false}]},{"ayah":3,"verseKey":"60:3","juz":28,"arabic":"لَن تَنفَعَكُمْ أَرْحَامُكُمْ وَلَآ أَوْلَـٰدُكُمْ ۚ يَوْمَ ٱلْقِيَـٰمَةِ يَفْصِلُ بَيْنَكُمْ ۚ وَٱللَّهُ بِمَا تَعْمَلُونَ بَصِيرٌ","fr":"Vos proches parents ne vous seront pas utiles, au Jour de la Résurrection, pas plus que ne vous le seront vos propres enfants. (Allah Seul, ce jour-là) vous départagera. Allah Voit tout ce que vous faites.","en":"Never will your relatives or your children benefit you; the Day of Resurrection He will judge between you. And Allāh, of what you do, is Seeing.","words":[{"position":1,"ar":"لَن","fr":"Jamais","en":"Never","tr":"lan","isWaqf":false},{"position":2,"ar":"تَنفَعَكُمْ","fr":"va bénéfice vous","en":"will benefit you","tr":"tanfaʿakum","isWaqf":false},{"position":3,"ar":"أَرْحَامُكُمْ","fr":"votre proches","en":"your relatives","tr":"arḥāmukum","isWaqf":false},{"position":4,"ar":"وَلَآ","fr":"et non","en":"and not","tr":"walā","isWaqf":false},{"position":5,"ar":"أَوْلَـٰدُكُمْ ۚ","fr":"votre enfants","en":"your children","tr":"awlādukum","isWaqf":false},{"position":6,"ar":"يَوْمَ","fr":"(en ce) Jour","en":"(on the) Day","tr":"yawma","isWaqf":false},{"position":7,"ar":"ٱلْقِيَـٰمَةِ","fr":"(de la) Résurrection","en":"(of) the Resurrection","tr":"l-qiyāmati","isWaqf":false},{"position":8,"ar":"يَفْصِلُ","fr":"Il jugera","en":"He will judge","tr":"yafṣilu","isWaqf":false},{"position":9,"ar":"بَيْنَكُمْ ۚ","fr":"entre vous","en":"between you","tr":"baynakum","isWaqf":false},{"position":10,"ar":"وَٱللَّهُ","fr":"Et Allah","en":"And Allah","tr":"wal-lahu","isWaqf":false},{"position":11,"ar":"بِمَا","fr":"de ce que","en":"of what","tr":"bimā","isWaqf":false},{"position":12,"ar":"تَعْمَلُونَ","fr":"vous faire","en":"you do","tr":"taʿmalūna","isWaqf":false},{"position":13,"ar":"بَصِيرٌۭ","fr":"(est) Clairvoyant","en":"(is) All-Seer","tr":"baṣīrun","isWaqf":false}]},{"ayah":4,"verseKey":"60:4","juz":28,"arabic":"قَدْ كَانَتْ لَكُمْ أُسْوَةٌ حَسَنَةٌ فِىٓ إِبْرَٰهِيمَ وَٱلَّذِينَ مَعَهُۥٓ إِذْ قَالُوا۟ لِقَوْمِهِمْ إِنَّا بُرَءَٰٓؤُا۟ مِنكُمْ وَمِمَّا تَعْبُدُونَ مِن دُونِ ٱللَّهِ كَفَرْنَا بِكُمْ وَبَدَا بَيْنَنَا وَبَيْنَكُمُ ٱلْعَدَٰوَةُ وَٱلْبَغْضَآءُ أَبَدًا حَتَّىٰ تُؤْمِنُوا۟ بِٱللَّهِ وَحْدَهُۥٓ إِلَّا قَوْلَ إِبْرَٰهِيمَ لِأَبِيهِ لَأَسْتَغْفِرَنَّ لَكَ وَمَآ أَمْلِكُ لَكَ مِنَ ٱللَّهِ مِن شَىْءٍ ۖ رَّبَّنَا عَلَيْكَ تَوَكَّلْنَا وَإِلَيْكَ أَنَبْنَا وَإِلَيْكَ ٱلْمَصِيرُ","fr":"Vous avez un exemple édifiant en Abraham et en ceux qui étaient avec lui, lorsqu’ils dirent à leur peuple : « Nous vous désavouons, vous et ce que vous adorez en dehors d’Allah. Nous vous renions. L’inimitié et la rancœur sont désormais et à tout jamais entre nous, tant que vous n’aurez pas cru exclusivement en Allah. » À l’exception de ce qu’avait dit Abrahm à son père : « J’implorerai en ta faveur le pardon (d’Allah), mais je ne pourrai rien faire pour toi contre (la sentence) d’Allah. Seigneur ! C’est à Toi que nous nous en remettons, c’est auprès de Toi que nous nous repentons, et c’est vers Toi que sera le devenir !","en":"There has already been for you an excellent pattern in Abraham and those with him, when they said to their people, \"Indeed, we are disassociated from you and from whatever you worship other than Allāh. We have denied you, and there has appeared between us and you animosity and hatred forever until you believe in Allāh alone\" - except for the saying of Abraham to his father, \"I will surely ask forgiveness for you, but I have not [power to do] for you anything against Allāh. Our Lord, upon You we have relied, and to You we have returned, and to You is the destination.","words":[{"position":1,"ar":"قَدْ","fr":"Certes","en":"Indeed","tr":"qad","isWaqf":false},{"position":2,"ar":"كَانَتْ","fr":"(là) est","en":"(there) is","tr":"kānat","isWaqf":false},{"position":3,"ar":"لَكُمْ","fr":"pour vous","en":"for you","tr":"lakum","isWaqf":false},{"position":4,"ar":"أُسْوَةٌ","fr":"un exemple","en":"an example","tr":"us'watun","isWaqf":false},{"position":5,"ar":"حَسَنَةٌۭ","fr":"bon","en":"good","tr":"ḥasanatun","isWaqf":false},{"position":6,"ar":"فِىٓ","fr":"en","en":"in","tr":"fī","isWaqf":false},{"position":7,"ar":"إِبْرَٰهِيمَ","fr":"Ibrahim","en":"Ibrahim","tr":"ib'rāhīma","isWaqf":false},{"position":8,"ar":"وَٱلَّذِينَ","fr":"et ceux","en":"and those","tr":"wa-alladhīna","isWaqf":false},{"position":9,"ar":"مَعَهُۥٓ","fr":"avec lui","en":"with him","tr":"maʿahu","isWaqf":false},{"position":10,"ar":"إِذْ","fr":"quand","en":"when","tr":"idh","isWaqf":false},{"position":11,"ar":"قَالُوا۟","fr":"ils dirent","en":"they said","tr":"qālū","isWaqf":false},{"position":12,"ar":"لِقَوْمِهِمْ","fr":"à leur peuple","en":"to their people","tr":"liqawmihim","isWaqf":false},{"position":13,"ar":"إِنَّا","fr":"Certes, nous","en":"Indeed, we","tr":"innā","isWaqf":false},{"position":14,"ar":"بُرَءَٰٓؤُا۟","fr":"(sont) désavoué","en":"(are) disassociated","tr":"buraāu","isWaqf":false},{"position":15,"ar":"مِنكُمْ","fr":"de vous","en":"from you","tr":"minkum","isWaqf":false},{"position":16,"ar":"وَمِمَّا","fr":"et de ce que","en":"and from what","tr":"wamimmā","isWaqf":false},{"position":17,"ar":"تَعْبُدُونَ","fr":"vous adorez","en":"you worship","tr":"taʿbudūna","isWaqf":false},{"position":18,"ar":"مِن","fr":"de","en":"from","tr":"min","isWaqf":false},{"position":19,"ar":"دُونِ","fr":"hormis","en":"besides","tr":"dūni","isWaqf":false},{"position":20,"ar":"ٱللَّهِ","fr":"Allah","en":"Allah","tr":"l-lahi","isWaqf":false},{"position":21,"ar":"كَفَرْنَا","fr":"Nous ont nia","en":"We have denied","tr":"kafarnā","isWaqf":false},{"position":22,"ar":"بِكُمْ","fr":"vous","en":"you","tr":"bikum","isWaqf":false},{"position":23,"ar":"وَبَدَا